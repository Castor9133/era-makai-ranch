
;兎耳族
@TRIBE_FEATURE_CONFIG_RABBITEAR

CLEARLINE LINECOUNT
PRINTL 选择【兔耳族】的种族设定。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL 固定：素质【动物耳】【尾巴】
PRINTLC [ 0] 素质【胆怯】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／兔耳族,0),1)
PRINTLC [ 1] 素质【喜欢偷懒】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／兔耳族,1),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(8)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL 被赋予素质【胆小】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／兔耳族"),INPUT_NUM)
CASE 1
	PRINTL 被赋予素质【喜欢偷懒】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／兔耳族"),INPUT_NUM)
CASE 98
	PRINTL 【兔耳族】的种族设定回复到默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_RABBITEAR
CASE 99
	RETURN
ENDSELECT
RESTART


