
;基礎・プロフィールの変更シャッフル
;ARGS→CHANGE_STATE
@SELF_CHARA_MAKE_PROFILE_INPUT_SHUFFLE(ARGS)
#DIM SHUFFLE_REF

SELECTCASE ARGS
CASE "名称"
	;名前用画面に飛ばす
	CALL CHARA_MAKE_SLAVE_SHUFFLE_NAME(1)
	
CASE "种族"
	;一般種族から
	CALL RANDOM_LIST_TRIBE_NORMAL(10)
	CSTR:种族 = %LIST_TRIBE:10%
	CALL CATEGORY_TRIVE
	
CASE "上位种族"
	INVERTBIT CFLAG:上位种族,0
	
CASE "职业"
	;7000～7350までのランダム　王族は出ない
	;STR:手動入力ジョブ→7000
	SHUFFLE_REF = RAND:7
	STR_REF = 7000 +SHUFFLE_REF *50
	STR_MAX = 50
	CALL STR_REF_SHUFFLE(STR_REF)
	CSTR:职业 = %RESULTS%
	
	;特徴反映設定→の前に何になったか出す
	PRINTFORML 职业重新调整→【%CSTR:职业%】
	CALL SELF_CHARA_MAKE_JOB_FEATURE(SHUFFLE_REF)
	
CASE "身份"
	;やめとく
	
CASE "所属"
CASE "服装"
	CALL RANDOM_SLAVE_CLOTHE
	
CASE "进入魔界的目的"
	;0～5のランダム
	CFLAG:进入魔界的目的 = RAND:6
	
CASE "身高"
	CALL RANDOM_SLAVE_HEIGHT
CASE "体型"
	CALL RANDOM_SLAVE_SHAPE
CASE "肤色"
	CALL RANDOM_SLAVE_SKIN_COLOR
CASE "胸围大小"
	CALL RANDOM_SLAVE_BUST
CASE "性经验"
	CALL RANDOM_SLAVE_VARGIN

;2ページ目→途中で終わってるのでここに来ない

;3ページ目
CASE "性格"
	CALL RANDOM_SLAVE_PERSONALITY
CASE "台词"
	CALL KOJO_SETTING
CASE "第一人称","陷落前的主人公的称呼","陷落后的主人公的称呼","阴茎称呼","膣称呼","肛门称呼"
	;なし
ENDSELECT



