
;①責めでの精神SOURCE追加処理
@MIND_SOURCE_PLUS
#DIM MIND_FIX

;噴乳量による乳牛堕ち
;計算式に合わせるように多めに
LOVE = (NOWEX:喷乳 +NOWEX:母乳不足 /2) *(10 +ABL:搾乳中毒) *3

;体内凌辱中は半減しとく
SIF TFLAG:体内凌辱中
	LOVE /= 2
SOURCE:乳牛 += LOVE

;搾乳中毒>=5で屈服増加
MIND_FIX = LIMIT(ABL:搾乳中毒 -5,0,20)
SOURCE:屈服 += (LOVE *MIND_FIX /10)

;おっぱい責めされているときTALENTにより恭順・恥辱
IF SOURCE:Ｂ快感 || SOURCE:Ｎ快感
	SIF TALENT:乳房刺激厌恶感
		SOURCE:耻辱 += 2000
	SIF TALENT:炫耀胸部
		SOURCE:恭顺 += 1000
	SIF MARK:消除乳房自卑感
		SOURCE:恭顺 += 1000
	SIF MARK:消除乳房刺激厌恶感
		SOURCE:恭顺 += 3000
ENDIF

;ちんぽ使用中の感情SOURCE
CALL MIND_SOURCE_PLUS_PENIS

;露出時追加
SIF TFLAG:Ｎ露出
	SOURCE:耻辱 += 1000
SIF TFLAG:Ｖ露出
	SOURCE:耻辱 += 1000

;責められているとき中毒Lvによって恭順にかかる
SIF TFLAG:搾乳刺激
	SOURCE:恭顺 += (ABL:搾乳中毒 *200)
SIF TFLAG:吸奶
	SOURCE:恭顺 += (ABL:母性 *200)
SIF SOURCE:受虐狂
	SOURCE:恭顺 += (ABL:受虐癖 *200)
SIF SOURCE:射精次数
	SOURCE:恭顺 += (ABL:精液中毒 *500)

;絶頂で淫欲追加
LOVE = NOWEX:总绝顶 *300
SIF LOVE > 1000
	LOVE = 1000 +(LOVE -1000) /10
SOURCE:淫欲 += LOVE

;恥じらい→搾乳中毒がなければ噴乳で恐怖増加
IF TALENT:害羞 && ABL:搾乳中毒 < 10
	DAMAGE = NOWEX:喷乳 +NOWEX:母乳不足 /2
	SOURCE:恐怖 += (DAMAGE *5)
ENDIF

;弱気→拘束中でマゾっ気なければ恐怖増加
SIF TALENT:弱势 && ABL:受虐癖 < 10 && TFLAG:拘束BIT
	SOURCE:恐怖 += 1000

;目隠しでも追加増加
SIF TALENT:弱势 && ABL:受虐癖 < 10 && TFLAG:眼罩
	SOURCE:恐怖 += 1500

;膨乳時
;乳牛堕ち→淫欲・恭順　していない→負の感情
IF SOURCE:膨乳阶段
	IF !CFLAG:乳牛
		SOURCE:恐怖 += (SOURCE:膨乳阶段 *2000)
		SOURCE:不快 += (SOURCE:膨乳阶段 *1000)
		SOURCE:反感 += (SOURCE:膨乳阶段 *2000)
		SOURCE:失意 += (SOURCE:膨乳阶段 *3000)
	ELSE
		SOURCE:淫欲 += (SOURCE:膨乳阶段 *2000)
		SOURCE:恭顺 += (SOURCE:膨乳阶段 *1000)
	ENDIF
	SIF MARK:淫乳
		SOURCE:淫欲 += (SOURCE:膨乳阶段 *2000)
ENDIF



;ちんぽ使用中の感情SOURCE
@MIND_SOURCE_PLUS_PENIS

;使用中でないならおわり
SIF !TFLAG:Ｐ使用BIT
	RETURN

;好感度0で乳牛堕ちもしていない→TALENTでいろいろ振り分け
SIF BASE:好感度 || CFLAG:乳牛
	RETURN

;共通
SIF TALENT:自尊心高
	SOURCE:反感 += 2000
SIF TALENT:高傲
	SOURCE:反感 += 3000
SIF TALENT:坚强
	SOURCE:反感 += 2000
IF TALENT:清纯
	SOURCE:屈服 += 1000
	SOURCE:耻辱 += 2000
ENDIF
IF TALENT:贞操观念
	SOURCE:反感 += 2000
	SOURCE:耻辱 += 1000
	SOURCE:屈服 += 1000
	SOURCE:失意 += 1000
ENDIF

SIF TALENT:自尊心低
	SOURCE:屈服 += 2000
SIF TALENT:卑屈
	SOURCE:屈服 += 3000
SIF TALENT:弱势
	SOURCE:屈服 += 3000
SIF TALENT:害羞
	SOURCE:耻辱 += 2000
SIF TALENT:悲观
	SOURCE:失意 += 2000

SIF TALENT:高雅
	SOURCE:不快 += 2000

;各部位
;おまんこ
IF GETBIT(＃Ｐ使用／Ｖ插入＃)
	SIF TALENT:自尊心高
		SOURCE:耻辱 += 1000
	SIF TALENT:高傲
		SOURCE:耻辱 += 2000
	SIF TALENT:清纯
		SOURCE:耻辱 += 2000
	IF TALENT:贞操观念
		SOURCE:反感 += 2000
		SOURCE:耻辱 += 2000
		SOURCE:屈服 += 2000
		SOURCE:失意 += 2000
	ENDIF
	
	SIF TALENT:害羞
		SOURCE:屈服 += 2000
	SIF TALENT:悲观
		SOURCE:失意 += 2000
	
	;膣内射精時追加
	IF TFLAG:膣内精液
		SIF TALENT:清纯
			SOURCE:屈服 += 3000
		IF TALENT:贞操观念
			SOURCE:耻辱 += 3000
			SOURCE:屈服 += 3000
			SOURCE:失意 += 7000
		ENDIF
		SIF TALENT:害羞
			SOURCE:屈服 += 3000
		SIF TALENT:悲观
			SOURCE:失意 += 4000
	ENDIF
ENDIF

;アナル
IF GETBIT(＃Ｐ使用／Ａ插入＃)
	SIF TALENT:自尊心高
		SOURCE:屈服 += 2000
	SIF TALENT:高傲
		SOURCE:屈服 += 3000
	SIF TALENT:坚强
		SOURCE:屈服 += 2000
	SIF TALENT:抗拒
		SOURCE:屈服 += 4000
	SIF TALENT:清纯
		SOURCE:屈服 += 1000
	
	;尻穴射精時追加
	IF TFLAG:尻穴精液
		SIF TALENT:自尊心高
			SOURCE:屈服 += 1000
		SIF TALENT:高傲
			SOURCE:屈服 += 1000
		SIF TALENT:抗拒
			SOURCE:屈服 += 2000
		SIF TALENT:清纯
			SOURCE:屈服 += 1000
	ENDIF
ENDIF

;パイズリ
IF GETBIT(＃Ｐ使用／乳交＃)
	SIF TALENT:清纯
		SOURCE:屈服 += 2000
	SIF TALENT:害羞
		SOURCE:屈服 += 2000
	SIF TALENT:炫耀胸部
		SOURCE:屈服 += 2000
	IF TALENT:乳房刺激厌恶感
		SOURCE:耻辱 += 2000
		SOURCE:屈服 += 2000
		SOURCE:失意 += 5000
	ENDIF
	
	;パイズリ射精時追加
	IF TFLAG:乳内精液
		SIF TALENT:炫耀胸部
			SOURCE:恭顺 += 2000
		IF TALENT:乳房刺激厌恶感
			SOURCE:耻辱 += 2000
			SOURCE:屈服 += 5000
			SOURCE:失意 += 5000
		ENDIF
	ENDIF
ENDIF

;おくち
IF GETBIT(＃Ｐ使用／Ｍ插入＃)
	SIF TALENT:自尊心高
		SOURCE:屈服 += 1000
	SIF TALENT:高傲
		SOURCE:屈服 += 2000
	SIF TALENT:清纯
		SOURCE:屈服 += 2000
	SIF TALENT:抗拒
		SOURCE:屈服 += 2000
	SIF TALENT:害羞
		SOURCE:屈服 += 2000
	
	;口内射精時追加
	IF TFLAG:口内精液
		SIF TALENT:自尊心高
			SOURCE:屈服 += 1000
		SIF TALENT:高傲
			SOURCE:屈服 += 1000
		SIF TALENT:清纯
			SOURCE:屈服 += 1000
		SIF TALENT:抗拒
			SOURCE:屈服 += 1000
		SIF TALENT:害羞
			SOURCE:屈服 += 1000
		SIF TALENT:污臭敏感
			SOURCE:屈服 += 2000
	ENDIF
ENDIF








