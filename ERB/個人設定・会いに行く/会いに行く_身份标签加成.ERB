@IDENTITY_TAG_TRAIN_SOURCE_BOOST
SIF TARGET < 1
	RETURN
SIF !TFLAG:调教中 && !TFLAG:日程外Ｈ
	RETURN
FOR LOCAL:1, 0, 600
	SIF SOURCE:(LOCAL:1) <= 0
		CONTINUE
	LOCALS = %SOURCENAME:(LOCAL:1)%
	LOCAL:93 = GET_TRAIN_PERMILLE_FOR_SOURCE_NAME(LOCALS)
	SIF LOCAL:93 <= 1000
		CONTINUE
	SOURCE:(LOCAL:1) = SOURCE:(LOCAL:1) * LOCAL:93 / 1000
NEXT


@GET_LABOR_PERMILLE_FOR_SCHEDULE, ARGS:0
