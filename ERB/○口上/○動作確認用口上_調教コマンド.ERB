; ARGS:0 场景；ARGS:1～ 用于更细分
@KOJO_GENERAL_操作确认口上_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

; 进入此处时 ARGS:0 固定为「调教命令」；分支名见 TRAIN.csv
; 当前流程：@COM 地文 → 口上

SELECTCASE ARGS:1
CASE "执行后"
	IF SOURCE:处女丧失
		CALL MESSAGE_BOX,@"「test_本指令导致处女丧失时会进入本候选。」"
		RETURN
	ELSEIF SOURCE:Ａ处女丧失
		CALL MESSAGE_BOX,@"「test_本指令导致 A 处女丧失时会进入本候选。」"
		RETURN
	ELSEIF SOURCE:Ｍ处女丧失
		CALL MESSAGE_BOX,@"「test_本指令导致 M 处女丧失时会进入本候选。」"
		RETURN
	ELSEIF SOURCE:初次乳交
		CALL MESSAGE_BOX,@"「test_本指令为首次乳交时会进入本候选。」"
		RETURN
	ELSEIF SOURCE:初吻
		CALL MESSAGE_BOX,@"「test_本指令为首次接吻时会进入本候选。」"
		RETURN
	ENDIF
	CALL MESSAGE_BOX,@"「test_随时间推进的调教指令：与具体指令无关、仅做通用判定的执行后口上。」"

CASE "揉胸","育乳按摩","浓厚母乳按摩","乳罐按摩"
	; 从这里开始按变体细分；分支越多越有趣也越费工
	; 常见写法：按好感／心境等拆分
	
	; 先看是否「首次」：工程在口上显示『之后』执行 EXP:(SELECTCOM+1000)++
	; 故该值为 0 表示本角色从未受过该指令
	; 隶属乳牛却从未揉过胸……若一直只榨乳倒也可能
	; 用 \n 换行；源码里不要用 Enter 直接断行
	; 勿为换行连写两次 CALL（只会显示其中一句）
	
	; 首次
	IF !EXP:(SELECTCOM+1000)
		CALL MESSAGE_BOX,@"「test_调教指令【揉胸】首次执行时的台词。」"
	ELSE
		CALL MESSAGE_BOX,@"「test_调教指令【揉胸】第 2 次及以后的台词。」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「test_胸围 ≥【丰乳】时进入候选。」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「test_胸围 ≤【贫乳】时进入候选。」"
		SIF EX:Ｂ绝顶 >= 100
			CALL MESSAGE_BOX,@"「test_本场调教中 B 高潮累计 ≥100 次时进入候选。」"
		SIF !TFLAG:Ｎ露出
			CALL MESSAGE_BOX,@"「test_非【胸露出】状态时进入候选。」"
		
		; 调教中可查污渍：GETBIT(STAIN:乳房,4) 判定乳房是否涂有润滑液（详见 Stain.csv）
		SIF GETBIT(STAIN:乳房,4)
			CALL MESSAGE_BOX,@"「test_乳房涂有润滑液时进入候选。」"
	ENDIF
	
CASE "榨乳"
	IF MARK:母乳体质
		CALL MESSAGE_BOX,@"「test_调教指令【榨乳】且为【母乳体质】时的台词。」"
		SIF ABL:搾乳中毒 >= 10
			CALL MESSAGE_BOX,@"「test_调教指令【榨乳】且为【母乳体质】、且【榨乳中毒】≥10 时进入候选。」"
	ELSE
		CALL MESSAGE_BOX,@"「test_调教指令【榨乳】且非【母乳体质】时的台词。」"
	ENDIF

CASE "拧乳头"
	CALL MESSAGE_BOX,@"「test_调教指令【拧乳头】的台词。」"

CASE "Ｃ爱抚"
	CALL MESSAGE_BOX,@"「test_调教指令【Ｃ爱抚】的台词。」"
	SIF ABL:Ｃ敏感度 >= 200 || ABL:Ｃ感觉 >= 10
		CALL MESSAGE_BOX,@"「test_【Ｃ爱抚】执行时 C 敏感 ≥200\% 或 C 感觉 ≥10 时进入候选。」"

CASE "Ｖ指插入"
	CALL MESSAGE_BOX,@"「test_调教指令【Ｖ指插入】的台词。」"

CASE "Ａ指插入"
	CALL MESSAGE_BOX,@"「test_调教指令【Ａ指插入】的台词。」"
	IF PALAM:Ａ润滑 >= 5000
		CALL MESSAGE_BOX,@"「test_【Ａ指插入】执行且 A 润滑 ≥5000 时进入候选。」"
	ELSE
		CALL MESSAGE_BOX,@"「test_【Ａ指插入】执行且 A 润滑 ＜5000 时进入候选。」"
	ENDIF

CASE "尻爱抚"
	CALL MESSAGE_BOX,@"「test_调教指令【尻爱抚】的台词。」"
	
CASE "胸爱抚"
	CALL MESSAGE_BOX,@"「test_调教指令【胸爱抚】的台词。」"
	
CASE "挠痒"
	CALL MESSAGE_BOX,@"「test_调教指令【挠痒】的台词。」"
	
; 相似指令可写在同一 CASE（逗号分隔）；首次判定仍各自独立
CASE "吸奶","母乳吸尽"
	CALL MESSAGE_BOX,@"「test_调教指令【吸奶】【母乳吸尽】共用台词。」"
	
	; 榨乳处理前会先显示口上，可读当前奶量
	IF BASE:母乳容量
		CALL MESSAGE_BOX,@"「test_【吸奶／母乳吸尽】执行且母乳容量非 0 时进入候选。」"
	ELSE
		CALL MESSAGE_BOX,@"「test_【吸奶／母乳吸尽】执行且母乳容量为 0 时进入候选。」"
	ENDIF
	
CASE "吸乳头","揉胸吸奶","直饮触手复合搾乳"
	CALL MESSAGE_BOX,@"「test_调教指令【吸乳头】【揉胸吸奶】【直饮触手复合搾乳】共用台词。」"
	CALL MESSAGE_BOX,@"「test_逗号可合并相似指令；若用 1000 段 EXP 记经验，则每条指令各自有首次判定，请注意。」"
	
CASE "接吻"
	SIF TALENT:无接吻经验
		RETURN
	CALL MESSAGE_BOX,@"「test_调教指令【接吻】的台词。」"
	CALL MESSAGE_BOX,@"「test_初吻口上在【事件】侧触发；【无接吻经验】时请直接 RETURN，勿在此重复。」"
	
CASE "Ｃ舔舐"
