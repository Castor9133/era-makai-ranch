
;挿入しながらの乳吸いに身長制限つけるかコンフィグ
;RETURN1でNG
@BUST_SUCK_HEIGHT_CONFIG_JUDGE
#DIM BUST_HEIGHT

SIF !GETBIT(＃身高差限制／插入吸乳＃)
	RETURN
SIF !TFLAG:Ｐ使用BIT
	RETURN

;絶壁の場合身長差が10cm以上あるとダメ
;50cm差あっても10=Jあれば吸える
BUST_HEIGHT = CFLAG:身高 +ABL:胸围大小 *50 +100
SIF CFLAG:PLAYER:身高 > BUST_HEIGHT
	RETURN 1



;挿入しながらのキス
;RETURN1でNG
@KISS_HEIGHT_CONFIG_JUDGE

SIF !GETBIT(＃身高差限制／插入接吻＃)
	RETURN
SIF !TFLAG:Ｐ使用BIT
	RETURN

;身長差が30cm以上あるとダメ
SIF CFLAG:PLAYER:身高 > CFLAG:身高 +300
	RETURN 1



;立ち拘束時のパイズリ
@PAIZURI_HEIGHT_CONFIG_JUDGE

SIF !GETBIT(＃身高差限制／站立乳交＃)
	RETURN

;あなたより40cm以上身長が低いなら立ちパイズリ可能
SIF CFLAG:PLAYER:身高 < CFLAG:身高 +400
	SETBIT ＃体位制限／乳交＃




