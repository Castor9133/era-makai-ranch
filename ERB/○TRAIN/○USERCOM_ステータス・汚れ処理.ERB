
;USERCOMから飛ばす用
@SHOW_STATUS_DETAIL_TRAIN

PRINTFORML [ 0] %CALLNAME%的状态
PRINTL [ 1] 污垢表示・擦拭
PRINTL [ 2] 个人设置
PRINTFORML [ 8] %CALLNAME:0%的状态
PRINTL

;ちょい追加
SIF FLAG:开发者模式
	PRINTL [90] 调教限制部分的计数器重置（仅开发者模式）
PRINTL [99] 取消
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL SHOW_STATUS_DETAIL_PLUS("调教中")
CASE 1
	CALL SHOW_STAIN
CASE 2
	CALL SLAVE_CONFIG
CASE 8
	SAVE_TARGET = TARGET
	TARGET = 0
	CALL SHOW_STATUS_DETAIL_PLUS("调教中")
	TARGET = SAVE_TARGET
CASE 90
	SIF !FLAG:开发者模式
		RETURN
	TFLAG:剩余时间 = 100
	TFLAG:时间压缩有效回合数 = 0
	CFLAG:当日制限／肉体改造药 = 0
	CFLAG:当日限制／肉体改造精华 = 0
	
ENDSELECT



;汚れ表示
@SHOW_STAIN
#DIM LIQUID

CALL MANYL(5)
PRINTFORML %CALLNAME%的污垢
FOR LOCAL,0,12
	;♂はＣＶなし、♀はＰなし
	SIF STAINNAME:LOCAL == "阴茎"
		CONTINUE
	PRINTFORM %STAINNAME:LOCAL,6%：
	IF !STAIN:LOCAL
		CALL PRINTL_WORD_COLOR("特别","灰")
		CONTINUE
	ENDIF
	FOR LIQUID,0,8
		SIF GETBIT(STAIN:LOCAL,LIQUID)
			PRINTFORM %STR:(LIQUID +6000)%　
	NEXT
	PRINTL
NEXT
CALL MANYL(3)
PRINTFORML %CALLNAME:0%的污垢
FOR LOCAL,0,12
	;口と手とちんぽ以外不要では？
	SIF !GROUPMATCH(STAINNAME:LOCAL,"阴茎","口","手")
		CONTINUE
	IF TEQUIP:0:避孕套 && STAINNAME:LOCAL == "阴茎"
		PRINT 橡胶Ｐ：
	ELSE
		PRINTFORM %STAINNAME:LOCAL,6%：
	ENDIF
	IF !STAIN:0:LOCAL
		CALL PRINTL_WORD_COLOR("特别","灰")
		CONTINUE
	ENDIF
	FOR LIQUID,0,8
		SIF GETBIT(STAIN:0:LOCAL,LIQUID)
			PRINTFORM %STR:(LIQUID +6000)%　
	NEXT
	PRINTL
NEXT
PRINTL
IF STAIN:0:手
	PRINTFORMLC [ 0] 擦掉%CALLNAME:0%手上的污垢
ELSE
	CALL PRINTLC_WORD_COLOR("　不用擦手","灰")
ENDIF
PRINTL [ 9] 返回
INPUT
PRINTL
SIF RESULT == 0
	CALL HAND_WASH




;TARGETに汚れ付与
;ARGS→部位
;ARGS:1→汚れ
@SET_STAIN_TARGET(ARGS,ARGS:1)
#DIM LIQUID

;STRから汚れ名を引っ張ってくる
FOR LOCAL,6000,6010
	SIF STR:LOCAL != ARGS:1
		CONTINUE
	LIQUID = LOCAL -6000
	BREAK
NEXT

;汚れがなければ付与メッセージの準備+SETBIT
IF !GETBIT(STAIN:ARGS,LIQUID)
	RESULT = GETNUM(STAIN,ARGS)
	SETBIT STAIN:RESULT,LIQUID
	SETBIT STAIN:(RESULT +50),LIQUID
ENDIF



;PLAYERに汚れ付与
;ARGS→部位
;ARGS:1→汚れ
@SET_STAIN_PLAYER(ARGS,ARGS:1)
#DIM LIQUID

FOR LOCAL,6000,6010
	SIF STR:LOCAL != ARGS:1
		CONTINUE
	LIQUID = LOCAL -6000
	BREAK
NEXT

IF !GETBIT(STAIN:0:ARGS,LIQUID)
	RESULT = GETNUM(STAIN,ARGS)
	SETBIT STAIN:0:RESULT,LIQUID
	SETBIT STAIN:0:(RESULT +50),LIQUID
ENDIF



;汚れ交換
;ARGS→TARGETの部位
;ARGS:1→PLAYERの部位
@SWAP_STAIN(ARGS,ARGS:1)

FOR LOCAL,0,10
	;奴隷→あなた
	SIF !GETBIT(STAIN:ARGS,LOCAL)
		CONTINUE
	SIF !GETBIT(STAIN:0:(ARGS:1),LOCAL)
		CALL SET_STAIN_PLAYER((ARGS:1),STR:(LOCAL +6000))
NEXT
FOR LOCAL,0,10
	;あなた→奴隷
	SIF !GETBIT(STAIN:0:(ARGS:1),LOCAL)
		CONTINUE
	SIF !GETBIT(STAIN:ARGS,LOCAL)
		CALL SET_STAIN_TARGET(ARGS,STR:(LOCAL +6000))
NEXT


