
;搾乳器の開発
@UPGRADE_LACTATION_MACHINE

CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_UPGRADE("物品制作")
PRINTFORML 使用资金或者%CALLNAME:0%的魔力，进行人类用快感搾乳器的开发。
FOR LOCAL,900,910
	;価格設定されていれば表示
	SIF ITEMPRICE:LOCAL
		PRINTFORMLC [{LOCAL}] %ITEMNAME:LOCAL% 
NEXT
PRINTL
DRAWLINE

;解説と開発画面
CALL ITEM_DETAIL_LACTATION_MACHINE
CALL PRINTL_ALIGN
DRAWLINE
IF ITEMNAME:SELECT_ITEM == "魔动快感搾乳器"
	IF ITEM:SELECT_ITEM
		PRINTL 现在的ver不需要持有多个
	ELSEIF ITEMPRICE:SELECT_ITEM <= MONEY
		PRINTL [  0] 开发 
	ELSE
		PRINTL 资金不足
	ENDIF
ELSEIF ITEMNAME:SELECT_ITEM == "触手快感搾乳器"
	IF ITEM:SELECT_ITEM
		PRINTL 现在的ver不需要持有多个
	ELSEIF ITEMPRICE:SELECT_ITEM <= BASE:0:魔力
		PRINTL [  0] 开发 
	ELSE
		PRINTL MP不足
	ENDIF
ELSE
	CALL PRINTL_WORD_COLOR("　开发","灰")
ENDIF
DRAWLINE
CALL RIGHT_RETURN_BUTTON(0,"戻る")
BINPUT
SELECTCASE RESULT
CASE 0
	;購入処理　霊力か魔力
	IF ITEMNAME:SELECT_ITEM == "魔动快感搾乳器"
		ITEM:SELECT_ITEM ++
		MONEY -= ITEMPRICE:SELECT_ITEM
		PRINTFORMW 【%ITEMNAME:SELECT_ITEM%】开发完成了 
	ELSEIF ITEMNAME:SELECT_ITEM == "触手快感搾乳器"
		ITEM:SELECT_ITEM ++
		BASE:0:魔力 -= ITEMPRICE:SELECT_ITEM
		PRINTFORMW 【%ITEMNAME:SELECT_ITEM%】开发完成了 
	ENDIF

CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART

