; ======================================
; 泛用口上・调教命令（性格：女仆）
; ======================================

@KOJO_GENERAL_女仆口上1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:2
CASE "执行"
	SELECTCASE ARGS:1
	CASE "手淫","授乳手交"
		CALL MESSAGE_BOX,@"「遵命。将为您进行手部侍奉……♥」"
		CALL MESSAGE_BOX,@"「若您想更快些……请用眼神示意……我会立刻调整。」"

	CASE "口交","触手口交"
		CALL MESSAGE_BOX,@"「遵命。将以口部侍奉……请您放松。」"
		CALL MESSAGE_BOX,@"「若您皱眉……我会立刻放轻；若您眯眼……我会更深一些。」"

	CASE "正常位","后背位","对面坐位","背面坐位","骑乘位","对面立位","背面立位","强制骑乘位","背面骑乘位"
		CALL MESSAGE_BOX,@"「遵命。将以身体侍奉……请您把重心交给我。」"

	CASE "足交"
		CALL MESSAGE_BOX,@"「遵命。将以足部侍奉……我会控制力度与节奏。」"
		CALL MESSAGE_BOX,@"「若您抬眉……我会更快；若您皱眉……我会更轻。」"

	CASE "肛塞"
		CALL MESSAGE_BOX,@"「遵命。将进行肛塞装着……请您放松后方。」"

	CASE "尿道塞"
		CALL MESSAGE_BOX,@"「遵命。将进行尿道塞装着……我会尽量减轻不适。」"

	CASEELSE
		CALL MESSAGE_BOX,@"「遵命。将执行%ARGS:1%。」"
	ENDSELECT

CASE "继续"
	CALL MESSAGE_BOX,@"「继续服务中……我会按您最舒服的节奏引导。」"

CASE "移除"
	SELECTCASE ARGS:1
	CASE "肛塞"
		CALL MESSAGE_BOX,@"「已解除肛塞。请先缓一缓呼吸。」"
	CASE "尿道塞"
		CALL MESSAGE_BOX,@"「已解除尿道塞。若仍有不适，请立刻告知。」"
	CASEELSE
		CALL MESSAGE_BOX,@"「已解除。若有不适，请立刻吩咐我。」"
	ENDSELECT

CASEELSE
ENDSELECT
RETURN

