
;衣服没収処理
@CLOTHE_SEIZURE

;衣服・下着・アクセサリーと別々
CALL CLOTHE_SEIZURE_CLOTHE
CALL CLOTHE_SEIZURE_LINGERIE
CALL CLOTHE_SEIZURE_ACCESSORY



;衣服
@CLOTHE_SEIZURE_CLOTHE

;一時的脱衣フラグがあるか見る
SIF !TFLAG:临时脱衣／衣服
	RETURN

;コンフィグ有効の場合だけ
IF CFLAG:无抵抗
	SIF !GETBIT(＃衣服没收／无抵抗＃)
		RETURN
ELSE
	SIF !GETBIT(＃衣服没收／抵抗＃)
		RETURN
ENDIF
PRINTFORML 要把%CALLNAME%的%＃穿着衣服／名称＃%没收吗？
CALL ASK_YN
SIF !RESULT
	EQUIP:装备中ID／衣服 = 0



;下着
@CLOTHE_SEIZURE_LINGERIE

SIF !TFLAG:临时脱衣／内衣上装 && !TFLAG:临时脱衣／内衣下装
	RETURN
IF CFLAG:无抵抗
	SIF !GETBIT(＃内衣没收／无抵抗＃)
		RETURN
ELSE
	SIF !GETBIT(＃内衣没收／抵抗＃)
		RETURN
ENDIF
PRINTFORML 要把%CALLNAME%的内裤没收吗？
CALL ASK_YN
SIF RESULT
	RETURN
EQUIP:装备中ID／内衣上装 = 0
EQUIP:装备中ID／内衣下装 = 0



;アクセサリー
@CLOTHE_SEIZURE_ACCESSORY

SIF !SUMARRAY(TFLAG,130,140)
	RETURN
IF CFLAG:无抵抗
	SIF !GETBIT(＃饰品没收／无抵抗＃)
		RETURN
ELSE
	SIF !GETBIT(＃饰品没收／抵抗＃)
		RETURN
ENDIF
PRINTFORML 要把%CALLNAME%的饰品没收吗？
CALL ASK_YN
SIF !RESULT
	VARSET EQUIP,0,10,20

