
;牛角族
@TRIBE_FEATURE_CONFIG_COWHORN

CLEARLINE LINECOUNT
PRINTL 请选择【牛角族】的种族设定。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL 固定：素质【动物耳】【尾巴】【双角】
PRINTLC [ 0] 素质【贪吃】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／牛角族,0),1)
PRINTLC [ 1] 素质【老实】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／牛角族,1),1)
PRINTLC [ 2] 胸围大小提升至【丰乳】【爆乳】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／牛角族,2),1)
PRINTLC [ 3] 体质【先天母乳体质】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／牛角族,3),1)
PRINTLC [ 4] 母乳容量・生产力＋30%
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／牛角族,4),1)
PRINTLC [ 5] 基础体力＋200
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／牛角族,5),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(11)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL 被赋予素质【贪吃】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／牛角族"),INPUT_NUM)
CASE 1
	PRINTL 被赋予素质【老实】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／牛角族"),INPUT_NUM)
CASE 2
	PRINTL 胸围大小将提升至【丰乳】【爆乳】。（超过此值无效）
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／牛角族"),INPUT_NUM)
CASE 3
	PRINTL 体质【先天母乳体质】被赋予。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／牛角族"),INPUT_NUM)
CASE 4
	PRINTL 在共同状态计算后，母乳容量和生产力的补偿需要额外30%的奖金。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／牛角族"),INPUT_NUM)
CASE 5
	PRINTL 在普通状态计算后体力增加200。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／牛角族"),INPUT_NUM)
CASE 98
	PRINTL 将【牛角族】的种族设定回复为默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_COWHORN
CASE 99
	RETURN
ENDSELECT
RESTART


