;触手フェラチオ、触手イラマチオ共通部分
@MOUSE_TENTACLE_REMOVE_MESSAGE

SIF !TFLAG:口内精液
	RETURN
IF CFLAG:崩坏
	PRINTFORML %CALLNAME%的口中溢出了触手的%SLANG_SEMEN()%…
ELSEIF (ABL:精液中毒 +ABL:触手中毒 >= 10) || ＃陷落状态／隶属＃
	CALL PRINT_WORD_COLOR,@"　%CALLNAME%口中残留的触手%SLANG_SEMEN()%喝干了…","桃"
	CALL HEARTCB(0xD02830)
	PRINTL
ELSEIF MARK:恐怖刻印
	PRINTFORML %CALLNAME%含着泪水将口中残留的触手%SLANG_SEMEN()%喝干了…
ELSE
	PRINTFORML %CALLNAME%吐出了口中残留的触手%SLANG_SEMEN()%…
ENDIF


