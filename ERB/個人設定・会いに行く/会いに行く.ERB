
;[会いに行く]前フラグ処理
@VISIT_SLAVE_BEFORE

;[会いに行く]の時抽出継続フラグOFF
CFLAG:继续抽出 = 0
CALL RESET_TRAIN_PALAM
TFLAG:日程外Ｈ = 1
PLAYER = MASTER
CALL BEFORE_TRAIN_T_CLOTHE
CALL BEFORE_TRAIN_T_CLOTHE_M
CALL BEFORE_TRAIN_LUBRICATION
CALL VISIT_SLAVE

;後処理もここ
CALL RESET_TRAIN_PALAM
FLAG:当前访问次数 ++

;制限撤廃なら0にする
SIF GETBIT(＃限制解除／访问次数＃)
	FLAG:当前访问次数 = 0



;[会いに行く]選択
@VISIT_SLAVE

;行動でHP増減するので毎回個人の業務可能チェックを入れる
CALL TARGET_SCHEDULE_POSSIBLE

;スケジュール外でのリセット
TFLAG:Ｐ抽出后等待跳过 = 0
VARSET TFLAG,0,30,100
VARSET TEQUIP

;調教者にちんぽ存在するかチェック
CALL PLAYER_PENIS_CHECK

;制限撤廃コンフィグを見る
CALL CHECK_LIMIT_BREAK_CONFIG
CLEARLINE LINECOUNT
CALL SHOW_SLAVE_STATE(2)
CALL KOJO_PRINT("访问","入口")
PRINTL
CALL VISIT_SLAVE_CHECK
CALL PRINTL_ALIGN(2)
DRAWLINE
PRINTL [99] 返回
BINPUT
PRINTL
IF CSTR:状态／主人公的孩子 == "成长后"
	SELECTCASE RESULT
	CASE 3,5,12,13,14
		CHILD_COM = RESULT
		CALL CHILD_REBELLION
		SIF RESULT
			RESTART
		RESULT = CHILD_COM
	ENDSELECT
ENDIF
SELECTCASE RESULT
CASE 0
	CALL VISIT_HAIR_STYLE_CHANGE_BEFORE
CASE 1
	CALL VISIT_EYE_COLOR_CHANGE_BEFORE
CASE 2
	CALL VISIT_REPAIR_CLOTHE
CASE 4
	CALL VISIT_CHANGE_MASTER_CALL
CASE 5
	CALL VISIT_SETTING_NEW_POSITION_BEFORE
CASE 6
	CALL VISIT_SETTING_NEW_CALLNAME_BEFORE
CASE 7
	CALL VISIT_TAKE_ENERGY_DRINK
CASE 8
	CALL VISIT_DRINK_HERBAL_TEA
CASE 9
	TFLAG:日程外Ｈ = 0
	CALL VISIT_CHANGE_CHARA_CLOTHE
	TFLAG:日程外Ｈ = 1
CASE 10
	CALL VISIT_STROKING_HEAD
CASE 11
	CALL VISIT_KISS
CASE 12
	CALL VISIT_BREAST_FEEDING
	
	;一時的脱衣状態・露出状態リセット
	VARSET TFLAG,0,120,145
	CALL AJUST_STRIP_FLAG
CASE 13
	CALL VISIT_EP_INJECT(1)
CASE 14
	CALL VISIT_DOSAGE
CASE 15
	CALL VISIT_PLAY_WITH_CHILD
CASE 99
	RETURN
ENDSELECT
RESTART



;拘束投薬
@VISIT_DOSAGE

TFLAG:调教前母乳体质 = MARK:母乳体质
CALL COM800
IF RESULT
	CFLAG:时刻限制／用药 = 1
	CFLAG:时刻限制／Ｈ = 1
	CALL SOURCE_CHECK
	PRINTW
ENDIF
SELECTCOM = 0
CALL AUTO_SCHEDULE_LACTATION



;霊力注入
;ARG→[会いに行く]から直接来た
@VISIT_EP_INJECT(ARG)

;挿入自体をキャンセル→また選択可能
;挿入後に注ぎ込むのをキャンセル→このコマンドでの挿入が不可になる→「おっぱい吸わせて」からのみ
V_PENIS = %CALLNAME:0%
CALL COM30
IF RESULT
	TFLAG:Ｖ装备 = 1
	SETBIT ＃Ｐ使用／Ｖ插入＃
	SIF ARG
		CALL PRINT_IMAGE("调教执行")
	CALL LOST_VARGIN
	CALL LOST_VARGIN_PLAYER
	SELECTCOM = 30
	CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
	EXP:(SELECTCOM +1000) ++
	
	CFLAG:时刻限制／灵力注入 = 1
	CFLAG:时刻限制／Ｈ = 1
	CALL COM905
	IF RESULT
		SELECTCOM = 905
		CALL SOURCE_CHECK
	ELSE
		PRINTL 不再注入灵力精液…
	ENDIF
ELSE
	PRINTL 决定不要插入了…
ENDIF

;霊力精液のため絶対射精してる
SIF TFLAG:Ｐ使用BIT
	CALL COM890
PRINTW
SELECTCOM = 0

