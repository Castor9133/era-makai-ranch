
;ヴァンパイア
@TRIBE_FEATURE_CONFIG_VAMPIRE

CLEARLINE LINECOUNT
PRINTL 选择[吸血鬼]的种族设定。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL 固定：经常拥有魔力·素质【魔界适应】
PRINTLC [ 0] 肤色变为【色白】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,0),1)
PRINTLC [ 1] 发色变为【银色】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,1),1)
PRINTLC [ 2] 使所持魔力加倍
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,2),1)
PRINTLC [ 3] 素质【回复快】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,3),1)
PRINTLC [ 4] 素质【药毒耐性】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,4),1)
PRINTLC [ 5] 素质【被动物讨厌】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,5),1)
PRINTLC [ 6] 素质【怕太阳】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,6),1)
PRINTLC [ 7] 基础体力＋400
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,7),1)
PRINTL
PRINTLC [10] 素质【不怕痛】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,10),1)
PRINTLC [11] 素质【煽动】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,11),1)
PRINTLC [12] 素质【少食】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,12),1)
PRINTLC [13] 素质【自尊心高】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,13),1)
PRINTLC [14] 素质【高傲】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,14),1)
PRINTLC [15] 素质【领袖魅力】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,15),1)
PRINTLC [16] 素质【抖Ｓ】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,16),1)
PRINTLC [17] 素质【高雅】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／吸血鬼,17),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(16)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL 肤色选择种抽到【标准】、【褐色】、【小麦色】时将变为【色白】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 1
	PRINTL 使发色变成【银发】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 2
	PRINTL 在普通状态计算后魔力倍增。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 3
	PRINTL 被赋予素质【回复快】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 4
	PRINTL 被赋予素质【药毒耐性】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 5
	PRINTL 被赋予素质【被动物讨厌】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 6
	PRINTL 被赋予素质【怕太阳】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 7
	PRINTL 体力在普通状态计算后会增加400。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 10
	PRINTL 被赋予素质【不怕痛】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 11
	PRINTL 被赋予素质【煽动】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 12
	PRINTL 被赋予素质【少食】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 13
	PRINTL 被赋予素质【自尊心高】。
	PRINTL ※和【高傲】二选一
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
	SIF GETBIT(FLAG:种族设定／吸血鬼,13) && GETBIT(FLAG:种族设定／吸血鬼,14)
		CLEARBIT FLAG:种族设定／吸血鬼,14
CASE 14
	PRINTL 被赋予素质【高傲】。
	PRINTL ※和【自尊心高】二选一
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
	SIF GETBIT(FLAG:种族设定／吸血鬼,13) && GETBIT(FLAG:种族设定／吸血鬼,14)
		CLEARBIT FLAG:种族设定／吸血鬼,13
CASE 15
	PRINTL 被赋予素质【领袖魅力】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 16
	PRINTL 被赋予素质【抖Ｓ】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 17
	PRINTL 被赋予素质【高雅】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／吸血鬼"),INPUT_NUM)
CASE 98
	PRINTL 【吸血鬼】的种族设定回复到默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_VAMPIRE
CASE 99
	RETURN
ENDSELECT
RESTART


