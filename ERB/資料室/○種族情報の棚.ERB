
;種族の棚
@REFERENCE_TRIBE

CLEARLINE LINECOUNT
ALIGNMENT CENTER
PRINTL --- 种族信息 ---
PRINTL ○素质和ABL的记述很多都是未实装的。请您谅解。
DRAWLINE
PRINTL --- 通常的种族 ---
ALIGNMENT LEFT
FOR LOCAL,5100,5200
	IF LOCAL == 5120
		PRINTL
		ALIGNMENT CENTER
		PRINTL --- 特殊的种族 ---
		ALIGNMENT LEFT
		
	ELSEIF LOCAL == 5140
		PRINTL
		ALIGNMENT CENTER
		PRINTL --- 魔界的人型种族 ---
		ALIGNMENT LEFT
		
	ELSEIF LOCAL == 5180
		PRINTL
		ALIGNMENT CENTER
		PRINTL --- 魔界的其他种族 ---
		ALIGNMENT LEFT
		
	ENDIF
	SIF STR:LOCAL != ""
		PRINTFORMLC [{LOCAL -4900}] %STR:LOCAL%
NEXT
CALL MANYL(2)
DRAWLINE
PRINTL [  9] 回到入口
INPUT
IF RESULT >= 200 && RESULT < 300
	CALL REFERENCE_SEARCH(RESULT)
ELSEIF RESULT == 9
	RETURN
ENDIF
RESTART

