
;乳首の色決定
@RANDOM_SLAVE_NIPPLE_COLOR

;BOX詰め+ループ付きランダム
;FLAG:候補割合／乳首の色／ピンク→3150
;FLAG:候補割合／乳首の色／褐色肌／ピンク→3170
LAST_SHUFFLE_S = %CSTR:乳头颜色%

;褐色・小麦色なら褐色系用割合
FLAG_REF = 3150
SIF GROUPMATCH(CSTR:肤色,"褐色","小麦色")
	FLAG_REF = 3170
STR_REF = 6570
CALL RANDOM_BOX_LOTTERY(9)
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE_S == RESULTS
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0
CSTR:乳头颜色 = %RESULTS%
CALL AUTOSET_NIPPLE_COLOR_CODE



;カラーコード適応
@AUTOSET_NIPPLE_COLOR_CODE

SELECTCASE CSTR:乳头颜色
CASE "粉红色"
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_PINK
CASE "深粉色"
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_DEEPPINK
CASE "亮粉色"
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_HOTPINK
CASE "樱桃粉"
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_CHERRYPINK
CASE "浅粉色"
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_LIGHTPINK
CASE "宝石红"
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_RUBYRED
CASE "栗棕色"
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_RUSSETBROWN
CASE "棕色"
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_BROWN
ENDSELECT

