;ARG:0は入れ替える方法、ARG:1は入れ替えるキャラ（２回目の選択のみ表示）
@SELECT_CHARA_SORT(ARG:0, ARG:1)
#DIM DYNAMIC PAGE
#DIM SWAP_SLAVE_NUM

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINT 请选择要排序的奴隶。替换方法：
SELECTCASE ARG
CASE 1
	PRINTL ＜交换＞
CASE 2
	PRINTL ＜插入＞
ENDSELECT
SIF ARG:1
	PRINTFORML 第一个：%CALLNAME:(SWAP_SLAVE_NUM)%
DRAWLINE
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	IF CFLAG:牛舍号码
		CALL PRINT_WORD_COLOR("[牛舍] ","黄")
	ELSEIF CSTR:日程 == "体内凌辱"
		CALL PRINT_WORD_COLOR("[体内] ","桃")
	ELSE
		PRINT 　　　 
	ENDIF
	CALL TABLE_STATUS("调教对象")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTLC [  8] 更改显示项目
PRINTLC 　
PRINTL [ 99] 取消
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN 99
CASEELSE
	SWAP_SLAVE_NUM = RESULT -100
	SIF SWAP_SLAVE_NUM <= 0 || SWAP_SLAVE_NUM >= CHARANUM || !SWAP_SLAVE_NUM
		RESTART
	PRINTFORMW  已选择%CALLNAME:(SWAP_SLAVE_NUM)%。
	RETURN SWAP_SLAVE_NUM
ENDSELECT
RESTART


