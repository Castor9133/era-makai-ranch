			CALL MESSAGE_BOX,@"「嗯……虽然是细致的工作，但按照步骤来应该没问题」"
		ELSE
			CALL MESSAGE_BOX,@"「这样精细的工作，%SELF_CALL()%是否能够胜任呢……」"
		ENDIF
