
;傭兵アルバイトに気付く周り地の文
;戦闘準備
@MONSTER_BATTLE_PREPARE_MESSAGE

PRINTFORML %CALLNAME%%PRINT_EXIST_GROUP()%注意到了%PRINT_MONSTER()%的形影，紧张地持起了武器。


;隠れる
@MONSTER_HIDE_MESSAGE

CALL KOJO_PRINT("日程","追踪","潜伏")
PRINTFORML %CALLNAME%%PRINT_EXIST_GROUP()%躲藏起来，试图不被%PRINT_MONSTER()%发现…


;不意打ち直前
@MONSTER_UNNOTICE_MESSAGE

PRINTFORML %CALLNAME%%PRINT_EXIST_GROUP()%没有注意到正在追踪它的%PRINT_MONSTER()%！



;傭兵と遭遇
@CHASE_SLAVE_ENCOUNT_MESSAGE

IF TFLAG:潜伏
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%%PRINT_EXIST_GROUP()%曾试图隐藏，但被%PRINT_MONSTER()%发现了！","黄"
	CALL KOJO_PRINT("日程","追踪","潜伏失败")
ELSEIF TFLAG:突袭
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%%PRINT_EXIST_GROUP()%被%PRINT_MONSTER()%突袭了！","黄"
ELSE
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%%PRINT_EXIST_GROUP()%与%PRINT_MONSTER()%进入了战斗状态！","黄"
ENDIF


;戦闘開始前
;ARGS→状態
@BATTLE_BEFORE_MESSAGE(ARGS)

SELECTCASE ARGS
CASE "自尊心高"
	CALL KOJO_PRINT("战斗","战斗开始")
	PRINTFORML 可能是因为过于自负，%CALLNAME%明知胜算渺茫，却仍然举起了类似武器的东西…
CASE "委托他人"
	CALL KOJO_PRINT("战斗","委托他人")
	PRINTFORML %CALLNAME%迅速躲到同伴身后…
CASE "投降"
	CALL KOJO_PRINT("战斗","投降")
	PRINTFORML 毫无战斗能力的%CALLNAME%恐惧地举起双臂投降了…
	FORCEWAIT
ENDSELECT


;あなた戦闘開始前
@MASTER_BATTLE_MAIN_BEFORE_MESSAGE

PRINTFORMW 由于已经大致知道%CALLNAME%%PRINT_EXIST_GROUP()%的位置，所以决定首先进行空间转移以接近他们。
PRINTL ………
PRINTFORML 在魔界旅行的%CALLNAME%%PRINT_EXIST_GROUP()%前方，一个魔法阵出现，%CALLNAME:BATTLE_CHARA%出现了！
CALL KOJO_PRINT("日程","追踪","找到了")
PRINTW …看来传送比自己想象的要精准。



;ニンゲン勝利時
@TARGET_WIN_MESSAGE

;BATTLE_CHARAでメッセージ変更
IF BATTLE_CHARA >= 0
	PRINTFORML %CALLNAME:BATTLE_CHARA%战败于%CALLNAME%%PRINT_EXIST_GROUP()%…
ELSE
	PRINTFORML %CALLNAME%%PRINT_EXIST_GROUP()%战胜了%PRINT_MONSTER()%！
ENDIF
CALL KOJO_PRINT("战斗","胜利")


;傭兵アルバイト勝利時
@TARGET_DEFEAT_MESSAGE

;降参した場合ここは飛ばす
IF !TFLAG:投降
	PRINTFORML %PRINT_MONSTER()%战胜了%CALLNAME%！
	CALL KOJO_PRINT("战斗","败北")
ENDIF
PRINTFORMW %PRINT_MONSTER()%捕获了%CALLNAME%。


;あなた勝利
@MASTER_BATTLE_WIN_MESSAGE

;降参した場合ここは飛ばす
IF !TFLAG:投降
	PRINTFORML %CALLNAME:BATTLE_CHARA%战胜了%CALLNAME%！
	CALL KOJO_PRINT("战斗","败北")
ENDIF
PRINTFORML %CALLNAME:BATTLE_CHARA%捕获了%CALLNAME%。

;直で役場に帰って手続きしてそのまま持ち帰る
IF !BATTLE_CHARA
	PRINTL 决定立即返回魔族行会，办完手续后直接带回。
ELSE
	PRINTFORML %CALLNAME:0%决定和%CALLNAME:BATTLE_CHARA%一起返回魔族行会，办完手续就直接带回去。
	SIF TFLAG:投降
		RETURN
	PRINTFORM %CALLNAME:BATTLE_CHARA%似乎
	SELECTCASE BASE:BATTLE_CHARA:战斗适性
		CASE IS <= 20
			PRINTL 急于回家…
		CASEELSE
			PRINTL 有点得意…
	ENDSELECT
ENDIF


;あなた負け
@PLAYER_DEFEAT_MESSAGE

PRINTFORML %CALLNAME:BATTLE_CHARA%通过个人传送门返回了市政厅。
PRINTL 在医生那里检查，似乎没有受伤留下的外伤，只是感到非常疲劳。
PRINTFORMW %CALLNAME:BATTLE_CHARA% 【HP0】



;しんがり逃し
@UNIT_ESCAPE_BATTLE_MESSAGE

CALL KOJO_PRINT("战斗","殿后")
CALL PRINTL_WORD_COLOR,@"为了防止全军覆没，同伴们挺身而出，放走了%CALLNAME%！","黄"


;しんがりに魔物側勝利
@TARGET_ESCAPE_DEFEAT_MESSAGE

PRINTFORMW %PRINT_MONSTER()%战胜了%CALLNAME%的同伴！
PRINTFORML 在同伴们与对手搏斗的时候，%CALLNAME%似乎逃走了。
PRINTFORML %CALLNAME%希望与帮助自己逃脱的同伴会合…


;しんがりに魔物側敗北
@TARGET_ESCAPE_WIN_MESSAGE

CALL KOJO_PRINT("战斗","同伴全灭胜利")
SETCOLOR 0xE02020
PRINTL ・・・
PRINTFORML 虽然取得了胜利，但是%CALLNAME%的伙伴们无法与%CALLNAME%会合，最终成为了魔兽的猎物…
RESETCOLOR
PRINTFORML %CALLNAME%并不知情，只是渴望与那些放过自己的同伴再次相聚…












