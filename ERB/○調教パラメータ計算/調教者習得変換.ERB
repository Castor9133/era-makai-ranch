
;増加量計算
;ARG→増加するキャラ,PLAYERかASSI
@PLAYER_TECHNIQUE_EXP_UP_CALC(ARG)

;調教者習得SOURCEのみかかってくる
;調教中あまりにも多いので調教中は1/3する
SIF TFLAG:调教中
	SOURCE:调教者习得 /= 3
CALL RANDOM_FIX(SOURCE:调教者习得,5,"调教者习得")
SOURCE:调教者习得 += FIX

;TARGETをイかせたら倍で上がる　回数は見ない
;表示される元を倍にする
SIF NOWEX:总绝顶
	SOURCE:调教者习得 *= 2
IF ABL:ARG:技巧 < 5
	EXPUP = SOURCE:调教者习得 *(100 -20 *ABL:ARG:技巧)
	EXPUP /= 100
ELSE
	EXPUP = SOURCE:调教者习得 /ABL:ARG:技巧
	SIF ABL:ARG:技巧 >= 10
		EXPUP /= 2
ENDIF
SIF TALENT:ARG:学得快
	TIMES EXPUP,1.20
SIF TALENT:ARG:学得慢
	TIMES EXPUP,0.80
CALL DIFFICULTY_CONFIG_APPLY("性EXP获得量")



;ASSIがいる場合の技巧EXP処理
;今たぶん使ってない
@ASSI_TECHNIQUE_EXP_UP

SIF !SOURCE:调教者习得 || ASSI < 0
	RETURN
