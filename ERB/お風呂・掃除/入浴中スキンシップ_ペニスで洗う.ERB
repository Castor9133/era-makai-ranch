
;おまんこをペニスで洗う？
@BATHLOOM_SLAVE_WASHING_V_IN_PENIS

;洗うと言えるか？なので共通を使わない
;ここで処女結界破壊はできないことにする
;RETURN99でキャンセルする
SIF TALENT:处女结界
	RETURN 99

;正常位
V_PENIS = %CALLNAME:0%
SELECTCOM = 30
CALL COM30
IF !RESULT
	PRINTW 决定不要插入了…
	RETURN 99
ENDIF
TFLAG:Ｖ装备 = 1
SETBIT ＃Ｐ使用／Ｖ插入＃

;洗うので不潔ではないのと潤滑増加
SOURCE:不洁 = 0
PALAM:Ｖ润滑 += 3000
LOSEBASE:体力 += 20
LOSEBASE:气力 += 40

;地の文をキャンセルしてくるのでここで書く
CALL PRINT_IMAGE("调教执行")
CALL BATHLOOM_SLAVE_WASHING_V_IN_PENIS_MESSAGE
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
EXP:(SELECTCOM +1000) ++
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++

;1回リセット
TFLAG:指令中射精次数 = 0
IF !BASE:0:精力
	RESULT = 3
ELSE
	PRINTL
	;継続コマンド選択
	PRINTFORML [ 0] 揉捏%SAVESTR:标识／乳房%
	PRINTFORML [ 1] 吸吮%SAVESTR:标识／母乳%
	PRINTFORML [ 2] %SAVESTR:标识／精液%注入
	PRINTFORML [ 3] 拔出%SAVESTR:标识／阴茎%
	INPUT
	PRINTL
ENDIF
SELECTCASE RESULT
CASE 0
	;挿入状態からの乳揉み呼び出し
	CALL BATHLOOM_BUST_MASSAGE(1)
CASE 1
	CALL BATHLOOM_BUST_SUCK(1)
;CASE 2
	;一度射精してても再度射精まで行動
CASE 3
	;基本的にWAIT入れるとこを飛ばす
	WAIT_SKIP = 1
	CALL COM890
	WAIT_SKIP = 0
	PRINTW
	RETURN
ENDSELECT

;あとは射精までピストンする
CALL EJACULATION_PISTON



;アナルをペニスで洗う　ほんとか？
@BATHLOOM_SLAVE_WASHING_A_IN_PENIS

;Ａ後背位
A_PENIS = %CALLNAME:0%
SELECTCOM = 41
CALL COM41
IF !RESULT
	PRINTW 决定不要插入了…
	RETURN 99
ENDIF
TFLAG:Ａ装备 = 1
SETBIT ＃Ｐ使用／Ａ插入＃

;洗うので若干不潔ではないのと潤滑増加
SOURCE:不洁 /= 2
LOSEBASE:体力 += 30
LOSEBASE:气力 += 60
PALAM:Ａ润滑 += 3000
CALL PRINT_IMAGE("调教执行")
CALL BATHLOOM_SLAVE_WASHING_A_IN_PENIS_MESSAGE
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
EXP:(SELECTCOM +1000) ++
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++
TFLAG:指令中射精次数 = 0
IF !BASE:0:精力
	RESULT = 3
ELSE
	PRINTL
	;継続コマンド選択　後背位から吸えない
	PRINTFORML [ 0] 揉捏%SAVESTR:标识／乳房%
	PRINTFORML [ 2] %SAVESTR:标识／精液%注入
	PRINTFORML [ 3] 拔出%SAVESTR:标识／阴茎%
	INPUT
	PRINTL
ENDIF
SELECTCASE RESULT
CASE 0
	CALL BATHLOOM_BUST_MASSAGE(1)
CASE 3
	WAIT_SKIP = 1
	CALL COM890
	WAIT_SKIP = 0
	PRINTW
	RETURN
ENDSELECT
CALL EJACULATION_PISTON


