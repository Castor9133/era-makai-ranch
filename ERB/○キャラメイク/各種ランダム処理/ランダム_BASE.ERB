
;奴隷候補のBASEパラメータ
@RANDOM_SLAVE_BASE_STATUS

;ランダムから来たかで通る関数変える
;SLAVE_HP_FIXで補正をかけてたけど廃止
CALL SLAVE_LEVEL_CALC
CALL SLAVE_HP_CALC
CALL SLAVE_EP_CALC
CALL SLAVE_MP_CALC
CALL SLAVE_SP_CALC
CALL SLAVE_BATTLE_POWER_CALC
CALL SLAVE_BATTLE_SPECIAL_CALC



;レベル計算（EP計算と分割）
@SLAVE_LEVEL_CALC

;ランク*10+乱数Lv
MAXBASE:等级 = CFLAG:级别*10 +RAND:10
MAXBASE:等级 = LIMIT(MAXBASE:等级,1,MAXBASE:等级)
BASE:等级 = MAXBASE:等级

;非戦闘職なら1
SIF !CFLAG:非战斗职业
	RETURN
MAXBASE:等级 = 1
BASE:等级 = MAXBASE:等级
CFLAG:级别 = 0



;霊力計算
@SLAVE_EP_CALC

IF CFLAG:非战斗职业
	STATUS = 100
ELSE
	;レベル→霊力計算
	;STATUS = RESULT　になってる
	CALL LEVEL_EP_CALC
ENDIF
MAXBASE:灵力 = STATUS
BASE:灵力 = MAXBASE:灵力

