
;使おうぜ、ドラゴンボール
@USE_ITEM_PLAYER_DRAGON_BALL

PRINTL 尝试集齐7个＜龙之珠＞放置…
PRINTW 珠子开始漂浮并旋转成圆圈…刺眼的光后，一条巨龙出现了！

;呼び出し状態によりセリフ変化
CALL SUMMON_DRAGON_MESSAGE

;TARGET=0して願い事選択画面へ
TARGET = 0
CALL SUMMON_DRAGON_SELECT_WISH



;願い事選択
@SUMMON_DRAGON_SELECT_WISH

CLEARLINE LINECOUNT
CALL SELECT_WISH_CHARA
CALL SELECT_WISH_NOTCHARA
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTLC [300] 上一个角色
PRINTLC [ 80] 选择角色
PRINTL [301] 下一个角色
PRINTL [ 99] 再考虑一下
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL SELECT_WISH_MILK_FLAVOR
CASE 1
	CALL SELECT_WISH_NASTY_TALENT
CASE 2
	CALL SELECT_WISH_WORK_ABL
CASE 3
	CALL SELECT_WISH_DEFAULT_BUSTSIZE
CASE 4
	CALL SELECT_WISH_CAPTURE
CASE 5
	CALL SELECT_WISH_STRONGER
CASE 10
	CALL SELECT_WISH_GIVE_LINGERIE
CASE 11
	CALL SELECT_WISH_GIVE_MONEY
CASE 12
	CALL SELECT_WISH_GROW_SPA
CASE 20
	CALL DRAGON_WISH_ADD_MESSAGE
CASE 21
	CALL DRAGON_KINTAMA_MESSAGE
CASE 80
	SAVE_TARGET = TARGET
	CALL SELECT_WISH_TARGET_CHANGE
CASE 300
	CALL CHANGE_TARGET_CHARA(0,"愿望选择")
CASE 301
	CALL CHANGE_TARGET_CHARA(1,"愿望选择")
CASE 99
	CALL DRAGON_CANCEL_MESSAGE
	
	;キャンセルした状態にしとく
	FLAG:龙召唤状态 = 2
	SIF !RESULT
		RETURN
ENDSELECT

;願い事を決定したらキンタマ0コになってる→終了処理
SIF ITEM:龙之珠
	RESTART
CALL WISH_AFTER_MESSAGE
FLAG:龙之珠发现率修正 = DRAGON_BALL_CT
FLAG:龙召唤状态 = 1
FLAG:龙召唤次数 ++
RETURN



;キャラ系
@SELECT_WISH_CHARA

CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT
PRINTFORM 选择中：%CALLNAME% 
CALL PRINT_AFFILIATION_DATA
CALL MANYL(2)
IF MARK:母乳体质
	PRINTFORML [ 0] %SAVESTR:标识／母乳%口味选择
ELSE
	CALL PRINTL_WORD_COLOR("　非【母乳体质】","灰")
ENDIF
IF !TARGET
	CALL PRINTL_WORD_COLOR,@"　%CALLNAME%无法赋予性器素质","灰"
ELSE
	PRINTL [ 1] 性器素质选择
ENDIF
PRINTL [ 2] 工作能力选择
PRINTL
IF ABL:胸围大小 > ABL:初始值／胸围大小
	PRINTFORM [ 3] 想要还原胸围：%PRINT_BUSTSIZE(ABL:胸围大小)%
	CALL PRINT_BUST_C(1,1,0)
	PRINTFORM →%PRINT_BUSTSIZE(ABL:初始值／胸围大小)%
	CALL PRINT_BUSTSIZE_SPECIFY(1,1,ABL:初始值／胸围大小)
	PRINTL
ELSE
	CALL PRINTL_WORD_COLOR("　胸围大小没有变化","灰")
ENDIF
IF CFLAG:追踪对象
	PRINTL [ 4] 捕获回来
ELSE
	CALL PRINTL_WORD_COLOR("　不是追踪目标","灰")
ENDIF
IF !TARGET
	PRINTL [ 5] 想变强
ELSE
	CALL PRINTL_WORD_COLOR,@"　只能直接强化%CALLNAME:0%","灰"
ENDIF



;キャラ以外
@SELECT_WISH_NOTCHARA

SIF TARGET
	RETURN
PRINTL
PRINTL 　《 除了角色 》
PRINTL [10] 请给我穿着的下衣
PRINTL [11] 想要钱
IF !ITEM:天然温泉
	IF MONEY >= ITEMPRICE:天然温泉
		PRINTFORML [12] 我们附近能冒出温泉吗？（工程费用：%VALUE_DIGIT(ITEMPRICE:天然温泉)%G）
	ELSE
		CALL PRINTL_WORD_COLOR,@"　温泉的工程费用不足：%VALUE_DIGIT(ITEMPRICE:天然温泉)%G","灰"
	ENDIF
ELSE
	CALL PRINTL_WORD_COLOR("　温泉已经涌出了","灰")
ENDIF
PRINTL

;初対面のみ
IF !FLAG:龙召唤次数
	PRINTL [20] 「增加愿望的数量」不行吗？
	PRINTL [21] 顺便问一下，这个珠子是龙蛋吗？
ENDIF

