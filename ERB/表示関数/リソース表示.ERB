
;開発などリソース表示
;ARGS→表示リソース
@SHOW_RESOURCE_UPGRADE(ARGS)

DRAWLINE
CALL SHOW_DATE

;CALL SHOW_WEATHER
SELECTCASE ARGS
CASE "资金"
	CALL SHOW_MONEY(1)
CASE "物品制作"
	CALL SHOW_MONEY(1)
	CALL SHOW_STORAGE_POWER
	CALL SHOW_MASTER_EP
CASE "调教AP","魔法AP","触手AP","禁断AP"
	PRINTFORML 　【%ARGS%】%VALUE_DIGIT(MONEY:ARGS)%

CASE "ALL"
	CALL SHOW_MONEY(1)
	{
	PRINTFORML 【调教AP】%VALUE_DIGIT(MONEY:调教AP)%　【魔法AP】%VALUE_DIGIT(MONEY:魔法AP)% 
	【触手AP】%VALUE_DIGIT(MONEY:触手AP)%　【禁断AP】%VALUE_DIGIT(MONEY:禁断AP)%　
	}
	CALL SHOW_STORAGE_POWER
	CALL SHOW_MASTER_EP
ENDSELECT
DRAWLINE



;町役場用
@SHOW_RESOURCE_HALL

DRAWLINE
CALL SHOW_DATE
CALL SHOW_WEATHER
PRINTL
CALL SHOW_MONEY
CALL SHOW_BUDGET(1)
CALL SHOW_MASTER_EP
PRINTFORML 魔力枷锁：{FLAG:追踪中人数 +CMATCH(EQUIP:魔力枷锁,1)}／{ITEM:魔力枷锁}（使用中＋使用预定／持有数量）
DRAWLINE



;研究所用
@SHOW_RESOURCE_INSTITUTE

DRAWLINE
CALL SHOW_DATE
CALL SHOW_WEATHER
PRINTL
CALL SHOW_STORAGE_POWER
CALL SHOW_MONEY
CALL SHOW_BUDGET
PRINTFORML 　　　贡献pt：%VALUE_DIGIT(MONEY:贡献PT)%pt
DRAWLINE




;通常店用
@SHOW_RESOURCE_SHOP

CALL SHOW_DATE
CALL SHOW_WEATHER
PRINTL
CALL SHOW_MONEY
CALL SHOW_BUDGET(1)
DRAWLINE



;ローン組む場合
@SHOW_RESOURCE_SHOP_LOAN

CALL SHOW_DATE
CALL SHOW_WEATHER
PRINTL
CALL SHOW_MONEY
CALL SHOW_LOAN
DRAWLINE



;メインメニュー
@SHOW_RESOURCE_MAIN

DRAWLINE
PRINT 　
CALL SHOW_DATE
CALL SHOW_WEATHER
CALL SHOW_MONEY(1)
PRINT 　
CALL SHOW_STORAGE_POWER
CALL SHOW_COW_HEALTH(2)
CALL SHOW_FINANCE_VALUE
CALL SHOW_BATHLOOM_CLEAN(1)
DRAWLINE



;資金表示
;ARG→改行
@SHOW_MONEY(ARG)

;行になんかあれば空欄つける
SIF !LINEISEMPTY()
	PRINT 　　　
PRINTFORM 资金：%VALUE_DIGIT(MONEY)%G　
SIF ARG
	PRINTL



;経費計上可能額の表示
;ARG→改行
@SHOW_BUDGET(ARG)

SIF !LINEISEMPTY()
	PRINT 　　　
PRINTFORM 经费计上：%VALUE_DIGIT(MONEY:经费计上)%／%VALUE_DIGIT(FLAG:最大日销售额)%G 
CALL PRINT_COLORBAR(MONEY:经费计上,FLAG:最大日销售额,8,BARCOLORSET("红"),RESULT:1)
SIF ARG
	PRINTL



;ローン可能額の表示
@SHOW_LOAN
#DIM LOAN_VALUE

SIF !LINEISEMPTY()
	PRINT 　　　

;ローン可能額→最大一日売上*20*自治体レベル
IF !FLAG:魔界等级／冈地街
	CALL PRINTL_WORD_COLOR("贷款：冈地街需要Lv1以上","灰")
	RETURN
ENDIF
LOAN_VALUE = FLAG:最大日销售额 *20 *FLAG:魔界等级／冈地街
PRINTFORM 贷款：%VALUE_DIGIT(MONEY:贷款)%／%VALUE_DIGIT(LOAN_VALUE)%G 
CALL PRINT_COLORBAR(MONEY:贷款,LOAN_VALUE,8,BARCOLORSET("红"),RESULT:1)
PRINTL



;貯蔵霊力魔力表示
;ARG→途中で改行
@SHOW_STORAGE_POWER(ARG)

PRINTFORMLC 储存灵力：%VALUE_DIGIT(MONEY:储存灵力)%EP
SIF ARG
	PRINTL

;貯蔵できない状態なら帰る
IF !FLAG:储存魔力上限值
	CALL PRINTL_WORD_COLOR("无魔力储存器","灰")
	RETURN
ENDIF
PRINTFORM 储存魔力：%VALUE_DIGIT(MONEY:储存魔力)%／%VALUE_DIGIT(FLAG:储存魔力上限值)%MP 
CALL PRINT_COLORBAR(MONEY:储存魔力,FLAG:储存魔力上限值,8,BARCOLORSET("深紫"),RESULT:1)
PRINTL



;あなた霊力魔力表示
;ARG→改行
@SHOW_MASTER_EP(ARG)

PRINTFORM %CALLNAME:0%的灵力：%VALUE_DIGIT(BASE:0:灵力)%／%VALUE_DIGIT(MAXBASE:0:灵力)%EP 
CALL PRINT_COLORBAR(BASE:0:灵力,MAXBASE:0:灵力,8,BARCOLORSET(""),RESULT:1)
IF ARG
	PRINTL
ELSE
	PRINT 　　　
ENDIF
PRINTFORM %CALLNAME:0%的魔力：%VALUE_DIGIT(BASE:0:魔力)%／%VALUE_DIGIT(MAXBASE:0:魔力)%MP 
CALL PRINT_COLORBAR(BASE:0:魔力,MAXBASE:0:魔力,8,BARCOLORSET("深紫"),RESULT:1)
PRINTL



;魔界乳牛の健康度表示
;ARG→1：改行　2：メインメニューの1スペース
@SHOW_COW_HEALTH(ARG)

SIF !LINEISEMPTY()
	PRINT 　　　
SIF ARG == 2
	PRINT 　
PRINTFORM 魔界乳牛 健康度：{FLAG:奶牛健康度,3} 
CALL PRINT_COLORBAR(FLAG:奶牛健康度,100,8,BARCOLORSET("青绿"),RESULT:1)
SIF ARG == 1
	PRINTL



;事務作業量表示
;ARG→改行
@SHOW_FINANCE_VALUE(ARG)

SIF !LINEISEMPTY()
	PRINT 　　　
PRINTFORM 事务工作量：{FLAG:事务工作量} 
CALL PRINT_COLORBAR(FLAG:事务工作量,20,8,BARCOLORSET("红"),RESULT:1)
SIF FLAG:事务工作量 >= 20
	CALL PRINT_WORD_COLOR("！工作太多了","黄")
SIF ARG
	PRINTL



;風呂の掃除進捗
;ARG→改行
@SHOW_BATHLOOM_CLEAN(ARG)

SIF !LINEISEMPTY()
	PRINT 　　　
IF FLAG:主人公的浴池清洁完毕
	PRINT 浴池清洁：◯
ELSE
	PRINT 浴池清洁：☓
ENDIF

;大浴場建ててるかで変える
IF ITEM:大浴场
	PRINTFORM 　　　大浴场：{FLAG:大浴场清洁完成度}\% 
	CALL PRINT_COLORBAR(FLAG:大浴场清洁完成度,100,8,BARCOLORSET("浅蓝色"),RESULT:1)
ENDIF
SIF ARG
	PRINTL



