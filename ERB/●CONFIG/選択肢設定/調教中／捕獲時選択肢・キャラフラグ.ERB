
;捕獲時選択肢・キャラフラグ
@CAPTURE_CONFIG

CLEARLINE LINECOUNT
PRINTL 进行捕获时选项和默认角色标志设置。
DRAWLINE
PRINTL 　《 捕获时操作 》
PRINTLC [ 0] 打开用药画面（持有＜触手束缚＞时）
CALL PRINT_ONOFF(GETBIT(＃捕获时用药＃),1)
PRINTLC [ 1] 角色配置打开
CALL PRINT_ONOFF(GETBIT(＃捕获时设定画面＃),1)
PRINTLC [ 2] 奴隶捕获时的挤奶器自动购买
CALL PRINT_ONOFF(GETBIT(＃搾乳器自动购入＃),1)
PRINTL

PRINTL 　《 加入奴隶的处理默认 》
PRINTLC [10] 与员工相同的晚餐
CALL PRINT_ONOFF(FLAG:加入奴隶默认／晚餐许可,1)
PRINTLC [11] 大浴场使用许可（持有＜大浴场＞时）
CALL PRINT_ONOFF(FLAG:加入奴隶默认／入浴许可,1)
PRINTL

PRINTL 　《 能力有效个人默认 》

;STR:アビリティ有効個人BIT→22020
STR_REF = 22020
FOR LOCAL,0,10
	SIF STR:(STR_REF +LOCAL) == ""
		CONTINUE
	PRINTFORMLC [{LOCAL +20}] %STR:(STR_REF +LOCAL)%
	CALL PRINT_ONOFF(GETBIT(FLAG:加入奴隶默认／能力有效个人BIT,LOCAL),1)
NEXT
CALL PRINTL_ALIGN(-5)
CALL DEFAULT_VOID_RETURN_BUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 98
	PRINTL 回复默认状态屏幕显示设置？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_CAPTURE_CONFIG
CASE 99
	RETURN
CASEELSE
	CALL CHANGE_CAPTURE_CONFIG(RESULT)
ENDSELECT
RESTART



;設定変更
;ARG→INPUT
@CHANGE_CAPTURE_CONFIG(ARG)

;全部NUM
SELECTCASE ARG
CASE 0 TO 9
	INVERTBIT FLAG:捕获时选项BIT,ARG
CASE 10
	INVERTBIT FLAG:加入奴隶默认／晚餐许可,0
CASE 11
	INVERTBIT FLAG:加入奴隶默认／入浴许可,0
CASE 20 TO 29
	INVERTBIT FLAG:加入奴隶默认／能力有效个人BIT,ARG -20
ENDSELECT




