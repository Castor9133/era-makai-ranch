
;アビリティ・魔術ON／OFF
@ABILITY_ACTIVATION

CLEARLINE LINECOUNT
PRINTL 切换能力・魔法的有效／无效。（也显示学习前的内容）
DRAWLINE

;STR:アビリティ有効BIT→22000
STR_REF = 22000
FOR LOCAL,0,20
	SIF STR:(STR_REF +LOCAL) == ""
		CONTINUE
	
	;オトコならふたなりちんぽ除外
	SIF STR:(STR_REF +LOCAL) == "扶她阴茎" && TALENT:0:男性
		CONTINUE
	PRINTFORMLC [{LOCAL,2}] %STR:(STR_REF +LOCAL)%
	CALL PRINT_ONOFF(GETBIT(FLAG:能力有效BIT,LOCAL),1)
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTLC [ 90] 一括开启
PRINTLC 　
PRINTL [ 99] 完成
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 19
	INVERTBIT FLAG:能力有效BIT,RESULT
CASE 90
	FLAG:能力有效BIT = 65535
CASE 99
	RETURN
ENDSELECT
RESTART

