@DEBUG_CHARA_NAME_EDIT_PAGE_3

FOR LOCAL,50,100
	SIF LOCAL %10 == 0
		PRINTL
	STR_NAME = %CSTRNAME:LOCAL%
	SIF STR_NAME == ""
