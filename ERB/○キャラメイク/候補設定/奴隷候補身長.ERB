
;身長おおよそ決定
@RANDOM_LIST_HEIGHT(ARG)

;FLAG:候補割合／身長／幼児体型→3100
FLAG_REF = 3100
STR_REF = 6500
CALL RANDOM_BOX_LOTTERY(9)
LIST_HEIGHT:ARG = %RESULTS%

;種族補正
FLAG_NAME = 种族设定／%LIST_TRIBE:ARG%
TRIBE_FLAG_A = 外观反映率／%LIST_TRIBE:ARG%
SELECTCASE LIST_TRIBE:ARG
CASE "精灵","暗精灵","仙人","龙人","妖狐"
	SIF GROUPMATCH(LIST_HEIGHT:ARG,"标准","矮小","娇小") && GETBIT(FLAG:FLAG_NAME,0) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		LIST_HEIGHT:ARG = 高挑
CASE "半身人"
	SIF !GROUPMATCH(LIST_HEIGHT:ARG,"幼儿体型") && GETBIT(FLAG:FLAG_NAME,0) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		LIST_HEIGHT:ARG = 儿童体型
ENDSELECT



