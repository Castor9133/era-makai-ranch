
;標的のステータス表示
;ARG：飛んできた場所　0：SHOP　1：全奴隷一覧　2：標的キャラ行動選択
@GUILD_STATUS_DETAIL(ARG)

CLEARLINE LINECOUNT
CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT
CALL PRINT_NAME_STATUS
CALL PRINT_AFFILIATION_DATA
PRINTFORM  级别,2}　★{CFLAG:级别}
SIF CFLAG:同伴规模 && BASE:同伴战斗力1 
	PRINTFORM ／{CFLAG:同伴级别}
PRINTL
CALL PRINT_BUST_DETAIL
PRINTFORM 　性格：【%CSTR:性格%】
CALL PRINT_EXTERIOR
PRINTL
CALL SHOW_EQUIP
CALL PRINT_NOW_PURPOSE
PRINTL
CALL SHOW_TALENT_LIST
CALL SHOW_TALENT_NASTY
CALL SHOW_MARK_LIST(1)

;メインメニューから見るとき用に分割
CALL PRINT_CHASE_STATUS



;追跡者情報など
;ARG→1なら次の関数でHPとかOFF
@PRINT_CHASE_STATUS(ARG)

CALL PRINT_TARGET_BATTLE_STATUS(ARG)
PRINTL
SELECTCASE CFLAG:追踪对象
CASE 1
	SELECTCASE CFLAG:追踪者
	CASE 0
		PRINTL 正在追踪（当前无追踪者）
	CASE 1
		PRINTFORML 哥布林军团{CFLAG:追踪人数}部隊正在追踪
	CASE 2
		PRINTFORML 新秀雇佣兵{CFLAG:追踪人数}名正在追踪
	CASE 3
		PRINTFORML 老手雇佣兵{CFLAG:追踪人数}名正在追踪
	CASE 4
		PRINTFORML 鬼人雇佣兵{CFLAG:追踪人数}名正在追踪
	ENDSELECT
CASE 2
	PRINTFORML 正在捕获 凌辱次数：{CFLAG:轮奸次数} 
CASE 3
	PRINTL 运输中 
CASEELSE
	PRINTL 可能是BUG
ENDSELECT
DRAWLINE




