
;洗ってもらうコマンド
@BATHLOOM_PLAYER_WASHING

CALL MANYL(5)
IF TFLAG:浴缸内
	PRINTFORML %CALLNAME:0%和%CALLNAME%从浴缸里爬出来。
	TFLAG:浴缸内 = 0
ENDIF

;娘が成長中なら普通に洗う一択
IF CSTR:状态／主人公的孩子 == "成长中"
	CALL BATHLOOM_PLAYER_WASHING_BODY
	PRINTW
	RETURN
ENDIF
PRINTL 选择清洗你的方式。
PRINTL
PRINTL [ 0] 被洗全身
PRINTFORML [ 1] 使用%SAVESTR:标识／乳房%进行清洗
IF !BASE:PLAYER:精力
	CALL PRINTL_WORD_COLOR,@"　%CALLNAME:PLAYER%的精力不足。","灰"
	PRINTL
	PRINTL
ELSE
	PRINTFORML [ 2] 请清洗%SAVESTR:标识／阴茎%
	PRINTL [ 3] 被乳交
	PRINTFORML [ 4] 用%SAVESTR:标识／膣%仔细清洗%SAVESTR:标识／阴茎%
ENDIF
PRINTL
PRINTL [99] 取消
BINPUT
PRINTL
IF CSTR:状态／主人公的孩子 == "成长后"
	SELECTCASE RESULT
	CASE IS != 0
		CHILD_COM = RESULT
		CALL CHILD_REBELLION
		SIF RESULT
			RETURN
		RESULT = CHILD_COM
	ENDSELECT
ENDIF
SELECTCASE RESULT
CASE 0
	CALL BATHLOOM_PLAYER_WASHING_BODY
CASE 1
	CALL BATHLOOM_PLAYER_WASHING_USE_BUST
CASE 2
	CALL BATHLOOM_PLAYER_WASHING_PENIS
	
	;RETURN 99してきてたらキャンセル
	SIF RESULT == 99
		RETURN
CASE 3
	CALL BATHLOOM_PLAYER_WASHING_PAIZURI
	SIF RESULT == 99
		RETURN
CASE 4
	CALL BATHLOOM_PLAYER_WASHING_USE_VAGINA
	SIF RESULT == 99
		RETURN
CASEELSE
	RETURN
ENDSELECT
PRINTW



;普通に洗ってもらう
@BATHLOOM_PLAYER_WASHING_BODY

CALL PRINT_IMAGE("奉仕")
CALL BATHLOOM_PLAYER_WASHING_BODY_MESSAGE
SOURCE:爱情 += 1000
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++



;おっぱい洗い
@BATHLOOM_PLAYER_WASHING_USE_BUST

CALL PRINT_IMAGE("奉仕")
CALL BATHLOOM_PLAYER_WASHING_USE_BUST_MESSAGE
LOSEBASE:体力 += 50
LOSEBASE:气力 += 30
SOURCE:Ｂ快感 = 2000
SOURCE:Ｎ快感 = 1000
SOURCE:学习 = 2000
SOURCE:耻辱 = 1000
SOURCE:爱情 = 3000
SOURCE:屈辱 = 500
SOURCE:支配 = 500
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++



;ちんぽ洗ってもらう
@BATHLOOM_PLAYER_WASHING_PENIS

;手コキを呼ぶ→奉仕不可なら帰る
CALL COM57
SIF !RESULT
	RETURN 99
LOSEBASE:体力 += 20
LOSEBASE:气力 += 20
SOURCE:不洁 = 0
CALL PRINT_IMAGE("奉仕")
CALL BATHLOOM_PLAYER_WASHING_PENIS_MESSAGE
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
EXP:(SELECTCOM +1000) ++
SELECTCOM = 0
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++
PRINTL
CALL EJACULATION_PISTON



;パイズリ洗い
@BATHLOOM_PLAYER_WASHING_PAIZURI

SELECTCOM = 53
CALL COM53
SIF !RESULT
	RETURN 99
SETBIT ＃Ｐ使用／乳交＃
LOSEBASE:体力 += 20
LOSEBASE:气力 += 20
SOURCE:不洁 = 0
CALL PRINT_IMAGE("乳交")
CALL BATHLOOM_PLAYER_WASHING_PAIZURI_MESSAGE
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
EXP:(SELECTCOM +1000) ++
SELECTCOM = 0
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++
PRINTL
CALL EJACULATION_PISTON



;騎乗位ちんぽ洗い
@BATHLOOM_PLAYER_WASHING_USE_VAGINA

;騎乗位かどうかで奉仕判定変化するので先にSELECTCOM設定
SELECTCOM = 34
CALL COM34
SIF !RESULT
	RETURN 99
TFLAG:Ｖ装备 = 1
SETBIT ＃Ｐ使用／Ｖ插入＃
LOSEBASE:体力 += 20
LOSEBASE:气力 += 20
SOURCE:不洁 = 0
PALAM:Ｖ润滑 += 3000
CALL PRINT_IMAGE("调教执行")
CALL BATHLOOM_PLAYER_WASHING_USE_VAGINA_MESSAGE
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
EXP:(SELECTCOM +1000) ++
SELECTCOM = 0
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++
PRINTL
CALL EJACULATION_PISTON



