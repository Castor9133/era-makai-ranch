; ======================================
; 泛用口上・调教命令（性格：愚忠）
; ======================================

@KOJO_GENERAL_愚忠口上1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:2
CASE "执行"
	SELECTCASE ARGS:1
	CASE "足交"
		CALL MESSAGE_BOX,@"「命令确认：足交。我会执行。」"
	CASE "肛塞"
		CALL MESSAGE_BOX,@"「命令确认：肛塞装着。我会执行。」"
	CASE "尿道塞"
		CALL MESSAGE_BOX,@"「命令确认：尿道塞装着。我会执行。」"
	CASE "舔阴蒂","舔阴道","刺激龟头","真空口交","肛门指揉按摩","玩弄阴唇","G点指压","阴道指奸","肛门指奸","尿道口指弄","尿道口指奸","口内搅舌","压舌探喉","深喉","触手深喉"
		CALL KOJO_SHARE_ADVANCED_TRAIN_DISPATCH, ARGS:1, ARGS:2
	CASEELSE
		CALL MESSAGE_BOX,@"「命令确认：%ARGS:1%。我会执行。」"
	ENDSELECT
	CALL MESSAGE_BOX,@"「不必解释理由。只要是您的命令……我就会照做。」"

CASE "继续"
	CALL MESSAGE_BOX,@"「继续执行中。请继续下达命令。」"

CASE "移除"
	SELECTCASE ARGS:1
	CASE "肛塞"
		CALL MESSAGE_BOX,@"「肛塞已解除。若您需要，我可立即重新装着。」"
	CASE "尿道塞"
		CALL MESSAGE_BOX,@"「尿道塞已解除。若您需要，我可立即重新装着。」"
	CASEELSE
		CALL MESSAGE_BOX,@"「已解除。若您需要，我随时可以继续。」"
	ENDSELECT

CASEELSE
ENDSELECT
RETURN

