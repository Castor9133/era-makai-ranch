
;不動産
@ITEM_SHOP_ESTATE
#DIM DYNAMIC SELECT_NUM

CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP_LOAN
CALL CAN_LOAN_MONEY_CALC
PRINTL 　　　《 建筑・扩建 》
CALL ESTATE_LIST
DRAWLINE
CALL ITEM_SHOP_ESTATE_DETAIL(SELECT_NUM)
CALL PRINTL_ALIGN
CALL ESTATE_JUDGE(SELECT_NUM)
DRAWLINE
CALL RIGHT_RETURN_BUTTON
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	;購入処理→SELECT_NUMで変化
	CALL TOWN_ESTATE_BUY(SELECT_NUM)
CASE 99
	RETURN
CASE 10 TO 10 +ESTATE_LIST_NUM
	SELECT_NUM = RESULT
ENDSELECT
RESTART



;購入処理
;ARG→INPUT
@TOWN_ESTATE_BUY(ARG)
#DIM EXTENTION_NUM
#DIM COWSHED_LIMIT
#DIMS BUILDING

SELECTCASE ARG
CASE 11
	;増築する牛舎を先に選択
	PRINTL 选择要扩建的牛舍。每扩建一次就增加10只家畜。
	
	;FLAG:第1牛舎増築段階→500
	;FLAG:第1牛舎家畜頭数→502
	;-10
	FLAG_REF = 490
	FLAG_REF:1 = 492
	FOR LOCAL,1,11
		COWSHED_LIMIT = FLAG:(FLAG_REF +LOCAL *10) *10
		SIF !COWSHED_LIMIT
			BREAK
		IF COWSHED_LIMIT >= 100
			CALL PRINTL_WORD_COLOR,@"%COWSHED_NAME:LOCAL%已最大扩建","灰"
		ELSE
			PRINTFORM [{LOCAL,2}] %COWSHED_NAME:LOCAL,24%：
			PRINTFORML 家畜数 {FLAG:(FLAG_REF:1 +LOCAL *10),2}／{COWSHED_LIMIT,2} （最多100个）
		ENDIF
	NEXT
	DRAWLINE
	PRINTL [99] 返回
	BINPUT
	PRINTL
	SIF RESULT == 99
		RETURN
	EXTENTION_NUM = RESULT
	CALL TOWN_ESTATE_BUY_MESSAGE(ARG,"牛舍扩建")
	CALL ASK_BUILD
	SIF !RESULT
		CALL BUILD_COMMON(ARG,EXTENTION_NUM,"牛舍扩建")
	
;通常建築処理は同じ
;発注ミス防止に先に建築物名を呼び出し
CASE 10,12 TO 10 +ESTATE_LIST_NUM
	CALL TOWN_ESTATE_BUILDING_REF(ARG)
	BUILDING = %RESULTS%
	CALL TOWN_ESTATE_BUY_MESSAGE(ARG,BUILDING)
	CALL ASK_BUILD
	SIF !RESULT
		CALL BUILD_COMMON(ARG,0,BUILDING)
ENDSELECT



;建築依頼
@ASK_BUILD

PRINTL
PRINTL 做建造委托吗？
PRINTLC [ 0] 委托建造
PRINTL [ 1] 停止
INPUT
IF !RESULT
	RETURN 0
ELSE
	RETURN 1
ENDIF


