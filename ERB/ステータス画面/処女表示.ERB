;出産
@PRINT_VIRGIN_DETAIL_BIRTH

SIF !GETBIT(＃经验显示／出产＃)
	RETURN
SIF !EXP:出产
	RETURN

;デフォでEXP:出産がある場合用の処理
SIF EXP:出产 && 0 == EXP:地上经验次数／人类／出产 + EXP:地上经验次数／魔族／出产 + EXP:经验次数／主人公／出产 + EXP:经验次数／异形／出产
	EXP:地上经验次数／人类／出产 = EXP:出产

PRINT 　　　　　　　初産：
VARGIN_PERSON = %CSTR:初经验／出产%之子
SIF CSTR:初经验／出产 == ""
	VARGIN_PERSON = 未知
PRINTFORM %VARGIN_PERSON,16,LEFT%　
IF !EXP:地上经验次数／人类／出产 && !EXP:地上经验次数／魔族／出产 && EXP:经验次数／主人公／出产 && !EXP:经验次数／异形／出产
	PRINTFORM 出产回数：%CALLNAME:0%的子女・{EXP:经验次数／主人公／出产}回
ELSE
	;他のに合わせて地上経験人数／ニンゲンand魔族としたかったけど出産した子の親(の人数)とかだと表現しづらかったので変更
	PRINTFORM 出产次数：地上{EXP:地上经验次数／人类／出产}回
	SIF EXP:地上经验次数／魔族／出产
		PRINTFORM +魔界{EXP:地上经验次数／魔族／出产}回
	SIF EXP:经验次数／主人公／出产
		PRINTFORM +%CALLNAME:0%之子{EXP:经验次数／主人公／出产}回
	SIF EXP:经验次数／异形／出产
		PRINTFORM +异形的孩子{EXP:经验次数／异形／出产}回
ENDIF
PRINTL



