
;ペットと棒遊び：地の文
;ｲﾇﾁｬﾝだけ
;TARGET,ANIMAL,PET_NAME指定済み
@PET_COMMU_MESSAGE_PLAY_NICE_STICK

FLAG_NAME = 亲和度／%ANIMAL%
IF TALENT:受动物喜欢 || BASE:FLAG_NAME >= 8000
	CALL PET_COMMU_MESSAGE_PLAY_NICE_STICK_LOVE
	
	;投げる回数が多いのでむしろ懐かれてる場合のが体力消費が多い
	DAMAGE = 150
ELSEIF !TALENT:被动物讨厌 || BASE:FLAG_NAME >= 5000
	CALL PET_COMMU_MESSAGE_PLAY_NICE_STICK_LOW
	DAMAGE = 120
ELSE
	CALL PET_COMMU_MESSAGE_PLAY_NICE_STICK_HATE
	DAMAGE = 50
ENDIF



;【動物に好かれる】orなつき時
@PET_COMMU_MESSAGE_PLAY_NICE_STICK_LOVE

PRINTFORML %CALLNAME%决定用一根形状不错的棒子和%PET_NAME%玩耍。
SELECTCASE RAND:3
CASE 0
	PRINTFORML 试着递给%PET_NAME%一根棒子，它高兴地在%CALLNAME%周围嬉戏。
	PRINTFORML 投掷棒子，%PET_NAME%兴高采烈地追赶！
	PRINTFORML 用两个头巧妙地咬住，%PET_NAME%飞奔到%CALLNAME%身边，再次伸出棒子示意再来一次。
CASE 1
	PRINTFORML 试着递给%PET_NAME%一根棒子，它咬住其中一端递给了%CALLNAME%。
	PRINTFORML 当%CALLNAME%拿起另一端时，它们开始互相拉着玩！
	PRINTL
	PRINTFORML 当%PET_NAME%用力时，%CALLNAME%被强大的牵引力拉动，倚在%PET_NAME%身上。
	PRINTFORML %PET_NAME%毫不畏惧，非常高兴地嬉戏玩耍。
CASE 2
	PRINTFORML 试着递给%PET_NAME%一根棒子，但它拒绝接受并跑开了…
	PRINTFORML …然而，它在助跑后跳到%CALLNAME%身上夺过了棒子！
	PRINTL
	PRINTFORML %PET_NAME%把夺来的棒子放在%CALLNAME%脚下，然后远离等待%CALLNAME%再次拿起。
	PRINTFORML 尽管试图抬高或摇动棒子以防被夺走，%PET_NAME%总是等待机会夺过棒子！
ENDSELECT
PRINTL ………
PRINTFORML 反复几次后，当棒子破烂不堪时，%PET_NAME%似乎非常满足。




;【動物に嫌われる】ではないor嫌われるけどなつき程々
@PET_COMMU_MESSAGE_PLAY_NICE_STICK_LOW

;上と同じ
CALL PET_COMMU_MESSAGE_PLAY_NICE_STICK_LOVE



;【動物に嫌われる】
@PET_COMMU_MESSAGE_PLAY_NICE_STICK_HATE

PRINTFORML %CALLNAME%尝试用一根形状不错的棒子和%PET_NAME%玩耍…
PRINTFORML 尝试递给%PET_NAME%一根棒子，结果被咬住夺走了…
SELECTCASE RAND:3
CASE 0
	PRINTFORML %PET_NAME%似乎在挥动棒子玩耍…
CASE 1
	PRINTFORML %PET_NAME%似乎在咬碎棒子玩耍…
CASE 2
	PRINTFORML %PET_NAME%似乎在投掷和捡起棒子玩耍…
ENDSELECT
PRINTL ………
PRINTFORML 反复几次后，当棒子破烂不堪时，%PET_NAME%似乎非常满足。





