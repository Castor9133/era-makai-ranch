; ======================================
; 泛用口上・调教命令（性格：妹系）
; ======================================

@KOJO_GENERAL_妹系口上1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:2
CASE "执行"
	SELECTCASE ARGS:1
	CASE "揉胸","育乳按摩","浓厚母乳按摩","乳罐按摩","胸爱抚","拧乳头"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「呀……♥ 轻点……我会乖乖的……♥」"
			CALL MESSAGE_BOX,@"「……再摸一下……也、也不是不行……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「不、不行！别摸那里……！」"
		ENDIF

	CASE "接吻"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……亲、亲一下嘛……♥ ……再多……就耍赖……♥」"
			CALL MESSAGE_BOX,@"「……唔……不许笑我……♥」"
			CALL MESSAGE_BOX,@"「……舌头伸过来……♥ ……我、我会缠上去……你别吓我……♥」"
			CALL MESSAGE_BOX,@"「……别磕到牙啦……♥ 嗯嗯……可以再凶一点……♥ ……亲到晕……鼻子撞了也……不许停……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「太近了！不行！」"
		ENDIF
	CASE "舔舐脸"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……舔脸……像小狗……♥ ……那、那我也舔回去……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……脸……别舔……！」"
		ENDIF
	CASE "舔舐耳","舔舐腋"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……耳朵……不行……会痒到哭……♥ ……腋下……更不行……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……别碰……那些地方……！」"
		ENDIF

	CASE "口交","触手口交"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……我会含住……别太用力顶……♥」"
			CALL MESSAGE_BOX,@"「……舒服的话……要说哦……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……要我用嘴……？才不要……！」"
		ENDIF

	CASE "深喉","触手深喉"
		CALL KOJO_SHARE_ADVANCED_TRAIN_DISPATCH, ARGS:1, ARGS:2

	CASE "手淫","授乳手交"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……这样……舒服吗……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「手、手就行吗……？」"
		ENDIF

	CASE "足交"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「用脚……也可以……我会努力……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「用脚……好奇怪……」"
		ENDIF

	CASE "舔阴蒂","舔阴道","刺激龟头","真空口交","肛门指揉按摩","玩弄阴唇","G点指压","阴道指奸","肛门指奸","尿道口指弄","尿道口指奸","口内搅舌","压舌探喉"
		CALL KOJO_SHARE_ADVANCED_TRAIN_DISPATCH, ARGS:1, ARGS:2

	CASE "正常位","后背位","对面坐位","背面坐位","骑乘位","对面立位","背面立位","强制骑乘位","背面骑乘位"
		CALL KOJO_CHS_VPOS_妹系口上1(ARGS:1, ARGS:2)

	CASE "Ａ正常位","Ａ后背位","Ａ对面坐位","Ａ背面坐位","Ａ骑乘位","Ａ对面立位","Ａ背面立位","强制Ａ骑乘位","Ａ背面骑乘位"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「后面……也要吗……？呜……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「那里不行！」"
		ENDIF

	CASE "打屁股","皮鞭抽打"
		CALL MESSAGE_BOX,@"「呜……别打……我会乖的……！」"

	CASE "肛塞"
		CALL MESSAGE_BOX,@"「后面……要放进去吗……？呜……慢点……」"

	CASE "尿道塞"
		CALL MESSAGE_BOX,@"「那、那里不行……会很奇怪……！」"

	CASEELSE
		CALL MESSAGE_BOX,@"「……要做%ARGS:1%吗……？嗯……」"
	ENDSELECT

CASE "继续"
	SELECTCASE ARGS:1
	CASE "正常位","后背位","对面坐位","背面坐位","骑乘位","对面立位","背面立位","强制骑乘位","背面骑乘位"
		CALL KOJO_CHS_VPOS_妹系口上1(ARGS:1, ARGS:2)
	CASEELSE
		CALL MESSAGE_BOX,@"「……还要继续吗……？」"
	ENDSELECT

CASE "移除"
	SELECTCASE ARGS:1
	CASE "肛塞"
		CALL MESSAGE_BOX,@"「……拔出来了……？呼……太、太好了……」"
	CASE "尿道塞"
		CALL MESSAGE_BOX,@"「……拿掉了……呜……轻松一点了……」"
	CASEELSE
		CALL MESSAGE_BOX,@"「……拿掉了……？呼……」"
	ENDSELECT

CASEELSE
ENDSELECT
RETURN

