
;USERCOMから飛ばす用
;装備解除入り口
@TRAIN_RELEASE_COMMON

SIF !MATCH(TEQUIP,1)
	RETURN
PRINTFORML %CALLNAME%的刑具（包括插入・触手）全部取下吗？
CALL ASK_YN
SIF RESULT
	RETURN

;調教終了からも来るので関数化
CALL ALL_TEQUIP_REMOVE
PREVCOM = 0
IF !TFLAG:拘束BIT
	PRINTW
	RETURN
ENDIF
PRINTL
PRINTL 也要解除拘束吗？
CALL ASK_YN
SIF !RESULT
	CALL TRAIN_BIND_RUN(0)



;調教装備全部取り外し
@ALL_TEQUIP_REMOVE

SIF TFLAG:Ｐ使用BIT
	CALL COM890

;搾乳器外し
SIF TFLAG:搾乳器
	CALL COM891
SIF TFLAG:搾乳触手
	CALL COM892

;触手外し
IF TEQUIP:刷子触手
	SELECTCOM = 110
	CALL COM110
ENDIF

;TEQUIP:触手乳揉み→100
FOR LOCAL,100,120
	SIF !TEQUIP:LOCAL
		CONTINUE
	SELECTCOM = LOCAL
	TRYCALLFORM COM{LOCAL}
NEXT

;道具外し
;TEQUIP:バイブ→201
FOR LOCAL,200,220
	SIF !TEQUIP:LOCAL
		CONTINUE
	SELECTCOM = LOCAL
	TRYCALLFORM COM{LOCAL}
NEXT
VARSET TEQUIP
VARSET TFLAG,0,50,80



