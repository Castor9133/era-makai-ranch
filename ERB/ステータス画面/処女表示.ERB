
;処女表示詳細
;ARG→1なら改行
@PRINT_VIRGIN_DETAIL(ARG)

SIF !FLAG:正在化妆角色
	PRINT 在地上
PRINTFORML 性经验：【%CSTR:性经验%】
CALL PRINT_VIRGIN_DETAIL_V
CALL PRINT_VIRGIN_DETAIL_A
CALL PRINT_VIRGIN_DETAIL_M
CALL PRINT_VIRGIN_DETAIL_PAIZURI
CALL PRINT_VIRGIN_DETAIL_KISS
CALL PRINT_VIRGIN_DETAIL_MILK
CALL PRINT_VIRGIN_DETAIL_BIRTH
RESETCOLOR
SIF ARG
	PRINTL



;Ｖ
@PRINT_VIRGIN_DETAIL_V

SIF !GETBIT(＃经验显示／Ｖ性交＃)
	RETURN
IF TALENT:处女结界
	CALL PRINTL_WORD_COLOR("【处女结界】","浅蓝色")
	RETURN
ENDIF
IF TALENT:处女
	CALL PRINT_WORD_COLOR("【处女】","浅蓝色")
ELSE
	CALL PRINT_WORD_COLOR("【非处女】","桃")
	PRINT 　初次体验：
	VARGIN_PERSON = %CSTR:初经验／Ｖ%
	SIF CSTR:初经验／Ｖ == ""
		VARGIN_PERSON = 未知
	PRINTFORM %VARGIN_PERSON,16,LEFT%　
	
	;経験人数を追加
	IF !EXP:地上经验人数／人类／Ｖ性交 && !EXP:地上经验人数／魔族／Ｖ性交 && EXP:经验次数／主人公／Ｖ性交 && !EXP:经验次数／异形／Ｖ性交
		PRINTFORM 经验人数：只有%CALLNAME:0%・{EXP:经验次数／主人公／Ｖ性交}下
	ELSE
		PRINTFORM 经验人数：地上{EXP:地上经验人数／人类／Ｖ性交}人
		SIF EXP:地上经验人数／魔族／Ｖ性交
			PRINTFORM +魔界{EXP:地上经验人数／魔族／Ｖ性交}人
		SIF EXP:经验次数／主人公／Ｖ性交
			PRINTFORM +%CALLNAME:0%{EXP:经验次数／主人公／Ｖ性交}回
		SIF EXP:经验次数／异形／Ｖ性交
			PRINTFORM +异形{EXP:经验次数／异形／Ｖ性交}回
	ENDIF
ENDIF
PRINTL



