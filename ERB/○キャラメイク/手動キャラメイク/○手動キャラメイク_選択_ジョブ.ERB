
;手動キャラメイクのジョブ
@SELF_CHARA_MAKE_JOB

PRINTL 请选择职业类别。
PRINTL （有些包括在随机中没有出现的项目，或者有比喻性的填充）
PRINTLC [ 0] 近战物理
PRINTLC [ 1] 远程物理
PRINTLC [ 2] 魔法师
PRINTLC [ 3] 魔法战士
PRINTLC [ 4] 远近皆可
PRINTLC [ 5] 道具・支援战斗
PRINTLC [ 6] 非战斗
PRINTLC [ 7] 王族
CALL INPUTBUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 900
	CSTR:职业 =
CASE 901
	PRINTL 请输入职业名称
	INPUTS
	CSTR:职业 = %RESULTS%
CASE 0 TO 7
	CALL SELF_CHARA_MAKE_JOB_CATEGORY(RESULT)
ENDSELECT



;カテゴリ選択後
;ARG→カテゴリ
@SELF_CHARA_MAKE_JOB_CATEGORY(ARG)

;STR:手動入力ジョブ→7000
STR_REF = 7000 +ARG *50
PRINTL 选择职业。
FOR LOCAL,STR_REF,STR_REF +50
	SIF STR:LOCAL == ""
		CONTINUE
	PRINTFORMLC [{LOCAL -STR_REF,2}] %STR:LOCAL%
NEXT
PRINTL
PRINTL [99] （取消）
BINPUT
SIF RESULT == 99
	RETURN
CSTR:职业 = %STR:(RESULT +STR_REF)%
CALL SELF_CHARA_MAKE_JOB_FEATURE(ARG)



;ジョブ決定後の特徴反映設定
;ARG→カテゴリ
@SELF_CHARA_MAKE_JOB_FEATURE(ARG)

CALL MANYL(3)
SELECTCASE ARG
CASE 0,1
	SIF !CFLAG:魔力量
		RETURN
	PRINTL 选择了物理系的职业。将[魔力量]设置为0？
	CALL ASK_YN
	IF !RESULT
		CFLAG:魔力量 = 0
		CALL SLAVE_MP_CALC
		CALL SLAVE_BATTLE_POWER_CALC(1)
	ENDIF
	
CASE 2,3
	SIF CFLAG:魔力量
		RETURN
	PRINTL 选择了魔法系的职业。将[魔力量]增加？
	CALL ASK_YN
	SIF RESULT
		RETURN
	PRINTL 输入魔力量与灵力的比例。
	INPUT
	IF RESULT >= 0
		CFLAG:魔力量 = RESULT
		CALL SLAVE_MP_CALC
		CALL SLAVE_BATTLE_POWER_CALC(1)
	ENDIF

CASE 6
	SIF CFLAG:非战斗职业
		RETURN
	PRINTL 选择了非战斗职业。进行[非战斗职业]设置，等级为1？
	CALL ASK_YN
	SIF RESULT
		RETURN
	CFLAG:非战斗职业 = 1
	MAXBASE:等级 = 1
	BASE:等级 = MAXBASE:等级
	CFLAG:级别 = 0
	BASE:回复次数 = 0
	BASE:大技次数 = 0
	CALL SLAVE_EP_CALC
	CALL SLAVE_BATTLE_POWER_CALC(1)

CASE 7
	SIF CSTR:身份 == "王族"
		RETURN
	PRINTL 选择了王族职业。你想把身份改成[王族]吗？
	CALL ASK_YN
	SIF RESULT
		RETURN
	CSTR:身份 = 王族
	
	;身分からの母乳価格補正確認
	CALL SELF_CHARA_MAKE_MILK_PRICE
ENDSELECT

