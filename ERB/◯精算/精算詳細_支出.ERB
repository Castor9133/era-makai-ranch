;先に乳牛
COST = PET_FOOD_PRICE_BASE_COW *PET_FOOD_PRICE_FIX:(FLAG:食物种类／魔界乳牛) /100
PRINTFORML 　　　　魔界乳牛：%VALUE_DIGIT(COST)%G 
CALL GET_PET_FLAG_REF
FOR LOCAL,0,20
	ANIMAL = %ITEMNAME:(ITEM_REF +LOCAL)%
	SIF ANIMAL == "" || !ITEM:ANIMAL
		CONTINUE
	PET_NAME = %PET_NAME_REF(ANIMAL)%
	FOOD_TYPE = FLAG:(FLAG_REF:2 +LOCAL)
	COST = PET_FOOD_PRICE_BASE:LOCAL *PET_FOOD_PRICE_FIX:FOOD_TYPE /100
	PRINTFORML %PET_NAME,16%：%VALUE_DIGIT(COST)%G 
NEXT
PRINTFORML →%VALUE_DIGIT(MONEY_COST:3)%G 
PRINTL
PRINTL 【魔动器魔力电池费】
{
PRINTFORML 牧场设施用：%VALUE_DIGIT(ONEDAY_COST_RANCH_BATTERY)%G 　生活用：%VALUE_DIGIT(ONEDAY_COST_HOME_BATTERY)%G 
　调教用追加费用：%VALUE_DIGIT(MONEY:电池追加消耗金额)%G 
}
PRINTFORML →%VALUE_DIGIT(MONEY_COST:4)%G 
SIF SAVE_BATTERY_COST
	{
	CALL PRINTL_WORD_COLOR,@"　由于储存魔力而节省电池费：%VALUE_DIGIT(SAVE_BATTERY_COST)%G　
	貯蔵器魔力-%VALUE_DIGIT(SAVE_BATTERY_COST / 2)%MP","黄"
	}
PRINTL
PRINTL 【杂费】
