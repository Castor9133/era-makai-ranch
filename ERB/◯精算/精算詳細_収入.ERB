
;収入詳細
@SETTLEMENT_DETAIL_PAGE2
#DIM REWORD,10

PRINTL 　《 收入 》
PRINTFORML 魔界乳牛的牛奶出货金额：%VALUE_DIGIT(MONEY_SELL:1)%G

;牛舎外分まとめて表示
EXIST = 0
IF COWSHED_TOTAL_MILK_CC:0
	EXIST ++
	{
	PRINTFORML 奴隶的%SAVESTR:标识／母乳%：计%VALUE_DIGIT(COWSHED_TOTAL_MILK_CC:0,"母乳"),8% ／
	%VALUE_DIGIT(COWSHED_TOTAL_MILK_PRICE:0)%G 
	}
ENDIF

;牛舎内表示
FOR LOCAL,1,11
	;そもそもまとめて表示じゃないなら0のまま
	SIF !COWSHED_TOTAL_MILK_CC:LOCAL
		CONTINUE
	EXIST ++
	{
	PRINTFORML %COWSHED_NAME:LOCAL,38%：计%VALUE_DIGIT(COWSHED_TOTAL_MILK_CC:LOCAL,"母乳"),8% ／
	%VALUE_DIGIT(COWSHED_TOTAL_MILK_PRICE:LOCAL)%G 
	}
NEXT
SIF EXIST >= 2
	PRINTFORM 　奴隶的%SAVESTR:标识／母乳%合计：%VALUE_DIGIT(MONEY_SELL:2)%G 
SIF SETTLEMENT_EFFECT_DRAGON_BALL
	CALL PRINT_WORD_COLOR,@"龙蛋奖励×2","黄"
PRINTL

;奴隷数は変更ないのでIFのまま
VARSET REWORD
IF FLAG:合作伙伴奴隶数量／人类搾乳牧场
	REWORD:1 = FLAG:合作伙伴奴隶数量／人类搾乳牧场 *PARTNER_ALLSLAVE_REWORD
	{
	PRINTFORML 　＜人类搾乳牧场＞报酬：%VALUE_DIGIT(PARTNER_ALLSLAVE_REWORD)%G×{FLAG:事业合作奴隶数／人类搾乳牧场}匹 →
	%VALUE_DIGIT(REWORD:1)%G
	}
ENDIF
SIF MONEY_SELL:3
	PRINTFORML 　事业合作报酬合计：%VALUE_DIGIT(MONEY_SELL:3)%G
PRINTFORML ＜合计收入：%VALUE_DIGIT(MONEY_SELL:0)%G ＞


