; ======================================
; 泛用口上（性格：温柔大姐姐）
; 温顺、成熟、稳重；关系上玩家高位、奴隶低位（不必句句自称奴隶，以柔顺服从为主）。可有怀疑、疑问、伤心与痛，表达方式仍从低位出，不对等顶撞。
; 口上識別名：温柔大姐姐1（Str.csv 6120）
; 许可证：CC BY-NC
; ======================================

@KOJO_GENERAL_INDEX_温柔大姐姐1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

IF TFLAG:Ｍ装备
	CALL KOJO_GENERAL_MOUTH_SHACKLE_1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
	RETURN
ELSEIF CFLAG:崩坏 && !CFLAG:洗脑
	IF GROUPMATCH(ARGS:0,"例文")
	ELSEIF GROUPMATCH(ARGS:1,"洗脑触手","崩坏")
	ELSE
		IF NOWEX:总绝顶
			CALL MESSAGE_BOX,@"「……脑子……糊成一片了……♥」"
			CALL MESSAGE_BOX,@"「……别松手……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……我……还清醒吗……」"
		ENDIF
		RETURN
	ENDIF
ENDIF

SELECTCASE ARGS:0
CASE "身体"
	CALL KOJO_GENERAL_温柔大姐姐1_EXCRETION_BODY(ARGS:1, ARGS:2)
	RETURN
CASE "例文"
	CALL MESSAGE_BOX,@"「【温柔大姐姐1】已设置。\n关系前提：玩家高位（牧场主／主人），角色低位（奴隶、调教对象；乳牛线可叠牲畜身份）。不必句句说「奴」——大部分时候靠柔顺、从命、恳求来体现位阶。\n个性：可以怀疑、可以心里打鼓、可以疼、可以难过，但不对玩家吆五喝六。\n屈服后：更软、更顺，暗盼%MASTER_CALL()%也轻待自己。\n恋慕后：多一分体贴%MASTER_CALL()%身体的温柔，把羞耻包在「慢点」「帮%MASTER_CALL()%擦」「先喝水」里。」"

CASE "身体事件"
	SELECTCASE ARGS:1
	CASE "产後初调"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……刚生完又叫我。……行。你先坐稳，让我瞧瞧气色——别太逞强；也……别当我只这一回就丢开的人。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……产后头一回……我认得是调教，从命。……只求这一程轻些……也看我一眼……我还撑得住吗……」"
		ELSE
			CALL MESSAGE_BOX,@"「……产褥未完，身子还虚。……%MASTER_CALL()%执意要……我不敢不从，只求……手下留一分情。」"
		ENDIF
	CASE "妊娠性事初回"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……有了。……别那样看我……我会误以为自己……真被%MASTER_CALL()%需要着。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……怀上了……心里乱得很……不敢说假话骗自己安心……只求%MASTER_CALL()%一句准话：孩子和我……要怎样安置。」"
		ELSE
			CALL MESSAGE_BOX,@"「……怀上了……整宿睡不着……不敢多嘴，只求%MASTER_CALL()%……别装作没看见我的肚子。」"
		ENDIF
	CASE "妊娠性事"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……身子沉，容易累。……若还要调教……我跟%MASTER_CALL()%的步子……也请……疼我一分。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……身子沉……我会尽力跟上……求%MASTER_CALL()%……放慢些。」"
		ELSE
			CALL MESSAGE_BOX,@"「……我……撑不了太久……只求……怜惜些用我……」"
		ENDIF
	CASE "妊娠调教谨慎开场"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……怀着还来……不是不怕。……可%MASTER_CALL()%叫我，我会把腹围和体力都算好再来。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……%MASTER_CALL()%有令，我来。……只求……别拿腹中孩子当赌注……这是我……唯一敢求的一件。」"
		ELSE
			CALL MESSAGE_BOX,@"「……身子沉……若%MASTER_CALL()%一定要……我从命。……只求……别拿肚子逞狠。」"
		ENDIF
	ENDSELECT

CASE "调教命令"
	CALL KOJO_GENERAL_温柔大姐姐1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

CASE "绝顶"
	SIF TEQUIP:深喉
		CALL MESSAGE_BOX,@"「……喉咙……要坏了……♥ ……别笑……」"
	IF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「……不行了……♥ ……抱紧……让我晓得%MASTER_CALL()%还在……♥」"
	ELSEIF ＃陷落状态／屈服以上＃
		CALL MESSAGE_BOX,@"「……要散了……♥ ……求%MASTER_CALL()%……抱着我……别让我垮下去……♥」"
	ELSE
		CALL MESSAGE_BOX,@"「……住手……！……这副样子……不想被%MASTER_CALL()%看见……」"
	ENDIF

CASE "射精"
	IF SOURCE:膣内射精经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……里面……好烫……♥ ……先别动……我帮%MASTER_CALL()%顺顺呼吸……♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……里面……受下了……下回……求%MASTER_CALL()%……让我有个准备……」"
		ELSE
			CALL MESSAGE_BOX,@"「……里面……好慌……」"
		ENDIF
	ELSEIF SOURCE:尻穴射精经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……后面也……♥ ……真是的……过来，我帮%MASTER_CALL()%擦干净……♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……后面……怕……求%MASTER_CALL()%……轻些……」"
		ELSE
			CALL MESSAGE_BOX,@"「……后面……那样……受不住……求%MASTER_CALL()%……」"
		ENDIF
	ENDIF

CASE "访问"
	SELECTCASE ARGS:1
	CASE "入口"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……来了？门没锁。……先喝口水，%MASTER_CALL()%嘴唇都干了。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……请进。……我候着吩咐……长话短说也好，都听着。」"
		ELSE
			CALL MESSAGE_BOX,@"「……若仅有令……站在门外说……我也一样听。」"
		ENDIF
	CASE "摸头"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……像哄孩子似的。……也好……只求%MASTER_CALL()%……准许我借这点亲近……伺候一会儿……」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……这样摸……我会……贪这点暖……」"
		ELSE
			CALL MESSAGE_BOX,@"「……我不是供%MASTER_CALL()%逗着顺毛的玩物……可……也不敢拂开%MASTER_CALL()%的手……」"
		ENDIF
	CASE "接吻"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……过来。……轻点，我跟着%MASTER_CALL()%换气。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……要吻的话……我张嘴候着……求%MASTER_CALL()%……别当玩笑。」"
		ELSE
			CALL MESSAGE_BOX,@"「……我不敢躲……只盼……不是一时兴起的作弄……」"
		ENDIF
	CASE "侍奉口爆终了"
		SELECTCASE ARGS:2
		CASE "忍住"
			CALL MESSAGE_BOX,@"「……好啊，收住了。……来，靠着我喘两口，别憋着。」"
			CALL MESSAGE_BOX,@"「……没关系的。……你说了算，我都在。」"
		CASE "咽下"
			CALL MESSAGE_BOX,@"「……乖乖咽下去了呢。……真乖……待会给你倒水漱漱口，嗯？」"
			CALL MESSAGE_BOX,@"「……别害羞……我都接着了，你放松。」"
		ENDSELECT
	CASE "揉胸轻抚"
		CALL MESSAGE_BOX,@"「……好啦……只是揉一下……不会笑话你的。」"
		CALL MESSAGE_BOX,@"「……慢慢来……手劲我替你收着。」"
	CASE "拥抱嗅闻"
		CALL MESSAGE_BOX,@"「……抱这么紧……像要把姐姐藏起来似的。」"
		CALL MESSAGE_BOX,@"「……头发里……都让你闻遍了……小坏蛋。」"
	CASEELSE
	ENDSELECT

CASE "战斗"
	SELECTCASE ARGS:1
	CASE "攻击"
		CALL MESSAGE_BOX,@"「……让开。我来断后。」"
	CASE "被击中"
		CALL MESSAGE_BOX,@"「……小伤。……别慌。」"
	CASEELSE
	ENDSELECT

CASEELSE
ENDSELECT
RETURN


@KOJO_GENERAL_温柔大姐姐1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
CALL KOJO_GENERAL_温柔大姐姐口上1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
RETURN


;--------------------------------------------
; 排泄羞耻／身体
;--------------------------------------------
@KOJO_GENERAL_温柔大姐姐1_EXCRETION_BODY(ARGS:0, ARGS:1)
SELECTCASE ARGS:0
CASE "排泄事故"
	SELECTCASE ARGS:1
	CASE "肠"
		CALL MESSAGE_BOX,@"「……别、别看……这种样子……连我自己都嫌……」"
	CASE "尿"
		CALL MESSAGE_BOX,@"「……对不起……我……没守住体面……」"
	CASEELSE
		CALL MESSAGE_BOX,@"「……」"
	ENDSELECT
CASE "放尿主动"
	CALL MESSAGE_BOX,@"「……在你面前……排出来……好羞耻……可是……我会照做……」"
CASE "灌肠妊娠求饶"
	CALL MESSAGE_BOX,@"「……求%MASTER_CALL()%……看在腹中孩子的份上……那种刺激……先停一停……」"
CASEELSE
ENDSELECT
RETURN 1

