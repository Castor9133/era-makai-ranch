
;精算詳細
@SETTLEMENT_DETAIL
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTL 　《 结算详情 》
CALL HALFLINE
TRYCALLFORM SETTLEMENT_DETAIL_PAGE{PAGE}
CALL PRINTL_ALIGN
DRAWLINE
PRINTFORMLC [ 0] 页面切换＜PAGE{PAGE}／{PAGE_MAX}＞
PRINTFORMLC [ 1] 奴隶的%SAVESTR:标识／母乳%个别详细
PRINTL [99] 完成
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 1
	CALL SETTLEMENT_DETAIL_MILK_INDEX
CASE 99
	RETURN
ENDSELECT
RESTART







