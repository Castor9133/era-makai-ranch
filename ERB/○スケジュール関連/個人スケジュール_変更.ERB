
;キャラ選択INPUT後
;ARG→INPUT
;ARGS→元ページ　　メインメニュー・全奴隷・牛舎
@SCHEDULE_PLAN_CHANGE(ARG,ARGS)

SELECTCASE ARG
CASE 0
	CSTR:日程 = 自由
	SIF CSTR:SAVE_TARGET:状态／主人公的孩子 == "成长中"
		VARSET CSTR:SAVE_TARGET,"假日",350,357
CASE 1
	CSTR:日程 = 奶农
CASE 2
	SAVE_TARGET = TARGET
	CALL TRAIN_SLAVE_SELECT
CASE 3
	CSTR:日程 = 事务
CASE 4
	CSTR:日程 = 调剂
CASE 5
	CSTR:日程 = 大浴场清洁
CASE 6
	CSTR:日程 = 训练
CASE 7
	CSTR:日程 = 图书馆
CASE 100
	CSTR:日程 = 等待
CASE 101
	CSTR:0:日程 = 调教
	CFLAG:0:调教对象ID = CFLAG:ID
	CSTR:日程 = 调教对象
CASE 102
	CSTR:日程 = 搾乳
CASE 103
	CSTR:日程 = 抽出
CASE 104
	CSTR:日程 = 体内凌辱准备
CASE 105
	CSTR:日程 = 释放准备
CASE 106
	CSTR:日程 = 体内凌辱
CASE 107
	CSTR:日程 = 触手刺激搾乳

CASE 200
	CALL VISIT_SLAVE_BEFORE
	RETURN 1
	
CASE 201
	IF CSTR:状态／主人公的孩子 == "成长后"
		CALL CHILD_REBELLION
		SIF RESULT
			RETURN
	ENDIF
	CALL MANYL(2)
	CALL SCHEDULE_MOVE_COWSHED
CASE 202
	PRINTFORML 是否将%CALLNAME%从%COWSHED_NAME:(CFLAG:牛舍号码)%中放出来？
	CALL ASK_YN
	SIF RESULT
		RETURN
	
	;FLAG:第1牛舎家畜頭数→502
	FLAG_REF = 492
	FLAG:(FLAG_REF +CFLAG:牛舍号码 *10) --
	CFLAG:牛舍号码 = 0
	CALL SCHEDULE_RESET_TARGET
	CALL CHARA_WHEREABOUTS_TARGET

CASE 208
	CALL USE_ITEM_PLAYER
CASE 209
	CALL DRINK_COLD_MILK_AUTO(1)
	SIF WAIT_ON
		PRINTW
	WAIT_ON = 0
CASE 210
	;あなたと奴隷で別の関数
	IF !TARGET
		CALL PLAYER_CONFIG
	ELSE
		CALL SLAVE_CONFIG
	ENDIF
	RETURN 1

CASE 211
	CALL SHOW_STATUS_DETAIL_PLUS(ARGS)
	RETURN 1
	
CASE 212
	CALL AUTO_SCHEDULE
	RETURN 1
	
CASE 300
	CALL CHANGE_TARGET_CHARA(0,ARGS)
	
	;上の関数でTARGETを変更してRESTARTする形式にする（大量に関数呼び出しされると不具合あるかなと）
	RETURN 1
CASE 301
	CALL CHANGE_TARGET_CHARA(1,ARGS)
	RETURN 1
ENDSELECT



;牛舎に入れる
@SCHEDULE_MOVE_COWSHED

;FLAG:第1牛舎増築段階→500
;FLAG:第1牛舎スケジュール→501
;FLAG:第1牛舎家畜頭数→502
FLAG_REF = 490
FLAG_REF:1 = 491
FLAG_REF:2 = 492
PRINTFORML 选择送入%CALLNAME%的牛舍。
FOR COWSHED_NUM,1,11
	SIF COWSHED_NUM > ITEM:牛舍
		BREAK
	
	;現在の乳牛頭数
	COWSHED_SLAVE = FLAG:(FLAG_REF:2 +COWSHED_NUM *10)
	
	;最大乳牛頭数
	COWSHED_CAPACITY = FLAG:(FLAG_REF +COWSHED_NUM *10)*10
	
	IF COWSHED_SLAVE >= COWSHED_CAPACITY
		SETCOLOR 64,64,64
		PRINTFORM 　<{COWSHED_NUM,2}> 
	ELSE
		PRINTFORM 　[{COWSHED_NUM,2}] 
	ENDIF
	{
	PRINTFORM %COWSHED_NAME:COWSHED_NUM,20%： {COWSHED_SLAVE,3}／{COWSHED_CAPACITY,3}　
	\@ FLAG:(FLAG_REF:1 +COWSHED_NUM *10) ? 榨乳工厂 # 搾乳家畜 \@用 
	}
	RESETCOLOR
	SIF COWSHED_SLAVE >= COWSHED_CAPACITY
		PRINT ≪满员≫
	PRINTL
NEXT
DRAWLINE
PRINTFORML [99] 取消
BINPUT
SIF RESULT == 99
	RETURN
CFLAG:牛舍号码 = RESULT
CSTR:日程 = 牛舍
CALL CHARA_WHEREABOUTS_TARGET

;乳牛頭数+1
FLAG:(FLAG_REF:2 +CFLAG:牛舍号码 *10) ++
SIF FLAG:(FLAG_REF:2 +CFLAG:牛舍号码 *10) == FLAG:(FLAG_REF +CFLAG:牛舍号码 *10) *10
	PRINTW 牛舍满员了。


