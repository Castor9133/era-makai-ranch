
;アイテム説明と購入数
;ARG→PAGE
;ARGS→どのメニューから来たか
;ITEM_ID_MIN,ITEM_ID_MAX指定済み
@ITEM_DETAIL_CLOTHE(ARG,ARGS)

;対応IDでないなら汎用出して帰る
IF SELECT_ITEM < ITEM_ID_MIN || SELECT_ITEM >= ITEM_ID_MAX || ITEMNAME:SELECT_ITEM == ""
	PRINTL  　《 显示选定物品的说明 》
	RETURN
ENDIF

;とりあえずアイテム名、価格、所持数を出す
SELECTCASE ARGS
CASE "购物"
	;一式は所持数のみ
	IF ITEM_ID_MIN == 1000
		PRINTFORM 　《 %ITEMNAME:SELECT_ITEM% 》持有数量{ITEM:SELECT_ITEM,2}着 
	ELSE
		PRINTFORM 　《 %ITEMNAME:SELECT_ITEM% 》%VALUE_DIGIT(ITEMPRICE:SELECT_ITEM)%G 持有数量{ITEM:SELECT_ITEM,2}着 
	ENDIF
CASE "更衣"
	PRINTFORM 　《 %ITEMNAME:SELECT_ITEM% 》持有数量{ITEM:SELECT_ITEM,2}着 
CASE "造型"
	PRINTFORM 　《 %ITEMNAME:SELECT_ITEM% 》
ENDSELECT

;対応ドットがある場合表示
;暫定的に＜布の服＞＜旅人の服＞は同じ
IF ITEMNAME:SELECT_ITEM == "旅人之服"
	SPRITECREATED @"布衣_标准_巨乳"
	SIF RESULT
		CALL PRINT_WORD_COLOR("＜像素画支持的衣服＞（与＜布衣＞通用）","黄")
ELSE
	SPRITECREATED @"%ITEMNAME:SELECT_ITEM%_标准_巨乳"
	IF RESULT
		CALL PRINT_WORD_COLOR("＜像素画对应服装＞","黄")
	ELSE
		SPRITECREATED @"%ITEMNAME:SELECT_ITEM%"
		SIF RESULT
			CALL PRINT_WORD_COLOR("＜像素画对应服装＞","黄")
	ENDIF
ENDIF
PRINTL

;ページで分割する：長いので
SELECTCASE ARG
CASE 1
	;一式は価格出すかの処理含む
	CALL ITEM_DETAIL_CLOTHE_CLOTHESET(ARGS)
CASE 2
	CALL ITEM_DETAIL_CLOTHE_WORK
CASE 3
	CALL ITEM_DETAIL_CLOTHE_LINGERIE
CASE 4
	CALL ITEM_DETAIL_CLOTHE_ACCESSORY
CASE 5
	CALL ITEM_DETAIL_CLOTHE_ADULT_LINGERIE
CASE 6
	CALL ITEM_DETAIL_CLOTHE_ADULT_CLOTHE
CASE 7
	CALL ITEM_DETAIL_CLOTHE_HUMAN_REPLICA
CASE 8
	CALL ITEM_DETAIL_CLOTHE_OTHER_WORLD
CASE 9
	CALL ITEM_DETAIL_CLOTHE_OTHER_WORLD_LINGERIE
CASE 10
	CALL ITEM_DETAIL_CLOTHE_ARMOR
ENDSELECT


