
;あなたが自由時間の場合の行動選択
@MASTER_FREE_TIME_SELECT

TARGET = 0
SIF CSTR:日程 != "自由"
	RETURN

PRINTL 　　　《 空闲时间 》
;HP30%未満だと休憩にしておわり
IF BASE:体力 < MAXBASE:体力 *30 /100
	PRINTFORMW %CALLNAME%因为太累了，决定在自己的房间休息一下…
	CSTR:日程 = 休息
	RETURN
ENDIF
PRINTFORML %CALLNAME%在空闲时间做什么？
PRINTL
PRINTL [ 0] 在自己房间休息

;ITEM:堕天馬→100　選択肢を1から始めるので-1
ITEM_REF = 100 -1
PRINTL
FOR LOCAL,1,11
	ANIMAL = %ITEMNAME:(ITEM_REF +LOCAL)%
	SIF ANIMAL == ""
		CONTINUE
	
	;分けないとエラー出す
	SIF !ITEM:ANIMAL
		CONTINUE
	PRINTFORML [{LOCAL,2}] 使用%PET_NAME_REF(ANIMAL)%
NEXT
BINPUT
SELECTCASE RESULT
CASE 0
	PRINTFORMW %CALLNAME%决定在自己的房间休息…
	CSTR:日程 = 休息
CASE 1 TO 10
	CALL MASTER_PLAY_ANIMAL_SELECT(RESULT -1)
	CSTR:日程 = 行动完毕
ENDSELECT
DRAWLINE



