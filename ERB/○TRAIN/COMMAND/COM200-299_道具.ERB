@COM250
;ローション
;時間経過なし

PRINTL 在哪里使用润滑液？
PRINTL
IF TALENT:处女结界
	CALL PRINTL_WORD_COLOR,@"因为【处女结界】无法触碰%SAVESTR:标识／膣%","灰"
ELSEIF !TFLAG:Ｖ露出
	CALL PRINTL_WORD_COLOR,@"需要脱衣使%SAVESTR:标识／膣%露出","黄"
ELSE
	IF TFLAG:Ｖ润滑液
		CALL PRINTL_WORD_COLOR,@"%SAVESTR:标识／膣%润滑液已使用","灰"
	ELSE
		PRINTFORML [ 0] %SAVESTR:标识／膣%
	ENDIF
ENDIF

IF TFLAG:Ａ润滑液
	CALL PRINTL_WORD_COLOR,@"%SAVESTR:标识／肛门%润滑液已使用","灰"
ELSEIF !TFLAG:Ａ露出
	CALL PRINTL_WORD_COLOR,@"脱衣%SAVESTR:标识／肛门%需要露出","黄"
ELSE
	PRINTFORML [ 1] %SAVESTR:标识／肛门%
ENDIF

IF TFLAG:Ｂ润滑液
	CALL PRINTL_WORD_COLOR,@"%SAVESTR:标识／乳房%润滑液已使用","灰"
ELSE
	PRINTFORML [ 2] %SAVESTR:标识／乳房%
ENDIF
PRINTL
PRINTL [99] 取消
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL COM290
CASE 1
	CALL COM291
CASE 2
	CALL COM292
CASEELSE
	RETURN
ENDSELECT
RETURN 1



