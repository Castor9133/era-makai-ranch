
;スケジュール実行
@MAIN_PHASE

;人手が足りてるか、条件を満たしていないスケジュールがないかの判定
CALL SCHEDULE_JUDGE(1)
SIF RESULT
	RETURN

;スケジュールごとにそれぞれ実行
DRAWLINE
CALL WORK_DRAIN
CALL MASTER_REMOVE
CALL MASTER_VORE_MOVE
CALL MASTER_FREE_TIME_SELECT

CALL MAIN_REST_ROOM
CALL MAIN_REST_CAGE
CALL WORK_TRAINING
CALL VISIT_LIBRARY
CALL WORK_FINANCE
CALL WORK_LARGE_BATHLOOM_CLEANING
CALL WORK_PHARMACY
CALL WORK_LACTATION
CALL SLAVE_LACTATION
CALL SLAVE_T_LACTATION
CALL COWSHED_LACTATION
CALL MASTER_VORE_SEX
CALL TRAIN_LESBIAN_CHECK
CALL NO_TRAIN_T_CLOTHE
CALL RINKAN_SLAVE_CHECK
CALL MAIN_CHASE_SLAVE

;帰宅スケジュール
CALL GOING_HOME

;BEGIN TRAINをしている場合ターンエンド処理を調教終了のほうで行う　飛ぶのでSIFでおＫ
SIF CSTR:0:日程 == "调教"
	BEGIN TRAIN

; 日结束：妊娠/产褥/静养等日次推进（全员）
TRYCALL PREGNANCY_DAILY_TICK_ALL, 1
TRYCALL RANCH_TAG_DAILY_ALL, 1
TRYCALL MAGIC_绝顶育成_DAILY_ALL, 1
; 托儿所在日结推进前，建议主工程先统计并设置 FLAG:魔界_可献乳人数（见 ○NURSERY_CORE.ERB）
TRYCALL NURSERY_DAILY

CALL MAIN_TURNEND
;SHOPへ戻る

