
;調教時の衣服脱がし処理
;ARGS→脱がせる部位　ARGS:1→脱衣形式　ARG→アクセサリー時の取り外し部位
@TRAIN_CLOTHE_STRIP(ARGS,ARGS:1,ARG)

;前回コマンドをリセット
PREVCOM = 0

;壁乳拘束だと下半身系、下半身含め系NG
{
SIF GETBIT(＃拘束／下半身填壁乳＃) && GROUPMATCH(ARGS:1,"下半脱衣","下部撕裂","下身脱衣","一件半脱","批量撕掉",
"脱衣","全半脱衣","全脱衣")
}
	RETURN

SELECTCASE ARGS
CASE "衣服"
	SELECTCASE ARGS:1
	CASE "上半脱衣"
		CALL STRIP_MESSAGE_CLOTHE_JACKET
		CALL STRIP_MESSAGE_CLOTHE_BUST
		SETBIT ＃半脱／衣服上＃
		SETBIT ＃半脱／外衣＃
	CASE "下半脱衣"
		CALL STRIP_MESSAGE_CLOTHE_VAGINA
		SETBIT ＃半脱／衣服下＃
	
	CASE "上部撕裂"
		CALL STRIP_MESSAGE_CLOTHE_JACKET
		CALL BREAK_MESSAGE_CLOTHE_BUST
		SETBIT EQUIP:(EQUIP:装备中ID／衣服),1
		SETBIT ＃半脱／外衣＃
	CASE "下部撕裂"
		CALL BREAK_MESSAGE_CLOTHE_VAGINA
		SETBIT EQUIP:(EQUIP:装备中ID／衣服),2
	
	CASE "一件半脱"
		;両方できる場合じゃないとここ来ない
		CALL STRIP_MESSAGE_CLOTHE_JACKET
		CALL STRIP_MESSAGE_CLOTHE_BUST
		CALL STRIP_MESSAGE_CLOTHE_VAGINA
		SETBIT ＃半脱／衣服上＃
		SETBIT ＃半脱／衣服下＃
		SETBIT ＃半脱／外衣＃
	
	CASE "批量撕掉"
		CALL STRIP_MESSAGE_CLOTHE_JACKET
		CALL BREAK_MESSAGE_CLOTHE_BUST
		CALL BREAK_MESSAGE_CLOTHE_VAGINA
		SETBIT EQUIP:(EQUIP:装备中ID／衣服),1
		SETBIT EQUIP:(EQUIP:装备中ID／衣服),2
		SETBIT ＃半脱／外衣＃
	
	CASE "脱衣"
		CALL STRIP_MESSAGE_CLOTHE_JACKET
		CALL STRIP_MESSAGE_CLOTHE_ALL
		TFLAG:临时脱衣／衣服 = 1
		SETBIT ＃半脱／外衣＃
	ENDSELECT
	CALL AJUST_STRIP_FLAG

CASE "内衣"
	SELECTCASE ARGS:1
	CASE "上身脱衣"
		CALL STRIP_MESSAGE_LINGERIE_BUST
		TFLAG:临时脱衣／内衣上装 = 1
	CASE "下身脱衣"
		CALL STRIP_MESSAGE_LINGERIE_VAGINA
		TFLAG:临时脱衣／内衣下装 = 1
		SIF GROUPMATCH(＃穿着内衣下装／名称＃,"连体紧身衣","学校游泳衣","触手服装")
			TFLAG:临时脱衣／内衣上装 = 1
	CASE "上半脱衣"
		CALL STRIP_MESSAGE_LINGERIE_BUST_HALF
		SETBIT ＃半脱／内衣上装＃
	CASE "下半脱衣"
		CALL STRIP_MESSAGE_LINGERIE_VAGINA_HALF
		SETBIT ＃半脱／内衣下装＃
	
	CASE "一件半脱"
		CALL STRIP_MESSAGE_LINGERIE_BUST_HALF
		CALL STRIP_MESSAGE_LINGERIE_VAGINA_HALF
		SETBIT ＃半脱／内衣下装＃
		SETBIT ＃半脱／内衣上装＃
		
	CASE "脱衣"
		CALL STRIP_MESSAGE_LINGERIE_ALL
		TFLAG:临时脱衣／内衣上装 = 1
		TFLAG:临时脱衣／内衣下装 = 1
	ENDSELECT
	CALL AJUST_STRIP_FLAG

CASE "总计"
	SELECTCASE ARGS:1
	CASE "上半脱衣"
		CALL STRIP_MESSAGE_CLOTHE_JACKET
		CALL STRIP_MESSAGE_CLOTHE_BUST
		CALL STRIP_MESSAGE_LINGERIE_BUST_HALF
		SETBIT ＃半脱／衣服上＃
		SETBIT ＃半脱／内衣上装＃
		SETBIT ＃半脱／外衣＃
	
	CASE "下半脱衣"
		CALL STRIP_MESSAGE_CLOTHE_VAGINA
		CALL STRIP_MESSAGE_LINGERIE_VAGINA_HALF
		SETBIT ＃半脱／衣服下＃
		SETBIT ＃半脱／内衣下装＃
	
	CASE "全半脱衣"
		CALL STRIP_MESSAGE_CLOTHE_JACKET
		CALL STRIP_MESSAGE_CLOTHE_BUST
		CALL STRIP_MESSAGE_CLOTHE_VAGINA
		CALL STRIP_MESSAGE_LINGERIE_BUST_HALF
		CALL STRIP_MESSAGE_LINGERIE_VAGINA_HALF
		SETBIT ＃半脱／衣服上＃
		SETBIT ＃半脱／内衣上装＃
		SETBIT ＃半脱／衣服下＃
		SETBIT ＃半脱／内衣下装＃
		SETBIT ＃半脱／外衣＃
	
	CASE "全脱衣"
		CALL STRIP_MESSAGE_CLOTHE_JACKET
		CALL STRIP_MESSAGE_CLOTHE_ALL
		CALL STRIP_MESSAGE_LINGERIE_ALL
		TFLAG:临时脱衣／衣服 = 1
		TFLAG:临时脱衣／内衣上装 = 1
		TFLAG:临时脱衣／内衣下装 = 1
		SETBIT ＃半脱／外衣＃
	ENDSELECT
	CALL AJUST_STRIP_FLAG

CASE "饰品"
	FLAG_REF = 120
	
	;ARGSで一括指定の場合と違う場合
	IF ARGS:1 == "批量删除"
		;アクセサリー装備してるか見てないならおわり
		SIF !SUMARRAY(EQUIP,10,20)
			RETURN
		PRINTFORML 卸下了%CALLNAME%上的所有饰品。
		FOR LOCAL,10,20
			SIF GETBIT(＃拘束／下半身填壁乳＃) && LOCAL == 13
				CONTINUE
			SIF EQUIP:LOCAL
				TFLAG:(LOCAL +FLAG_REF) = 1
		NEXT
	ELSE
		;ARGが取り外し部位
		;装備中ID／眼→10　一時的脱衣／眼→130
		PRINTFORML 已卸下%CALLNAME%的%ITEMNAME:(EQUIP:ARG)%。
		TFLAG:(ARG +FLAG_REF) = 1
	ENDIF

CASE "外衣"
	SELECTCASE ARGS:1
	CASE "半脱"
		CALL STRIP_MESSAGE_CLOTHE_JACKET
		SETBIT ＃半脱／外衣＃
	ENDSELECT
ENDSELECT



;授乳スリット開き処理
@OPEN_NIPPLE_SLIT

;乳首つまみは例外処理
SIF !TFLAG:授乳开口 || SELECTCOM != 12
	RETURN

;授乳スリットは処理に一工夫して使い回す
;自分で開くか
IF SOURCE:自主脱衣
	PRINTFORML %CALLNAME%亲自打开乳头开衩，露出%SLANG_N()%…
ELSEIF !TFLAG:授乳开口
	IF ＃穿着衣服／乳沟露出＃
		PRINTFORM %CALLNAME%的衣服的乳沟中伸手摸索着…
	ELSE
		PRINTFORM %CALLNAME%的衣服侧面伸手摸索着…
	ENDIF
	PRINTFORML 拉开乳头开衩，露出%CALLNAME%的%SLANG_N()%…
	TFLAG:授乳开口 = 1
ELSE
	PRINTFORML 拉开乳头开衩，露出%CALLNAME%的%SLANG_N()%…
ENDIF
TFLAG:授乳开口开放 = 1
TFLAG:Ｎ露出 = 1
SOURCE:Ｎ露出地文表示 = 1
CALL AJUST_STRIP_FLAG


