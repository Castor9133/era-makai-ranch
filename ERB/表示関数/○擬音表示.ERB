;乳房露出擬音
@ONOMATOPOEIA_STRIP_BUST

;ここは繰り返さない
CALL ONOMATOPOEIA_COMMON
SELECTCASE ABL:胸围大小
CASE 0
	PRINT 嘶咚…❤
CASE 1 TO BUSTSIZE_普乳 -1
	PRINT 噗玲❤
CASE BUSTSIZE_普乳 TO BUSTSIZE_巨乳 -1
	PRINT 噗lu❤
CASE BUSTSIZE_巨乳 TO BUSTSIZE_丰乳 -1
	SELECTCASE RAND:3
	CASE 0
		PRINT 噗lu❤
	CASE 1
		PRINT 啵咦❤
	CASEELSE
		PRINT 踏噗❤
	ENDSELECT
CASE BUSTSIZE_丰乳 TO BUSTSIZE_爆乳 -1
	SELECTCASE RAND:5
	CASE 0
		PRINT 噗lu❤
	CASE 1
		PRINT 啵咦❤
	CASEELSE
		PRINT 啪lu❤
	ENDSELECT

;爆乳以上
CASEELSE
	SELECTCASE RAND:5
	CASE 0
		PRINT 噗lu❤
	CASE 1
		PRINT 啪lu❤
	CASEELSE
		PRINT Do哒噗❤
	ENDSELECT
ENDSELECT

