
;アイテム説明と購入数
;ARG→SELECT_ITEM
@ITEM_DETAIL_ABILITY(ARG)

;非対応IDか名称なしならそのまま帰る
IF ARG < ITEM_ID_MIN || ARG >= ITEM_ID_MAX || ITEMNAME:ARG == ""
	PRINTL  　《 将显示所选能力的说明。 》
	RETURN

;とりあえずアイテム名、価格を出す
;ここでは基礎値出す
ELSEIF ABILITY_LEVEL_MAX:ARG
	PRINTFORML 　《 %ITEMNAME:ARG% 》%VALUE_DIGIT(ITEMPRICE:ARG)%AP（基础值）：Lv{ITEM:ARG}／{ABILITY_LEVEL_MAX:ARG}
ELSE
	PRINTFORML 　《 %ITEMNAME:ARG% 》%VALUE_DIGIT(ITEMPRICE:ARG)%AP（基础值）：当前Lv{ITEM:ARG}
ENDIF

;1限チェック
CALL ABILITY_GET_ONCE_CHECK(ARG)
