		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「ああ゛っ！？ ちょっ、%MASTER_CALL()%、もう少し濡らすとかさ…」"
		ELSE
			CALL MESSAGE_BOX,@"「うあ゛っ！何、考えてんだい…っ！」"
		ENDIF
	ENDIF

CASE "尻爱抚"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
