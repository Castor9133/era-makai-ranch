; ARGS:0 场景；ARGS:1/2 用于更细分
@KOJO_GENERAL_慇懃口上1_EVENT(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:0

CASE "进入魔界的"
	SELECTCASE ARGS:1
	CASE "魔界水晶1"
		CALL MESSAGE_BOX,@"「这就是魔界… 我以为会是更荒凉的艰苦之地……」"
	CASE "魔界水晶2"
		CALL MESSAGE_BOX,@"「附近的【魔界水晶】好像已经被采光了呢……」\n「我早就知道不会那么容易……我们要小心行事」"
	CASE "魔界植物1"
		CALL MESSAGE_BOX,@"「这就是魔界… 没想到这里植物生长得如此茂盛……」"
	CASE "魔界植物2"
		CALL MESSAGE_BOX,@"「附近的【魔界植物】好像也被采光了呢……」\n「我早就知道不会那么容易……我们要小心行事」"
	CASE "夺回1"
		CALL MESSAGE_BOX,@"「这就是魔界… 乍看之下并不像恶鬼横行的地方……」"
	CASE "夺回2"
		CALL MESSAGE_BOX,@"（即使在半路倒下也绝不打算退缩……）\n「请务必平安……！」"
	CASE "声望1"
		CALL MESSAGE_BOX,@"「这就是魔界… 没想到是个如此宁静的地方呢……」"
	CASE "声望2"
		CALL MESSAGE_BOX,@"「不过这里毕竟是魔界，想要名声也不成问题」\n（不过最好还是不要靠近城堡那边的『那个』……）"
	CASE "大门事故1"
		CALL MESSAGE_BOX,@"「……っ！ ……ここは…？ %SELF_CALL()%、难道真的是魔界……！？"
	CASE "大门事故2"
		CALL MESSAGE_BOX,@"「该怎么办呢…… 不可能有什么可以依靠的地方……」"
	CASE "大门事故3"
		CALL MESSAGE_BOX,@"「不过好像还是有像街道一样的地方呢……」\n「应该还是有谈判的余地吧……虽然这也许是天真的想法……」"
	CASE "讨伐1"
		CALL MESSAGE_BOX,@"「这就是魔界… 终于来到魔族横行的地方了……」"
	CASE "讨伐2"
		CALL MESSAGE_BOX,@"「那个首领应该把那座城堡当做据点吧…… 出发了……！」"
	CASE "特殊种族1"
		CALL MESSAGE_BOX,@"「这就是魔界… 并不是充满瘴气的地方呢……」"
	CASE "特殊种族2"
		CALL MESSAGE_BOX,@"「那么……为了地上脆弱的人民，我将全力以赴」"
	CASE "即将处置1"
		CALL MESSAGE_BOX,@"（为了救同伴而来的我却犯下这样的错误…… 不，我现在就算咒骂自己的浅薄也是为时已晚……）"
	CASE "即将处置2"
		CALL MESSAGE_BOX,@"（要不是有【处女结界】的庇护，恐怕我现在早已陷入悲惨境地了……）\n「但是，为什么%SELF_CALL()%还活着呢……？」"
	CASE "拍卖1"
		CALL MESSAGE_BOX,@"（竟然有人把人类拿去拍卖…… 这一路上一定有很多人遭受了非人的对待……）"
	CASE "异世界转移1"
		CALL MESSAGE_BOX,@"「……这里究竟是哪里呢……？」"
	CASE "异世界转移2"
		CALL MESSAGE_BOX,@"「从未见过的风景…… 就像是童话故事的国度一样呢……」"
	CASE "异世界转移3"
		CALL MESSAGE_BOX,@"「那边可见的街道……？ 如果能与住在那里的居民沟通的话……」"
	ENDSELECT

CASE "事件"
	IF TFLAG:Ｍ装备
		CALL KOJO_PRINT("Ｍ装备中事件",ARGS:1,ARGS:2,ARGS:3)
		
		;CALLの関係でＭ装備中イベント呼び出した場合ここでリセットが必要
		MESSAGE_COUNT = 0
		RETURN
	ENDIF
	
	SELECTCASE ARGS:1
	CASE "领取奴隶"
		IF CFLAG:轮奸次数
			CALL MESSAGE_BOX,@"「啊，经历过这样的事情之后，接下来还要成为奴隶……」"
		ELSE
			CALL MESSAGE_BOX,@"「…こ、ここは牧場…？」"
			CALL MESSAGE_BOX,@"「…把我带到这样的地方打算做什么呢……」"
			CALL MESSAGE_BOX,@"「…请马上解除我的束缚……」"
		ENDIF
		
	CASE "母乳体质化"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「あぁ…♥ %MASTER_CALL()%的缘故能够流出母乳…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「あ、あぁ… 这种事是不可能发生的……」"
		ENDIF
		
	CASE "魔力母乳体质化"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「嗯啊……魔力正在流出……这样下去，只会被彻底榨干呢…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「っ！？ 魔力が抜けて…っ %SELF_CALL()%的胸部究竟是做了什么……！？」"
		ENDIF
		
	CASE "超乳化"
		IF CFLAG:乳牛
			CALL MESSAGE_BOX,@"「啊♥ 能够得到与乳牛相称的身体真是感激不尽……♥♥」\n「今后请把我当作『奶牛家畜』永远饲养吧♥♥」"
		ELSEIF ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「ふあぁ…♥ 我已经被弄成了如此放荡的胸部啊♥♥」\n「我再也只能作为%MASTER_CALL()%的乳奴活下去了…♥♥」"
		ELSE
			CALL MESSAGE_BOX,@"「怎……啊……这样的……不，这是谎言……」\n「请还给我……%SELF_CALL()%的身体，请还给我……！」"
		ENDIF
		
	CASE "崩坏"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"（あ…あ…%MASTER_CALL()%に……こわされ……）"
			ELSE
				CALL MESSAGE_BOX,@"（已经……一切……都无所谓了……呵呵……）"
			ENDIF
		CASEELSE
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"「啊……呜……%MASTER_CALL()%……请，您饶恕我……」"
			ELSE
				CALL MESSAGE_BOX,@"「あぁ……あ…ぁ……っ…？」"
			ENDIF
		ENDSELECT
		
	CASE "反抗消除"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"（在这里谁都不会来帮忙…… 可怕……痛苦……）\n（我不会反抗的……请您饶恕我……！）"
		CASEELSE
			CALL MESSAGE_BOX,@"（可怕……如果这种惩罚继续下去肯定会被摧毁……）\n「我、我再也不敢反抗了……请您饶恕我……」"
		ENDSELECT
	
	CASE "屈服"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"（我会听从任何可悲的命令……请把我从这里带出去……）"
		CASEELSE
			CALL MESSAGE_BOX,@"「哈……呜……%SELF_CALL()%是%MASTER_CALL()%的忠实仆人……」\n「…… 请随意使用……"
		ENDSELECT
	
	CASE "陷落"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"（啊……通过地狱般的快感我终于理解了……）\n（%SELF_CALL()%无法对这位大人反抗……）"
		CASEELSE
			CALL MESSAGE_BOX,@"「那个……能告诉我一些关于%MASTER_CALL()%的事情吗……？」\n「我、我只是想稍微巧妙一些而已……」"
		ENDSELECT
	
	CASE "恋慕告白"
		SELECTCASE ARGS:2
		CASE "前"
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「那、那……听说%MASTER_CALL()%是『家畜爱上了主人』的话，您会笑吗……」\n「『为什么会问这种事呢』……不，那个……%SELF_CALL()%是……那个……」"
			ELSE
				CALL MESSAGE_BOX,@"「那、那……听说%MASTER_CALL()%是『奴隶爱上了主人』的话，您会笑吗……」\n「『为什么会问这种事呢』……不，那个……%SELF_CALL()%是……那个……」"
			ENDIF
		CASE "后"
			CALL MESSAGE_BOX,@"「%SELF_CALL()%……我……非常喜欢%MASTER_CALL()%……！」\n「一旦这么想后……就再也抑制不住了……请问，这会给您带来麻烦吗……？」"
		ENDSELECT
	
	CASE "隶属告白"
		SELECTCASE ARGS:2
		CASE "前"
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「%SWEET_MASTER_CALL()%…♥ %SELF_CALL()%想再次表达对%MASTER_CALL()%让我成为家畜的感谢……♥♥」"
			ELSE
				CALL MESSAGE_BOX,@"「%MASTER_CALL()%…♥ %SELF_CALL()%已经身心都被%MASTER_CALL()%所束缚了……♥♥」\n「现在%MASTER_CALL()%就是%SELF_CALL()%活着的意义……♥♥」"
			ENDIF
		CASE "后"
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「原来还有如此美好的生活方式，我之前完全不知道……♥♥」\n「我将身心全部奉献给您……请您让我永远留在您身边♥♥♥」"
			ELSE
				CALL MESSAGE_BOX,@"「请您让我直到身心衰朽的那一天都在您身边……%MASTER_CALL()%」\n「在生病时和健康时，我都将我的一切奉献给%MASTER_CALL()%，发誓效忠于您♥♥」"
			ENDIF
		ENDSELECT
	
	CASE "乳牛堕落"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"（あぁ♥ きもちいい…しあわせ…♥ 过去的生活与这至福相比毫无价值……♥）\n（我已经不需要『人生』了……♥♥ 从今往后我将作为乳牛幸福地生活下去……♥♥）"
		CASEELSE
			CALL MESSAGE_BOX,@"「あぁ～…♥♥ きもちいい♥ きもちいい♥ 乳房真舒服……♥」\n「被挤奶的快感刻印在我的骨髓里……♥」\n「知道作为乳牛被饲养的幸福之后，根本不可能再回到人类的生活了……♥♥」"
		ENDSELECT
	
	CASE "处女结界破坏"
		SIF TALENT:性知识贫乏
			RETURN
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「直到现在保护着%SELF_CALL()%的结界也已经不再需要了……♥♥」\n\d"
		ELSE
			CALL MESSAGE_BOX,@"「…っ！ 结界无法维持……为什么……！？"
		ENDIF
	
	CASE "处女丧失前"
		IF CFLAG:乳牛 || CFLAG:洗脑
			;乳牛状態で乙女心もないだろ、ということで素質：乙女心の判定はしない
			IF GETBIT(＃Ｐ使用／Ｖ插入＃)
				IF TFLAG:拘束BIT
					CALL MESSAGE_BOX,@"「啊……在被束缚的情况下经历初体验……♥ 虽然可怕，但更多的是兴奋……♥」"
				ELSEIF TFLAG:眼罩
					CALL MESSAGE_BOX,@"「啊……在被蒙眼的情况下经历初体验……♥ 虽然可怕，但更多的是兴奋……♥」"
				ELSE
					CALL MESSAGE_BOX,@"「あぁ…♥ %SELF_CALL()%的初次，献给%MASTER_CALL()%呢…♥♥」"
				ENDIF
			ELSEIF TFLAG:眼罩
				CALL MESSAGE_BOX,@"「%MASTER_CALL()%…？ 虽然被蒙上了眼，但……难道说……♥」"
			ELSE
				CALL MESSAGE_BOX,@"「啊咿嘻…♥ %SELF_CALL()%的初次，居然被这样的东西夺走了……♥♥」"
			ENDIF
		ELSEIF ＃陷落状态／恋慕以上＃
			;こちらは乙女心の判定あり
			IF GETBIT(＃Ｐ使用／Ｖ插入＃)
				IF TALENT:少女心
					CALL MESSAGE_BOX,@"「あぁ…♥ %SELF_CALL()%的纯洁，献给这世上最敬爱的您呢…♥♥」"
				ELSEIF TFLAG:眼罩
					CALL MESSAGE_BOX,@"「あぁ…♥ 如果要蒙眼，至少请边抱着我边做……♥♥\n　我想感受到%MASTER_CALL()%的存在……♥♥」"
				ELSE
					CALL MESSAGE_BOX,@"「啊♥ %MASTER_CALL()%…♥ 终于到了这一刻……♥♥」"
				ENDIF
			ELSEIF TALENT:少女心
				CALL MESSAGE_BOX,@"「不、这样……！ 我想把初次献给%MASTER_CALL()%……っ」"
			ELSEIF TFLAG:眼罩
				CALL MESSAGE_BOX,@"「%MASTER_CALL()%…？ 虽然被蒙上了眼，但……难道说……」"
			ELSE
				CALL MESSAGE_BOX,@"「啊……我还以为初次是要献给%MASTER_CALL()%的……\n　不、不是的……随%MASTER_CALL()%的愿望……」"
			ENDIF
		ELSEIF TALENT:贞操观念 || TALENT:少女心
			CALL MESSAGE_BOX,@"「不、我不想……っ 那绝对不行……求求您了……っ！ 不，不行啊！」"
		ELSEIF ＃陷落状态／陷落以上＃ || TALENT:不在乎贞操
			CALL MESSAGE_BOX,@"「呜……我本以为有朝一日会有这样的时刻到来……」"
		ELSEIF V_PENIS == "触手"
			CALL MESSAGE_BOX,@"「呜……初次的对象居然是触手……！？ 太……残酷了……っ」"
		ELSEIF V_PENIS == "妖精"
			CALL MESSAGE_BOX,@"「不，不行啊！ ゴブリンなんかにっ……ぁぁあああああっ！」"
		ELSE
			CALL MESSAGE_BOX,@"「放开我！ 我还从未做过这种事……っ 不，不行啊！」"
		ENDIF
	
	CASE "处女丧失后"
		IF CFLAG:乳牛 || CFLAG:洗脑
			IF GETBIT(＃Ｐ使用／Ｖ插入＃)
				IF TFLAG:拘束BIT || TFLAG:眼罩
					CALL MESSAGE_BOX,@"「はぅっ♥ ……如果初次是这样的话，嗜好就歪掉了……♥♥\n　请您负责%MASTER_CALL()%……♥♥」"
				ELSE
					CALL MESSAGE_BOX,@"「能和亲爱的您相连，居然如此幸福……♥♥」"
				ENDIF
			ELSE
				IF TFLAG:眼罩
					CALL MESSAGE_BOX,@"「呜呜♥…果然如此♥……真是个可恶的人……♥♥」"
				ELSE
					CALL MESSAGE_BOX,@"「呜呜♥……那、那是什么……泪水？……一定是因为疼痛……♥♥」"
				ENDIF
			ENDIF
		ELSEIF ＃陷落状态／恋慕以上＃
			IF GETBIT(＃Ｐ使用／Ｖ插入＃)
				IF TALENT:少女心
					CALL MESSAGE_BOX,@"「ふあぁ…♥ 与心爱的您融为一体，幸福得令人害怕……♥♥\n　%SELF_CALL()%、初次会如此幸福，真的可以吗……♥♥♥」"
				ELSEIF TFLAG:眼罩
					CALL MESSAGE_BOX,@"「%MASTER_CALL()%♥♥ %SWEET_MASTER_CALL()%…♥♥ 我爱您呀♥♥」"
				ELSE
					CALL MESSAGE_BOX,@"「能和亲爱的您相连，居然如此幸福……♥♥」"
				ENDIF
			ELSE
				IF TALENT:少女心
					CALL MESSAGE_BOX,@"「明明知道%SELF_CALL()%的心情……%MASTER_CALL()%真是个冷酷的人……呜呜…」"
				ELSE
					CALL MESSAGE_BOX,@"「呜呜……竟然……以这样的方式散失纯洁……」"
				ENDIF
			ENDIF
		ELSEIF TALENT:贞操观念 || TALENT:少女心
			CALL MESSAGE_BOX,@"「……这、这一定是梦……没错，只是个糟糕的……梦…」"
		ELSEIF ＃陷落状态／陷落以上＃ || TALENT:不在乎贞操
			IF V_PENIS == "妖精"
				CALL MESSAGE_BOX,@"「……虽然对初体验并没有抱有什么梦想……\n　竟然被这种低贱的哥布林夺走……实在是忍无可忍……」"
			ELSEIF PALAM:Ｖ润滑 >= 10000
				CALL MESSAGE_BOX,@"「嗯……并没有想象中那么痛苦……」"
			ELSE
				CALL MESSAGE_BOX,@"「呜……当然是很痛的……！\n　如果要顾虑的话，那请快点拔出来吧……っ」"
			ENDIF
		ELSE
			CALL MESSAGE_BOX,@"「あぐっ……ぐっ…ひぅ…」"
		ENDIF
	
	CASE "Ａ处女丧失前"
		IF TALENT:性知识贫乏
			CALL MESSAGE_BOX,@"「……？ 到底打算对%ANAL_CALL()%做什么……？\n　…っ！？ %ANAL_CALL()%にっ…捻じ込まれてっ…！？」"
		ELSEIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			IF GETBIT(＃Ｐ使用／Ａ插入＃)
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「……好痛……！？　可是……%ANAL_CALL()%深处……麻麻的……像被搔到一样……好奇怪……♥」"
					CALL MESSAGE_BOX,@"「%MASTER_CALL()%……连这里……也会变成只属于您的形状吗……♥」"
				ELSE
					CALL MESSAGE_BOX,@"「%MASTER_CALL()%♥ 崭新的%ANAL_CALL()%……请随意使用哦♥♥」"
				ENDIF
			ELSEIF A_PENIS == "触手"
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「……痛……！？　可是……被撑开的同时……深处……发酥……好恶心……♥」"
				ELSE
					CALL MESSAGE_BOX,@"「触手进入%ANAL_CALL()%还是有点可怕……っ」"
				ENDIF
			ELSE
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「……痛……！？　可是……%ANAL_CALL()%……像有自己的想法一样……一缩一缩……♥」"
				ELSE
					CALL MESSAGE_BOX,@"「啊哈哈♥ %SELF_CALL()%的%ANAL_CALL()%请多多玩耍哦♥♥」"
				ENDIF
			ENDIF
		ELSEIF A_PENIS == "妖精"
			CALL MESSAGE_BOX,@"「……っ！？ 请不要碰%ANAL_CALL()%……！？」"
		ELSE
			IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
				CALL MESSAGE_BOX,@"「……那边……不行……！？　痛……！？　……可是……深处……好奇怪……」"
			ELSE
				CALL MESSAGE_BOX,@"「那、那边不对…… っ～～～！」"
			ENDIF
		ENDIF
	
	CASE "Ａ处女丧失后"
		IF TALENT:性知识贫乏
			CALL MESSAGE_BOX,@"「呜呜…%ANAL_CALL()%是……排泄的地方……呜咕……」"
		ELSEIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			IF GETBIT(＃Ｐ使用／Ａ插入＃)
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「……还火辣辣地疼……可是……深处……像被点燃一样……忍不住想夹紧……♥」"
