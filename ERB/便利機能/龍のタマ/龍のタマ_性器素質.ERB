
;性器素質付与
@SELECT_WISH_NASTY_TALENT

;TALENT:名器→30
TALENT_REF = 30
TALENT_MAX = 20
PRINTFORML 请选择要赋予给%CALLNAME%的性器素质。
FOR LOCAL,TALENT_REF,TALENT_REF +TALENT_MAX
	TALENT_NAME = %TALENTNAME:LOCAL%
	SIF TALENT_NAME == "" || TALENT_NAME == "先天母乳体质"
		CONTINUE
	
	;もうある場合はダメ
	IF TALENT:LOCAL
		CALL PRINTL_WORD_COLOR,@"【%TALENT_NAME%】已持有","桃"
	ELSEIF TALENT_NAME == "极上乳压" && ABL:胸围大小 < BUSTSIZE_巨乳
		CALL PRINTL_WORD_COLOR,@"【%TALENT_NAME%】需要【巨乳】或以上","灰"
	ELSE
		PRINTFORML [{LOCAL -TALENT_REF,2}] 【%TALENT_NAME%】
	ENDIF
NEXT
PRINTL
PRINTL [99] 取消
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 19
	TALENT_NUM = TALENT_REF +RESULT
	PRINTFORML 是否要给%CALLNAME%赋予素质【%TALENTNAME:TALENT_NUM%】？
	CALL ASK_YN
	SIF RESULT
		RETURN
	TALENT:TALENT_NUM = 1
	CALL PRINTW_WORD_COLOR,@"%CALLNAME%已经学会了【%TALENTNAME:TALENT_NUM%】！","桃"
	ITEM:龙之珠 = 0
ENDSELECT





