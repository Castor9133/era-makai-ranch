@KOJO_GENERAL_INDEX_妹系1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

IF TFLAG:Ｍ装备
	CALL KOJO_GENERAL_MOUTH_SHACKLE_1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
	RETURN
ELSEIF CFLAG:崩坏 && !CFLAG:洗脑
	IF GROUPMATCH(ARGS:0,"例文")
	ELSEIF GROUPMATCH(ARGS:1,"洗脑触手","崩坏")
	ELSE
		IF NOWEX:总绝顶
			CALL MESSAGE_BOX,@"「呜……♥ 不、不行……脑袋要坏掉了……♥」"
			CALL MESSAGE_BOX,@"「别、别丢下我……♥ ……还要……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……别走……」"
		ENDIF
		RETURN
	ENDIF
ENDIF

SELECTCASE ARGS:0
CASE "身体"
	CALL KOJO_GENERAL_妹系1_EXCRETION_BODY(ARGS:1, ARGS:2)
	RETURN
CASE "例文"
	CALL MESSAGE_BOX,@"「【妹系1】已设置。\n爱撒娇、黏人、嘴硬也会靠过来；陷落后更像乖孩子求奖励。」"

CASE "调教命令"
	CALL KOJO_GENERAL_妹系1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

CASE "绝顶"
	;深喉中的高潮（新增：深喉性癖相关口上）
	SIF TEQUIP:深喉
		CALL MESSAGE_BOX,@"「咳、咳咳……♥ 喉咙被塞得好满……%MASTER_CALL()%……太、太会欺负人了……♥」"
	SIF TEQUIP:深喉
		CALL MESSAGE_BOX,@"「……别看嘛……这样我会更难忍……会更想黏着你……♥」"
	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「不行啦……♥ 我很乖吧……♥ 奖励、奖励我……♥♥」"
	ELSEIF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「%MASTER_CALL()%……♥ 看着我……我、我要去了……♥」"
		CALL MESSAGE_BOX,@"「别停……我会乖乖的……♥」"
	ELSEIF ＃陷落状态／屈服以上＃
		CALL MESSAGE_BOX,@"「呜……♥ 不要、太快……♥」"
	ELSE
		CALL MESSAGE_BOX,@"「不行！……啊……♥」"
	ENDIF
	SIF NOWEX:Ａ绝顶
		IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
			CALL MESSAGE_BOX,@"「呀……！？　%MASTER_CALL()%……%ANAL_CALL()%……好痛……可是……里面……好怪……♥」"
			CALL MESSAGE_BOX,@"「……是不是……坏掉了……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「痛……！？　屁股……不要……%MASTER_CALL()%……好痛……！」"
			CALL MESSAGE_BOX,@"「……呜呜……那里……不要……」"
		ENDIF
	SIF NOWEX:Ｕ绝顶
		IF TEQUIP:尿道塞 || TFLAG:尿道装备
			SIF TALENT:尿道敏感 || EX:尿道调教经验 >= 15
				CALL MESSAGE_BOX,@"「……尿道塞顶着……一颤就被它拽走……%MASTER_CALL()%……我、我真的要……♥」"
			SIF !(TALENT:尿道敏感 || EX:尿道调教经验 >= 15)
				CALL MESSAGE_BOX,@"「痛痛……尿道里塞着还动……别、别欺负我了……！」"
		ELSE
			SIF TALENT:尿道敏感 || EX:尿道调教经验 >= 15
				CALL MESSAGE_BOX,@"「%MASTER_CALL()%……下面那条线……又刺又软……要坏掉啦……♥」"
			SIF !(TALENT:尿道敏感 || EX:尿道调教经验 >= 15)
				CALL MESSAGE_BOX,@"「别弄尿道……又憋又难受……呜……！」"
		ENDIF

CASE "射精"
	IF SOURCE:膣内射精经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「里面……好烫……♥ ……我会忍着……♥」"
			CALL MESSAGE_BOX,@"「……别走……抱着我……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「不、不可以在里面……！」"
		ENDIF
	ELSEIF SOURCE:尻穴射精经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「后面……也……射进来了……♥ ……好坏……♥」"
			CALL MESSAGE_BOX,@"「……别笑我……抱紧点……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「那里不行！」"
		ENDIF
	ELSEIF SOURCE:精饮经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……咽下去了……♥ ……我很乖吧……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「咳……咳咳……！」"
		ENDIF
	ELSEIF TEQUIP:手淫
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「手上……黏黏的……♥ ……我帮你擦……」"
			CALL MESSAGE_BOX,@"「……别走……再摸摸我……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……好脏……」"
		ENDIF
	ELSEIF SOURCE:股间射精
		CALL MESSAGE_BOX,@"「弄在身上了……♥ ……呜……你、你好坏……」"
		CALL MESSAGE_BOX,@"「……我帮你擦……别走……」"
	ELSEIF SOURCE:乳房射精
		CALL MESSAGE_BOX,@"「在胸口……？呜……别看……♥」"
		CALL MESSAGE_BOX,@"「……我、我会擦干净……」"
	ELSEIF SOURCE:颜面射精
		CALL MESSAGE_BOX,@"「脸上……？！……呜……好、好羞耻……」"
		CALL MESSAGE_BOX,@"「……别笑……抱一下……」"
	ENDIF

CASE "搾乳"
	IF SOURCE:母乳漏出
		CALL MESSAGE_BOX,@"「呀……自己漏出来了……♥」"
		RETURN
	ENDIF
	IF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「轻点……胸口酸酸的……♥」"
		CALL MESSAGE_BOX,@"「……我会乖乖的……别太用力……♥」"
	ELSE
		CALL MESSAGE_BOX,@"「不要摸那边……！」"
	ENDIF

CASE "抽出"
	CALL MESSAGE_BOX,@"「……腿软了……抱、抱一下……」"
	CALL MESSAGE_BOX,@"「……别放开我……」"

CASE "阴茎称呼变更"
	CALL MESSAGE_BOX,@"「……要叫那个吗……好、好吧……我会记住……」"

CASE "膣称呼变更"
	CALL MESSAGE_BOX,@"「那、那里也要改叫法……？呜……我知道了……」"

CASE "肛门称呼变更"
	CALL MESSAGE_BOX,@"「后面……也要……？太坏了……」"

CASE "吸欧派"
	SELECTCASE ARGS:1
	CASE "开始"
		CALL MESSAGE_BOX,@"「……就一下哦……别咬……」"
	CASE "结束"
		CALL MESSAGE_BOX,@"「……胸口麻麻的……你、你满意了吧……」"
	ENDSELECT

CASE "访问"
	SELECTCASE ARGS:1
	CASE "入口"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「你来啦。……要我在你旁边候着，%SELF_CALL()%就不去门口乱晃……♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……你来啦……看完别、别转眼就走嘛……」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「……你进我屋了。今天……又要做啥啊……」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……你进房间了。没正事的话%SELF_CALL()%要回角落了。」"
		ELSE
			CALL MESSAGE_BOX,@"「……别理我。当%SELF_CALL()%不在这间屋里。」"
		ENDIF
	CASE "衣服修理"
		CALL MESSAGE_BOX,@"「衣服破了……？给、给我。%SELF_CALL()%会补好……你要在旁边看也行，但不许笑%SELF_CALL()%笨手笨脚。」"
	CASE "摸头"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「嗯……再摸。」"
			CALL MESSAGE_BOX,@"「%SELF_CALL()%会更乖……所以你也要一直摸着，别放开……♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……摸、摸头可以。」"
			CALL MESSAGE_BOX,@"「但你摸了就要负责。……不许摸完就走。」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「……突然摸什么嘛。」"
			CALL MESSAGE_BOX,@"「……不过……你要摸就摸。%SELF_CALL()%不会躲。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……别弄乱我的头发。」"
			CALL MESSAGE_BOX,@"「摸一下就行了，别以为这样就能装作温柔。」"
		ELSE
			CALL MESSAGE_BOX,@"「别碰！……%SELF_CALL()%会咬人。」"
		ENDIF
	CASE "接吻"
		IF TALENT:无接吻经验
			RETURN
		ELSEIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「……亲我。」"
			CALL MESSAGE_BOX,@"「再多一点……别停……%SELF_CALL()%会乖乖的……♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……亲一下。」"
			CALL MESSAGE_BOX,@"「……不、不是命令也行……%SELF_CALL()%自己想要……」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「……就一下下。」"
			CALL MESSAGE_BOX,@"「你不许笑。笑了%SELF_CALL()%就不亲了。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……快点。」"
			CALL MESSAGE_BOX,@"「%SELF_CALL()%不想把嘴唇交给你太久。」"
		ELSE
			CALL MESSAGE_BOX,@"「别靠近！%SELF_CALL()%讨厌你！」"
		ENDIF
	CASE "停止泌乳"
		IF CFLAG:魔界_妊娠S == 1 || CFLAG:魔界_妊娠S == 2
			CALL MESSAGE_BOX,@"「……现在停吗……？%SELF_CALL()%……不太想……」"
		ELSEIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「停、停止泌乳……？……好吧……%SELF_CALL()%会努力停下来……」"
		ELSE
			CALL MESSAGE_BOX,@"「停、停止泌乳……？……好吧……%SELF_CALL()%会努力停下来……」"
		ENDIF
	CASE "终止妊娠"
		CALL MESSAGE_BOX,@"「……要终止吗……？嗯……我、我知道了……」"
	CASE "侍奉口爆终了"
		SELECTCASE ARGS:2
		CASE "忍住"
			CALL MESSAGE_BOX,@"「……诶……真的忍住啦？……那我……是不是……很听话……？」"
			CALL MESSAGE_BOX,@"「……嘴还好酸……可你说停……我就停。」"
		CASE "咽下"
			CALL MESSAGE_BOX,@"「……咕嘟……全吞了啦……别捏我脸看有没有漏……！」"
			CALL MESSAGE_BOX,@"「……好烫……可是……是你给的……我会咽干净的……」"
		ENDSELECT
	CASE "揉胸轻抚"
		CALL MESSAGE_BOX,@"「……哥……揉、揉那边……我会……忍不住出声啦……」"
		CALL MESSAGE_BOX,@"「……又不是小朋友喝奶……别闹……」"
	CASE "拥抱嗅闻"
		CALL MESSAGE_BOX,@"「……背后抱……好犯规……心跳你全听见了对不对……」"
		CALL MESSAGE_BOX,@"「……再闻……我要……藏你衣领里了哦……」"
	CASEELSE
	ENDSELECT

CASE "肉体改造"
	CALL MESSAGE_BOX,@"「……身体要变了吗……？别、别弄太奇怪……」"

CASE "日程"
	SELECTCASE ARGS:1
	CASE "调教"
		SELECTCASE ARGS:2
		CASE "开始调教"
			CALL MESSAGE_BOX,@"「……今天也要吗……？轻点……好不好……」"
		CASE "调教结束"
			CALL MESSAGE_BOX,@"「……结束了……？那、那就抱一下……」"
		ENDSELECT
	CASEELSE
	ENDSELECT

CASE "事件"
	CALL MESSAGE_BOX,@"「……我能帮上忙吗……？别不理我……」"

CASE "战斗"
	SELECTCASE ARGS:1
	CASE "攻击"
		CALL MESSAGE_BOX,@"「我、我上了！」"
	CASE "被击中"
		CALL MESSAGE_BOX,@"「好痛……呜……」"
	CASEELSE
	ENDSELECT

CASEELSE
ENDSELECT
RETURN

@KOJO_GENERAL_妹系1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
CALL KOJO_GENERAL_妹系口上1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
RETURN

;--------------------------------------------
; 排泄羞耻／身体（本口上专用）
;--------------------------------------------
@KOJO_GENERAL_妹系1_EXCRETION_BODY(ARGS:0, ARGS:1)
SELECTCASE ARGS:0
CASE "排泄事故"
	SELECTCASE ARGS:1
	CASE "肠"
		CALL MESSAGE_BOX,@"「……哥哥……别看……出来了啦……」"
	CASE "尿"
		CALL MESSAGE_BOX,@"「……呜呜……尿出来了……好丢脸……」"
	CASEELSE
		CALL MESSAGE_BOX,@"「……」"
	ENDSELECT
CASE "放尿主动"
	CALL MESSAGE_BOX,@"「……要在哥哥面前尿……心脏快跳出来了……」"
CASE "灌肠妊娠求饶"
	CALL MESSAGE_BOX,@"「……宝宝还在肚子里……灌肠好可怕……可以不要吗……？」"
CASEELSE
ENDSELECT
RETURN 1


