
;早期返済
@AGRI_COOP_LOAN_REPAY
#DIM PAY

CALL MANYL(3)

;まず経費から
IF MONEY:经费计上
	PAY = LIMIT(MONEY,0,MONEY:经费计上)
	PRINTFORML 当前正在计入经费：%VALUE_DIGIT(MONEY:经费计上)%G。 
	PRINTFORML 　　　　持有金：%VALUE_DIGIT(MONEY)%G。 
	PRINTL
	PRINTFORML 要用所持金%VALUE_DIGIT(PAY)%G提前计入经费吗？
	CALL ASK_YN
	SIF RESULT
		RETURN
	MONEY -= PAY
	MONEY:经费计上 -= PAY
	PRINTFORML %VALUE_DIGIT(PAY)%G已提前计入。
	SIF !MONEY:经费计上
		CALL PRINT_WORD_COLOR("费用入帐完成","黄")
	PRINTW
ENDIF
IF MONEY:贷款
	PAY = LIMIT(MONEY,0,MONEY:贷款)
	PRINTFORML 当前贷款金额：%VALUE_DIGIT(MONEY:贷款)%G。 
	PRINTFORML 　　　　　　　持有金：%VALUE_DIGIT(MONEY)%G。 
	PRINTL
	PRINTFORML 要用所持金%VALUE_DIGIT(PAY)%G提前偿还贷款吗？
	CALL ASK_YN
	SIF RESULT
		RETURN
	MONEY -= PAY
	MONEY:贷款 -= PAY
	PRINTFORML %VALUE_DIGIT(PAY)%G已提前偿还。
	SIF !MONEY:贷款
		CALL PRINT_WORD_COLOR("贷款偿还完成","黄")
	PRINTW
ENDIF

