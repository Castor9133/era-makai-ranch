
;[会いに行く]前フラグ処理
@VISIT_SLAVE_BEFORE

;[会いに行く]の時抽出継続フラグOFF
CFLAG:继续抽出 = 0
CALL RESET_TRAIN_PALAM
TFLAG:日程外Ｈ = 1
PLAYER = MASTER
CALL BEFORE_TRAIN_T_CLOTHE
CALL BEFORE_TRAIN_T_CLOTHE_M
CALL BEFORE_TRAIN_LUBRICATION
CALL VISIT_SLAVE

;後処理もここ
CALL RESET_TRAIN_PALAM
FLAG:当前访问次数 ++

;制限撤廃なら0にする
SIF GETBIT(＃限制解除／访问次数＃)
	FLAG:当前访问次数 = 0



;[会いに行く]選択
@VISIT_SLAVE

;行動でHP増減するので毎回個人の業務可能チェックを入れる
CALL TARGET_SCHEDULE_POSSIBLE

;スケジュール外でのリセット
TFLAG:Ｐ抽出后等待跳过 = 0
VARSET TFLAG,0,30,100
VARSET TEQUIP

;調教者にちんぽ存在するかチェック
CALL PLAYER_PENIS_CHECK

;制限撤廃コンフィグを見る
CALL CHECK_LIMIT_BREAK_CONFIG
CLEARLINE LINECOUNT
CALL SHOW_SLAVE_STATE(2)
CALL KOJO_PRINT("访问","入口")
TRYCALL EXCRETION_VISIT_BLADDER_HOOK
PRINTL
CALL VISIT_SLAVE_CHECK
CALL PRINTL_ALIGN(2)
DRAWLINE
PRINTL [99] 返回
BINPUT
PRINTL
IF CSTR:状态／主人公的孩子 == "成长后"
	SELECTCASE RESULT
	CASE 3,5,12,13,14
		CHILD_COM = RESULT
		CALL CHILD_REBELLION
		SIF RESULT
			RESTART
		RESULT = CHILD_COM
	ENDSELECT
ENDIF
SELECTCASE RESULT
CASE 0
	CALL VISIT_HAIR_STYLE_CHANGE_BEFORE
CASE 1
	CALL VISIT_EYE_COLOR_CHANGE_BEFORE
CASE 2
	CALL VISIT_REPAIR_CLOTHE
CASE 4
	CALL VISIT_CHANGE_MASTER_CALL
CASE 5
	CALL VISIT_SETTING_NEW_POSITION_BEFORE
CASE 6
	CALL VISIT_SETTING_NEW_CALLNAME_BEFORE
CASE 7
	CALL VISIT_TAKE_ENERGY_DRINK
CASE 8
	CALL VISIT_DRINK_HERBAL_TEA
CASE 9
	TFLAG:日程外Ｈ = 0
	CALL VISIT_CHANGE_CHARA_CLOTHE
	TFLAG:日程外Ｈ = 1
CASE 10
	CALL VISIT_STROKING_HEAD
CASE 11
	CALL VISIT_KISS
CASE 12
	CALL VISIT_BREAST_FEEDING
	
	;一時的脱衣状態・露出状態リセット
	VARSET TFLAG,0,120,145
	CALL AJUST_STRIP_FLAG
CASE 13
	CALL VISIT_EP_INJECT(1)
CASE 14
	CALL VISIT_DOSAGE
CASE 15
	CALL VISIT_PLAY_WITH_CHILD
CASE 16
	CALL VISIT_MANUAL_DRY
CASE 17
	CALL VISIT_ABORT_PREGNANCY
CASE 18
	CALL VISIT_SERVE_CLIMAX_VISIT
CASE 19
	CALL VISIT_BREAST_TEASE_NONLACT
CASE 20
	CALL VISIT_EMBRACE_SNIFF
CASE 99
	RETURN
ENDSELECT
RESTART



;拘束投薬
@VISIT_DOSAGE

TFLAG:调教前母乳体质 = MARK:母乳体质
CALL COM800
IF RESULT
	CFLAG:时刻限制／用药 = 1
	CFLAG:时刻限制／Ｈ = 1
	CALL SOURCE_CHECK
	PRINTW
ENDIF
SELECTCOM = 0
CALL AUTO_SCHEDULE_LACTATION



;霊力注入
;ARG→[会いに行く]から直接来た
@VISIT_EP_INJECT(ARG)
#DIM 注入部位

;挿入自体をキャンセル→また選択可能
;挿入後に注ぎ込むのをキャンセル→このコマンドでの挿入が不可になる→「おっぱい吸わせて」からのみ
;部位選択→倍率：前穴100%／后穴50%／口穴30%（COM905で反映）
V_PENIS = %CALLNAME:0%
PRINTL 以哪个部位进行灵力注入？
PRINTL 　（向奴隶传递的灵力量会依部位而变）
PRINTL [0] 前穴（膣内）…传递效率 100％
PRINTL [1] 后穴（肛门内）…传递效率 50％
PRINTL [2] 口穴（口内）…传递效率 30％
PRINTL [99] 返回
BINPUT
SELECTCASE RESULT
CASE 0
	注入部位 = 0
	TFLAG:灵力注入倍率 = 100
	CALL COM30
CASE 1
	注入部位 = 1
	TFLAG:灵力注入倍率 = 50
	CALL COM40
CASE 2
	注入部位 = 2
	TFLAG:灵力注入倍率 = 30
	CALL COM51
CASEELSE
	RETURN
ENDSELECT
IF !RESULT
	PRINTL 决定不要插入了…
	TFLAG:灵力注入倍率 = 0
	RETURN
ENDIF
SELECTCASE 注入部位
CASE 0
	TFLAG:Ｖ装备 = 1
	SETBIT ＃Ｐ使用／Ｖ插入＃
CASE 1
	TFLAG:Ａ装备 = 1
	SETBIT ＃Ｐ使用／Ａ插入＃
CASE 2
	SETBIT ＃Ｐ使用／Ｍ插入＃
ENDSELECT
SIF ARG
	CALL PRINT_IMAGE("调教执行")
SIF 注入部位 == 0
	CALL LOST_VARGIN
SIF 注入部位 == 0
	CALL LOST_VARGIN_PLAYER
SELECTCASE 注入部位
CASE 0
	SELECTCOM = 30
CASE 1
	SELECTCOM = 40
CASE 2
	SELECTCOM = 51
ENDSELECT
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
EXP:(SELECTCOM +1000) ++
CFLAG:时刻限制／灵力注入 = 1
CFLAG:时刻限制／Ｈ = 1
CALL COM905
IF RESULT
	SELECTCOM = 905
	CALL SOURCE_CHECK
ELSE
	PRINTL 不再注入灵力精液…
ENDIF

;霊力精液のため絶対射精してる
SIF TFLAG:Ｐ使用BIT
	CALL COM890
PRINTW
SELECTCOM = 0

