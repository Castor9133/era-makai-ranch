
;世界観の棚
@REFERENCE_WORLD

CLEARLINE LINECOUNT
ALIGNMENT CENTER
PRINTL --- 世界观 ---
DRAWLINE
FOR LOCAL,5000,5100
	SIF STR:LOCAL != ""
		PRINTFORMLC [{LOCAL -4900}] %STR:LOCAL%
NEXT
ALIGNMENT LEFT
CALL MANYL(2)
DRAWLINE
PRINTL [  9] 回到入口
INPUT
IF RESULT >= 100 && RESULT < 200
	CALL REFERENCE_SEARCH(RESULT)
ELSEIF RESULT == 9
	RETURN
ENDIF
RESTART

