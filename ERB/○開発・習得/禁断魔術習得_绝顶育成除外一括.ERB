; 覆盖 @FORBIDDEN_MAGIC_GET_BULK：绝顶育成（755）改由成人店现金购买，禁止一括用禁断AP 误购
@FORBIDDEN_MAGIC_GET_BULK

PRINTL 使用当前的技能点一括学习列表前的可学习页面内魔法。
PRINTL ・如果AP不足，将不会进行后续的魔法学习。
PRINTL 执行批量学习？
CALL ASK_YN
SIF RESULT
	RETURN

;記録
AP_BEFORE = MONEY:禁断AP
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	; 755＜绝顶育成＞：仅成人店所持金购买
	SIF ITEMNAME:LOCAL == "绝顶育成"
		CONTINUE
	;習得前提魔術も見る
	SIF !ITEMPRICE:LOCAL || ITEM:LOCAL || (MAGIC_GET_PREMISE:LOCAL && !ITEM:(MAGIC_GET_PREMISE:LOCAL))
		CONTINUE
	
	;習得不可魔力で終了
	SIF ITEMPRICE:LOCAL > MONEY:禁断AP
		BREAK
	ITEM:LOCAL ++
	MONEY:禁断AP -= ITEMPRICE:LOCAL
	CALL PRINTL_WORD_COLOR,@"学习了【%ITEMNAME:LOCAL%】。","浅蓝色"
NEXT
PRINTFORML 消费AP：%TOSTR(AP_BEFORE -MONEY:禁断AP)%
IF AP_BEFORE == MONEY:禁断AP
	PRINTW 魔法的习得失败了。

;LOCALがITEM_ID_MAXなら全て習得した
ELSEIF LOCAL >= ITEM_ID_MAX
	PRINTW 《 习得了所有的魔法 》
ELSE
	PRINTW
ENDIF
SELECT_ITEM = 0
