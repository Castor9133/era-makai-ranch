@COM105
;触手Ｖ挿入

IF TEQUIP:SELECTCOM
	TRYCALLFORM COM{SELECTCOM}_REMOVE
	TRYCALLFORM COM{SELECTCOM}_REMOVE_MESSAGE
	TFLAG:膣内精液 = 0
	RETURN 1
ENDIF
CALL V_INSERT_CONFIRM(1)
SIF RESULT
	RETURN
LOSEBASE:气力 += 10
SOURCE:异形恐惧 += 500
SOURCE:已用时间 = 1
TEQUIP:触手Ｖ插入 = 1
SIF !FLAG:主人公的触手也是主人公
	V_PENIS = 触手

;増量あれば潤滑増加
SIF ITEM:触手分泌液增量 && GETBIT(＃有效／触手分泌液增量＃)
	SOURCE:Ｖ润滑追加 += 10000
RETURN 1



