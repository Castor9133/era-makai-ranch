
;犬耳族
@TRIBE_FEATURE_CONFIG_DOGEAR

CLEARLINE LINECOUNT
PRINTL 请选择【狗耳族】的种族设定。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL 固定：素质【动物耳】【尾巴】
PRINTLC [ 0] 素质【锯齿】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／犬耳族,0),1)
PRINTLC [ 1] 素质【好奇心】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／犬耳族,1),1)
PRINTLC [ 2] 素质【污臭敏感】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／犬耳族,2),1)
PRINTLC [ 3] 素质【隶属愿望】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／犬耳族,3),1)
PRINTLC [ 4] 基础体力＋200
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／犬耳族,4),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(6)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL 被赋予素质【锯齿】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／犬耳族"),INPUT_NUM)
CASE 1
	PRINTL 被赋予素质【好奇心】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／犬耳族"),INPUT_NUM)
CASE 2
	PRINTL 被赋予素质【污臭敏感】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／犬耳族"),INPUT_NUM)
CASE 3
	PRINTL 被赋予素质【隶属愿望】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／犬耳族"),INPUT_NUM)
CASE 4
	PRINTL 在普通状态计算后体力增加200。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／犬耳族"),INPUT_NUM)
CASE 98
	PRINTL 将【狗耳族】的种族设定回复为默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_DOGEAR
CASE 99
	RETURN
ENDSELECT
RESTART


