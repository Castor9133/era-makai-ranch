
;隣接キャラをTARGETに指定し直す
@SLAVE_SORT
#DIM LOOP_BASE
#DIM TEMP_NUM

;キャンセルしたらそのまま戻るようにした
CALL MANYL(5)
IF CHARANUM < 2
	PRINTW 没有可重新排列的奴隶
	RETURN
ELSE
	PRINTL 重新排列奴隶的显示顺序
ENDIF
CALL HALFLINE
PRINTL [ 1] 更改位置（交换）
PRINTL [ 2] 更改位置（插入）
PRINTL [ 3] 更改顺序（排序）
PRINTL
PRINTL [99] 取消
INPUT
PRINTL
SELECTCASE RESULT
CASE 1,2
	CALL SLAVE_SORT_REPLACE(RESULT)
CASE 3
	CALL SLAVE_SORT_ALL
ENDSELECT



;入れ替え／挿入
;ARG→1：入れ替え　2：挿入
@SLAVE_SORT_REPLACE(ARG)
#DIM SWAP_NUM1
#DIM SWAP_NUM2
#DIM CHARA_NUM,2

SWAP_NUM1 = -1
SWAP_NUM2 = -1

;プロファイル表示
CALL SELECT_CHARA_SORT(ARG, 0)

;キャンセルした
SIF RESULT == 99
	RETURN
SWAP_NUM1 = RESULT
CALL SELECT_CHARA_SORT(ARG, SWAP_NUM1)
SIF RESULT == 99
	RETURN
SWAP_NUM2 = RESULT

;入れ替えと挿入で変化
IF ARG == 1
	PRINTFORMW %CALLNAME:(SWAP_NUM1)%与%CALLNAME:(SWAP_NUM2)%交换成功。
	SWAPCHARA SWAP_NUM1, SWAP_NUM2

	;交換確認用
	;PRINTFORMW %CALLNAME:(SWAP_NUM1)%と%CALLNAME:(SWAP_NUM2)%を入れ替えました。
ELSE
	CHARA_NUM:0 = SWAP_NUM1
	IF SWAP_NUM1 < SWAP_NUM2
		PRINTFORML %CALLNAME:(SWAP_NUM1)%已插入到编号为{SWAP_NUM2}的位置。
		REPEAT CHARANUM
			CHARA_NUM:1 = CHARA_NUM:0 + 1
			SWAPCHARA CHARA_NUM:0,CHARA_NUM:1
			CHARA_NUM:0 += 1
			SIF CHARA_NUM:1 == SWAP_NUM2
				BREAK
		REND
	ELSEIF SWAP_NUM1 > SWAP_NUM2
		PRINTFORML %CALLNAME:(SWAP_NUM1)%已插入到编号为{SWAP_NUM2}的位置。
		REPEAT CHARANUM
			CHARA_NUM:1 = CHARA_NUM:0 - 1
			SWAPCHARA CHARA_NUM:1,CHARA_NUM:0
			CHARA_NUM:0 -= 1
			SIF CHARA_NUM:1 == SWAP_NUM2
				BREAK
		REND
	ENDIF
ENDIF



;ソート
@SLAVE_SORT_ALL
#DIM TEMP_FLAG

CLEARLINE LINECOUNT
PRINTL 请选择要排序的条目。
CALL HALFLINE
PRINTL [ 0] 序号
PRINTL [ 1] 可吸收的灵力
