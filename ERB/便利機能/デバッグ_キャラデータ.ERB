;変更場所
;ARG→INPUT
@DEBUG_CHARA_NAME_EDIT_INPUT(ARG)

SELECTCASE ARG
CASE 0
	PRINTL 请输入显示名。
	INPUTS
	SIF RESULTS != ""
		CALLNAME = %RESULTS%
CASE 1
	PRINTL 请输入全名／本名。
	INPUTS
	NAME = %RESULTS%
CASE 2
	PRINTL 请输入唯一识别名。
	INPUTS
	CSTR:识别名 = %RESULTS%
CASE 3
	PRINTL 请输入原作名称。
	INPUTS
	CSTR:原作名 = %RESULTS%
CASE 4
	PRINTL 请输入眼睛特征。
	INPUTS
	CSTR:眼睛特征 = %RESULTS%
CASE 100 TO 300
	IF CSTRNAME:(ARG -100) == "乳头颜色"
		CALL CHANGE_SLAVE_NIPPLE_COLOR
	ELSE
		PRINTFORML %CSTRNAME:(ARG -100)%请输入。
		INPUTS
		CSTR:(ARG -100) = %RESULTS%
	ENDIF
ENDSELECT




;乳首の色変更
@CHANGE_SLAVE_NIPPLE_COLOR

CLEARLINE LINECOUNT
CALL PRINT_NIPPLE_COLOR
PRINTL [ 0] 重新调整
PRINTL [ 1] 直接输入
PRINTL [ 2] 更改颜色编码
PRINTL
PRINTL [99] 完成
INPUT
SELECTCASE RESULT
CASE 0
	CALL RANDOM_SLAVE_NIPPLE_COLOR

CASE 1
	PRINTL 请输入乳头的颜色。
	INPUTS
	CSTR:乳头颜色 = %RESULTS%

CASE 2
	CALL EDIT_COLOR_CODE(CFLAG:颜色编码／乳头,1)
	SIF RESULT
		CFLAG:颜色编码／乳头 = RESULT
CASE 99
	RETURN
ENDSELECT
RESTART





