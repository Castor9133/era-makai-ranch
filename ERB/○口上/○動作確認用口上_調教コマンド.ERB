CASE "正常位","后背位","对面坐位","背面坐位","骑乘位","背面骑乘位","对面立位","背面立位","强制骑乘位"
		;CALL MESSAGE_BOX,@"「test_↓ 调用 V 性交共通口上」"
		;CALL MESSAGE_BOX,@"「test_实务上只保留下方 CALL，勿留这三行说明，较利于处女丧失分支」"
		;CALL MESSAGE_BOX,@"「test_若按体位拆分 CASE，请勿用 ↓ 或另行补写」"
		; 拆分后处女例外要各写一遍；共用函数可省事并在丧失时跳过执行口上
	CALL KOJO_GENERAL_操作确认口上_TRAIN_INSIDE("Ｖ性交",ARGS:2)

CASE "Ａ正常位","Ａ后背位","Ａ对面坐位","Ａ背面坐位","Ａ骑乘位","Ａ背面骑乘位","Ａ对面立位","Ａ背面立位","强制Ａ骑乘位"
		;CALL MESSAGE_BOX,@"「test_↓ 调用 A 性交共通口上」"
