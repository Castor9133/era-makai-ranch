
;反抗削除メッセージ
@CAPITULATION_DELETE_RESIST_MESSAGE

IF !TFLAG:哥布林轮奸
	IF CSTR:日程 == "体内凌辱"
		PRINTFORML 被数次体内肉壁凌辱后，%CALLNAME%了解了自己的处境，无法反抗%CALLNAME:0%。，
		PRINTFORML 不知道能不能传达到，在%CALLNAME:0%的体内发出了请求原谅的声音…
	ELSE
		PRINTFORML %CALLNAME%在尊严被践踏的情况下，暂时决定不反抗%CALLNAME:0%…
	ENDIF
ENDIF
CALL PRINTL_WORD_COLOR,@"曾经反抗%CALLNAME:0%的%CALLNAME%逐渐变得老实了…","桃"
CALL PRINTL_WORD_COLOR,@"%CALLNAME%的【反抗】消失了","浅蓝色"



;屈服メッセージ
@CAPITULATION_SUCCUMB_MESSAGE

IF CSTR:日程 == "体内凌辱"
	PRINTFORML %CALLNAME%似乎心碎了。再也不会有违抗%CALLNAME:0%的念头了吧……
ELSE
	PRINTFORML %CALLNAME%似乎已经崩溃，宣誓效忠%CALLNAME:0%…
ENDIF
CALL PRINTL_WORD_COLOR,@"%CALLNAME%变得【屈服】了","浅蓝色"



;陥落メッセージ
@CAPITULATION_FALLING_MESSAGE

IF CSTR:日程 == "体内凌辱"
	PRINTFORML 经过%CALLNAME:0%的调教，%CALLNAME%已经完全沉醉于性爱的快感之中
	PRINTFORML 意识到「只要放弃尊严，就能得到最大的幸福」，逐渐顺从%CALLNAME:0%…
ELSE
	PRINTFORML %CALLNAME%似乎有了心境的变化，顺从了%CALLNAME:0%…
ENDIF
CALL PRINTL_WORD_COLOR,@"%CALLNAME%【陷落】了。","浅蓝色"



;恋慕化メッセージ前
@CAPITULATION_LOVE_MESSAGE_BEFORE

IF CFLAG:乳牛
	PRINTFORML %CALLNAME%露出发情的表情开始说话…
ELSE
	PRINTFORML %CALLNAME%正在踌躇不安地想要说些什么…
ENDIF
IF CSTR:状态／主人公的孩子 == "成长后"
	PRINTFORM %CALLNAME%
ELSE
	IF CSTR:状态／主人公的孩子 == "调教后"
		PRINT 开始调教时
	ELSE
		PRINT 来到牧场时
	ENDIF
	PRINTFORML 经过训练后变得如此顺从的%CALLNAME%，
	SIF MARK:母乳体质
		PRINT 搾乳
	PRINT 所谓的调教
ENDIF
PRINTFORML 似乎在交往中对%CALLNAME:0%产生了爱情…



;後
@CAPITULATION_LOVE_MESSAGE_AFTER

PRINTFORML %CALLNAME%向%CALLNAME:0%表白了「喜欢」…
SIF !CFLAG:乳牛
	PRINTFORML 然后%CALLNAME%害羞地笑了笑。
CALL PRINTL_WORD_COLOR,@"%CALLNAME%变成了【恋慕】。","桃"



;隷属化メッセージ前
@CAPITULATION_LOVE_SLAVE_MESSAGE_BEFORE

PRINTFORML %CALLNAME%一脸发情地向%CALLNAME:0%表达感谢…
PRINTFORML %CALLNAME%似乎无法压抑自己对%CALLNAME:0%的爱情…



;後
@CAPITULATION_LOVE_SLAVE_MESSAGE_AFTER

PRINTFORML %CALLNAME%发誓要把自己的『一切』奉献给%CALLNAME:0%…
CALL PRINTL_WORD_COLOR,@"%CALLNAME%变成【隶属】了。","桃"



;乳牛堕ちメッセージ
@CAPITULATION_CATTLE_MESSAGE

ALIGNMENT CENTER
SETCOLOR 0xFF70FF
IF CSTR:日程 == "体内凌辱"
	PRINTFORML %CALLNAME:0%在体内空间的无休止的触手搾乳快感刺激，已经足够让%CALLNAME%放弃尊严了。
ELSE
	PRINTFORML 在多次被当做乳牛对待，从%PRINT_BUST()%开始持续被榨%SAVESTR:标识／母乳%，%CALLNAME%越过了最后的底线。
ENDIF
PRINTFORML 与其勉强维护人类的尊严，不如作为乳牛被%CALLNAME:0%榨%SAVESTR:标识／母乳%，一遍又一遍地用%SAVESTR:标识／乳房%绝顶，
PRINTFORML 才发现过上乳牛的生活…被榨取%SAVESTR:标识／母乳%的感觉，那才是真正的幸福。
PRINTFORM %CALLNAME%成了搾乳快感的俘虏，彻底抛弃了人类的尊严…
CALL HEARTCB(0xD02830)
PRINTL
CALL HEARTCB(0xD02830)
PRINTFORM %CALLNAME%接受作为【乳牛】生活
CALL HEARTCB(0xD02830)
RESETCOLOR
PRINTL
ALIGNMENT LEFT



;乳責め嫌悪解消メッセージ
@CAPITULATION_CATTLE_LOVE_BUST_MESSAGE

SETCOLOR 0xFF70FF
PRINTFORM %CALLNAME%被%CALLNAME:0%充分地进行搾乳调教，爱上了自己能得到%CALLNAME:0%的爱与%PRINT_BUST()%…
CALL HEARTCB(0xD02830)
PRINTL
CALL HEARTCB(0xD02830)
PRINTFORM %CALLNAME%【乳房刺激厌恶感】消除
CALL HEARTCB(0xD02830)
RESETCOLOR
PRINTL



