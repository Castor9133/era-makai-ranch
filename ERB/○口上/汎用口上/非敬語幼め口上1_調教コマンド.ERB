; ARGS:0 场景；ARGS:1～ 用于更细分
@KOJO_GENERAL_非敬語幼め1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

; 进入本函数时 ARGS:0 固定为「调教命令」
; 按命令与情境分支；名称见 TRAIN.csv
; 当前流程：@COM 地之文 → 口上

SELECTCASE ARGS:1
CASE "揉胸","育乳按摩","浓厚母乳按摩","乳罐按摩"
	; 从此处起按变体分支；分支越多越有趣也越费工。
	; 分支方式自定，常按好感/陷落等状态分较省事。
	
	; 先看是否「首次」：EXP:(SELECTCOM +1000)++ 放在口上显示**之后**执行
	; 故该值为 0 表示该角色尚未经历过本命令
	; 细节略，用下方 IF 做首次即可
	; 隶属乳牛从未揉胸只挤奶…倒也可能
	; 写 \n 会换行；源码里用 Enter 换行不符合规范
	; 连续两次 CALL 只会显示其一，故不能靠双 CALL 凑换行
	
	; 首次
	IF !EXP:(SELECTCOM+1000)
		; 不直接显示，先 CALL MESSAGE_BOX 把候选台词放进「箱子」
		; 参考了触手宫氏口上
		; [MASTER_CALL]：对主人的称呼（如「主人」）
		; [SWEET_MASTER_CALL]：撒娇式称呼（如「主银～」）
		; ↑ 用后常接 ♥；插在句中易显违和
		; [SELF_CALL]：第一人称（如「我」）
		; ♥ 显示时会变成心形符号
		
		;乳牛、隶属、洗脑时
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「%SWEET_MASTER_CALL()%♥♥ 在摸%SELF_CALL()%的胸部呢♥♥♥\n　捏也好、揉也罢、都是%MASTER_CALL()%的自由哦♥ %SELF_CALL()%的胸部、是%MASTER_CALL()%的东西啦♥♥♥」"
		
		; 用 ELSE 则不会进入随机候选池
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%的胸部、随意玩弄也可以哦…♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「嗯…摸胸部这种事…很有趣吗…？♥」"
		; 也可按素质等再分支
		ELSEIF TALENT:害羞 && TFLAG:Ｎ露出
			CALL MESSAGE_BOX,@"「呀啊！不、不行！不可以揉胸部！」"
		ELSE
			CALL MESSAGE_BOX,@"「不要、胸部…不可以碰…」"
		ENDIF
		; 首次分支为确保只显示上述内容，此处 RETURN
		RETURN
		
	ENDIF
	
	; 第二次及以后
	;乳牛、隶属、洗脑时
	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「啊♥ %SWEET_MASTER_CALL()%♥♥ 请随意玩弄%SELF_CALL()%的胸部吧♥♥♥」"
		CALL MESSAGE_BOX,@"「请随意玩弄…吧…♥ %SELF_CALL()%的胸部、%MASTER_CALL()%的东西…♥♥♥」"
		CALL MESSAGE_BOX,@"「呼呼♥ 揉胸、好舒服啊…♥♥♥」"
		
		; 即使连续写多条，一次口上调用也只会随机显示其中一条
		; MESSAGE_BOX：向箱中投放 → 从箱中抽一条显示
		; 可按条件追加候选，例如胸围达丰乳以上时追加
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%的大胸部，是为了%MASTER_CALL()%而长大的♥♥」"
			
		; 还可追加其它条件分支
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「%MASTER_CALL()%…♥ %SELF_CALL()%的胸部明明很小、但还是爱着%SELF_CALL()%啊…♥♥」"
			
		; 本次调教 B 绝顶累计 100 次以上
		; 注：NOWEX 写在「调教命令」段多为死分支，此处用 EX 累计更合适
		; 适合写「再被○○就不行了」类临场感台词
		SIF EX:Ｂ绝顶 >= 100
			CALL MESSAGE_BOX,@"「啊——♥♥♥ 不可噫♥♥♥ 现在摸胸，%SELF_CALL()%♥♥♥」"
		
		; 调教中可查污渍：GETBIT(STAIN:乳房,4) 判定胸部是否附着润滑液
		; 详见 Stain.csv
		SIF GETBIT(STAIN:乳房,4)
			CALL MESSAGE_BOX,@"「哎呀♥ 润滑液弄得%SELF_CALL()%的胸部滑溜溜的，啊啊♥♥♥ 好下流的声音啊♥♥♥」"
	
	ELSEIF ＃陷落状态／恋慕以上＃
		; 恋慕线可比上面略矜持
		CALL MESSAGE_BOX,@"「%MASTER_CALL()%…♥ %SELF_CALL()%的胸部、喜欢吗…？♥」"
		CALL MESSAGE_BOX,@"「请尽情…♥ 想揉多久都没问题哦…♥♥」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%的大胸部，是为了%MASTER_CALL()%而长大的♥♥」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「%MASTER_CALL()%…♥ %SELF_CALL()%的胸部明明很小、但还是爱着%SELF_CALL()%啊…♥♥」"
		
	ELSEIF ＃陷落状态／陷落以上＃
		; 宜先写苛刻条件，否则易总命中上方分支
		CALL MESSAGE_BOX,@"「嗯…光是胸部吗…♥」"
		CALL MESSAGE_BOX,@"「真是的…随你喜欢好了…」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「嗯…真是的…男人真是只想着胸部啊… …嘛、如果是%MASTER_CALL()%的话倒还不错…」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「%SELF_CALL()%的胸被摸… …很开心吗？…这、这样啊…」"
	
	ELSEIF ＃陷落状态／屈服以上＃
		; 比下段更「认命」
		CALL MESSAGE_BOX,@"「嗯…光是胸部吗…♥」"
		CALL MESSAGE_BOX,@"「真是的…随你喜欢吧…」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「嗯…真是的…男人真是只想着胸部啊…」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「%SELF_CALL()%的胸被摸… …开心吗…？…嘿嘿…」"
	
	ELSE
		; 无反抗刻印/枷锁但性格反抗 → 傲娇口吻
		; 也可按素质等再分支
		IF TALENT:害羞 && TFLAG:Ｎ露出
			CALL MESSAGE_BOX,@"「不、不要！不要摸胸部…」"
			CALL MESSAGE_BOX,@"「噫！住、住手！」"
			CALL MESSAGE_BOX,@"「呀！讨厌、胸部被男人舔到了…！」"
		ELSE
			CALL MESSAGE_BOX,@"「不要、不要碰%SELF_CALL()%！」"
			; 曾写错：!NOWEX:总绝顶 易恒真；应看本次调教累计绝顶次数
			SIF EX:总绝顶 < 5
				CALL MESSAGE_BOX,@"「嗯…才没有感觉！」"
			SIF TFLAG:眼罩
				CALL MESSAGE_BOX,@"「嗯…把眼睛遮住要做的事情、是这个啊…」"
			SIF TFLAG:拘束BIT
				CALL MESSAGE_BOX,@"「嗯…把人绑起来想做的事情、是这个啊…」"
		ENDIF
	ENDIF
	; 揉胸分支到此…不短吧？
	
; 以下继续其它调教命令
