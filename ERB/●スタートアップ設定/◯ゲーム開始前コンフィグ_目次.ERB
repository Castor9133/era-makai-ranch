
;ゲーム開始前コンフィグ・牧場状態変更
@NEWGAME_RANCH_SETTING

CLEARLINE LINECOUNT
PRINTL 可以在游戏开始前进行设置。
DRAWLINE
PRINT [ 0] 阈值定数确认
CALL PRINTL_WORD_COLOR,@"　＜建议先确认＞","黄"
PRINTL
PRINTL [ 1] 确认魔界居民台词显示颜色

;引き継ぎ有効なら出す→霊力記録されているかで確認
IF GLOBAL:继承前周次数
	PRINTL [ 2] NEWGAME+设定
ELSE
	CALL PRINTL_WORD_COLOR,@"　NEWGAME+无效","灰"
ENDIF
PRINTL
PRINTL [10] 配置
PRINTL 　・页面1～3→可以随时自由更改
PRINTL 　・页面4～5→游戏开始后更改需要特殊道具（页面5的部分内容随时可以更改）
PRINTL 　・页面6 　→游戏开始后仅在＜开发者模式＞下可以更改
CALL PRINT_DIFFICULTY
PRINTL
PRINTLC [11] 牧场名更改
PRINTFORML ：%SAVESTR:牧场名%
PRINTLC [12] 宠物兼交通工具更改
PRINT ：

;ペット関係のフラグ番号一斉取得
CALL GET_PET_FLAG_REF
FOR LOCAL,0,10
	ANIMAL = %ITEMNAME:(ITEM_REF +LOCAL)%
	SIF ANIMAL == "" || !ITEM:ANIMAL
		CONTINUE
	PRINTFORM %ANIMAL%／%PET_NAME_REF(ANIMAL)%　
	CALL PRINT_PET_GENDER(FLAG:(FLAG_REF +LOCAL),1)
NEXT
PRINTL
PRINTFORML [13] 「%CALLNAME:0%」自定义
PRINTFORML [14] 住在牧场的孩子　　：「%CALLNAME:1%」自定义
PRINTFORML [15] 由尤金带来的奴隶：「%CALLNAME:2%」自定义
PRINTL ・可以切换【巫女】【修女】

CALL PRINTL_ALIGN
DRAWLINE
CALL PRINTL_WORD_COLOR,@"[99] 开始游戏","黄"
BINPUT
SELECTCASE RESULT
CASE 0
	CALL NEWGAME_CONFIRM_THRESHOLD
CASE 1
	CALL NEWGAME_CONFIRM_MAKAI_MESSAGE
CASE 2
	CALL NEWGAMEPLUS_CONFIG

CASE 10
	;この時点でDAYが0なのでコンフィグいろいろ弄れる
	CALL GAME_CONFIG
CASE 11
	CALL NEWGAME_RANCH_NAME_BEFORE
CASE 12
	CALL NEWGAME_FIRST_PET
CASE 13
	TARGET = 0
	CALL NEWGAME_PLAYER_DATA
CASE 14
	TARGET = 1
	CALL CHARA_MAKE_FIXED_SLAVE("最初的奴隶")
CASE 15
	TARGET = 2
	CALL CHARA_MAKE_FIXED_SLAVE("处女结界")
CASE 99
	RETURN
ENDSELECT
RESTART




