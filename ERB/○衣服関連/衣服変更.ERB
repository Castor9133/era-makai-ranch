
;衣服変更
@VISIT_CHANGE_CHARA_CLOTHE
#DIM DYNAMIC PAGE

PAGE_MAX = 11
CLEARLINE LINECOUNT
CALL PRINT_PORTRAIT(1)
PRINTFORML %CALLNAME%衣服的更变。
IF TARGET
	PRINT 分类：【可以赠送】
ELSE
	PRINT 分类：【可装备】
ENDIF
CALL PRINT_WORD_COLOR("【装备中】","桃")
CALL PRINT_WORD_COLOR("【角色拥有】","淡蓝色")
CALL PRINT_WORD_COLOR("【不可更改】","灰")
PRINTL
CALL SHOW_EQUIP
CALL HALFLINE
EXIST = 0
BR = 0
CALL CLOTHE_LIST_COMMON(PAGE,"更衣")
PRINTL
DRAWLINE
CALL ITEM_DETAIL_CLOTHE(PAGE,"更衣")
CALL PRINTL_ALIGN
CALL PRINT_NOW_PAGE(PAGE,1,1)

;アイテムとして所持orキャラが所持で着せられる
CALL CHANGE_CLOTHE_CHECK
CALL NEW_CLOTHE_CHECK
PRINTLC [ 90] 脱衣
PRINTLC 　
PRINTL [ 99] 完成
BINPUT
PRINTL

;目次の時はページ変更
IF !PAGE && RESULT <= PAGE_MAX
	PAGE = RESULT
	RESTART
ENDIF
SELECTCASE RESULT
CASE 0
	CALL CHANGE_CHARA_CLOTHE_ENTER
CASE 1
	IF CSTR:SELECT_ITEM == "" && EQUIP:SELECT_ITEM
		CALL CHANGE_CHARA_CLOTHE_DETAIL_CHANGE
	ELSE
		CALL CHANGE_CHARA_NEW_CLOTHE
	ENDIF
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
	SELECT_ITEM = 0
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_ITEM = 0
CASE 89
	PAGE = 0
CASE 90
	CALL CHARA_CLOTHE_STRIP
CASE 99
	SELECT_ITEM = 0
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART

