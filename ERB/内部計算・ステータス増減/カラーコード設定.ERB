
;カラーコードの設定
;髪色
@AUTOSET_HAIR_COLOR_CODE

SELECTCASE CSTR:发色
CASE "黑色头发"
	CFLAG:颜色编码／发 = 0
CASE "金色头发"
	CFLAG:颜色编码／发 = 0xFFD700
CASE "栗色头发"
	CFLAG:颜色编码／发 = 0xD26930
CASE "红色头发"
	CFLAG:颜色编码／发 = 0xFF2020
CASE "桃色头发"
	CFLAG:颜色编码／发 = 0xF19CA7
CASE "青色头发"
	CFLAG:颜色编码／发 = 0x49BDF0
CASE "绿色头发"
	CFLAG:颜色编码／发 = 0x00FF00
CASE "银色头发"
	CFLAG:颜色编码／发 = 0xA9AAAA
CASE "紫色头发"
	CFLAG:颜色编码／发 = 0xFF82FF
CASE "白色头发"
	CFLAG:颜色编码／发 = 0xF8F8F8
CASE "橙色头发"
	CFLAG:颜色编码／发 = 0xF5A323
CASE "天蓝色头发"
	CFLAG:颜色编码／发 = 0x7FFFD4
ENDSELECT


;目の色
@AUTOSET_EYE_COLOR_CODE

;左右別のほうが手動時便利
CALL AUTOSET_EYE_COLOR_CODE_RIGHT
CALL AUTOSET_EYE_COLOR_CODE_LEFT



