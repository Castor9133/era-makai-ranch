
;配布奴隷のシャッフル項目一覧
;ARG→INPUT
@FIXED_SLAVE_CHANGE_INPUT(ARG)

SELECTCASE ARG
CASE 0
	CHANGE_STATE = 名称
CASE 1
	CHANGE_STATE = 乳房弹性
CASE 2
	CHANGE_STATE = 乳头颜色
CASE 3
	CHANGE_STATE = 颜色编码／乳头
CASE 4
	CHANGE_STATE = 发色
CASE 5
	CHANGE_STATE = 头发特征
CASE 6
	CHANGE_STATE = 发型
CASE 7
	CHANGE_STATE = 发型一键调整
CASE 8
	CHANGE_STATE = 颜色编码／发
CASE 9
	CHANGE_STATE = 阴毛
	
CASE 10
	CHANGE_STATE = 右瞳色
CASE 11
	CHANGE_STATE = 颜色编码／右目
CASE 12
	CHANGE_STATE = 左瞳色
CASE 13
	CHANGE_STATE = 颜色编码／左目

CASE 20
	CHANGE_STATE = 陷落后的主人公的称呼

CASE 30
	CHANGE_STATE = 台词
ENDSELECT

;SELF_CHARA_MAKE_RANDOMが有効かどうかで呼ぶ関数変更
IF SELF_CHARA_MAKE_RANDOM
	CALL FIXED_SLAVE_CHANGE_INPUT_SHUFFLE(CHANGE_STATE)
ELSE
	CALL FIXED_SLAVE_CHANGE_INPUT_MANUAL(CHANGE_STATE)
ENDIF


