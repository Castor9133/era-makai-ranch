; ======================================
; 泛用口上・调教命令（性格：女仆）
; ======================================

@KOJO_GENERAL_女仆口上1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:2
CASE "执行"
	SELECTCASE ARGS:1
	CASE "接吻"
		CALL MESSAGE_BOX,@"「遵命。接吻侍奉：唇舌与呼吸同步，请您放松下颌。」"
		CALL MESSAGE_BOX,@"「若需放慢或加深，请以指节轻叩我肩两下为信。」"
		CALL MESSAGE_BOX,@"「深吻时：我会注意不让牙齿相碰；嗯……请您舌尖再用些力，搅动也可以再深一点。」"
		CALL MESSAGE_BOX,@"「在您鼻息平稳前，我会跟随您的节奏；若感到牙齿碰到，请立刻用眼神示意我放慢。」"
	CASE "舔舐脸"
		CALL MESSAGE_BOX,@"「遵命。面部舔舐：力度以不牵拉皮肤为上限。」"
	CASE "舔舐耳","舔舐腋"
		CALL MESSAGE_BOX,@"「遵命。耳／腋舔舐：我会分段停顿，避免过度刺激。」"

	CASE "手淫","授乳手交"
		CALL MESSAGE_BOX,@"「遵命。将为您进行手部侍奉……♥」"
		CALL MESSAGE_BOX,@"「若您想更快些……请用眼神示意……我会立刻调整。」"

	CASE "口交","触手口交"
		CALL MESSAGE_BOX,@"「遵命。将以口部侍奉……请您放松。」"
		CALL MESSAGE_BOX,@"「若您皱眉……我会立刻放轻；若您眯眼……我会更深一些。」"

	CASE "舔阴蒂","舔阴道","刺激龟头","真空口交","肛门指揉按摩","玩弄阴唇","G点指压","阴道指奸","肛门指奸","尿道口指弄","尿道口指奸","口内搅舌","压舌探喉"
		CALL KOJO_SHARE_ADVANCED_TRAIN_DISPATCH, ARGS:1, ARGS:2

	CASE "正常位","后背位","对面坐位","背面坐位","骑乘位","对面立位","背面立位","强制骑乘位","背面骑乘位"
		CALL KOJO_CHS_VPOS_女仆口上1(ARGS:1, ARGS:2)

	CASE "足交"
		CALL MESSAGE_BOX,@"「遵命。将以足部侍奉……我会控制力度与节奏。」"
		CALL MESSAGE_BOX,@"「若您抬眉……我会更快；若您皱眉……我会更轻。」"

	CASE "肛塞"
		CALL MESSAGE_BOX,@"「遵命。将进行肛塞装着……请您放松后方。」"

	CASE "尿道塞"
		CALL MESSAGE_BOX,@"「遵命。将进行尿道塞装着……我会尽量减轻不适。」"

	CASE "深喉","触手深喉"
		CALL KOJO_SHARE_ADVANCED_TRAIN_DISPATCH, ARGS:1, ARGS:2

	CASEELSE
		CALL MESSAGE_BOX,@"「遵命。将执行%ARGS:1%。」"
	ENDSELECT

CASE "继续"
	SELECTCASE ARGS:1
	CASE "正常位","后背位","对面坐位","背面坐位","骑乘位","对面立位","背面立位","强制骑乘位","背面骑乘位"
		CALL KOJO_CHS_VPOS_女仆口上1(ARGS:1, ARGS:2)
	CASEELSE
		CALL MESSAGE_BOX,@"「继续服务中……我会按您最舒服的节奏引导。」"
	ENDSELECT

CASE "移除"
	SELECTCASE ARGS:1
	CASE "肛塞"
		CALL MESSAGE_BOX,@"「已解除肛塞。请先缓一缓呼吸。」"
	CASE "尿道塞"
		CALL MESSAGE_BOX,@"「已解除尿道塞。若仍有不适，请立刻告知。」"
	CASEELSE
		CALL MESSAGE_BOX,@"「已解除。若有不适，请立刻吩咐我。」"
	ENDSELECT

CASEELSE
ENDSELECT
RETURN

