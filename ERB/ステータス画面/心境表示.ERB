CASE "超乳状态"
	CALL PRINT_WORD_COLOR("即使成功逃脱，也要面对接下来的问题…","红")
	
CASE "绝望"
	CALL PRINT_WORD_COLOR("谁来帮帮我…","红")
	
CASE "不放弃"
	PRINT 即使处于这种状态也绝不放弃…
	
CASE "肉体陷落"
	PRINTFORM 即使身体被如此虐待，内心也不会屈服…
	
CASE "屈服状态"
	PRINTFORM %CSTR:主人公的称呼／陷落前%服从您…所以请至少像对待人一样对待我…
	
CASE "陷落状态"
	PRINT 这样在牧场生活或许也不错…
		
CASE "搾乳奴隶"
	CALL PRINT_WORD_COLOR("不屈服于搾乳快感…","桃")
	CALL HEARTCB(0xD02830)
		
CASE "搾乳家畜"
	CALL PRINT_WORD_COLOR,@"被榨取%SAVESTR:标识／母乳%，感觉很舒服…要坚强才不会屈服…","桃"
