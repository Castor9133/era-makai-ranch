; ======================================
; 泛用口上・调教命令（性格：闷骚的小姐姐）
; 书卷气、爱讲理、嘴硬心软，修辞偏书面，但落在人与人的边界、羞意与赌气上（少用术语玩梗）。
; ======================================

@KOJO_GENERAL_闷骚小姐姐口上1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:2
CASE "执行"
	SELECTCASE ARGS:1
	CASE "揉胸","育乳按摩","浓厚母乳按摩","乳罐按摩","胸爱抚","拧乳头"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……触感……太清楚了……♥ ……算你……找对地方了……♥」"
			CALL MESSAGE_BOX,@"「……继续……我、我把呼吸稳住就好……♥」"
			CALL MESSAGE_BOX,@"「……别问脸为什么烫……♥ ……问就是你掌心……太欺负人……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……胸口不是谁都能碰的。……要么松手，要么先说清楚你为什么碰。」"
		ENDIF
	CASE "接吻"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……接吻就专心接吻……♥ ……别一下一下……又像在想别的事……♥」"
			CALL MESSAGE_BOX,@"「……别笑……我在匀呼吸……♥」"
			CALL MESSAGE_BOX,@"「……牙齿……别磕到……♥ 嗯……舌头……再贴紧一点……♥」"
			CALL MESSAGE_BOX,@"「……磕到了……我要记仇……♥ ……不过……刚才那样搅……我、我没真的生气……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……驳回。……这种事要提前说一声——你刚才那一下算偷袭。」"
		ENDIF
	CASE "舔舐脸"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……舔脸……算什么正经……♥ ……分明是欺负我躲不开……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……脸也不行。……我准你凑这么近了吗。」"
		ENDIF
	CASE "舔舐耳","舔舐腋"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……耳朵……一碰我就酥……♥ ……腋下……你太坏了……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……不行。……这和接吻不是一回事，别想混过去。」"
		ENDIF
	CASE "口交","触手口交"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……含住了……♥ ……我会……好好……♥ ……别拿出去当笑料讲……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……嘴也不是随便开的门。……要进来，先说你把我当什么。」"
		ENDIF
	CASE "舔阴蒂","舔阴道","刺激龟头","真空口交","肛门指揉按摩","玩弄阴唇","G点指压","阴道指奸","肛门指奸","尿道口指弄","尿道口指奸","口内搅舌","压舌探喉"
		CALL KOJO_SHARE_ADVANCED_TRAIN_DISPATCH, ARGS:1, ARGS:2
	CASE "正常位","后背位","对面坐位","背面坐位","骑乘位","对面立位","背面立位","强制骑乘位","背面骑乘位"
		CALL KOJO_CHS_VPOS_闷骚小姐姐1(ARGS:1, ARGS:2)
	CASE "深喉","触手深喉"
		CALL KOJO_SHARE_ADVANCED_TRAIN_DISPATCH, ARGS:1, ARGS:2
	CASE "肛勾"
		CALL MESSAGE_BOX,@"「……后面……被牵着……光想你手劲我就脸红……♥ ……链子轻点……别猛地一扽……♥」"
	CASE "贞操带"
		CALL MESSAGE_BOX,@"「……这一锁……什么都试不了……行，我认，你是成心把我关在这儿。」"
	CASE "尾塞"
		CALL MESSAGE_BOX,@"「……尾巴这儿……羞都写在脸上……♥ ……别那么盯着看……♥」"
	CASE "舌锻口塞"
		CALL MESSAGE_BOX,@"「……唔嗯……！……呜呜……」（话全堵在口塞后面，只剩鼻腔里的抗议和压不住的涎水声）"
	CASEELSE
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……行……我陪你……♥ ……但我保留损你两句的权利……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……不行。……先停一下——你得把我当一个人问一句，别装作我已经默许了。」"
		ENDIF
	ENDSELECT
CASE "继续"
	SELECTCASE ARGS:1
	CASE "肛勾","尾塞"
		CALL MESSAGE_BOX,@"「……后面……还在被折腾……♥ ……别突然用力……我受不住……♥」"
	CASE "贞操带"
		CALL MESSAGE_BOX,@"「……胯间……锁得死死的……♥ ……让我……喘口气……求你了……就十秒……♥」"
	CASE "舌锻口塞"
		CALL MESSAGE_BOX,@"「……嗯……哈……唔咕……」（轻轻的也照样难堪——说不出话，发抖和呜咽全替嘴交代了）"
	CASE "正常位","后背位","对面坐位","背面坐位","骑乘位","对面立位","背面立位","强制骑乘位","背面骑乘位"
		CALL KOJO_CHS_VPOS_闷骚小姐姐1(ARGS:1, ARGS:2)
	CASEELSE
		CALL MESSAGE_BOX,@"「……还来……♥ ……第二回了……♥」"
		CALL MESSAGE_BOX,@"「……一遍一遍……♥ ……%MASTER_CALL()%……明知道我会嘴硬……还故意……♥」"
	ENDSELECT
CASE "移除"
	SELECTCASE ARGS:1
	CASE "舌锻口塞"
		CALL MESSAGE_BOX,@"「……哈啊……咳咳……」（口塞一拿开，先呛出半声，喘了两下才找回调门）"
		CALL MESSAGE_BOX,@"「……刚才……没说完的……不算吵架啊……这事只准烂在我们俩中间，别往外说。」"
	CASE "肛勾","贞操带","尾塞"
		CALL MESSAGE_BOX,@"「……卸掉了……刚才那段丢人的……我自个记着，你别拿去当人前谈资。」"
	CASEELSE
		CALL MESSAGE_BOX,@"「……先停。……我去缓一缓。」"
		CALL MESSAGE_BOX,@"「……收拾干净……心事……我也带走一半……♥」"
	ENDSELECT
CASEELSE
ENDSELECT
RETURN
