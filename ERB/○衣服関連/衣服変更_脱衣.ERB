
;脱衣処理
@CHARA_CLOTHE_STRIP

CALL CHANGE_CLOTHE_RESIST_CHECK
PRINTL 的部位衣物脱下？
PRINTFORM [ 1] 衣服　　　
CALL PART_EQUIP_ITEM("衣服")
PRINTFORM [ 3] 内衣（上）
CALL PART_EQUIP_ITEM("内衣上装")

;上下セットなら飛ばす
IF EQUIP:装备中ID／内衣上装 == EQUIP:装备中ID／内衣下装 && EQUIP:装备中ID／内衣上装
	CALL PRINT_WORD_COLOR("内衣上下套装","灰")
ELSE
	PRINTFORM [ 4] 内衣（下）
	CALL PART_EQUIP_ITEM("内衣下装")
ENDIF
PRINTL
PRINTFORM [10] 　眼
CALL PART_EQUIP_ITEM("眼")
PRINTFORM [11] 　头
CALL PART_EQUIP_ITEM("头")
PRINTFORM [12] 　腕
CALL PART_EQUIP_ITEM("腕")
PRINTFORM [13] 　腿
CALL PART_EQUIP_ITEM("腿")
PRINTFORM [14] 　颈
CALL PART_EQUIP_ITEM("颈")
PRINTFORM [15] 外衣
CALL PART_EQUIP_ITEM("外衣")
PRINTL
PRINTLC [90] 全脱衣
PRINTLC [91] 衣服・内衣全脱衣
PRINTL [92] 饰品全部摘除
PRINTL [99] 取消
BINPUT
PRINTL
SELECTCASE RESULT
CASE 1
	CALL CLOTHE_STRIP_LINGERIE_OVERWRITE

CASE 3
	SIF EQUIP:装备中ID／内衣上装 == EQUIP:装备中ID／内衣下装
		EQUIP:装备中ID／内衣下装 = 0
	EQUIP:装备中ID／内衣上装 = 0

CASE 4
	SIF EQUIP:装备中ID／内衣上装 == EQUIP:装备中ID／内衣下装
		EQUIP:装备中ID／内衣上装 = 0
	EQUIP:装备中ID／内衣下装 = 0

CASE 10 TO 19
	EQUIP:RESULT = 0
CASE 90
	VARSET EQUIP,0,0,20
CASE 91
	VARSET EQUIP,0,0,10
CASE 92
	VARSET EQUIP,0,10,20
ENDSELECT
CALL CHANGE_CLOTHE_RESIST(2)



;装備している衣服
;ARGS→表示箇所
@PART_EQUIP_ITEM(ARGS)
#DIMS CLOTHE

PRINT  当前：
CLOTHE = 装备中ID／%ARGS%
IF !EQUIP:CLOTHE
	CALL PRINTL_WORD_COLOR("无","灰")
ELSE
	PRINTFORML %ITEMNAME:(EQUIP:CLOTHE)%
ENDIF

