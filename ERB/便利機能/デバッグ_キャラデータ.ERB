
;キャラデータ変更対象選択
@DEBUG_CHARA_NAME_EDIT_SELECT
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML 选择要重命名的角色。
FOR TARGET_COUNT,0,20
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("牛舍")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTL [ 99] 完成
BINPUT
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	TARGET = RESULT -100
	CALL DEBUG_CHARA_NAME_EDIT
ENDSELECT
RESTART



;名前とかを変更する
@DEBUG_CHARA_NAME_EDIT
#DIM DYNAMIC PAGE

PAGE_MAX = 3
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML 将%CALLNAME%的数据进行更改
PRINTL （考虑到版本更新可能增加新元素。可能会有一些错误，请注意）
PRINTL ※在此屏幕上更改种族等信息不会反映在素质等方面。
PRINTL ※由于追加扩展的影响，顺序可能会有所不同，请谅解。
CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT
CALL PRINT_ALL_STATE
PRINTFORM %CALLNAME%
CALL PRINT_AFFILIATION_DATA
PRINTL
TRYCALLFORM DEBUG_CHARA_NAME_EDIT_PAGE_{PAGE}
CALL PRINTL_ALIGN
DRAWLINE
CALL PRINT_NOW_PAGE(PAGE)
PRINTLC [300] 上一个角色
PRINTLC 　
PRINTL [301] 下一个角色
PRINTL [ 99] 完成
BINPUT
SELECTCASE RESULT
CASE 0 TO 79,100 TO 199
	CALL DEBUG_CHARA_NAME_EDIT_INPUT(RESULT)
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 300
	CALL CHANGE_TARGET_CHARA(0,"角色配置")
CASE 301
	CALL CHANGE_TARGET_CHARA(1,"角色配置")
CASE 99
	RETURN
ENDSELECT
RESTART



@DEBUG_CHARA_NAME_EDIT_PAGE_1

CALL PRINT_IMAGE_TEST
PRINTL
PRINTFORML [  0] 显示名　　　　　：%CALLNAME%
PRINTFORML [  1] 全名　　　：%NAME%
PRINTFORML [  2] 识别名　　　　　：%CSTR:识别名%
PRINTFORML [  3] 原作名　　　：%CSTR:原作名%
PRINTL 　　如果已经注册了对应辨识名和原作品名的图像，将显示图像。
PRINTL

;番号整理したのでFORでできると思う
FOR LOCAL,0,20
	STR_NAME = %CSTRNAME:LOCAL%
	SIF STR_NAME == ""
		CONTINUE
	PRINTFORML [{LOCAL +100,2}] %STR_NAME,16%：%CSTR:LOCAL%
NEXT



