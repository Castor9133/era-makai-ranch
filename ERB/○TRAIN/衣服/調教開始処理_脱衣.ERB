
;脱衣フラグ参照
@BEFORE_TRAIN_AUTO_STRIP_CHECK
#DIM STRIP

;全裸なら無視
SIF !SUMARRAY(EQUIP,0,20)
	RETURN -1
STRIP = CFLAG:个人设置／调教开始自动处理／脱衣

;0だと全体コンフィグ準拠→無抵抗・抵抗時でそれぞれ参照フラグが違う
IF !STRIP
	IF CFLAG:无抵抗
		STRIP = FLAG:默认脱衣状态／无抵抗
	ELSE
		STRIP = FLAG:默认脱衣状态／抵抗
	ENDIF
ENDIF

;他はキャラ個別設定を見る→そのまま
RETURN STRIP



;脱衣選択
@BEFORE_TRAIN_STRIP_SELECT
#DIM DYNAMIC SET
#DIM STRIP

CALL MANYL(3)
DEFAULT_SET = SET
PRINTFORML 要把%CALLNAME%的衣服脱掉吗？
CALL SHOW_EQUIP

;STR:デフォルト脱衣状態→8130
STR_REF = 8130
FOR LOCAL,0,7
	PRINTFORM [{LOCAL,2}] %STR:(STR_REF +LOCAL)%
	PRINTL
	IF LOCAL == 3 && !CFLAG:无抵抗
		CALL PRINTL_WORD_COLOR("　【抵抗】不会让你脱衣服","灰")
		BREAK
	ENDIF
NEXT
PRINTL
PRINT [ 9] 设置此角色的默认值
CALL PRINT_CHECKBOX(SET,1)
BINPUT
SELECTCASE RESULT
CASE 0 TO 7
	;デフォルトセット
	SIF DEFAULT_SET
		CFLAG:个人设置／调教开始自动处理／脱衣 = RESULT
	RETURN RESULT
CASE 9
	INVERTBIT SET,0
ENDSELECT
CLEARLINE 10
RESTART



;脱衣実行
;ARG→STRIP
@BEFORE_TRAIN_STRIP_RUN(ARG)

;0はスルー
SELECTCASE ARG
CASE 1
	CALL TRAIN_CLOTHE_STRIP("总计","全半脱衣")
CASE 2
	CALL TRAIN_CLOTHE_STRIP("总计","上半脱衣")
CASE 3
	;無抵抗じゃないと無効→BINPUTで飛ばす
	CALL TRAIN_CLOTHE_STRIP("总计","全脱衣")
CASE 4
	CALL TRAIN_CLOTHE_STRIP("总计","全脱衣")
	CALL TRAIN_CLOTHE_STRIP("饰品","批量删除")
CASE 5
	CALL TRAIN_CLOTHE_STRIP("衣服","脱衣")
	CALL TRAIN_CLOTHE_STRIP("饰品","批量删除")
CASE 6
	CALL TRAIN_CLOTHE_STRIP("衣服","脱衣")
	CALL TRAIN_CLOTHE_STRIP("内衣","一件半脱")
	CALL TRAIN_CLOTHE_STRIP("饰品","批量删除")
ENDSELECT



