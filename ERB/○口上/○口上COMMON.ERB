
; ======================================
; 口上统一入口
; ARGS:0 场景；ARGS:1/2 用于更细分
@KOJO_PRINT(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

; 文中 ♥ 与随机显示参考自触手宫，致谢
; 按 CFLAG 分流实际使用的口上
; 大意：以后多出口上时，尽量只动各口上文件、少改本共通

; 先清空 MESSAGE 箱
VARSET MESSAGE_BOX
VARSET MESSAGE_COUNT

; 口上总开关或本角色口上关闭则直接返回
SIF !FLAG:口上显示 || !CFLAG:口上显示
	RETURN

; 播口上时从行首开始
SIF !LINEISEMPTY()
	PRINTL

; 载入对应口上
; 用字符串判断好写，但数据量偏大；若成问题再改数值索引
; 目前文件数不至于失控，先保持字符串方式

; 使用「动作确认口上」时走全候选显示
IF CSTR:使用口上 == "操作确认口上"
	CALL KOJO_OPERATION_CHECK(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
	RETURN
ENDIF

; 若启用专用口上则先尝试专用
IF CFLAG:专用设置／口上
	TRYCALLFORM EX_KOJO_%CSTR:识别名%_%CSTR:原作名%(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
	
	; 专用侧若已写入 MESSAGE 则抽选+显示并结束
	; 这样可「只写想专有的几段，其余交给泛用」
	IF MESSAGE_COUNT
		CALL MESSAGE_PRINT
		RETURN
	ENDIF
ENDIF

; 未启用专用或未命中则调泛用口上
TRYCALLFORM KOJO_GENERAL_INDEX_%CSTR:使用口上%(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

; MESSAGE 箱非空则显示
SIF MESSAGE_COUNT
	CALL MESSAGE_PRINT



;======================================
; 口上追加：文中换行请用 \n
@MESSAGE_BOX(ARGS)

MESSAGE_BOX:(MESSAGE_COUNT ++) = %ARGS%

; ======================================
; 泛用口上：抽选与显示
@MESSAGE_PRINT
#DIM  LCOUNT,2		; 循环用
#DIM  FIND_ARRAY_COUNT,VARSIZE("MESSAGE_BOX")		; 各 stock 与历史重复次数
#DIM  CANDIDATE_COUNT		; 随机箱当前个数
#DIMS CANDIDATE_BOX,500	; 随机抽选用箱
#DIM  TEMP

; 初始化辅助数组
VARSET FIND_ARRAY_COUNT
VARSET CANDIDATE_COUNT
VARSET CANDIDATE_BOX
	
; 对照历史 MESSAGE_LOG，统计每条候选被用过几次
FOR LCOUNT:0,0,VARSIZE("MESSAGE_LOG")
	FOR LCOUNT:1,0,MESSAGE_COUNT
		SIF MESSAGE_BOX:(LCOUNT:1) == MESSAGE_LOG:(LCOUNT:0)
			FIND_ARRAY_COUNT:(LCOUNT:1)++
	NEXT
NEXT

; 按「重复越多权重越低」填充随机箱
; 箱内为经历史降权后的候选集合
TEMP = 0
WHILE (CANDIDATE_COUNT != VARSIZE("CANDIDATE_BOX"))
	; 以 1/(重复次数+1) 概率登记进 BOX
	; 即第 1 次后概率 1/2，第 2 次后 1/3，依此类推
	; 若 MESSAGE 只有一条则不再掷骰、直接登记
	;（避免无意义地反复抽满 VARSIZE 次）
	
	IF !(RAND:(FIND_ARRAY_COUNT:TEMP +1)) || MESSAGE_COUNT == 1
		CANDIDATE_BOX:CANDIDATE_COUNT = %MESSAGE_BOX:TEMP%
		CANDIDATE_COUNT ++
	ENDIF
	
	; 轮询下一条候选，到头则回到 0
	TEMP++
	SIF TEMP == MESSAGE_COUNT
		TEMP = 0
WEND

; 从随机箱中抽一条并显示
TEMP = RAND:VARSIZE("CANDIDATE_BOX")
CALL MESSAGE_PRINT_ESCAPE(CANDIDATE_BOX:TEMP)
RESETCOLOR
PRINTL

; 写入历史（队首为最新）
ARRAYSHIFT MESSAGE_LOG,1,""
MESSAGE_LOG:0 = %CANDIDATE_BOX:TEMP%

; 不在这里 VARSET MESSAGE_COUNT，便于地文等用「MESSAGE_COUNT≥1」判断刚播过口上



;======================================
; 泛用口上：转义与绘制
@MESSAGE_PRINT_ESCAPE(MESSAGE_VALUE,FONT_COLOR = 0)
#DIM  DYNAMIC SPLIT_COUNT
#DIM  DYNAMIC LCOUNT
#DIM  DYNAMIC FONT_COLOR
#DIMS DYNAMIC MESSAGE_VALUE
#DIMS DYNAMIC MESSAGE_ARRAY,100

VARSET MESSAGE_ARRAY

; 消息内 \d … \d：其间（或单独 \d 之后）用系统默认色
SPLIT MESSAGE_VALUE,"\d",MESSAGE_ARRAY
SPLIT_COUNT = RESULT
IF SPLIT_COUNT != 1
	FOR LCOUNT,0,SPLIT_COUNT
		; 奇数段为 \d 夹心 → 系统色递归
		IF LCOUNT %2 == 1
			CALL MESSAGE_PRINT_ESCAPE(MESSAGE_ARRAY:(LCOUNT),1)
		ELSE
			CALL MESSAGE_PRINT_ESCAPE(MESSAGE_ARRAY:(LCOUNT),0)
		ENDIF
	NEXT
	RETURN
ENDIF

; 消息内 \n
SPLIT MESSAGE_VALUE,"\n",MESSAGE_ARRAY
SPLIT_COUNT = RESULT
IF SPLIT_COUNT != 1
	FOR LCOUNT,0,SPLIT_COUNT
		CALL MESSAGE_PRINT_ESCAPE(MESSAGE_ARRAY:(LCOUNT),FONT_COLOR)
		SIF LCOUNT != (SPLIT_COUNT -1)
			PRINTL
	NEXT
	RETURN
ENDIF

; 消息内 ♥
SPLIT MESSAGE_VALUE,"♥",MESSAGE_ARRAY
SPLIT_COUNT = RESULT
IF SPLIT_COUNT != 1
	FOR LCOUNT,0,SPLIT_COUNT
		CALL MESSAGE_PRINT_ESCAPE(MESSAGE_ARRAY:(LCOUNT),FONT_COLOR)
		SIF LCOUNT != (SPLIT_COUNT -1)
			CALL HEARTCB(0xD02830)
	NEXT
	RETURN
ENDIF

; 字体色：FONT_COLOR=1 时强制 RESET；口上色为 0 也会 RESET
IF CFLAG:颜色编码／口上 && !FONT_COLOR
	SETCOLOR CFLAG:颜色编码／口上
ELSE
	RESETCOLOR
ENDIF

; 其余为纯文本
PRINTFORM %MESSAGE_VALUE%

RESETCOLOR

