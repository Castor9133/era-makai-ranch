
;仙人
@TRIBE_FEATURE_CONFIG_HERMIT

CLEARLINE LINECOUNT
PRINTL 请选择【仙人】的种族设定。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL 固定：始终拥有魔力
PRINTLC [ 0] 把身高向【高挑】靠拢
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／仙人,0),1)
PRINTLC [ 1] 肤色变为【色白】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／仙人,1),1)
PRINTLC [ 2] 把体型向【苗条】靠拢
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／仙人,2),1)
PRINTLC [ 3] 素质【回复快】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／仙人,3),1)
PRINTLC [ 4] 素质【受动物喜欢】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／仙人,4),1)
PRINTLC [ 5] 素质【魔界适应】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／仙人,5),1)
PRINTL
PRINTLC [10] 素质【少食】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／仙人,10),1)
PRINTLC [11] 素质【坚强】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／仙人,11),1)
PRINTLC [12] 素质【自制力】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／仙人,12),1)
PRINTLC [13] 素质【正义感】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／仙人,13),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(13)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL 当身高抽选到【标准】【矮小】【娇小】时，将转换为【高挑】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／仙人"),INPUT_NUM)
CASE 1
	PRINTL 肤色选择种抽到【标准】、【褐色】、【小麦色】时将变为【色白】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／仙人"),INPUT_NUM)
CASE 2
	PRINTL 体型从【苗条】和【瘦弱】中抽选。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／仙人"),INPUT_NUM)
CASE 3
	PRINTL 被赋予素质【回复快】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／仙人"),INPUT_NUM)
CASE 4
	PRINTL 被赋予素质【受动物喜欢】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／仙人"),INPUT_NUM)
CASE 5
	PRINTL 被赋予素质【魔界适应】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／仙人"),INPUT_NUM)
CASE 10
	PRINTL 被赋予素质【少食】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／仙人"),INPUT_NUM)
CASE 11
	PRINTL 被赋予素质【坚强】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／仙人"),INPUT_NUM)
CASE 12
	PRINTL 被赋予素质【自制力】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／仙人"),INPUT_NUM)
CASE 13
	PRINTL 被赋予素质【正义感】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／仙人"),INPUT_NUM)
CASE 98
	PRINTL 将【仙人】的种族设定回复为默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_HERMIT
CASE 99
	RETURN
ENDSELECT
RESTART


