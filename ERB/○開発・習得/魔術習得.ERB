
;魔術習得
;ネクロノミコン未所持はそもそもここに来ない
@MAGIC_GET
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_UPGRADE("魔法AP")
PRINTL 使用【魔法AP】学习魔法。
PRINTL
BR = 0
TRYCALLFORM MAGIC_GET_LIST_{PAGE}
PRINTL
DRAWLINE
CALL ITEM_DETAIL_MAGIC(SELECT_ITEM)
CALL PRINTL_ALIGN
CALL ABILITY_GET_JUDGE(SELECT_ITEM,"普通魔法")
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTLC [ 90] 批量学习
PRINTLC 　
PRINTL [ 99] 完成
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	;購入処理
	CALL ABILITY_GET_COST_CALC(SELECT_ITEM)
	ITEM:SELECT_ITEM ++
	MONEY:魔法AP -= COST
	IF ITEM:SELECT_ITEM == 1
		CALL PRINTW_WORD_COLOR,@"学习了【%ITEMNAME:SELECT_ITEM%】。","浅蓝色"
	ELSE
		CALL PRINTW_WORD_COLOR,@"【%ITEMNAME:SELECT_ITEM%】LvUP！ → {ITEM:SELECT_ITEM}","浅蓝色"
	ENDIF
	
	;一部習得時はマイルストーン直接呼び出し
	SELECTCASE ITEMNAME:SELECT_ITEM
	CASE "搾乳能量吸收"
		CALL MILESTONE_CHECK(GETNUM(FLAG,"魔术＜搾乳能量吸收＞获得"))
	CASE "传送"
		CALL MILESTONE_CHECK(GETNUM(FLAG,"魔法＜传送＞习得"))
	ENDSELECT
	
CASE 1
	;連続LvUP
	CALL MAGIC_GET_CONTINUE
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
	SELECT_ITEM = 0
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_ITEM = 0
CASE 90
	CALL MAGIC_GET_BULK
CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART



;連続習得
@MAGIC_GET_CONTINUE

;最大5まで一括増加
FOR LOCAL,0,5
	CALL ABILITY_GET_COST_CALC(SELECT_ITEM)
	SIF COST > MONEY:魔法AP
		BREAK
	ITEM:SELECT_ITEM ++
	MONEY:魔法AP -= COST
	CALL PRINTL_WORD_COLOR,@"【%ITEMNAME:SELECT_ITEM%】LvUP！ → Lv{ITEM:SELECT_ITEM}","浅蓝色"
NEXT
PRINTW



;一括習得
@MAGIC_GET_BULK

PRINTL 使用当前的技能点一括学习列表前的可学习页面内魔法。
PRINTL ・如果AP不足，将不会进行后续的魔法学习。
PRINTL ・有等级提升的魔法只学习Lv1。
PRINTL 执行批量学习？
CALL ASK_YN
SIF RESULT
	RETURN

;記録
AP_BEFORE = MONEY:魔法AP
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	;習得前提魔術も見る
	SIF !ITEMPRICE:LOCAL || ITEM:LOCAL || (MAGIC_GET_PREMISE:LOCAL && !ITEM:(MAGIC_GET_PREMISE:LOCAL))
		CONTINUE
	
	;習得不可魔力で終了
	SIF ITEMPRICE:LOCAL > MONEY:魔法AP
		BREAK
	ITEM:LOCAL ++
	MONEY:魔法AP -= ITEMPRICE:LOCAL
	CALL PRINTL_WORD_COLOR,@"学习了【%ITEMNAME:LOCAL%】。","浅蓝色"
NEXT
PRINTFORML 消费AP：%TOSTR(AP_BEFORE -MONEY:魔法AP)%
IF AP_BEFORE == MONEY:魔法AP
	PRINTW 魔法的习得失败了。

;LOCALがITEM_ID_MAXなら全て習得した
ELSEIF LOCAL >= ITEM_ID_MAX
	PRINTW 《 习得了所有的魔法 》
ELSE
	PRINTW
ENDIF
SELECT_ITEM = 0

