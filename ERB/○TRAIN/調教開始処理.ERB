
;調教前に衣服状態と拘束状態を変更
@BEFORE_TRAIN_COMMAND_BEFORE
#DIM STRIP
#DIM BIND

CALL 魔界_静养_不可劳动与调教
SIF RESULT
	RETURN
TRYCALL PREGNANCY_产後初调_尝试口上
TRYCALL PREGNANCY_妊娠_性事口上_尝试
TRYCALL PREGNANCY_妊娠调教_谨慎开场_尝试
CALL BEFORE_TRAIN_AJUST_STRIP_FLAG

;ここで止めればちょうどいい
WAIT

;フラグを呼び出してきて実行予約
CALL BEFORE_TRAIN_AUTO_STRIP_CHECK
STRIP = RESULT
CALL BEFORE_TRAIN_AUTO_BIND_CHECK
BIND = RESULT
CALL BEFORE_TRAIN_COMMAND(STRIP,BIND)

;１ターン目にそのまま反映されてしまうので初期化
SOURCE:Ｂ露出地文表示 = 0
SOURCE:Ｎ露出地文表示 = 0
SOURCE:Ｖ露出地文表示 = 0
SOURCE:脱衣消息显示 = 0



;変更
@BEFORE_TRAIN_COMMAND(SELECT_STRIP,SELECT_BIND)
#DIM DYNAMIC SELECT_STRIP
#DIM DYNAMIC SELECT_BIND
#DIM DYNAMIC USE_LOTION,5
#DIM DYNAMIC USE_BIYAKU,5

CALL MANYL(3)
CALL SHOW_EQUIP
SELECTCASE SELECT_STRIP
CASE -1
	CALL PRINTL_WORD_COLOR("< 0> ＜全裸＞","桃")
CASEELSE
	;STR:デフォルト脱衣状態→8130
	STR_REF = 8130
	PRINTFORML [ 0] 衣服：%STR:(STR_REF +SELECT_STRIP)%
ENDSELECT
SELECTCASE SELECT_BIND
CASE 0
	PRINTL [ 1] 不拘束
CASEELSE
	;STR:拘束中→3930
	STR_REF = 3930
	PRINTFORML [ 1] 拘束：%STR:(STR_REF +SELECT_BIND -1)%
ENDSELECT

;ローション、媚薬もここで見る
PRINTL
IF ITEM:润滑液
	PRINTFORML ・使用润滑液（脱衣后可使用：持有{ITEM:润滑液}）
	PRINTFORM [10] %SAVESTR:标识／膣,12%
	CALL PRINT_ONOFF(USE_LOTION:0,1)
	PRINTFORM [11] %SAVESTR:标识／肛门,12%
	CALL PRINT_ONOFF(USE_LOTION:1,1)
	PRINTFORM [12] %SAVESTR:标识／乳房,12%
	CALL PRINT_ONOFF(USE_LOTION:2,1)
ELSE
	CALL PRINTL_WORD_COLOR,@"＜润滑液＞无","灰"
ENDIF
PRINTL
IF !ITEM:媚药
	CALL PRINTL_WORD_COLOR,@"＜媚药＞无","灰"
ELSE
	ITEM_NAME = 媚药
	PRINTFORM [20] %ITEM_NAME,12%
	CALL PRINT_ONOFF(USE_BIYAKU:0)
	PRINTFORML （持有{ITEM:媚药}）
ENDIF
COST = MAGIC_USE_MP:GETNUM(ITEM,"媚药粘液")
IF !ITEM:媚药粘液
	CALL PRINTL_WORD_COLOR,@"＜媚药粘液＞无","灰"
ELSEIF BASE:0:魔力 < COST
	CALL PRINTL_WORD_COLOR,@"＜媚药粘液＞MP不足（需要%VALUE_DIGIT(COST)%MP）","灰"
ELSE
	ITEM_NAME = 媚药粘液
	PRINTFORM [21] %ITEM_NAME,12%
	CALL PRINT_ONOFF(USE_BIYAKU:1)
	PRINTFORML %VALUE_DIGIT(COST)%MP
ENDIF
PRINTL
PRINTL [99] 开始调教
BINPUT
SELECTCASE RESULT
CASE 0
	CALL BEFORE_TRAIN_STRIP_SELECT
	
	;キャンセル以外
	SIF RESULT >= 0
		SELECT_STRIP = RESULT
CASE 1
	CALL BEFORE_TRAIN_BIND_SELECT
	SIF RESULT >= 0
		SELECT_BIND = RESULT
CASE 10 TO 12
	INVERTBIT USE_LOTION:(RESULT -10),0
CASE 20,21
	INVERTBIT USE_BIYAKU:(RESULT -20),0
CASE 99
	;実行して調教へ
	;0～2の脱ぎは先に拘束
	IF SELECT_STRIP < 3
		CALL TRAIN_BIND_RUN(SELECT_BIND)
		CALL BEFORE_TRAIN_STRIP_RUN(SELECT_STRIP)
	ELSE
		CALL BEFORE_TRAIN_STRIP_RUN(SELECT_STRIP)
		CALL TRAIN_BIND_RUN(SELECT_BIND)
	ENDIF
	
	;媚薬
	IF USE_BIYAKU:1
		CALL COM550
	ELSEIF USE_BIYAKU:0
		CALL COM251
	ENDIF
	
	;衣服変更してからローション
	SIF ITEM:润滑液 && USE_LOTION:0 && TFLAG:Ｖ露出 && !TALENT:处女结界
		CALL COM290
	SIF ITEM:润滑液 && USE_LOTION:1 && TFLAG:Ａ露出
		CALL COM291
	SIF ITEM:润滑液 && USE_LOTION:2 && TFLAG:Ｂ露出
		CALL COM292
	RETURN
ENDSELECT
RESTART



;Ｖ潤滑を増加
@BEFORE_TRAIN_LUBRICATION

IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
	PALAM:Ｖ润滑 += 10000
ELSEIF ＃陷落状态／恋慕以上＃
	PALAM:Ｖ润滑 += 5000
ELSEIF ＃陷落状态／陷落以上＃
	PALAM:Ｖ润滑 += 2000
ENDIF
SIF PALAM:Ｖ润滑
	SETBIT STAIN:膣,1

;浴場で浣腸（洗屁眼）済み→本調教開始時のみＡ润滑を多めに（会いに行く等では消費しない）
IF TFLAG:调教中 && CFLAG:浴池灌肠待调教
	PALAM:Ａ润滑 += 16000
	PALAM:Ａ润滑 = LIMIT(PALAM:Ａ润滑,0,99999)
	CFLAG:浴池灌肠待调教 = 0
ENDIF



