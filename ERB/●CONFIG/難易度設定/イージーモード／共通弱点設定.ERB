
;ランダムキャラ共通弱点部位設定
@EASYMODE_SENSITIVE_WEEK_CONFIG

CLEARLINE LINECOUNT
PRINTL 将随机角色的部位敏感度初始值固定提升至200%。
PRINTL ・如果B敏感度设定为200%，N敏感度也会自动提升。
DRAWLINE

;STR:感度・感覚用部位→3920
STR_REF = 3920
FOR LOCAL,0,5
	PRINTFORM [{LOCAL,2}] %STR:(STR_REF +LOCAL)%敏感度　
	CALL PRINT_ONOFF(GETBIT(FLAG:随机角色通用弱点部位BIT,LOCAL),1)
NEXT
CALL PRINTL_ALIGN(-5)
CALL DEFAULT_VOID_RETURN_BUTTON(1)
BINPUT
PRINTL
SIF !FLAG:开发者模式 && DAY
	RETURN
SELECTCASE RESULT
CASE 98
	PRINTL 是否将随机角色的通用弱点部位设定恢复为默认？
	CALL ASK_YN
	SIF !RESULT
		FLAG:随机角色通用弱点部位BIT = 0
CASE 99
	RETURN
CASEELSE
	CALL CHANGE_SENSITIVE_WEEK_CONFIG(RESULT)
ENDSELECT
RESTART



;設定変更
;ARG→INPUT
@CHANGE_SENSITIVE_WEEK_CONFIG(ARG)

;ひっくり返すだけ
INVERTBIT FLAG:随机角色通用弱点部位BIT,ARG

;Ｂ弱点のときＮ弱点固定
SIF GETBIT(＃全员Ｂ弱点＃)
	SETBIT ＃全员Ｎ弱点＃

