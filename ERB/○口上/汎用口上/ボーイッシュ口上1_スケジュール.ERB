@KOJO_GENERAL_ボーイッシュ口上1_SCHEDULE(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:1
CASE "奶农"
	SELECTCASE ARGS:2
	CASE "初次"
		IF CFLAG:总搾乳量
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「%SELF_CALL()%も乳牛だし、家畜同士、通じ合える気がするぜ♥♥」"
			ELSEIF ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
				CALL MESSAGE_BOX,@"「必ず%MASTER_CALL()%の役に立ってみせるから…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「家畜の世話か……普通の方だよな…？」"
			ENDIF
		ELSE
			IF ABL:奶农 >= 5
				CALL MESSAGE_BOX,@"「家畜の世話…？ いくらか経験したことあるぜ」"
			ELSE
				CALL MESSAGE_BOX,@"「家畜の世話…？ とりあえずやってはみるけど…」"
			ENDIF
		ENDIF
	CASE "普通"
		IF TIME == 0 || TIME == 2
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"「いっぱい乳汁を搾って%MASTER_CALL()%の役に立たないとな…♥♥」"
				CALL MESSAGE_BOX,@"「へへ♥ 上手に世話したら%MASTER_CALL()%に褒めてもら诶かな…♥」"
				SIF ABL:搾乳中毒 >= 10
					CALL MESSAGE_BOX,@"「あ、不要…別に搾乳されている牛たちが羨ましいとか…思ってないし……」"
			ELSE
				CALL MESSAGE_BOX,@"「好好世話して、美味しい牛乳を沢山出してもらわねえとな…」"
				CALL MESSAGE_BOX,@"「ニンゲンに手を出さなくても、こうして好好仕事があん所以よー……」\n\d%CALLNAME%はぶつくさ言いながら仕事をこなしている…"
			ENDIF
		ELSE
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"「さぁ牛たち、外でのんびり過ごすよーに！」"
			ELSE
				CALL MESSAGE_BOX,@"「よし牛たち、健康のためには食事に睡眠、運動だっ！」"
			ENDIF
			SIF ABL:奶农 < 4
				CALL MESSAGE_BOX,@"「啊啊っ…待てっ……柵の外は不行だぁっ…」"
		ENDIF
		
		IF FLAG:奶牛健康度 >= 80
			CALL MESSAGE_BOX,@"「牛たちみんな元気がいいな…！ %SELF_CALL()%も見習わないとな」"
		ELSEIF FLAG:奶牛健康度 >= 50
			CALL MESSAGE_BOX,@"「牛たちもおだやかで…平和で何事もないのが一番だなぁ」"
		ELSE
			CALL MESSAGE_BOX,@"「なんか牛たちの元気がないような… %SELF_CALL()%が好好しねえと…」"
		ENDIF
	ENDSELECT
	
CASE "事务"
	SELECTCASE ARGS:2
	CASE "初次"
		IF ABL:事务 >= 8
			CALL MESSAGE_BOX,@"「事務作業……、こう見えて得意中の得意だぜ！」"
		ELSEIF ABL:事务 >= 4
			CALL MESSAGE_BOX,@"「事務作業……、まぁいくらかやってみればコツも掴めるだろ」"
		ELSE
			CALL MESSAGE_BOX,@"「事務作業…… %MASTER_CALL()%、頼む相手を間違えてるぞ」"
		ENDIF
	CASE "普通"
		IF ABL:事务 >= 8
			CALL MESSAGE_BOX,@"「事務処理だったら、この%SELF_CALL()%に任せときな！」"
		ELSEIF ABL:事务 >= 4
			CALL MESSAGE_BOX,@"「得意ってほどじゃないけど……好好仕事はやるって」"
		ELSE
			CALL MESSAGE_BOX,@"「おいおい、どう考えても人選ミスだろ……」"
		ENDIF
		SIF FLAG:事务工作量 >= 20
			CALL MESSAGE_BOX,@"「よくもまあ、こんなにため込んだもんだ……」"
		IF CSTR:日程 == CSTR:0:日程
			IF ABL:事务 >= 8
				CALL MESSAGE_BOX,@"「せっかくだし、先の分まで済ましとくか」"
			ELSEIF ABL:事务 >= 4
				CALL MESSAGE_BOX,@"「地上のアレコレと共通点もあるし、なんとかやれるもんだな」"
			ELSE
				CALL MESSAGE_BOX,@"「还続けてやれって？ 目、節穴か？」"
			ENDIF
		ENDIF
	ENDSELECT
	
CASE "调剂"
	SELECTCASE ARGS:2
	CASE "初次"
		IF TALENT:调合知识
			CALL MESSAGE_BOX,@"「調合の経験はそれなりに積んでるつもりだぜ」"
		ELSEIF ABL:药学 >= 5
			CALL MESSAGE_BOX,@"「嗯—……細かい作業但是、手順通りでいいならなんとか」"
		ELSE
			CALL MESSAGE_BOX,@"「へへ…自慢じゃねえが、%SELF_CALL()%にやらせると人災が起きるぜ！」"
		ENDIF
