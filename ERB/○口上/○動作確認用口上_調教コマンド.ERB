	ENDSELECT

CASE "纵乳交"
	SELECTCASE ARGS:2
	CASE "执行"
		SIF SOURCE:初次乳交
			RETURN
		CALL MESSAGE_BOX,@"「test_调教指令【纵乳交】执行瞬间的台词。」"
	CASE "继续"
		CALL MESSAGE_BOX,@"「test_调教指令【纵乳交】持续中的台词。」"
	ENDSELECT

CASE "强制纵乳交"
