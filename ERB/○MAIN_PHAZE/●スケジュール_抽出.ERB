DRAWLINE
CALL RESET_TRAIN_PALAM



;抽選したキャラの搾乳風景表示
@SLAVE_DRAIN_ENTRANCE

SIF CSTR:状态／主人公的孩子 == "成长后"
	CALL CHILD_REBELLION(1)
IF !EXP:执行次数／抽出
	KOJO_TYPE = 初次
ELSE
	KOJO_TYPE = 普通
ENDIF
CALL STANDBY_SLAVE_DRAIN_MESSAGE
CALL SLAVE_LACTATION_RUN(1,"抽出")
FLAG:上次显示角色ID／抽出 = CFLAG:ID
WAIT
CALL MANYL(2)



