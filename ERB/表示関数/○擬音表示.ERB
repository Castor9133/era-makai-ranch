
;擬音用の共通
@ONOMATOPOEIA_COMMON

;擬音用文字色
SETCOLOR FLAG:拟音显示颜色编码

;適当にスペース
FOR LOCAL,0,RAND:10
	PRINT  
NEXT



;擬音表示：こちらに一本化
;ARGS→基本分類　ARGS:1→ピストン時の部位とか
@ONOMATOPOEIA(ARGS,ARGS:1)

SELECTCASE ARGS
CASE "吸奶"
	;個別でONOFF見てOFFなら帰る
	SIF !GETBIT(FLAG:拟音表示,0)
		RETURN
	IF BASE:母乳容量 || NOWEX:喷乳
		SELECTCASE RAND:4
		CASE 0
			CALL ONOMATOPOEIA_SUCK
		CASEELSE
			CALL ONOMATOPOEIA_MILK_SUCK
		ENDSELECT
	ELSE
		CALL ONOMATOPOEIA_SUCK
	ENDIF
	
CASE "揉胸"
	SIF !GETBIT(FLAG:拟音表示,1)
		RETURN
	
	;おっぱいサイズで擬音変えてみる
	IF ABL:胸围大小 >= BUSTSIZE_爆乳
		CALL ONOMATOPOEIA_RUB_VERY_BIG_BOOB
	ELSEIF ABL:胸围大小 >= BUSTSIZE_巨乳
		CALL ONOMATOPOEIA_RUB_BIG_BOOB
	ELSEIF ABL:胸围大小 == 0
		CALL ONOMATOPOEIA_RUB_WALL_BOOB
	ELSE
		CALL ONOMATOPOEIA_RUB_BOOB
	ENDIF
	
CASE "搾乳器"
	SIF !GETBIT(FLAG:拟音表示,2)
		RETURN
	CALL ONOMATOPOEIA_LACTATION_CUP
	
CASE "舔舐"
	SIF !GETBIT(FLAG:拟音表示,3)
		RETURN
	CALL ONOMATOPOEIA_LICK

CASE "活塞运动"
	SIF !GETBIT(FLAG:拟音表示,4)
		RETURN
	
	;該当部位が濡れているかの判定
	IF ARGS:1 == "Ｖ" && PALAM:Ｖ润滑 >= 10000
		CALL ONOMATOPOEIA_PISTON_LUBRICATION
	ELSEIF ARGS:1 == "Ａ" && PALAM:Ａ润滑 >= 10000
		CALL ONOMATOPOEIA_PISTON_LUBRICATION
	ELSEIF ARGS:1 == "Ｍ"
		CALL ONOMATOPOEIA_PISTON_MOUSE
	ELSEIF ARGS:1 == "乳交"
		CALL ONOMATOPOEIA_PISTON_PAIZURI
	ELSE
		CALL ONOMATOPOEIA_PISTON
	ENDIF

CASE "射精"
	SIF !GETBIT(FLAG:拟音表示,5)
		RETURN
	CALL ONOMATOPOEIA_EJACULATION
	
CASE "吸阴蒂"
	SIF !GETBIT(FLAG:拟音表示,6)
		RETURN
	CALL ONOMATOPOEIA_SUCK
	
CASE "包乳花瓣搾乳触手"
	SIF !GETBIT(FLAG:拟音表示,7)
		RETURN
	
	;2段にしよう
	CALL ONOMATOPOEIA_LACTATION_TENTACLE_FLOWER1
	CALL ONOMATOPOEIA_LACTATION_TENTACLE_FLOWER2
	
CASE "透明杯状搾乳触手"
	SIF !GETBIT(FLAG:拟音表示,8)
		RETURN
	CALL ONOMATOPOEIA_LACTATION_TENTACLE_CUP1
	CALL ONOMATOPOEIA_LACTATION_CUP
	
CASE "榨乳蠕虫触手"
	SIF !GETBIT(FLAG:拟音表示,9)
		RETURN
	CALL ONOMATOPOEIA_LACTATION_TENTACLE_WORM
	
CASE "触手活塞"
	SIF !GETBIT(FLAG:拟音表示,10)
		RETURN
	
	;濡れている場合と同じにした
	CALL ONOMATOPOEIA_PISTON_LUBRICATION
	
CASE "乳房露出"
	SIF !GETBIT(FLAG:拟音表示,11)
		RETURN
	CALL ONOMATOPOEIA_STRIP_BUST
	
CASE "乳头露出"
	SIF !GETBIT(FLAG:拟音表示,12)
		RETURN
	CALL ONOMATOPOEIA_STRIP_NIPPLE

ENDSELECT
RESETCOLOR
SIF !LINEISEMPTY()
	PRINTL



;濡れている場合のピストン擬音
@ONOMATOPOEIA_PISTON_LUBRICATION

;擬音個別表示にしたので関数使う
CALL ONOMATOPOEIA_COMMON
FOR LOCAL,0,6
	SELECTCASE RAND:10
	CASE 0
		PRINT 啾啵
	CASE 1
		PRINT 啪呲
	CASE 2
		PRINT 滋噗
		ONOMATO_SKIP ++
	CASE 3
		PRINT 滋扭
	CASE 4
		PRINT 滋啾
	CASEELSE
		PRINT 啾噗
	ENDSELECT
	
	;1/2で「っ」追加　ONOMATO_SKIPが1ならスキップ
	SIF !RAND:2 && !ONOMATO_SKIP
		PRINT っ
	ONOMATO_SKIP = 0
	SELECTCASE RAND:100
	CASE 0 TO 69
		PRINT ❤ 
	CASEELSE
		PRINT ❤❤ 
	ENDSELECT
NEXT



