
;帰宅
@GOING_HOME

;ペットで外出していなければおわり
SIF !FLAG:已外出 || FLAG:已外出 == 20
	RETURN
TARGET = 0

;ITEM:堕天馬→100
;FLAG:外出済み　に+1からが入ってるので-1
ANIMAL = %ITEMNAME:(100 -1 +FLAG:已外出)%
PET_NAME = %PET_NAME_REF(ANIMAL)%

;たまに龍のタマ見つける
CALL GOING_HOME_DRAGON_BALL
PRINTFORML %CALLNAME%和%PET_NAME%一起从城里回家了。

;運動して体型-
PRINTFORM %PET_NAME%：
CALL PET_WEIGHT_MINUS(300)
PRINTL

;ごほうび選択
CALL MASTER_REWORD_ANIMAL_SELECT




