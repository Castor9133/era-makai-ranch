
;洗ってもらうコマンド
@BATHLOOM_PLAYER_WASHING

CALL MANYL(5)
SIF TARGET > 0
	CFLAG:本场景包茎口交前戏已消费 = 0
IF TFLAG:浴缸内
	PRINTFORML %CALLNAME:0%和%CALLNAME%从浴缸里爬出来。
	TFLAG:浴缸内 = 0
ENDIF

;娘が成長中なら普通に洗う一択
IF CSTR:状态／主人公的孩子 == "成长中"
	CALL BATHLOOM_PLAYER_WASHING_BODY
	PRINTW
	RETURN
ENDIF
PRINTL 选择清洗你的方式。
PRINTL
PRINTL [ 0] 被洗全身（顺带按摩肩颈，缓和疲劳）
PRINTL [ 5] 被舌头从头到脚舔遍……
PRINTFORML [ 1] 使用%SAVESTR:标识／乳房%进行清洗
PRINTL [ 8] 用胸推洗后背（乳推）
IF !PLAYER_PENIS
	CALL PRINTL_WORD_COLOR("　主人公无阴茎时无法进行素股清洗","灰")
ELSE
	PRINTL [ 7] 素股般清洗大腿与会阴（皂滑摩擦、不插入；处女也可侍奉）
ENDIF
IF !BASE:PLAYER:精力
	CALL PRINTL_WORD_COLOR,@"　%CALLNAME:PLAYER%的精力不足。","灰"
	PRINTL
	PRINTL
ELSE
	PRINTFORML [ 2] 口交清洗%SAVESTR:标识／阴茎%
	PRINTL [ 3] 被乳交
	PRINTFORML [ 4] 用%SAVESTR:标识／膣%仔细清洗%SAVESTR:标识／阴茎%
	IF !PLAYER_PENIS
		CALL PRINTL_WORD_COLOR("　主人公无阴茎时无法进行深喉组合","灰")
	ELSE
		PRINTL [ 6] 毒龙→水下深喉（先舔肛后深喉）
	ENDIF
ENDIF
PRINTL
PRINTL [99] 取消
BINPUT
PRINTL
SIF RESULT == 99
	RETURN
IF CSTR:状态／主人公的孩子 == "成长后"
	SELECTCASE RESULT
	CASE IS != 0
		CHILD_COM = RESULT
		CALL CHILD_REBELLION
		SIF RESULT
			RETURN
		RESULT = CHILD_COM
	ENDSELECT
ENDIF
SELECTCASE RESULT
CASE 0
	CALL BATHLOOM_PLAYER_WASHING_BODY
CASE 5
	CALL BATHLOOM_PLAYER_WASHING_TONGUE_BODY
CASE 1
	CALL BATHLOOM_PLAYER_WASHING_USE_BUST
CASE 2
	CALL BATHLOOM_PLAYER_WASHING_PENIS
	
	;RETURN 99してきてたらキャンセル
	SIF RESULT == 99
		RETURN
CASE 3
	CALL BATHLOOM_PLAYER_WASHING_PAIZURI
	SIF RESULT == 99
		RETURN
CASE 4
	CALL BATHLOOM_PLAYER_WASHING_USE_VAGINA
	SIF RESULT == 99
		RETURN
CASE 6
	CALL BATHLOOM_PLAYER_WASHING_RIM_THEN_DT
	SIF RESULT == 99
		RETURN
CASE 7
	IF !PLAYER_PENIS
		SELECTCOM = 0
		RETURN
	ENDIF
	CALL BATHLOOM_PLAYER_WASHING_SUMATA_THIGHS
CASE 8
	CALL BATHLOOM_PLAYER_WASHING_BUST_BACK_WASH
CASEELSE
	RETURN
ENDSELECT
PRINTW



;普通に洗ってもらう
@BATHLOOM_PLAYER_WASHING_BODY

CALL PRINT_IMAGE("奉仕")
CALL BATHLOOM_PLAYER_WASHING_BODY_MESSAGE
SOURCE:爱情 += 1000
CALL SOURCE_CHECK
LOCAL:81 = LIMIT(MAXBASE:0:体力 / 12, 45, 900)
LOCAL:82 = LIMIT(MAXBASE:0:气力 / 10, 45, 700)
BASE:0:体力 = LIMIT(BASE:0:体力 + LOCAL:81, 0, MAXBASE:0:体力)
BASE:0:气力 = LIMIT(BASE:0:气力 + LOCAL:82, 0, MAXBASE:0:气力)
PRINTFORML （%CALLNAME:0%：体力＋{LOCAL:81}　气力＋{LOCAL:82}）
TFLAG:亲密互动次数 ++



;舌で全身を「洗う」
@BATHLOOM_PLAYER_WASHING_TONGUE_BODY

CALL SERVICE_JUDGE
SIF !RESULT
	RETURN
CALL PRINT_IMAGE("奉仕")
CALL BATHLOOM_PLAYER_WASHING_TONGUE_BODY_MESSAGE
SOURCE:爱情 += 2200
SOURCE:耻辱 += 1600
SOURCE:屈辱 += 1100
SOURCE:学习 += 1200
SOURCE:不洁 += 400
LOSEBASE:体力 += 35
LOSEBASE:气力 += 25
CALL SOURCE_CHECK
LOCAL:83 = LIMIT(MAXBASE:0:气力 / 15, 30, 400)
BASE:0:气力 = LIMIT(BASE:0:气力 + LOCAL:83, 0, MAXBASE:0:气力)
PRINTFORML （%CALLNAME:0%：气力＋{LOCAL:83}）
TFLAG:亲密互动次数 ++



;おっぱい洗い
@BATHLOOM_PLAYER_WASHING_USE_BUST

CALL PRINT_IMAGE("奉仕")
CALL BATHLOOM_PLAYER_WASHING_USE_BUST_MESSAGE
LOSEBASE:体力 += 50
LOSEBASE:气力 += 30
SOURCE:Ｂ快感 = 2000
SOURCE:Ｎ快感 = 1000
SOURCE:学习 = 2000
SOURCE:耻辱 = 1000
SOURCE:爱情 = 3000
SOURCE:屈辱 = 500
SOURCE:支配 = 500
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++



;ちんぽを口で洗う（フェラ）
@BATHLOOM_PLAYER_WASHING_PENIS

SELECTCOM = 51
CALL COM51
SIF !RESULT
	RETURN 99
LOSEBASE:体力 += 25
LOSEBASE:气力 += 25
SOURCE:不洁 = 0
CALL PRINT_IMAGE("奉仕")
CALL BATHLOOM_PLAYER_WASHING_PENIS_MESSAGE
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
EXP:(SELECTCOM +1000) ++
SELECTCOM = 0
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++
PRINTL
CALL EJACULATION_PISTON



;毒龙（舔肛）→水下深喉
@BATHLOOM_PLAYER_WASHING_RIM_THEN_DT

CALL SERVICE_JUDGE
SIF !RESULT
	RETURN 99
SIF !PLAYER_PENIS
	RETURN 99
SIF !BASE:PLAYER:精力
	RETURN 99

;── 先：毒龙（奴隶舔主人公肛门）
LOSEBASE:体力 += 45
LOSEBASE:气力 += 40
SOURCE:耻辱 += 4200
SOURCE:屈辱 += 4800
SOURCE:爱情 += 900
SOURCE:不洁 += 5500
SOURCE:支配 += 900
SOURCE:调教者习得 += 450
SOURCE:已用时间 = 1
CALL PRINT_IMAGE("奉仕")
CALL BATHLOOM_PLAYER_WASHING_RIM_DT_PHASE1_MESSAGE
SOURCE:选择指令口上隐藏 = 1
CALL SOURCE_CHECK
PRINTW

;── 后：潜回浴缸内、水下深喉
TFLAG:浴缸内 = 1
SELECTCOM = 52
CALL COM52
LOSEBASE:体力 += 35
LOSEBASE:气力 += 45
SOURCE:不洁 = 0
CALL PRINT_IMAGE("奉仕")
CALL BATHLOOM_PLAYER_WASHING_RIM_DT_PHASE2_MESSAGE
CALL ONOMATOPOEIA_DEEP_THROAT
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
EXP:(SELECTCOM +1000) ++
SELECTCOM = 0
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++
PRINTL
CALL EJACULATION_PISTON
TFLAG:浴缸内 = 0



;パイズリ洗い
@BATHLOOM_PLAYER_WASHING_PAIZURI

SELECTCOM = 53
CALL COM53
SIF !RESULT
	RETURN 99
SETBIT ＃Ｐ使用／乳交＃
LOSEBASE:体力 += 20
LOSEBASE:气力 += 20
SOURCE:不洁 = 0
CALL PRINT_IMAGE("乳交")
CALL BATHLOOM_PLAYER_WASHING_PAIZURI_MESSAGE
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
EXP:(SELECTCOM +1000) ++
SELECTCOM = 0
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++
PRINTL
CALL EJACULATION_PISTON



;騎乗位ちんぽ洗い
@BATHLOOM_PLAYER_WASHING_USE_VAGINA

;騎乗位かどうかで奉仕判定変化するので先にSELECTCOM設定
