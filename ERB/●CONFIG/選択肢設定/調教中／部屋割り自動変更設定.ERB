
;部屋割り自動変更設定
@AUTO_ALLOCATION_ROOM_CONFIG

CLEARLINE LINECOUNT
PRINTL 在特定状态下进行房间分配自动更改设定。
DRAWLINE
PRINTLC [ 0] 进入＜牛舍＞时解除自己的房间。
CALL PRINT_ONOFF(GETBIT(＃自动房间分配／牛舍＃),1)
PRINTLC [ 1] 在【体内凌辱】开始时解除自己的房间。
CALL PRINT_ONOFF(GETBIT(＃自动房间分配／体内凌辱＃),1)

CALL PRINTL_ALIGN(-5)
CALL DEFAULT_VOID_RETURN_BUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 98
	PRINTL 是否将房间分配自动更改设定恢复为默认？
	CALL ASK_YN
	SIF !RESULT
		FLAG:房间分配自动更改BIT = 1
CASE 99
	RETURN
CASEELSE
	INVERTBIT FLAG:房间分配自动更改BIT,RESULT
ENDSELECT
RESTART



