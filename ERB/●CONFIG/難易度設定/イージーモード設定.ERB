
;イージーモード設定
@EASYMODE_CONFIG

CLEARLINE LINECOUNT
PRINTL 进行＜简单模式＞的设定。
CALL PRINTL_WORD_COLOR("《 简单模式设置 》在游戏开始前或开发者模式下才可以更改。","黄")
PRINTL 如果此画面中有任何项为ON，且不是[DEVELOP]或[CUSTOM]，难度将显示为[EASY]。
CALL PRINT_DIFFICULTY
DRAWLINE
FLAG_REF = 3600
FOR LOCAL,0,70
	SIF FLAGNAME:(LOCAL +FLAG_REF) == ""
		CONTINUE
	CALL PRINT_CONFIG_EASYMODE(LOCAL)
NEXT
PRINTL
PRINTL [70] 随机角色通用弱点部位设定
PRINTL [71] 各种次数限制解除设定
PRINTL [72] 轻松启动套件（仅在游戏开始时有效）

CALL PRINTL_ALIGN(-5)
CALL ON_OFF_BUTTON_FOOTER
BINPUT
PRINTL
SELECTCASE RESULT
CASE 82
	PRINTL 对于配置设置中被切换为ON/OFF的项目，设置[ON]会将其反转，而不给出解释
	CALL ASK_ONOFF
	FLAG:跳过ON／OFF项目的详细信息并反转 = RESULT
CASE 98
	;日付が1日目以降かつ開発者モード以外の場合RETURN
	SIF !FLAG:开发者模式 && DAY
		RETURN
	PRINTL 是否将＜简单模式＞的所有设定恢复为OFF？
	CALL ASK_YN
	SIF !RESULT
		VARSET FLAG,0,3600,3700
CASE 99
	RETURN
CASEELSE
	CALL CHANGE_EASYMODE_CONFIG(RESULT)
ENDSELECT
RESTART



;ARG→LOCAL　FLAG_REFを足すことでフラグ番号
@PRINT_CONFIG_EASYMODE(ARG)

FLAG_NAME = %FLAGNAME:(ARG +FLAG_REF)%
SELECTCASE FLAG_NAME
CASEELSE
	PRINTFORM [{ARG,2}] %FLAG_NAME,32%
	CALL PRINT_ONOFF(FLAG:FLAG_NAME)
ENDSELECT
PRINTL



;ARG→INPUT
@CHANGE_EASYMODE_CONFIG(ARG)

;下でRETURNがあるので確認のためここが先
SELECTCASE ARG
CASE 70	;ランダムキャラ共通弱点部位設定
	CALL EASYMODE_SENSITIVE_WEEK_CONFIG
CASE 71	;各種回数制限撤廃設定
	CALL EASYMODE_LIMIT_BREAK_CONFIG
CASE 72	;楽々スタートキット（ゲーム開始時のみ有効）
	CALL EASYMODE_GIFTSET_CONFIG
CASEELSE
	CALL CHANGE_EASYMODE_CONFIG_NAME(ARG)
ENDSELECT



@CHANGE_EASYMODE_CONFIG_NAME(ARG)

SIF !FLAG:开发者模式 && DAY
	RETURN
FLAG_NUM = ARG +FLAG_REF
FLAG_NAME = %FLAGNAME:FLAG_NUM%
CALL CHANGE_CONFIG_INVERTBIT
SIF RESULT
	RETURN
SELECTCASE FLAG_NAME
CASE "奴隶候补全员先天母乳体质"
	PRINTL 随机角色将必定成为【先天性母乳体质】。
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "母乳需要无限"
	PRINTL 每个角色的母乳需求值将变为无限。
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "在进入魔界的人类上堵车"
	PRINTL 进行进入魔界的人类抽签时，根据不同的目的，确保至少有一个候选者。
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "贡献pt零消费"
	PRINTL 在重新调整奴隶候选、从CSV文件加载以及手动角色创建时，消耗＜贡献pt＞将变为零。
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "免除纳税"
	PRINTL 无需在结算时缴税。（为提升魔界Lv，必须进行＜捐赠＞）
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT
ENDSELECT






