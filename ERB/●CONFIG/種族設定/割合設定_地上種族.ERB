
;種族設定
@NORMAL_TRIBE_CONFIG

;FLAG:候補割合／一般種族／人間→2600
FLAG_REF = 2600
STR_REF = 6510
FLAG:候选比例／一般种族／总计 = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +20)
TOTAL_RATIO = FLAG:候选比例／一般种族／总计
CLEARLINE LINECOUNT
PRINTL 设置人类的常规种族比例。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE

;20までなので共通できない
FOR LOCAL,0,20
	SIF FLAGNAME:(LOCAL +FLAG_REF) == ""
		BREAK
	SIF LOCAL %5 == 0 && LOCAL
		PRINTL
	PRINTFORM [{LOCAL,2}] %STR:(LOCAL +STR_REF),16%
	SIF !FLAG:(LOCAL +FLAG_REF)
		SETCOLOR 0x606060
	PRINTFORM ：{FLAG:(LOCAL +FLAG_REF),4}
	PRINTPLAIN 　
	RESETCOLOR
	PRINTBUTTON "[+10]",LOCAL +100
	PRINTBUTTON "[-10]",LOCAL +200
	PRINTPLAIN 　
	PRINTBUTTON "[×2]",LOCAL +300
	PRINTBUTTON "[÷2]",LOCAL +400
	PRINTPLAIN 　
	
	;合計0だとこの先飛ばす
	IF !TOTAL_RATIO
		SIF !LOCAL
			CALL PRINT_WORD_COLOR("！比率合计为0","黄")
		PRINTL
		CONTINUE
	ENDIF
	CONFIG_RATIO = FLAG:(FLAG_REF +LOCAL) *100
	CONFIG_RATIO /= TOTAL_RATIO
	
	;0ではないけど計算結果0なら「ほぼ0」
	IF !CONFIG_RATIO && FLAG:(FLAG_REF +LOCAL)
		PRINT 接近0% 
	ELSE
		PRINTFORM 　{CONFIG_RATIO,3}\% 
	ENDIF
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL TENDENCY_CONFIG_FOOTER
SELECTCASE INPUT_NUM
CASE 0 TO 19
	PRINTFORML %FLAGNAME:(INPUT_NUM +FLAG_REF)%的值获取。（0～1000)
	INPUT
	SIF RESULT >= 0 && RESULT <= 1000
		FLAG:(INPUT_NUM +FLAG_REF) = RESULT

CASE 100 TO 119
	FLAG_NUM = (INPUT_NUM +FLAG_REF -100)
	FLAG:FLAG_NUM = LIMIT(FLAG:FLAG_NUM +10,0,1000)

CASE 200 TO 219
	FLAG_NUM = (INPUT_NUM +FLAG_REF -200)
	FLAG:FLAG_NUM = LIMIT(FLAG:FLAG_NUM -10,0,1000)

CASE 300 TO 319
	FLAG_NUM = (INPUT_NUM +FLAG_REF -300)
	FLAG:FLAG_NUM = LIMIT(FLAG:FLAG_NUM *2,0,1000)

CASE 400 TO 419
	FLAG_NUM = (INPUT_NUM +FLAG_REF -400)
	FLAG:FLAG_NUM = LIMIT(FLAG:FLAG_NUM /2,0,1000)
CASE 98
	PRINTL 将一般种族比例回复为默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_NORMAL_TRIBE_CONFIG
CASE 99
	IF FLAG:候选比例／一般种族／总计 <= 0 || FLAG:候选比例／一般种族／总计 > 1000
		PRINTW 总出现比例应介于1到1000之间。
		RESTART
	ENDIF
	RETURN
ENDSELECT
RESTART


