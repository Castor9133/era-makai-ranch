
;個人ステータス表示
@SHOW_STATUS_DETAIL

;画像・ドット絵があるキャラとないキャラで改行がずれるのを防ぐ措置→内部でやった
CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT

;あなたと成長途中の子は別関数→ここに合わせないと表示がずれる
IF !TARGET
	CALL PRINT_ALL_STATE
	CALL SHOW_STATUS_PLAYER
	RETURN
ELSEIF CSTR:状态／主人公的孩子 == "成长中"
	CALL SHOW_STATUS_CHILD
	RETURN
ELSE
	CALL PRINT_ALL_STATE
ENDIF
PRINTFORM %CALLNAME%
CALL PRINT_AFFILIATION_DATA
SIF !CFLAG:非战斗职业 || BASE:等级 > 1
	PRINTFORM Lv{BASE:等级} 
PRINTL
PRINTFORM 【%CSTR:身高%】胸围大小：%PRINT_BUSTSIZE(ABL:胸围大小)%
CALL PRINT_BUST_C(1,1,1)
CALL PRINT_VIRGIN_SIMPLE
CALL PRINT_NOW_PURPOSE
PRINTL
CALL ABL_WORK_LIST(0)
CALL SHOW_SENSITIVE_LIST
PRINTL
CALL SHOW_EQUIP

;フラグで変更
SELECTCASE FLAG:选择画面显示形式／素质
CASE 0
	CALL SHOW_TALENT_LIST_SIMPLE
CASE 1
	CALL SHOW_TALENT_LIST
	CALL SHOW_TALENT_NASTY
ENDSELECT

;スキップなら飛ばす
SIF FLAG:选择画面显示形式／刻印 != 2
	CALL SHOW_MARK_LIST(1)
CALL PRINT_CAPITULATION_SIMPLE
PRINTL
CALL PRINT_SOME_DRINK



;あなたのステータス
@SHOW_STATUS_PLAYER

;女あなたならおっぱいも
PRINTFORM %CALLNAME%
IF TALENT:男性
	PRINTFORM 【%CSTR:身高%】
ELSE
	PRINTFORM 【%CSTR:身高%】胸围大小：%PRINT_BUSTSIZE(ABL:胸围大小)%
	CALL PRINT_BUST_C(1,1,1)
ENDIF

;行を合わせる
CALL MANYL(3)
CALL ABL_WORK_LIST(0)
CALL MANYL(2)
CALL SHOW_EQUIP
SELECTCASE FLAG:选择画面显示形式／素质
CASE 0
	CALL SHOW_TALENT_LIST_SIMPLE
CASE 1
	CALL SHOW_TALENT_LIST
	CALL SHOW_TALENT_NASTY
ENDSELECT
PRINTL
PRINTFORM  灵力：%VALUE_DIGIT(BASE:灵力)% 
CALL PRINT_COLORBAR(BASE:灵力,MAXBASE:灵力,8,BARCOLORSET(""),RESULT:1)
PRINTFORM  魔力：%VALUE_DIGIT(BASE:魔力)% 
CALL PRINT_COLORBAR(BASE:魔力,MAXBASE:魔力,8,BARCOLORSET("深紫"),RESULT:1)
PRINTFORML  <{BASE:魔力恢复率,2}\%\/day>

IF ITEM:绝伦 && GETBIT(＃有效／绝伦＃)
	CALL PRINT_WORD_COLOR,@"【绝伦】","桃"
ELSE
	PRINTFORM  精力：%VALUE_DIGIT(BASE:精力)% 
	CALL PRINT_COLORBAR(BASE:精力,MAXBASE:精力,8,BARCOLORSET(""),RESULT:1)
ENDIF
PRINTL



;子供のステータス
@SHOW_STATUS_CHILD

PRINT 【爱女】
PRINTFORM %CALLNAME%
CALL PRINT_AFFILIATION_DATA
SIF BASE:等级 > 1
	PRINTFORM Lv{BASE:等级} 
PRINTL
CALL SHOW_EQUIP

CALL ABL_WORK_LIST(0)
PRINTL
PRINTFORM  灵力：%TOSTR(BASE:灵力,"#,0")% 
CALL PRINT_COLORBAR(BASE:灵力,MAXBASE:灵力,8,BARCOLORSET(""),RESULT:1)
PRINTFORM  魔力：%TOSTR(BASE:魔力,"#,0")% 
CALL PRINT_COLORBAR(BASE:魔力,MAXBASE:魔力,8,BARCOLORSET("深紫"),RESULT:1)

PRINTL






