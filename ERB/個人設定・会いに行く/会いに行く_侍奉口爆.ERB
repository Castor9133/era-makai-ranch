
;==========================================
; 拜访・[18] 亲热一下（手→口→足→结尾可选口内射精或忍住）
; 独立地文、不经调教 SOURCE_CHECK；收尾处 **`KOJO_PRINT("访问","侍奉口爆终了",…)`** 接泛用口上。须恋慕或隶属、且奴隶上下内衣已装备（街市购入后更衣）见 GATE
;==========================================

@VISIT_SERVE_CLIMAX_GATE
#FUNCTION
SIF !PLAYER_PENIS
	RETURNF 0
SIF BASE:0:精力 <= 0
	RETURNF 0
SIF CFLAG:时刻限制／侍奉口爆
	RETURNF 0
SIF !＃陷落状态／恋慕以上＃ && !＃陷落状态／隶属＃
	RETURNF 0
SIF !EQUIP:装备中ID／内衣上装 || !EQUIP:装备中ID／内衣下装
	RETURNF 0
RETURNF 1



@VISIT_SERVE_CLIMAX_GRP
#FUNCTION
IF GROUPMATCH(CSTR:使用口上,"慇懃口上1","温柔大姐姐1","女仆口上1","大和抚子口上1","虔诚口上1","妹系口上1","天然口上1","人妻口上1")
	RETURNF 1
ELSEIF GROUPMATCH(CSTR:使用口上,"強気口上1","姉御肌口上1","ボーイッシュ口上1")
	RETURNF 2
ELSEIF CSTR:使用口上 == "闷骚小姐姐1"
	RETURNF 9
ELSEIF GROUPMATCH(CSTR:使用口上,"生真面目口上1","堅物口上1","気品口上1")
	RETURNF 3
ELSEIF GROUPMATCH(CSTR:使用口上,"懦弱口上1","非敬語幼め口上1")
	RETURNF 4
ELSEIF CSTR:使用口上 == "知心口上1"
	RETURNF 5
ELSEIF GROUPMATCH(CSTR:使用口上,"仇恨口上1","愚忠口上1")
	RETURNF 6
ELSEIF CSTR:使用口上 == "無口口上1"
	RETURNF 7
ELSE
	RETURNF 8
ENDIF



; 答应时的短反应（性格）：具体动作与声气，避免空泛隐喻
@VISIT_SERVE_CLIMAX_AGREE_TX
#DIM GRP
GRP = VISIT_SERVE_CLIMAX_GRP()
SELECTCASE GRP
CASE 1
	PRINTFORML %CALLNAME%把袖口卷到小臂，指尖在毛巾边抹干水汽才探向你腰带：「……按您说的顺序。失礼了。」
	PRINTFORML 她跪定时膝盖先找稳重心，吐息仍轻，耳根却先一步热起来。
CASE 2
	PRINTFORML %CALLNAME%嗤笑一声，掌心已经贴上：「规矩写这么细——行啊，看你第几步先绷不住。」
	PRINTFORML 她拇指腹摁住铃口下缘，力道像挑衅，指节却因收力而发白。
CASE 3
	PRINTFORML 「……收到。手→口→足，收尾按您方才点定的那档。」%CALLNAME%复述得像报工序，笔尖似的视线却在你小腹上划了一下。
	PRINTFORML 她指尖在太阳穴按了按，低声补一句：「……该咽的一滴不漏；该收住的……也不许我失手。」
CASE 9
	PRINTFORML %CALLNAME%推了推并不存在的眼镜，语气平得像在读摘要：「……手、口、足——三步。误差来源主要是你中途改需求。」
	PRINTFORML 她停半拍，补一句冷到骨子里的：「……放心，我不会把你的急，写成我的学术污点。」
CASE 4
	PRINTFORML 「……真的可以吗……？」%CALLNAME%指尖碰到就先缩半寸，又怯怯握住：「那、那我……会尽量……不弄脏……」
	PRINTFORML 她睫毛抖得厉害，却把掌心完整地贴上去，像把勇气垫在你皮肤下面。
CASE 5
	PRINTFORML %CALLNAME%没急着碰，先把手覆在你手背上停一拍：「……心跳快了。」这才滑下去，掌心温度贴着你的脉走。
	PRINTFORML 她抬眼确认你的表情，轻声道：「……你刚选的那条路……我照办到底。」
CASE 6
	IF CSTR:使用口上 == "愚忠口上1"
		PRINTFORML 「……奴都听见了。」%CALLNAME%应声俯身，先把手心焐热了才敢握住：「方才您点定的那条路……奴一定侍到底，不敢有半分懈怠。」
		PRINTFORML 她不敢抬眼直视，只把指腹贴得稳当；唇线抿得发白，像把每一句吩咐都嚼碎了咽下去。
	ELSE
		PRINTFORML 「……想让我来当你的泄欲工具吗？」%CALLNAME%咬住唇，仍是握住，嗓音发冷：「行——顺序你写好了，尽头怎样你也早选完了。」
		PRINTFORML 她笑得刻薄，指甲却掐进自己膝里，像忍着不把那句骂出来。
	ENDIF
CASE 7
	PRINTFORML 「…………」%CALLNAME%只点头，喉间轻轻「嗯」了一声。
	PRINTFORML 她把手心焐在你腹侧停住，像在默数节拍，指节才一寸寸往下滑。
CASEELSE
	PRINTFORML %CALLNAME%有些结巴地重复了一遍「手、口、脚……最后……」，说到一半自己先红了脸。
	PRINTFORML 她深吸一口气，把掌心贴上：「……我会……认真的。」
ENDSELECT
PRINTW
RETURN



@VISIT_SERVE_CLIMAX_VISIT

SIF !VISIT_SERVE_CLIMAX_GATE()
	RETURN

TFLAG:侍奉口爆不射精 = 0
CFLAG:本场景包茎口交前戏已消费 = 0
TFLAG:包茎口上待播 = 0

	PRINTFORML 你说清顺序：掌根与指腹先把你摸到脉跳顶在皮里，舌再贴着铃口与系带慢慢拖；脚跟上去，足弓与趾腹碾着茎侧和囊缘，趾根仍收着力道，像在逗你又像在伺候。
	PRINTFORML 推到极限时，口内射精还是由你忍住——最后一步再定；她听完，目光在你腰际停了一拍，咽了一下，点头。
	PRINTL
	PRINTL [0] 简洁推进
	PRINTL [1] 分段详写（性格差异较大）
	PRINTL [99] 作罢
BINPUT
SELECTCASE RESULT
CASE 99
	RETURN
CASE 1
	LOCAL:10 = 1
CASEELSE
	LOCAL:10 = 0
ENDSELECT

PRINTL
PRINTL 最后一步由你定夺——
PRINTL [0] 口内射精，让她咽下（精饮滋补）
PRINTL [1] 忍住在她唇边收住（不射精）
BINPUT
SELECTCASE RESULT
CASE 1
	TFLAG:侍奉口爆不射精 = 1
CASEELSE
	TFLAG:侍奉口爆不射精 = 0
ENDSELECT

PRINTL
CALL VISIT_SERVE_CLIMAX_AGREE_TX

IF PHIMOSIS_PLAYER_HAS_PHIMOSIS && !CFLAG:本场景包茎口交前戏已消费
	CALL PHIMOSIS_FIRST_ORAL_NARRATIVE(2)
	CALL PHIMOSIS_FIRST_ORAL_VISIT_KOJO_AND_FINISH
ENDIF
CALL VISIT_SERVE_CLIMAX_RUN(LOCAL:10)
RETURN



@VISIT_SERVE_CLIMAX_RUN(ARG)
#DIM GRP
GRP = VISIT_SERVE_CLIMAX_GRP()
SELECTCASE GRP
CASE 1
	CALL VISIT_SERVE_TX_GRP1(ARG)
CASE 2
	CALL VISIT_SERVE_TX_GRP2(ARG)
CASE 3
	CALL VISIT_SERVE_TX_GRP3(ARG)
CASE 9
	CALL VISIT_SERVE_TX_GRP9(ARG)
CASE 4
	CALL VISIT_SERVE_TX_GRP4(ARG)
CASE 5
	CALL VISIT_SERVE_TX_GRP5(ARG)
CASE 6
	CALL VISIT_SERVE_TX_GRP6(ARG)
CASE 7
	CALL VISIT_SERVE_TX_GRP7(ARG)
CASEELSE
	CALL VISIT_SERVE_TX_GRP8(ARG)
ENDSELECT

CALL VISIT_SERVE_CLIMAX_FINISH
RETURN 1



@VISIT_SERVE_CLIMAX_FINISH
#DIM ADD_HP
#DIM ADD_SP
#DIM ADD_EP
#DIM ADD_MP

ADD_HP = MAXBASE:体力 / 8
ADD_SP = MAXBASE:气力 / 7
ADD_EP = MAXBASE:灵力 / 12
ADD_MP = MAXBASE:魔力 / 12
ADD_HP = LIMIT(ADD_HP, 80, MAXBASE:体力)
ADD_SP = LIMIT(ADD_SP, 80, MAXBASE:气力)
ADD_EP = LIMIT(ADD_EP, 40, MAXBASE:灵力)
ADD_MP = LIMIT(ADD_MP, 40, MAXBASE:魔力)

LOCAL:99 = TFLAG:侍奉口爆不射精

BASE:体力 = LIMIT(BASE:体力 + ADD_HP, 0, MAXBASE:体力)
BASE:气力 = LIMIT(BASE:气力 + ADD_SP, 0, MAXBASE:气力)
BASE:灵力 = LIMIT(BASE:灵力 + ADD_EP, 0, MAXBASE:灵力)
BASE:魔力 = LIMIT(BASE:魔力 + ADD_MP, 0, MAXBASE:魔力)

PRINTL
PRINTFORML 她还穿着那身内衣——蕾丝边勒进肉里，刚才一举一动都落在你眼底；她无意识地揪了下摆，像想把那点羞耻藏回绳缝里。
IF TFLAG:侍奉口爆不射精
	LOCAL:90 = LIMIT(MAXBASE:0:精力 / 90, 50, 450)
	BASE:0:精力 = LIMIT(BASE:0:精力 - LOCAL:90, 0, MAXBASE:0:精力)
	CALL MIND_BASE_DIRECT_PLUS("好感度", 32)
	CALL MIND_BASE_DIRECT_MINUS("尊严", 20)
	PRINTFORML 铃口抵着她湿热的唇缝突突直跳，她仍含着前端吮得发酸，却抬眼等你一声收——你硬生生按住腰，把要冲口的那股压了回去。
	PRINTFORML %CALLNAME%喉间闷哼半声，舌尖还恋恋地刮过铃口下缘；手背蹭去自己唇角的水痕，替你理衣襟时指尖却还在抖。
ELSE
	LOCAL:90 = LIMIT(MAXBASE:0:精力 / 35, 150, 1200)
	BASE:0:精力 = LIMIT(BASE:0:精力 - LOCAL:90, 0, MAXBASE:0:精力)
	CALL MIND_BASE_DIRECT_PLUS("好感度", 45)
	CALL MIND_BASE_DIRECT_MINUS("尊严", 25)
	PRINTFORML 精液的热度贴上舌面时她闭了闭眼，喉肌两下便咽净；唇角只剩一道白痕，被她迅速舔去。
	PRINTFORML %CALLNAME%呼气里混着咸腥与皂粉似的余味，额发贴在鬓角，替你理平衣襟下摆时指尖还有些颤。
ENDIF

SIF LOCAL:99
	TRYCALL KOJO_PRINT("访问", "侍奉口爆终了", "忍住", "")
SIF !LOCAL:99
	TRYCALL KOJO_PRINT("访问", "侍奉口爆终了", "咽下", "")

CFLAG:时刻限制／侍奉口爆 = 1
CFLAG:时刻限制／Ｈ = 1
TFLAG:亲密互动次数 ++
TFLAG:侍奉口爆不射精 = 0

PRINTFORML （%CALLNAME%：体力＋{ADD_HP}　气力＋{ADD_SP}　灵力＋{ADD_EP}　魔力＋{ADD_MP}）
PRINTFORMW （%CALLNAME:0%：精力－{LOCAL:90}）
PRINTW
RETURN 1



