
; 口上设置（切换显示、使用口上、颜色、专用等）
@KOJO_SETTING
#DIM COLOR

IF !FLAG:口上表示
	PRINTL 整个游戏的口上表示设置为OFF。切换到要显示的设置？
	CALL ASK_YN
	IF !RESULT
		FLAG:口上表示 = 1
	ELSE
		RETURN
	ENDIF
ENDIF

CLEARLINE LINECOUNT
CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT
PRINTL
PRINTFORML 设置%CALLNAME%台词　性格：【%CSTR:性格%】
CALL KOJO_PRINT("例文")
CALL PRINTL_ALIGN(-10)
PRINTFORM [ 0] 　　口上表示
CALL PRINT_ONOFF(CFLAG:口上表示,1)
IF CFLAG:口上表示
	PRINTFORML [ 1] 　　使用口上%CSTR:使用口上%
	PRINT [ 2] 　口上颜色：
	COLOR = CFLAG:颜色编码／口上
	IF COLOR
		SETCOLOR COLOR
		PRINTFORML %UNICODE(0x2586)%(R:{GETRED(COLOR)} G:{GETGREEN(COLOR)} B:{GETBLUE(COLOR)})
		RESETCOLOR
	ELSE
		PRINTL 未设置显示颜色。
	ENDIF
	SIF !LINEISEMPTY()
		PRINTL
	PRINTFORM [ 3] 　　专属口上
	CALL PRINT_ONOFF(CFLAG:专用设置／口上,1)
	PRINTFORM [ 4] 专属事件
	CALL PRINT_ONOFF(CFLAG:专用设置／事件,1)
ELSE
	CALL PRINTL_WORD_COLOR("　　　使用口上","灰")
	CALL PRINTL_WORD_COLOR("　　口上表示色","灰")
	CALL PRINTL_WORD_COLOR("　　　专属口上","灰")
	CALL PRINTL_WORD_COLOR("　专属事件","灰")
ENDIF
DRAWLINE
PRINTL [99] 完成
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	INVERTBIT CFLAG:口上表示,0
	
CASE 1
	PRINTL 请选择要使用口上。
	
	; RESULT = 枚举到的函数个数；RESULTS:0.. 为各函数全名
	ENUMFUNCWITH "KOJO_GENERAL_INDEX_"
		;FOR LOCAL,0,ENUMFUNCBEGINSWITH("KOJO_GENERAL_INDEX_")
	FOR LOCAL,0,RESULT
		PRINTFORMLC [{LOCAL,2}] %SUBSTRING(RESULTS:LOCAL,19,-1)%
	NEXT
	PRINTL
	PRINTL
	PRINTL [99] 取消
	BINPUT
	SIF RESULT >= 0 && RESULT < 99
		CSTR:使用口上 = %SUBSTRING(RESULTS:RESULT,19,-1)%
	
CASE 2
	CALL EDIT_COLOR_CODE(CFLAG:颜色编码／口上,1)
	SIF RESULT
		CFLAG:颜色编码／口上 = RESULT
		
CASE 3
	; 不传参 TRYCALL 以检测专用口上函数是否存在
	TRYCCALLFORM EX_KOJO_%CSTR:识别名%_%CSTR:原作名%
		PRINTFORML 使用[%CSTR:识别名%_%CSTR:原作名%]的专属口上吗？
		CALL ASK_YN
		IF !RESULT
			CFLAG:专用设置／口上 = 1
		ELSE
			CFLAG:专用设置／口上 = 0
		ENDIF
	CATCH
		PRINTW 找不到专属口上。
	ENDCATCH
	
CASE 4
	; 与事件侧专用入口对应
	TRYCCALLFORM EX_EVENT_EXIST_%CSTR:识别名%_%CSTR:原作名%
		PRINTFORML 使用[%CSTR:识别名%_%CSTR:原作名%]的专属事件吗？
		CALL ASK_YN
		IF !RESULT
			CFLAG:专用设置／事件 = 1
		ELSE
			CFLAG:专用设置／事件 = 0
		ENDIF
	CATCH
		PRINTW 找不到专属事件。
	ENDCATCH

CASE 99
	IF CSTR:使用口上 == ""
		PRINTW 关闭口上表示标志，因为使用口上为空。
		CFLAG:口上表示 = 0
	ENDIF
	RETURN
	
ENDSELECT
RESTART


