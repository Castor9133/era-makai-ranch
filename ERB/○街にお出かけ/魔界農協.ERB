
;魔界農協
@TOWN_AGRI_COOP
#DIM DYNAMIC SELECT_NUM

CLEARLINE LINECOUNT
CALL PET_HOUSE_BLANC_CHECK
CALL SHOW_RESOURCE_SHOP
PRINTL 可以更改牧场中饲养的宠物的食物和设备，以及进行资金相关的处理。
PRINTL
PRINTL [ 0] 改变宠物食品类型

CALL MILESTONE_UNLOCK_CHECK("魔界奶牛设备","")
IF !RESULT
	CALL PRINTL_WORD_COLOR,@"　奶农业Lv1","灰"
ELSE
	PRINTL [ 1] 魔界乳牛用的设备设置
ENDIF

CALL MILESTONE_UNLOCK_CHECK("不动产","L")
IF RESULT
	IF !FLAG:空闲宠物小屋数
		CALL PRINTL_WORD_COLOR,@"　需要有空余的＜宠物小屋＞。","灰"
	ELSE
		PRINTL [ 2] 欢迎新的大型宠物
	ENDIF
ENDIF
PRINTL

CALL MILESTONE_UNLOCK_CHECK("纳税","L")
SIF RESULT
	PRINTL [10] 纳税比例的更变
IF !MONEY
	CALL PRINT_WORD_COLOR("没有持有金","灰")
ELSEIF MONEY:经费计上 || MONEY:贷款
	PRINT [11] 早期偿还开销・贷款
ELSE
	CALL PRINT_WORD_COLOR("无开销记账・贷款","灰")
ENDIF
PRINTL 
IF MONEY < DONATION_UNIT
	CALL PRINT_WORD_COLOR("所持金不足。","灰")
ELSE
	PRINTL [12] 捐赠
ENDIF
CALL PRINTL_ALIGN(-5)
DRAWLINE
CALL RIGHT_RETURN_BUTTON
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL AGRI_COOP_PET_FOOD_SELECT
CASE 1
	CALL AGRI_COOP_COWSHED_DEVICE_SELECT
CASE 2
	CALL AGRI_COOP_BUY_BIG_PET
CASE 10
	CALL AGRI_COOP_TAX_RATIO_SELECT
CASE 11
	CALL AGRI_COOP_LOAN_REPAY
CASE 12
	CALL AGRI_COOP_DONATION
CASE 99
	RETURN
ENDSELECT
RESTART


