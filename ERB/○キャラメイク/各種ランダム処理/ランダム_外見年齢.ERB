
;奴隷候補の外見年齢
@RANDOM_SLAVE_VISUAL_AGE
#DIM AGE_FIX

LAST_SHUFFLE = CFLAG:外表年龄
IF CHILD_HEIGHT_CHECK(CSTR:身高)
	;子供下限～上限まで
	CFLAG:外表年龄 = VISUAL_AGE_MIN +RAND:(VISUAL_AGE_CHILD_MAX -VISUAL_AGE_MIN +1)
ELSE
	;子供上限+1～大人上限まで
	;高身長以上の場合フラグ見て補正
	;オトコ対応
	IF TALENT:男性
		IF CFLAG:身高 > MALE_HEIGHT_MAX_标准
			AGE_FIX = LIMIT(VISUAL_AGE_ADULT_MAX -VISUAL_AGE_CHILD_MAX -FLAG:高挑时的外表年龄修正,1,VISUAL_AGE_ADULT_MAX)
			CFLAG:外表年龄 = VISUAL_AGE_CHILD_MAX +1 +FLAG:高挑时的外表年龄修正 +RAND:AGE_FIX
		ELSE
			CFLAG:外表年龄 = VISUAL_AGE_CHILD_MAX +1 +RAND:(VISUAL_AGE_ADULT_MAX -VISUAL_AGE_CHILD_MAX)
		ENDIF
	ELSE
		IF CFLAG:身高 > HEIGHT_MAX_标准
			AGE_FIX = LIMIT(VISUAL_AGE_ADULT_MAX -VISUAL_AGE_CHILD_MAX -FLAG:高挑时的外表年龄修正,1,VISUAL_AGE_ADULT_MAX)
			CFLAG:外表年龄 = VISUAL_AGE_CHILD_MAX +1 +FLAG:高挑时的外表年龄修正 +RAND:AGE_FIX
		ELSE
			CFLAG:外表年龄 = VISUAL_AGE_CHILD_MAX +1 +RAND:(VISUAL_AGE_ADULT_MAX -VISUAL_AGE_CHILD_MAX)
		ENDIF
	ENDIF
ENDIF
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE == CFLAG:外表年龄
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0

