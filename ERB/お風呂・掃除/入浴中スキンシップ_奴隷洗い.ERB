
;体を洗うコマンド
@BATHLOOM_SLAVE_WASHING

CALL MANYL(5)
IF TFLAG:浴缸内
	PRINTFORML %CALLNAME:0%和%CALLNAME%从浴缸里爬出来。
	TFLAG:浴缸内 = 0
ENDIF

;成長中の娘は普通洗い一択
IF CSTR:状态／主人公的孩子 == "成长中"
	CALL BATHLOOM_SLAVE_WASHING_BODY
	CALL SOURCE_CHECK
	TFLAG:亲密互动次数 ++
	PRINTW
	RETURN
ENDIF
PRINTL 选择要洗的部位。
PRINTL
PRINTL [ 0] 全身洗
PRINTFORMLC [ 1] 仔细清洗%SAVESTR:标识／乳房%
PRINTLC [ 2] 仔细清洗乳头
PRINTFORML [ 3] 仔细清洗%SAVESTR:标识／阴蒂%和尿道
PRINTL
IF !TALENT:处女结界
	PRINTFORMLC [ 4] 仔细清洗%SAVESTR:标识／膣%
	IF !BASE:PLAYER:精力
		CALL PRINTL_WORD_COLOR,@"　%CALLNAME:PLAYER%的精力不足，无法插入。","灰"
		PRINTL
	ELSEIF PLAYER_PENIS
		PRINTFORML [ 5] 用%SAVESTR:标识／阴茎%仔细清洗%SAVESTR:标识／膣%
	ENDIF
ELSE
	CALL PRINTL_WORD_COLOR("　【处女结界】无法触及","灰")
ENDIF
PRINTFORMLC [ 6] 仔细清洗%SAVESTR:标识／肛门%
PRINTL [ 8] 灌肠洗净（洗屁眼）…下次调教开始时肛门较湿润
IF !BASE:PLAYER:精力
	CALL PRINTL_WORD_COLOR,@"　%CALLNAME:PLAYER%的精力不足，无法插入。","灰"
	PRINTL
ELSEIF PLAYER_PENIS
	PRINTFORML [ 7] 用%SAVESTR:标识／阴茎%仔细清洗%SAVESTR:标识／肛门%
ENDIF
PRINTL
PRINTL [99] 取消
BINPUT
PRINTL
IF CSTR:状态／主人公的孩子 == "成长后"
	SELECTCASE RESULT
	CASE IS != 0
		CHILD_COM = RESULT
		CALL CHILD_REBELLION
		SIF RESULT
			RETURN
		RESULT = CHILD_COM
	ENDSELECT
ENDIF
SELECTCASE RESULT
CASE 0
	CALL BATHLOOM_SLAVE_WASHING_BODY
CASE 1
	CALL BATHLOOM_SLAVE_WASHING_BUST
CASE 2
	CALL BATHLOOM_SLAVE_WASHING_NIPPLE
CASE 3
	CALL BATHLOOM_SLAVE_WASHING_CLITORIS
CASE 4
	CALL BATHLOOM_SLAVE_WASHING_VAGINA
CASE 5
	CALL BATHLOOM_SLAVE_WASHING_V_IN_PENIS
	
	;RETURN 99してきてたらキャンセル
	SIF RESULT == 99
		RETURN
CASE 6
	CALL BATHLOOM_SLAVE_WASHING_ANAL
CASE 8
	CALL BATHLOOM_SLAVE_WASHING_ANAL_ENEMA
CASE 7
	CALL BATHLOOM_SLAVE_WASHING_A_IN_PENIS
	SIF RESULT == 99
		RETURN
CASEELSE
	RETURN
ENDSELECT
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++
PRINTW



;全部位共通
@BATHLOOM_SLAVE_WASHING_COMMON_SOURCE

;部位洗いには快楽値含めないことにした　変なタイミングで絶頂するので
SOURCE:耻辱 = 300
SOURCE:爱情 = 300
SOURCE:屈辱 = 100
SOURCE:支配 = 200
SOURCE:调教者习得 = 100
CALL PRINT_IMAGE("调教执行")



;全身洗い
@BATHLOOM_SLAVE_WASHING_BODY

;全部位共通の感情SOURCE呼び
CALL BATHLOOM_SLAVE_WASHING_COMMON_SOURCE
CALL BATHLOOM_SLAVE_WASHING_BODY_MESSAGE

IF GROUPMATCH(CSTR:状态／主人公的孩子,"成长中","成长后")
	SOURCE:Ａ快感／主人公刺激 = 300
	SOURCE:Ｂ快感／主人公刺激 = 300
	SOURCE:Ｃ快感／主人公刺激 = 300
	SOURCE:Ｎ快感／主人公刺激 = 300
	SIF !TALENT:处女结界
		SOURCE:Ｖ快感／主人公刺激 = 300
	SOURCE:爱情 += 1000
ELSE
	CALL MIND_BASE_DIRECT_PLUS("好感度",50)
ENDIF



