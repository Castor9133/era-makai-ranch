
;おっぱい吸わせて
@VISIT_BREAST_FEEDING

;先に露出フラグの判定通す
CALL AJUST_STRIP_FLAG
PRINTFORML 请求%CALLNAME%让我吸吮%SAVESTR:标识／母乳%。
CALL KOJO_PRINT("吸欧派","开始")
CALL BREAST_FEEDING_MESSAGE_BEFORE
SOURCE:脱衣消息显示 = 1
SIF !CFLAG:崩坏 && (＃陷落状态／屈服以上＃)
	SOURCE:自主脱衣 = 1
TFLAG:Ｐ抽出后等待跳过 = 1

;状態により変える
IF TFLAG:授乳开口
	CALL OPEN_NIPPLE_SLIT
ELSEIF !TFLAG:Ｎ露出
	CALL TRAIN_CLOTHE_STRIP("总计","上半脱衣")
ENDIF
CALL BREAST_FEEDING_MESSAGE_ACTION
MILK_SUCK_PLAYER = %CALLNAME:0%
FOR LOCAL,0,3
	CALL BREAST_FEEDING_SOURCE
	SIF !LOCAL
		CALL PRINT_IMAGE("调教执行")
	CALL ONOMATOPOEIA("吸奶")
	CALL SOURCE_CHECK
	TFLAG:亲密互动次数 ++
	PRINTL
	
	IF !BASE:0:精力
		WAIT_SKIP = 1
		CALL COM890
		WAIT_SKIP = 0
		PRINTW
	ENDIF

	;LOCAL<2の時継続選択肢
	SIF LOCAL < 2
		CALL BREAST_FEEDING_CHOICE
	
	;RETURN1でおわり
	SIF RESULT
		BREAK
	
	;ちんぽ挿れててまだ射精してない+LOCAL=2の場合射精するまでピストンへ
	SIF TFLAG:Ｐ使用BIT && LOCAL == 2
		CALL EJACULATION_PISTON
NEXT
IF EX:喷乳
	PRINTFORML 品尝了%CALLNAME%的%SLANG_MILK()%…
ELSE
	PRINTFORML 想吸%CALLNAME%的%SLANG_MILK()%，但是没有流出来…
ENDIF
CALL KOJO_PRINT("吸欧派","结束")
CALL BREAST_FEEDING_MESSAGE_AFTER
CFLAG:时刻限制／授乳 = 1
CFLAG:时刻限制／Ｈ = 1
SELECTCOM = 0



;SOURCE
@BREAST_FEEDING_SOURCE

LOSEBASE:体力 += 10
LOSEBASE:气力 += 20
SOURCE:Ｂ快感／主人公刺激 = 500
SOURCE:Ｎ快感／主人公刺激 = 2000
SOURCE:耻辱 = 2000
SOURCE:爱情 = 5000
SOURCE:屈辱 = 2000
SOURCE:不洁 = 500
SOURCE:支配 = 2000
SOURCE:授乳 = 2000
SOURCE:调教者习得 = 100
TFLAG:搾乳刺激 = 1
TFLAG:吸奶 = 1

;ドレイン有効か処理　エナジードレイン適用外ならOFF
SIF ITEM:搾乳能量吸收 && GETBIT(＃个人有效／搾乳能量吸收＃) && GETBIT(＃有效／搾乳能量吸取＃)
	TFLAG:能量吸收 = 1



;乳吸い継続選択肢
@BREAST_FEEDING_CHOICE

IF !BASE:母乳生产力
	PRINTFORML 似乎%CALLNAME%的极限快要到了…
	RETURN 1
ENDIF
PRINTLC [ 0] 再吸一点
IF PLAYER_PENIS && !TALENT:处女结界 && !GETBIT(＃Ｐ使用／Ｖ插入＃) && BASE:0:精力
	LOCAL = ABL:0:阴茎尺寸 - ABL:Ｖ尺寸 - ABL:Ｖ扩张
	SIF LOCAL > 20 || (ABL:0:阴茎尺寸 - ABL:初始值／Ｖ尺寸 * 3 > 0 && LOCAL > 0)
		SETCOLOR BARCOLORSET("浅红色")
	PRINTFORMLC [ 1] 插入%SAVESTR:标识／膣%进行乳汁交换
	RESETCOLOR
ENDIF
IF GETBIT(＃Ｐ使用／Ｖ插入＃) && ITEM:灵力注入 && BASE:0:灵力 >= 10000 && BASE:0:精力
	PRINTLC [ 2] 注入灵力精液
ENDIF
PRINTLC [ 9] 喝够了
BINPUT
SELECTCASE RESULT
CASE 0
	PRINTFORML 想再喝点%CALLNAME%%SLANG_MILK()%…
CASE 1
	CALL VISIT_BREAST_FEEDING_MILK_SWAP
CASE 2
	PRINTFORML 向%CALLNAME%注入灵力精液…
	PRINTL
	CALL COM905
	IF RESULT
		CFLAG:时刻限制／灵力注入 = 1
		SELECTCOM = 905
		CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
		EXP:(SELECTCOM +1000) ++
	ELSE
		PRINTL 不再注入灵力精液…
	ENDIF
CASEELSE
	RETURN 1
ENDSELECT
PRINTL



;ミルク交換
@VISIT_BREAST_FEEDING_MILK_SWAP

;もうＶ挿入してたら帰る　ここで処女結界破壊はできないことにする
SIF GETBIT(＃Ｐ使用／Ｖ插入＃) || TALENT:处女结界
	RETURN
PRINTFORML 让我们也给%CALLNAME%注入一些奶…

;下も脱がす
SIF !TFLAG:Ｖ露出
	CALL TRAIN_CLOTHE_STRIP("总计","下半脱衣")
V_PENIS = %CALLNAME:0%
CALL COM30

;処女喪失の確認でRETURN 1してきていない場合はキャンセルする
;待てよやっぱやめた、になるけどまあ仕方ない
IF !RESULT
	PRINTW 决定不要插入了…
	RETURN
ENDIF
LOSEBASE:体力 += 20
LOSEBASE:气力 += 30
TFLAG:Ｖ装备 = 1
SETBIT ＃Ｐ使用／Ｖ插入＃
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
SELECTCOM = 30
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
EXP:(SELECTCOM +1000) ++
PRINTW



