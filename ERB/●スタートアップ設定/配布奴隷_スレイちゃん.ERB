
;スレイちゃんデータ変更
@CHARA_MAKE_FIXED_SLAVE_FIRST
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL CHARA_MAKE_SLAVE_DATA(PAGE,"初期设定")
CALL FIXED_SLAVE_CHANGE_LIST
CALL PRINTL_ALIGN(2)
PRINTFORMLC [80] 更改显示项目 <PAGE{PAGE,2}／{PAGE_MAX}>
PRINTFORML [89] 选择方式切换：\@ SELF_CHARA_MAKE_RANDOM ? 调整 # 手动输入 \@
DRAWLINE

;スレイちゃんは固定
PRINTLC [90] 回复默认值
PRINTLC [98] 提示
PRINTL [99] 完成
BINPUT
PRINTL
SELECTCASE RESULT
CASE 80
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 89
	INVERTBIT SELF_CHARA_MAKE_RANDOM,0
CASE 90
	;キャラリセット関数を呼ぶ
	CALL NEWGAME_CHARA_RESET(1)
	SIF !FLAG:候选比例／一般种族／人类
		CALL CHARA_MAKE_FIXED_SLAVE_TRIBE_QUESTION
CASE 98
	CALL BROWSE_HINT("斯蕾设置")
CASE 99
	IF !CFLAG:口上表示 && FLAG:口上表示
		CALL PRINTL_WORD_COLOR,@"没有设置口上，可以吗？","黄"
		CALL ASK_YN
		SIF RESULT
			RESTART
	ENDIF
	RETURN
CASEELSE
	CALL FIXED_SLAVE_CHANGE_INPUT(RESULT)
ENDSELECT
RESTART


