
;ニューゲーム時の処理
@EVENTFIRST

;オートセーブがある場合上書きしちゃうよ警告
CHKDATA 99
IF !RESULT
	PRINTL 存在自动保存数据。
	CALL PRINTL_WORD_COLOR("收到奴隶后，自动保存数据会被覆盖，您确定吗？","黄")
	PRINTL
	PRINTLC [ 0] OK
	PRINTL [ 1] 返回标题
	INPUT
	IF RESULT
		RESETDATA
		CLEARLINE LINECOUNT
		JUMP SYSTEM_TITLE
	ENDIF
ENDIF
CALL README

;ゲーム開始直後のセッティング
CALL NEWGAME_FLAG_SET

;ゲーム開始前コンフィグ・牧場状態変更
CALL NEWGAME_RANCH_SETTING

;オープニング→内部で見るか聞く
CALL PROLOGUE

;初期設定の反映
CALL SET_START_FLAG
CALL MANYL(10)
BEGIN SHOP


