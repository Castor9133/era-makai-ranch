
;基礎・プロフィールの変更
;ARG→PAGE
;ARG:1→INPUT_NUM
@SELF_CHARA_MAKE_PROFILE_INPUT(ARG,ARG:1)

;ページ+INPUT_NUMでINPUT_NUMを上書き
;INPUT_NUMで変更箇所を指定する
INPUT_NUM = (ARG -1) *100 +ARG:1
SELECTCASE INPUT_NUM
CASE 0
	CHANGE_STATE = 名称
CASE 1
	CHANGE_STATE = 种族
CASE 2
	CHANGE_STATE = 上位种族
CASE 3
	CHANGE_STATE = 职业
CASE 4
	CHANGE_STATE = 身份
CASE 5
	CHANGE_STATE = 所属
CASE 6
	CHANGE_STATE = 服装
CASE 7
	CHANGE_STATE = 进入魔界的目的
CASE 10
	CHANGE_STATE = 身高
CASE 11
	CHANGE_STATE = 体型
CASE 12
	CHANGE_STATE = 肤色
CASE 13
	CHANGE_STATE = 胸围大小
CASE 14
	CHANGE_STATE = 性经验


;2ページ目
CASE 100 TO 120
	;ARG:1が元々のINPUT_NUM
	SIF TALENTNAME:(ARG:1 +TALENT_REF) == ""
		RETURN
	INVERTBIT TALENT:(ARG:1 +TALENT_REF),0
	
	;エルフ耳／ハーフリング耳は片方だけ
	SIF TALENTNAME:(ARG:1 +TALENT_REF) == "精灵耳"
		TALENT:半身人耳 = 0
	SIF TALENTNAME:(ARG:1 +TALENT_REF) == "半身人耳"
		TALENT:精灵耳 = 0
	RETURN


;3ページ目
CASE 200
	CHANGE_STATE = 性格
CASE 201
	CHANGE_STATE = 台词
	
;変更用関数に飛ばすようにした
CASE 210
	CHANGE_STATE = 第一人称
CASE 211
	CHANGE_STATE = 陷落前的主人公的称呼
CASE 212
	CHANGE_STATE = 陷落后的主人公的称呼
CASE 213
	CHANGE_STATE = 阴茎称呼
CASE 214
	CHANGE_STATE = 膣称呼
CASE 215
	CHANGE_STATE = 肛门称呼
ENDSELECT

;SELF_CHARA_MAKE_RANDOMが有効かどうかで呼ぶ関数変更
IF SELF_CHARA_MAKE_RANDOM
	CALL SELF_CHARA_MAKE_PROFILE_INPUT_SHUFFLE(CHANGE_STATE)
ELSE
	CALL SELF_CHARA_MAKE_PROFILE_INPUT_MANUAL(CHANGE_STATE)
ENDIF




