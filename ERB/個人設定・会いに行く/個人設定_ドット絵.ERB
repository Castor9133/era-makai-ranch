
;ドット絵・画像個人設定
@SLAVE_CONFIG_PORTRAIT

CLEARLINE LINECOUNT
CALL SHOW_SLAVE_STATE
PRINTLC [ 0] 人物画像OFF
CALL PRINT_ONOFF(CFLAG:表示OFF／头像)
CALL PRINTL_WORD_COLOR,@"　完整：\@ FLAG:头像／显示 ? ON 　 # OFF　 \@","黄"
PRINTLC [ 1] 像素画关闭
CALL PRINT_ONOFF(CFLAG:表示OFF／像素画)
CALL PRINTL_WORD_COLOR,@"　完整：\@ FLAG:像素画／显示 ? ON 　 # OFF　 \@","黄"
PRINTL
PRINTL 　《 像素画调整 》
PRINTLC [ 2] 像素画种族特征（背后）OFF
CALL PRINT_ONOFF(CFLAG:像素画设定／背后特征OFF,1)
PRINTLC [ 3] 像素画背景关闭
CALL PRINT_ONOFF(CFLAG:像素画设定／背景OFF,1)

IF CFLAG:身高 < FLAG:像素画／娇小适用上限数值
	PRINTLC [ 4] 像素画背部装饰高度调节
	CALL PRINT_ONOFF(CFLAG:像素画设定／背后高度调整,1)
ELSE
	CALL PRINTL_WORD_COLOR("　不被视为娇小，因此无效。","灰")
ENDIF

CALL PRINTL_ALIGN
DRAWLINE
PRINTL [99] 完成
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	INVERTBIT CFLAG:表示OFF／头像,0
CASE 1
	INVERTBIT CFLAG:表示OFF／像素画,0
CASE 2
	INVERTBIT CFLAG:像素画设定／背后特征OFF,0
CASE 3
	INVERTBIT CFLAG:像素画设定／背景OFF,0
CASE 4
	SIF CFLAG:身高 < FLAG:像素画／娇小适用上限数值
		INVERTBIT CFLAG:像素画设定／背后高度调整,0
CASE 99
	RETURN
ENDSELECT
RESTART


