
;傭兵を雇う
@EMPLOYMENT_MERCENARY

SIF CFLAG:追踪者
	RETURN
CALL ITEM_SHOP_BUDGET_MONEY_JUDGE
CLEARLINE LINECOUNT
PRINTFORML 选择兼职雇佣兵。
CALL SHOW_MONEY
CALL SHOW_BUDGET(1)
DRAWLINE

;FLAG:傭兵バイト標的ID／ゴブリン→440
;STR:ゴブリン軍団→3820
FLAG_REF = 440 -1
STR_REF = 3820 -1
FOR LOCAL,1,5
	SIF FLAGNAME:(FLAG_REF +LOCAL) == ""
		BREAK
	IF !FLAG:(FLAG_REF +LOCAL)
		;ゴブリンと他で変化
		IF LOCAL == 1
			PRINTFORML [{LOCAL,2}] %STR:(STR_REF +LOCAL),12%：%VALUE_DIGIT(MERCENARY_REWORD:LOCAL)%G／部队
		ELSE
			PRINTFORML [{LOCAL,2}] %STR:(STR_REF +LOCAL),12%：%VALUE_DIGIT(MERCENARY_REWORD:LOCAL)%G／人
		ENDIF
	ELSE
		CALL PRINTL_WORD_COLOR,@"%STR:(STR_REF +LOCAL),12%的人在追捕另一个目标","灰"
	ENDIF
NEXT
CALL PRINTL_ALIGN(-5)
PRINTFORML [9] 用于无法选择时的重置按钮
DRAWLINE
CALL RIGHT_RETURN_BUTTON(1)
BINPUT
INPUT_NUM = RESULT
PRINTL
SELECTCASE INPUT_NUM
CASE 0 TO 4
	COST = MERCENARY_REWORD:INPUT_NUM
	CALL MERCENARY_TRIBE(INPUT_NUM)
	CALL MERCENARY_BATTLE_DATA(INPUT_NUM)
	
	;ここだけGOTO必要
	$RETURN_BUDGET
	CALL MERCENARY_COST(INPUT_NUM)
	BINPUT
	PRINTL
	IF RESULT >= 1 && RESULT <= 3
		IF FLAG:购物／开销记账
			MONEY:经费计上 += (COST *RESULT)
		ELSE
			MONEY -= (COST *RESULT)
		ENDIF
		CFLAG:追踪者 = INPUT_NUM
		CFLAG:追踪人数 = RESULT
		FLAG:(FLAG_REF +INPUT_NUM) = CFLAG:ID
		PRINTFORMW %VALUE_DIGIT(COST *RESULT)%Gを支払い浓密%STR:(STR_REF +INPUT_NUM)%雇佣了{RESULT}%GROUP_CALL%。
	ELSEIF RESULT == 90
		FLAG:购物／开销记账 = 0
		GOTO RETURN_BUDGET
	ENDIF
CASE 9
	PRINTL 
	PRINTL 将重置所有任务状态
	PRINTL 请在正常运作的追踪中或运输中的佣兵完成任务后执行。
	PRINTL 
	CALL ASK_YN
	IF !RESULT
		FLAG_REF = 440
		FLAG_MAX = 4
		FOR LOCAL,FLAG_REF,FLAG_REF +FLAG_MAX
			FINDCHARA CFLAG:ID,FLAG:LOCAL
			IF RESULT > 0
				FLAG:LOCAL = 0
				CFLAG:RESULT:追踪者 = 0
				CFLAG:RESULT:追踪人数 = 0
			ENDIF
		NEXT
		PRINTW 已重置所有任务状态
	ENDIF
CASE 98
	CALL BROWSE_HINT("雇佣兵打工雇佣")
CASE 99
	RETURN
ENDSELECT
RESTART



;戦闘能力
;ARG→INPUT
@MERCENARY_BATTLE_DATA(ARG)

;TFLAGを持ってくる
;追跡者→ARG,人数は1でOK
CALL CHASE_SLAVE_MONSTER_PALAM_SET(ARG,1)

;ゴブリンと他で部隊／匹
IF ARG == 1
	GROUP_CALL = 部队
ELSE
	GROUP_CALL = 人
ENDIF
PRINTL
PRINTFORML 每个%GROUP_CALL%的合同金额：%VALUE_DIGIT(COST)%G
{
PRINTFORML 战斗力：%VALUE_DIGIT(TFLAG:兼职战斗力／最大值)%（基础%VALUE_DIGIT(MERCENARY_POWER:ARG)%
+军事Lv修正%VALUE_DIGIT(MERCENARY_POWER_LVFIX:ARG *FLAG:魔界等级／军事)%）
}
{
PRINTFORML 攻击力：%VALUE_DIGIT(TFLAG:兼职攻击力)%（基础%VALUE_DIGIT(MERCENARY_ATTACK:ARG)%
+军事Lv修正%VALUE_DIGIT(MERCENARY_ATTACK_LVFIX:ARG *FLAG:魔界等级／军事)%）攻击次数：{MERCENARY_ATTACK_NUM:ARG}
}

SELECTCASE ARG
CASE 1
	;ゴブリンくんたちは多いので部隊数で索敵能力低下（不意打ち確率低下）
	PRINTFORML 索敌能力：{MERCENARY_SEARCH:ARG}-5×部队数
CASE 2
	;ルーキーくんたちはLv6ごとに攻撃回数+1入れる・Lvごとに索敵値+10
	PRINTFORML 索敌能力：{MERCENARY_SEARCH:ARG}（仅限新手）每个军事Lv{MERCENARY_ATTACK_NUM_PLUS}的攻击次数+1・索敌值增加Lv×{MERCENARY_SEARCH_FIX}
CASEELSE
	PRINTFORML 索敌能力：{MERCENARY_SEARCH:ARG}
ENDSELECT
PRINTL



;雇用費用
;ARG→INPUT
@MERCENARY_COST(ARG)
#DIM BUDGET_OVER

IF FLAG:购物／开销记账
	PRINT ＜开销记账＞
	CALL SHOW_BUDGET(1)
ELSE
	PRINT ＜持有金＞
	CALL SHOW_MONEY(1)
ENDIF
BUDGET_OVER = 0
FOR LOCAL,1,4
	;経費計上の時超過しない
	IF FLAG:购物／开销记账 && COST *LOCAL > USE_MONEY
		CALL PRINTL_WORD_COLOR("雇佣兼职的不能超支经费","灰")
		BUDGET_OVER ++
		BREAK
	ELSEIF !FLAG:购物／开销记账 && COST *LOCAL > MONEY
		CALL PRINTL_WORD_COLOR("所持金不足。","灰")
		BREAK
	ENDIF
	PRINTFORML [{LOCAL,2}] {LOCAL}雇佣%GROUP_CALL%：%VALUE_DIGIT(COST *LOCAL)%G
NEXT
PRINTL

;経費超過していたら所持金支払い選択肢を出す
SIF BUDGET_OVER
	PRINTL [90] 换成持有金
PRINTL [99] 取消



;バイト説明
;ARG→INPUT
@MERCENARY_TRIBE(ARG)

SELECTCASE ARG
CASE 1
	PRINTL 哥布林领主的戈罗先生率领的低级魔族，哥布林军团。
	PRINTL 他们的数量多，具有高强度搜索和攻击次数多的特点。
	PRINTL 听说这是捉拿人类女性的工作，兴高采烈，似乎合同费用不会太高。
	CALL PRINT_WORD_COLOR("但是，他们可能会对捉拿的人类女性进行侵犯。","黄")
	PRINTL 即使戈罗先生阻止也可能是徒劳的。
	PRINTL 可能是因为没有太多的哥布林有钱进去整理装备的想法，所以即使军事Lv提升了，强度也不会提升多少。
	
CASE 2
	PRINTL 还是新秀雇佣兵打工的鸟人魔物，基尔君和他的伙伴。
	PRINTL 由于无法与老手雇佣兵相提并论，契约金相对较为实惠。
	PRINT 能力还不够成熟，但
	CALL PRINTL_WORD_COLOR("有时候能够凭直觉躲避对手的大招并回避。","黄")
	PRINTL 干劲比别人强一倍，军事Lv的战斗力增加非常大期待的新人。
	
CASE 3
	PRINTL 一位经验丰富的雇佣兵，吹火蜥蜴的魔物，泰拉大叔和他的同伴。
	PRINTL 由于是老手，所有能力都达到了高水平，尤其是在搜索能力方面表现出色。
	PRINTL 由于采用了保守的战斗方式，对于削弱对手力量的目标可能不太擅长。
	PRINTL 因为作为战士已经接近完成，即使军事Lv上升强化比例也是保守的。
	
CASE 4
	PRINTL 是魔界中拥有最强韧肉体的鬼人族兼职雇佣兵人高兹和他的同伴。
	PRINTL 压倒性的体力，加上攻击力速度也具备2次攻击可能。
	PRINT 但这可能是种族本身的特征
	CALL PRINTL_WORD_COLOR("索敌能力差很多，","黄")
	PRINTL 体格庞大，想喝点酒，契约金非常高。
	PRINTL 因为本来就很强，所以即使军事Lv上升，强化比例也很保守。
ENDSELECT

