CASE "Ｖ指插入"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「哈啊♥ 指头进来了啦啦♥ %MASTER_CALL()%的手指里面咿♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
