
;部屋割り変更
@ROOM_ALLOCATION
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTL 请选择要分配自室／寮的奴隶。分配房间后将被视为【员工】。
PRINTL （事务日程可用・休息时的恢复量增加・生活费略有增加）
PRINTL

;人数数えて牧場情報と共通部分
CALL CALC_PEOPLE_FLAG
CALL PRINT_ROOM_ALLOCATION
DRAWLINE
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	IF CFLAG:追踪对象
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：未捕获","灰"
	ELSEIF CSTR:住处 == "体内"
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：体内","灰"
	ELSEIF CSTR:状态／主人公的孩子 == "成长中"
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：成长中的女孩不可更换房间。","灰"
	ELSE
		PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
		CALL PRINT_POST_C
		CALL TABLE_STATUS("房间分配变更")
		SIF !LINEISEMPTY()
			PRINTL
	ENDIF
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  8] 更改显示项目
PRINTLC 　
PRINTL [ 99] 完成
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN

CASEELSE
	TARGET = RESULT -100
	CALL VISIT_ALLOCATION_ROOM
ENDSELECT
RESTART








