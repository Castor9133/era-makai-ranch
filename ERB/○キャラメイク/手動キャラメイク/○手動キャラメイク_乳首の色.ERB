
;乳首の色ちょっと長いのでここ
@SELECT_NIPPLE_COLOR

CALL MANYL(3)
PRINTL 请选择乳头的颜色。
SETCOLOR NIPPLE_COLOR_CODE_PINK
PRINTLC [ 0] 粉红色
SETCOLOR NIPPLE_COLOR_CODE_DEEPPINK
PRINTLC [ 1] 深粉色
SETCOLOR NIPPLE_COLOR_CODE_HOTPINK
PRINTLC [ 2] 亮粉色
SETCOLOR NIPPLE_COLOR_CODE_CHERRYPINK
PRINTLC [ 3] 樱桃粉
SETCOLOR NIPPLE_COLOR_CODE_LIGHTPINK
PRINTLC [ 4] 浅粉色
SETCOLOR NIPPLE_COLOR_CODE_RUBYRED
PRINTLC [ 5] 宝石红
SETCOLOR NIPPLE_COLOR_CODE_RUSSETBROWN
PRINTLC [ 6] 栗棕色
SETCOLOR NIPPLE_COLOR_CODE_BROWN
PRINTLC [ 7] 棕色
RESETCOLOR
CALL INPUTBUTTON
INPUT
SELECTCASE RESULT
CASE 0
	CSTR:乳头颜色 = 粉红色
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_PINK
	
CASE 1
	CSTR:乳头颜色 = 深粉色
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_DEEPPINK
	
CASE 2
	CSTR:乳头颜色 = 亮粉色
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_HOTPINK
	
CASE 3
	CSTR:乳头颜色 = 樱桃粉
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_CHERRYPINK
	
CASE 4
	CSTR:乳头颜色 = 浅粉色
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_LIGHTPINK
	
CASE 5
	CSTR:乳头颜色 = 宝石红
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_RUBYRED
	
CASE 6
	CSTR:乳头颜色 = 栗棕色
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_RUSSETBROWN
	
CASE 7
	CSTR:乳头颜色 = 棕色
	CFLAG:颜色编码／乳头 = NIPPLE_COLOR_CODE_BROWN
	
CASE 901
	CALL MANYL(3)
	PRINTL 请输入乳头颜色的显示名称。
	PRINTL （颜色编码请另行输入）
	INPUTS
	SIF RESULTS != ""
		CSTR:乳头颜色 = %RESULTS%
ENDSELECT



