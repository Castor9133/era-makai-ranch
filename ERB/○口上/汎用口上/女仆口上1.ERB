@KOJO_GENERAL_INDEX_女仆1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

IF TFLAG:Ｍ装备
	CALL KOJO_GENERAL_MOUTH_SHACKLE_1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
	RETURN
ELSEIF CFLAG:崩坏 && !CFLAG:洗脑
	IF GROUPMATCH(ARGS:0,"例文")
	ELSEIF GROUPMATCH(ARGS:1,"洗脑触手","崩坏")
	ELSE
		IF NOWEX:总绝顶
			CALL MESSAGE_BOX,@"「对、对不起……已经……脑子一片空白……要去了……♥」"
			CALL MESSAGE_BOX,@"「……撑、撑不住了……手也好腿也好……都听您的……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……听您的……我……在……」"
		ENDIF
		RETURN
	ENDIF
ENDIF

SELECTCASE ARGS:0
CASE "身体"
	CALL KOJO_GENERAL_女仆1_EXCRETION_BODY(ARGS:1, ARGS:2)
	RETURN
CASE "例文"
	CALL MESSAGE_BOX,@"「【女仆1】已设置。\n规矩、侍奉、克制的羞；更偏“贴身照料”的口吻——会听命，也会留意她累不累、别没精神还硬撑。」"

