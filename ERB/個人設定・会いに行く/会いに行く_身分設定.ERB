
;新身分
@VISIT_SETTING_NEW_POSITION_BEFORE

;身分を変えてる場合
IF EQUIP:家畜管理标签／身分
	PRINTL 回复原身份标识？（取下<家畜管理标签>）
	CALL ASK_YN
	SIF RESULT
		RETURN
	EQUIP:家畜管理标签／身分 = 0
	CSTR:身份 = %CSTR:初始值／身分%
	CFLAG:表示OFF／种族表示 = 0
	RETURN
ENDIF

;STR:身分・名前候補文面→5500
STR_REF = 5500
STR_MAX = 50
CALL VISIT_SETTING_NEW_POSITION



;新身分
@VISIT_SETTING_NEW_POSITION
#DIMS DYNAMIC NEW_POSITION
#DIM DYNAMIC PAGE

PAGE_MAX = 3
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML 将单词组合在一起，为%CALLNAME%设置一个新的身份。（＜家畜管理标签＞持有数量：{ITEM:家畜管理标签}）
PRINT 当前身份：
IF CSTR:身份 == ""
	CALL PRINTL_WORD_COLOR("【未设置】","灰")
ELSE
	PRINTFORML 【%CSTR:身份%】
ENDIF
PRINT 当前候选：
SIF !CFLAG:表示OFF／种族表示
	CALL PRINT_TRIVE
PRINTFORML 【%NEW_POSITION%】
CALL PRINT_TAG_WORD_CATEGORY(PAGE)
DRAWLINE
BR = 0
FOR LOCAL,STR_REF,STR_REF +STR_MAX
	SIF STR:LOCAL == ""
		CONTINUE
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
NEXT
CALL PRINTL_ALIGN(-5)
PRINTFORMLC [101] %CSTR:种族%
SIF CSTR:职业 != ""
	PRINTFORMLC [102] %CSTR:职业%
PRINTFORMLC [103] %CSTR:主人公的称呼／陷落后%
SIF CSTR:初始值／身分 != ""
	PRINTFORMLC [104] %CSTR:初始值／身分%
SIF CSTR:所属 != ""
	PRINTFORMLC [105] %CSTR:所属%
PRINTL
PRINTLC [110] （手动输入）
PRINTLC [111] （重置）
PRINTFORML [112] 种族表示：\@ CFLAG:表示OFF／种族表示 ? OFF # ON \@
DRAWLINE
PRINTLC [ 90] 完成
PRINTFORMLC [ 91] 页面切换：{PAGE}／{PAGE_MAX}
PRINTL [ 99] 取消
BINPUT
PRINTL
SELECTCASE RESULT
CASE 101
	NEW_POSITION += CSTR:种族
CASE 102
	NEW_POSITION += CSTR:职业
CASE 103
	NEW_POSITION += CSTR:主人公的称呼／陷落后
CASE 104
	NEW_POSITION += CSTR:初始值／身分
CASE 105
	NEW_POSITION += CSTR:所属
CASE 110
	PRINTL 请输入。（将添加到当前候选文后）
	INPUTS
	NEW_POSITION += RESULTS
CASE 111
	NEW_POSITION =
CASE 112
	INVERTBIT CFLAG:表示OFF／种族表示,0
CASE 90
	SIF NEW_POSITION == ""
		RETURN
	PRINTFORML %CALLNAME%的新身份是【%NEW_POSITION%】吗？（消费1个＜家畜管理标签＞）
	CALL ASK_YN
	SIF RESULT
		RESTART
	ITEM:家畜管理标签 --
	EQUIP:家畜管理标签／身分 = 1
	CSTR:身份 = %NEW_POSITION%
	PRINTFORML 已给%CALLNAME%添加了＜家畜管理タグ＞。
	PRINTFORML 标签上刻有%CALLNAME%的新身份，即【%NEW_POSITION%】的文字…
	
	;屈辱的な名前かチェック
	CALL CHECK_DISGRACE_WORD(NEW_POSITION)
	IF RESULT
		CALL KOJO_PRINT("访问","身份变更","屈辱的")
	ELSE
		CALL KOJO_PRINT("访问","身份变更","普通")
	ENDIF
	PRINTW
	RETURN
	
CASE 91
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	STR_REF = 5500 +(PAGE -1) *50
CASE 99
	SIF CSTR:身份 == CSTR:初始值／身分
		CFLAG:表示OFF／种族表示 = 0
	RETURN
CASEELSE
	NEW_POSITION += STR:(RESULT +STR_REF)
ENDSELECT
RESTART



;カテゴリ表示
;ARG→PAGE
@PRINT_TAG_WORD_CATEGORY(ARG)

ALIGNMENT CENTER
SELECTCASE ARG
CASE 1
	PRINTFORML --- %SAVESTR:标识／乳房% ---
CASE 2
	PRINTL --- 其他性器・性行为 ---
CASE 3
	PRINTL --- 性奴隶、家畜、所有物 ---
ENDSELECT
ALIGNMENT LEFT

