@COM110
;ブラシ触手
;装備として処理されずに別の装備をつけたらひっこむ

;ブラシ触手は番号違う
IF TEQUIP:刷子触手
	VARSET TEQUIP,0,150,160
	TRYCALLFORM COM{SELECTCOM}_REMOVE_MESSAGE
	RETURN 1
ENDIF
LOSEBASE:气力 += 10
SOURCE:异形恐惧 += 500
SOURCE:已用时间 = 1
CALL OPEN_NIPPLE_SLIT

;部位ごとに判断
SIF !TFLAG:Ｎ装备 && TFLAG:Ｎ露出
	TEQUIP:刷子触手Ｎ = 1
SIF !TFLAG:Ａ装备 && TFLAG:Ａ露出
	TEQUIP:刷子触手Ａ = 1
SIF !TFLAG:Ｂ装备 && TFLAG:Ｂ露出
	TEQUIP:刷子触手Ｂ = 1
SIF !TFLAG:Ｃ装备 && TFLAG:Ｃ露出
	TEQUIP:刷子触手Ｃ = 1

;Ｖのみ処女結界も判定
SIF !TALENT:处女结界 && !TFLAG:Ｖ装备 && TFLAG:Ｖ露出
	TEQUIP:刷子触手Ｖ = 1
TEQUIP:刷子触手 = 1

;コマンドを選んだフラグがないと解除しちゃう
SOURCE:刷子触手指令 = 1
RETURN 1



@COM112
;触手目隠し
;経過時間なし

IF TEQUIP:SELECTCOM
	TRYCALLFORM COM{SELECTCOM}_REMOVE
	TRYCALLFORM COM{SELECTCOM}_REMOVE_MESSAGE
	RETURN 1
ENDIF
TEQUIP:触手遮眼 = 1

;経過時間ない場合汎用装備フラグも必要
TFLAG:眼罩 = 1
TRYCALLFORM COM{SELECTCOM}_MESSAGE
EXP:(SELECTCOM +1000) ++
RETURN 1



