; ARGS:0 场景；ARGS:1～ 用于更细分
@KOJO_GENERAL_姉御肌1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

; 进入本函数时 ARGS:0 固定为「调教命令」
; 按命令与情境分支；名称见 TRAIN.csv
; 当前流程：@COM 地之文 → 口上

SELECTCASE ARGS:1
CASE "揉胸","育乳按摩","浓厚母乳按摩","乳罐按摩"
	; 从此处起按变体分支；分支越多越有趣也越费工。
	; 分支方式自定，常按好感/陷落等状态分较省事。
	
	; 先看是否「首次」：EXP:(SELECTCOM +1000)++ 放在口上表示**之后**执行
	; 故该值为 0 表示该角色尚未经历过本命令
	; 细节略，用下方 IF 做首次即可
	; 隶属乳牛从未揉胸只挤奶…倒也可能
	; 写 \n 会换行；源码里用 Enter 换行不符合规范
	; 连续两次 CALL 只会显示其一，故不能靠双 CALL 凑换行
	
	IF !EXP:(SELECTCOM+1000)
		; 不直接显示，先 CALL MESSAGE_BOX 把候选台词放进「箱子」
		; 参考了触手宫氏口上
		; [MASTER_CALL]：对主人的称呼（如「主人」）
		; [SWEET_MASTER_CALL]：撒娇式称呼（如「主银～」）
		; [SELF_CALL]：第一人称（如「我」）
		; ♥ 显示时会变成心形符号
		
		;乳牛、隶属、洗脑时
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「%SWEET_MASTER_CALL()%♥ %SELF_CALL()%的奶子想揉吗♥♥\n　随你便，乱搞一通吧♥ %SELF_CALL()%的身体是%MASTER_CALL()%的『东西』所以啊♥♥」"
		
		; 用 ELSE 则不会进入随机候选池
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%的奶子，随你自由摆弄哦…♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「嗯…揉这种东西…开心吗…？♥」"
		; 也可按素质等再分支
		ELSE
			CALL MESSAGE_BOX,@"「可恶っ，别碰啊！」"
		ENDIF
		; 首次分支为确保只显示上述内容，此处 RETURN
		RETURN
		
	ENDIF
	;乳牛、隶属、洗脑时
	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「喂，♥ %SWEET_MASTER_CALL()%♥ 把%SELF_CALL()%的奶子搞得乱七八糟的♥♥」"
		CALL MESSAGE_BOX,@"「做到你满意为止…♥ %SELF_CALL()%的奶子是%MASTER_CALL()%的『东西』啊…♥♥」"
		CALL MESSAGE_BOX,@"「哈啊啊♥ 奶子被揉搓，太爽了呜呜…♥♥」"
		
		; 即使连续写多条，一次口上调用也只会随机显示其中一条
		; MESSAGE_BOX：向箱中投放 → 从箱中抽一条显示
		; 可按条件追加候选，例如胸围达丰乳以上时追加
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%饱满成长的奶子，尽管收获吧♥♥」"
		; 还可追加其它条件分支
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「像%SELF_CALL()%这样的小奶子你也愿意疼爱呢…♥♥」"
		; 本次调教 B 绝顶累计 100 次以上
		; 注：NOWEX 写在「调教命令」段多为死分支，此处用 EX 累计更合适
		; 适合写「再被○○就不行了」类临场感台词
		SIF EX:Ｂ绝顶 >= 100
			CALL MESSAGE_BOX,@"「啊啊啊っ♥♥ 要死了♥♥ 现在奶子被碰的话，%SELF_CALL()%会完蛋的っ♥♥」"
	
	ELSEIF ＃陷落状态／恋慕以上＃
		; 恋慕线可比上面略矜持
		CALL MESSAGE_BOX,@"「%SELF_CALL()%的奶子，你可以尽兴玩到满足哦…？♥」"
		CALL MESSAGE_BOX,@"「呵呵…♥ 想揉奶子吗…？♥♥」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「嘿嘿…♥ %SELF_CALL()%引以为豪的奶子，%MASTER_CALL()%可以随便弄哦♥♥」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「像%SELF_CALL()%这样小巧的奶子，%MASTER_CALL()%也说可以吗…♥♥」"
		
	ELSEIF ＃陷落状态／陷落以上＃
		; 宜先写苛刻条件，否则易总命中上方分支
		CALL MESSAGE_BOX,@"「嗯…%MASTER_CALL()%还真是喜欢奶子呢…♥」"
		CALL MESSAGE_BOX,@"「好啦好啦…做到满意为止吧…♥」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「嗯…真是的…男人这东西，够大就行了吗…？ …嘛，%MASTER_CALL()%高兴的话那就好…」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「男人不是都喜欢大的吗…？%SELF_CALL()%的没法满足你吧…\n　…倒是一脸满足的表情呢… 那就算了…」"
	
	ELSEIF ＃陷落状态／屈服以上＃
		; 比下段更「认命」
		CALL MESSAGE_BOX,@"「嗯…这种脂肪块…有什么好的…」"
		CALL MESSAGE_BOX,@"「已经随你便了…」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「哈啊…真是的…男人这东西，够大就行了吗…？」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「玩弄%SELF_CALL()%小巧的奶子开心吗…？\n　…啊，是吗…开心吗…」"
	
	ELSE
		; 无反抗刻印/枷锁但性格反抗 → 傲娇口吻
		CALL MESSAGE_BOX,@"「可恶っ，放开！别随便乱碰啊！」"
		CALL MESSAGE_BOX,@"「凭什么随便乱揉啊！」"
		CALL MESSAGE_BOX,@"「切，真恶心！搞什么鬼…！」"
	ENDIF
	; 揉胸分支到此…不短吧？
	
; 以下继续其它调教命令
CASE "榨乳"
	IF !EXP:(SELECTCOM+1000)
		; 按是否母乳体质分支
		IF MARK:母乳体质
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「嗯哦哦ーっ♥♥ 乳汁♥ 乳汁被挤掉♥♥」"
			ELSEIF ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
				CALL MESSAGE_BOX,@"「嗯哈啊♥ 奶子被挤掉♥♥」"
			ELSEIF ＃陷落状态／屈服以上＃
				CALL MESSAGE_BOX,@"「啊哈…♥ 这样，简直像被当『家畜』对待…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「住手っ，别碰！%SELF_CALL()%可没打算当什么家畜啊！」"
			ENDIF
		ELSE
			IF ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
				CALL MESSAGE_BOX,@"「嗯嗯、啊♥ 就算挤奶子也出不来母乳哦♥」"
			ELSEIF ＃陷落状态／屈服以上＃
				CALL MESSAGE_BOX,@"「っ…啊哈♥ 就算像『家畜』一样被挤也什么都出不来啊…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「住手っ，别碰！%SELF_CALL()%可没打算当什么家畜啊！」"
			ENDIF
		ENDIF
		RETURN
	ENDIF
	IF MARK:母乳体质
		IF ABL:搾乳中毒 >= 10
			CALL MESSAGE_BOX,@"「啊ーっ♥♥ 嗯啊呜♥ 哈嘿っ♥♥ 更多♥ 更加挤吧ぇ♥♥」"
			CALL MESSAGE_BOX,@"「嗯啊っ♥♥ 乳汁出来ぅ♥ 出来好舒服っ♥ 啊啊啊っ♥♥」"
			CALL MESSAGE_BOX,@"「咕噜咕噜っ♥ 咕噜呜呜っ♥♥ 乳汁出来去了呜♥♥」"
		ENDIF
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「哈ーっ♥ 哈ーっ♥ 榨乳♥ 榨乳更加♥♥ 把%SELF_CALL()%的乳汁榨干♥♥」"
			CALL MESSAGE_BOX,@"「哈嘿っ♥ 哈嘿っ♥♥ %SWEET_MASTER_CALL()%♥ 喜欢被挤ぃ♥ 喜欢从奶头出乳汁ぃぃ♥♥」"
			CALL MESSAGE_BOX,@"「求求你っ♥ 挤吧っ♥ 忍不住被挤っ♥ 奶子忍不住了っ♥♥」"
			CALL MESSAGE_BOX,@"「哈啊啊♥ %SELF_CALL()%的奶子里っ♥ %MASTER_CALL()%的手指嵌进来了ぅ♥♥」"
			SIF ABL:胸围大小 >= BUSTSIZE_爆乳
				CALL MESSAGE_BOX,@"「哈啊ーっ…哈啊ーっ♥ %SELF_CALL()%满满的奶子，想出乳汁想得忍不住了哦♥♥」"
			SIF EX:Ｂ绝顶 >= 100
				CALL MESSAGE_BOX,@"「嗯~~♥♥ 奶子去了♥♥ 奶子让脑袋满满的ぅぅっ♥♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「%SELF_CALL()%的奶子，多挤点吧…♥」"
			CALL MESSAGE_BOX,@"「来…♥ 随便你挤…♥♥」"
			SIF ABL:胸围大小 >= BUSTSIZE_丰乳
				CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%装满母乳的奶子，随便你挤♥♥」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「嗯…要挤吗…？♥」"
			CALL MESSAGE_BOX,@"「好啦好啦…随便你吧…」"
			SIF ABL:胸围大小 >= BUSTSIZE_丰乳
				CALL MESSAGE_BOX,@"「嗯…真是的…男人这东西，够大就行了吗…？\n　…嘛，%MASTER_CALL()%高兴的话那就好…」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「嗯…有点难受啊…♥」"
			CALL MESSAGE_BOX,@"「算了…随你吧…」"
			SIF ABL:胸围大小 >= BUSTSIZE_丰乳
				CALL MESSAGE_BOX,@"「哈啊…真是的…男人这东西，够大就行了吗…？」"
		ELSE
			CALL MESSAGE_BOX,@"「住手っ！别挤！」"
			CALL MESSAGE_BOX,@"「可恶放开！%SELF_CALL()%可不记得自己成了家畜啊！」"
			CALL MESSAGE_BOX,@"「咕…真恶心啊…！搞什么鬼！」"
		ENDIF
	ENDIF

CASE "拧乳头"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「啊♥ 哦呼呼♥ 更加揉搓乳头吧ぇ♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「嗯！♥ 切、乳头被那样弄的话…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「嗯！ 凭什么随便碰乳头啊！」"
		ENDIF
		RETURN
	ENDIF
	IF ABL:Ｎ敏感度 >= 200 || ABL:Ｎ感觉 >= 10
		CALL MESSAGE_BOX,@"「啊♥ 那里っ♥♥ 敏感的地方っ♥♥」"
		CALL MESSAGE_BOX,@"「奶头ぃ♥ 奶头被揉搓着ぇぇ♥♥ 忍不住了ぃぃ♥♥」"
		CALL MESSAGE_BOX,@"「嗯哦~♥♥ 奶头别再弄了ぇぇ♥ 脑袋要变傻了ぅぅ♥♥」"
		CALL MESSAGE_BOX,@"「奶头ぃ♥ 啊♥ 喜欢奶头ぃぃ♥ 更加欺负奶头吧ぇぇ♥♥」"
		SIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「%SWEET_MASTER_CALL()%♥ 奶头更加揉搓吧ぇぇ♥♥」"
	ENDIF

	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「哈ーっ♥ 啊—っ♥ 更加揉搓%SELF_CALL()%的奶头吧ぇ♥♥」"
		CALL MESSAGE_BOX,@"「喂，♥ 奶头顶端麻麻的ぅ♥」"
	ELSEIF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「被那样揉搓乳头的话…疼得忍不住啊…♥」"
		CALL MESSAGE_BOX,@"「总是被玩弄乳头的话…好难受啊…♥」"
	ELSEIF ＃陷落状态／屈服以上＃
		CALL MESSAGE_BOX,@"「哈啊♥ 刚才开始就一直只弄乳头…嗯嗯♥」"
		CALL MESSAGE_BOX,@"「呼♥ ♥ 乳头被滚动着っ♥」"
	ELSE
		CALL MESSAGE_BOX,@"「搞什么啊…光弄乳头…♥」"
		CALL MESSAGE_BOX,@"「啊♥ 呜呜っ♥ 乳头、别、捏啊啊…っ」"
	ENDIF

CASE "Ｃ爱抚"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「啊♥ 阴蒂っ♥ 麻嗖嗖的ぅ♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「嗯咿！♥ 阴蒂被碰的话…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「啊！？ 你摸哪里啊！」"
		ENDIF
		RETURN
	ENDIF
	SIF ABL:Ｃ敏感度 >= 200 || ABL:Ｃ感觉 >= 10
		CALL MESSAGE_BOX,@"「那里很敏感啊ぇ♥ 身体黏糊糊的呜呜♥♥」"

	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「嗯嗯嗯♥ 揉搓着ぇ♥ 捏弄着ぇ♥ 更加玩弄%SELF_CALL()%的阴蒂吧ぇぇ♥♥」"
		CALL MESSAGE_BOX,@"「嗯哦哦♥ 敏感的地方♥ 被揉搓的话ぁ♥ 啊咿♥♥」"
	ELSEIF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「阴蒂…被玩弄的话好舒服…♥」"
		CALL MESSAGE_BOX,@"「啊♥ 那里っ♥ 更加玩弄个不停っ♥」"
	ELSEIF ＃陷落状态／屈服以上＃
		CALL MESSAGE_BOX,@"「嗯咿♥ 那里明明很敏感的说ぃ…♥」"
		CALL MESSAGE_BOX,@"「呜…っ♥ 阴蒂…麻了…♥」"
	ELSE
		CALL MESSAGE_BOX,@"「咕…被玩弄着…使不上力气…♥」"
		CALL MESSAGE_BOX,@"「呜啊♥ 阴蒂…别碰啊啊っ…！」"
	ENDIF

CASE "Ｖ指插入"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「哈啊♥ 手指进来了啦啦♥ %MASTER_CALL()%的手指在里面ぃ♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「呜啊啊っ！♥ 手指在里面的ぃっ…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「嗯啊っ！？ 你插什么进来啊！」"
		ENDIF
		RETURN
	ENDIF
	; [%PENIS_CALL()%] / [%VAGINA_CALL()%] / [%ANAL_CALL()%]：阴茎、阴道、肛门称呼
	; 与直接读 CSTR 不同：绝顶次数超阈值会进入「融化」称呼

	SIF ABL:Ｖ敏感度 >= 200 || ABL:Ｖ感觉 >= 10
		CALL MESSAGE_BOX,@"「哦ーっ♥ %VAGINA_CALL()%呃♥ 手指在里面乱来っ♥♥ 去了去了♥♥」"

