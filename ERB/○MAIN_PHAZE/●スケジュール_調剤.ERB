
;調剤
@WORK_PHARMACY
#DIM FIRST_WORKLOAD

WORKER = CMATCH(CSTR:日程,"调剂")
SIF !WORKER
	RETURN
PRINTL 　　　《 调剂 》
FIRST_WORKLOAD = MONEY:调合进行度
CALL WORKER_ABL_SET("调剂")

;調合知識があるか
CALL EXIST_KNOWLEDGE_CHECK
SIF RESULT
	RETURN

;調合薬品選択
CALL CHOOSE_PHARMACY
CALL RANDOM_CHARA_SCHEDULE_COMMON("调剂")
CALL SCHEDULE_ABL_MARK_BULK(0,"调剂")

;完成度チェック
CALL PHARMACY_TASK_CHECK
SIF !RESULT
	PRINTW
DRAWLINE




;調合知識があるか
@EXIST_KNOWLEDGE_CHECK

EXIST = 0

;メンバー内で調合知識が1人でもあるか
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "调剂"
		CONTINUE
	SIF TALENT:调合知识
		EXIST = 1
NEXT
IF !EXIST
	PRINTFORML 尝试进行调合，但由于没有人具备【调合知识】，无法继续进行…
	PRINTW
	DRAWLINE
	RETURN 1
ENDIF



;抽選したキャラの仕事表示
@WORK_PHARMACY_ENTRANCE

IF !EXP:执行次数／调剂
	KOJO_TYPE = 初次
ELSE
	KOJO_TYPE = 普通
ENDIF
CALL WORK_PHARMACY_BEGIN_MESSAGE
CALL WORK_PHARMACY_ABL_MESSAGE
CALL WORK_PHARMACY_RUN
FLAG:上次显示角色ID／调剂 = CFLAG:ID



;実行内容
@WORK_PHARMACY_RUN
#DIM OUTCOME

;体力が足りないとダメ
IF !BASE:体力
	PRINTFORML 积攒了很多疲劳的%CALLNAME%虽然还想工作，但不久就睡着了…
	HEAL_PRINT_DONE = 0
	CALL FALL_ASLEEP
	RETURN
ENDIF
CALL HP_COST(200,1)
OUTCOME = 500 +ABL:药学 *200
CALL RANDOM_FIX(OUTCOME,10,"调合进行度")
OUTCOME += FIX
MONEY:调合进行度 += OUTCOME
PRINTFORM %CALLNAME_DIGIT()% HP-{COST} 调合进行度+{OUTCOME} 
CALL EXP_UP("药学")
CALL WORK_LOVE_UP
CALL MIND_PALAM_AFTER_PRINT(1)
EXP:执行次数／调剂 ++
EXP:区间执行次数／调剂 ++
CFLAG:行动完毕 = 1



;調合薬品選択
@CHOOSE_PHARMACY

SIF FLAG:调合中药品ID
	RETURN

;ITEM:母乳分泌促進薬→350
ITEM_REF = 350
ITEM_MAX = 20
PRINTL 要调合哪种药品？
FOR LOCAL,ITEM_REF,ITEM_REF +ITEM_MAX
	;360以降は高度薬学台
	IF LOCAL == 360
		IF !ITEM:高级药学台
			CALL PRINTL_WORD_COLOR,@"制造即效药品需要＜高级药学台＞","黄"
			BREAK
		ELSE
			PRINTL
		ENDIF
	ENDIF
	
	;価格設定されていれば表示
	SIF !ITEMPRICE:LOCAL
		CONTINUE
	
	;必要進行度はITEMPRICEの倍にしとく
	PRINTFORML [{LOCAL -ITEM_REF,3}] %ITEMNAME:LOCAL,20%：必要进行度… %VALUE_DIGIT(ITEMPRICE:LOCAL *2)% 
NEXT
BINPUT
FLAG:调合中药品ID = RESULT +ITEM_REF
MONEY:调合进行度 = 0




;完成度チェック
@PHARMACY_TASK_CHECK
#DIM TASK
#DIM GET_ITEM

TASK = ITEMPRICE:(FLAG:调合中药品ID) *2
PRINTFORML 调合进度：%VALUE_DIGIT(MONEY:调合进行度)%／%VALUE_DIGIT(TASK)% 
SIF MONEY:调合进行度 < TASK
	RETURN

;進行度が必要値超えたら完了
GET_ITEM = MONEY:调合进行度 /TASK
ITEM:(FLAG:调合中药品ID) += GET_ITEM
MONEY:调合进行度 -= (TASK *GET_ITEM)
CALL PRINTL_WORD_COLOR,@"【%ITEMNAME:(FLAG:调合中药品ID)%】已经完成了{GET_ITEM}个！","浅蓝色"
PRINTFORML 是否继续调配%ITEMNAME:(FLAG:调合中药品ID)%？　进度：%VALUE_DIGIT(MONEY:调合进行度)%／%VALUE_DIGIT(TASK)% 
PRINTL （如果更改，进度将被重置）
CALL ASK_YN
IF RESULT
	FLAG:调合中药品ID = 0
	MONEY:调合进行度 = 0
ENDIF
RETURN 1



