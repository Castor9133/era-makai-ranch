
;==========================================
; 进阶调教共用台词（舔阴蒂／舔外阴阴道口／龟头责／真空口交／深喉／触手深喉）
; 由各泛用口上 KOJO_GENERAL_*_TRAIN 统一 CALL：KOJO_SHARE_ADVANCED_TRAIN_DISPATCH ARGS:1=Train.csv 名 ARGS:2=执行/继续
; 文风：简体中文为主；语气按 CSTR:使用口上 分组；陷落与癖好分叉
; 舔阴蒂／舔外阴（阴道口外）：主人公以口侍奉奴隶；共用台词为奴隶「被舔」侧反应（勿与奴隶舔主人公混淆）
;==========================================

@KOJO_SHARE_ADVANCED_TRAIN_DISPATCH(ARGS:1, ARGS:2)

SELECTCASE ARGS:1
CASE "舔阴蒂"
	CALL KOJO_SHARE_ADV_DISPATCH_LICK_CLITORIS(ARGS:2)
CASE "舔阴道"
	CALL KOJO_SHARE_ADV_DISPATCH_LICK_VULVA(ARGS:2)
CASE "刺激龟头"
	CALL KOJO_SHARE_ADV_DISPATCH_FOCUS_GLANS(ARGS:2)
CASE "真空口交"
	CALL KOJO_SHARE_ADV_DISPATCH_VACUUM_BJ(ARGS:2)
CASE "深喉"
	CALL KOJO_SHARE_ADV_DISPATCH_IRUMA(ARGS:2)
CASE "触手深喉"
	CALL KOJO_SHARE_ADV_DISPATCH_TENTACLE_DT(ARGS:2)
CASE "肛门指揉按摩","玩弄阴唇","G点指压","阴道指奸","肛门指奸","尿道口指弄","尿道口指奸","口内搅舌","压舌探喉"
	CALL KOJO_SHARE_FINGER_ADV_TRAIN_DISPATCH(ARGS:1, ARGS:2)
ENDSELECT
RETURN



