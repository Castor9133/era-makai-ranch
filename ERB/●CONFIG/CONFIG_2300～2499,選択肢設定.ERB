
;選択肢設定一覧
@LIST_CONFIG_CHOICE

PRINTL --- 《 选项设置 》 ---
ALIGNMENT LEFT
DRAWLINE
FLAG_REF = 2300
FOR LOCAL,0,50
	SIF FLAGNAME:(LOCAL +FLAG_REF) == ""
		CONTINUE
	CALL PRINT_CONFIG_CHOICE(LOCAL)
NEXT
PRINTL
PRINTL [70] 调教中／自动选项
PRINTL [71] 调教中／过滤・确认
PRINTL [72] 捕获时选项・角色标志
PRINTL [73] 房间分配自动更改设定


;ARG→LOCAL　FLAG_REFを足すことでフラグ番号
@PRINT_CONFIG_CHOICE(ARG)

FLAG_NAME = %FLAGNAME:(ARG +FLAG_REF)%
SELECTCASE FLAG_NAME
CASE "工作休息体力"
	PRINTFORM [{ARG,2}] %FLAG_NAME,32%：{FLAG:FLAG_NAME}在HP以下休息

CASE "搾乳休息母乳量"
	PRINTFORM [{ARG,2}] %FLAG_NAME,32%：{FLAG:FLAG_NAME}%MILK_COUNTING()%不足时休息

CASEELSE
	PRINTFORM [{ARG,2}] %FLAG_NAME,32%
	CALL PRINT_ONOFF(FLAG:FLAG_NAME)
ENDSELECT
PRINTL



;ARG→INPUT
@CHANGE_CONFIG_CHOICE(ARG)

SELECTCASE ARG
CASE 70	;調教中／自動選択肢
	CALL TRAIN_AUTO_CONFIG
CASE 71	;調教中／フィルタ・確認
	CALL TRAIN_FILTER_CONFIG
CASE 72	;捕獲時選択肢・キャラフラグ
	CALL CAPTURE_CONFIG
CASE 73	;部屋割り自動変更設定
	CALL AUTO_ALLOCATION_ROOM_CONFIG
CASEELSE
	CALL CHANGE_CONFIG_CHOICE_NAME(ARG)
ENDSELECT



@CHANGE_CONFIG_CHOICE_NAME(ARG)

FLAG_NUM = ARG +FLAG_REF
FLAG_NAME = %FLAGNAME:FLAG_NUM%
CALL CHANGE_CONFIG_INVERTBIT
SIF RESULT
	RETURN
SELECTCASE FLAG_NAME
CASE "工作休息体力"
	PRINTL 自动日程时，取消工作并日程[空闲时间]或[待机]
	PRINTL 请设定体力值。（0到1000HP）
	PRINTL
	PRINTL [300] 300HP（默认：体力不足300就休息）
	PRINTL 或输入0～1000之间的数字。
	INPUT
	SIF RESULT >= 0 && RESULT <= 1000
		FLAG:FLAG_NUM = RESULT

CASE "搾乳休息母乳量"
	PRINTL 自动日程时，取消搾乳并日程[空闲时间]或[待机]
	PRINTFORML 请设定母乳量。（0～1000%MILK_COUNTING()%）
	PRINTL
	PRINTFORML [500] 500%MILK_COUNTING()%（默认：如果母乳量低于500%MILK_COUNTING()%就休息）
	PRINTL 或输入0～1000之间的数字。
	INPUT
	SIF RESULT >= 0 && RESULT <= 1000
		FLAG:FLAG_NUM = RESULT

CASE "晚餐菜单交给我"
	PRINTL 设置是否不从候选中选择而自动决定晚餐菜单。
	PRINTL
	PRINTL [ 0] 从候选中选择（默认）
	PRINTL [ 1] 自动决定
	BINPUT
	FLAG:FLAG_NUM = RESULT

CASE "自动呼叫校正确认"
	PRINTL 人称、性器称呼等变更时，绝顶次数在一定程度以上是否设置以确认切换后的术语。
	PRINTL 如果手动输入，则会始终进行确认。
	PRINTL
	PRINTL [ 0] 交给系统
	PRINTL [ 1] 确认（默认）
	BINPUT
	FLAG:FLAG_NUM = RESULT
ENDSELECT


