
;牛舎管理
;ARG　牛舎番号
@COWSHED_MANAGE_ENTRANCE(ARG)

;FLAG:第1牛舎増築段階→500
;FLAG:第1牛舎スケジュール→501
;FLAG:第1牛舎家畜頭数→502
;FLAG:第1牛舎スケジュール表示→503
FLAG_REF = 490
FLAG_REF:1 = 491
FLAG_REF:2 = 492
FLAG_REF:3 = 493

;牛舎が立ってないときおわり
SIF ARG > ITEM:牛舍
	RETURN
COWSHED_NUM = ARG
COWSHED_CAPACITY = FLAG:(FLAG_REF +COWSHED_NUM *10)*10
CALL COWSHED_MANAGE
CALL SCHEDULE_ADJUST



;牛舎画面
@COWSHED_MANAGE

;牛舎内の現在の乳牛頭数を計算
FLAG:(FLAG_REF:2 +COWSHED_NUM *10) = CMATCH(CFLAG:牛舍号码,COWSHED_NUM)
COWSHED_SLAVE = FLAG:(FLAG_REF:2 +COWSHED_NUM *10)
CLEARLINE LINECOUNT
PRINTFORML %COWSHED_NAME:COWSHED_NUM,24%：{COWSHED_SLAVE,3}／{COWSHED_CAPACITY,3}匹 
DRAWLINE
IF COWSHED_SLAVE < COWSHED_CAPACITY
	PRINTL [ 0] 把牲口赶进牛舍 
ELSE
	CALL PRINTL_WORD_COLOR("　牛舍满员了","灰")
ENDIF
IF COWSHED_SLAVE
	PRINTLC [ 1] 把牲口赶出牛舍 
	PRINTLC [ 2] 一起移动 
	PRINTLC [ 3] 家畜的状态显示
ELSE
	CALL PRINTLC_WORD_COLOR("　牛舍里没有牲口","灰")
ENDIF
PRINTL
DRAWLINE
PRINTFORML [10] 处理奶牛：\@ FLAG:(FLAG_REF:1 +COWSHED_NUM *10) ? 榨乳工厂 # 搾乳家畜 \@
PRINT [11] 搾乳时显示：
SELECTCASE FLAG:(FLAG_REF:3 +COWSHED_NUM *10)
CASE 0
	PRINTL 分别显示
CASE 1
	PRINTL 显示所有人的搾乳总量＋显示LvUP
CASE 2
	PRINTL 显示所有人的搾乳总量＋隐藏LvUP
ENDSELECT
PRINTL [12] 牛舍更名 

CALL PRINTL_ALIGN(-5)
	;PRINTL [ 6] 牛舎で使用する責め具を変更 
DRAWLINE
PRINTLC [30] 上一个牛舍
PRINTLC [31] 下一个牛舍
PRINTL [99] 完成
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL COWSHED_MANAGE_PUTIN
CASE 1
	CALL COWSHED_MANAGE_PUTOUT
CASE 2
	CALL COWSHED_MANAGE_MOVE
CASE 3
	CALL COWSHED_MANAGE_STATUS
CASE 10
	PRINTFORML %COWSHED_NAME:COWSHED_NUM%的乳牛处理请选择。
	PRINTL [ 0] 搾乳家畜　　：中午让他休息一下
	PRINTL [ 1] 榨乳工厂：整天搾乳，不让休息
	BINPUT
	FLAG:(FLAG_REF:1 +COWSHED_NUM *10) = RESULT
		
CASE 11
	PRINTFORML %COWSHED_NAME:COWSHED_NUM%中乳牛日程执行时的显示状态请选择。
	PRINTL [ 0] 分别显示
	PRINTL [ 1] 显示所有人的搾乳总量＋显示LvUP
	PRINTL [ 2] 显示所有人的搾乳总量＋隐藏LvUP（刻印获取显示）
	PRINTL
	PRINTL [99] 取消
	INPUT
	SIF RESULT >= 0 && RESULT <= 2
		FLAG:(FLAG_REF:3 +COWSHED_NUM *10) = RESULT

CASE 12
	PRINTFORML 是否更改%COWSHED_NAME:COWSHED_NUM%的名称？
	PRINTLC [ 0] 输入
	PRINTLC [ 1] 回复默认值
	PRINTL [99] 取消
	INPUT
	IF RESULT == 0
		PRINTL 请输入牛舍名称。
		INPUTS
		SIF RESULTS != ""
			COWSHED_NAME:COWSHED_NUM = %RESULTS%
	ELSEIF RESULT == 1
		LOCALS = 第%TOSTR(COWSHED_NUM)%牛舍
		COWSHED_NAME:COWSHED_NUM =%LOCALS%
	ENDIF

CASE 30
	COWSHED_NUM --
	SIF COWSHED_NUM < 1
		COWSHED_NUM = ITEM:牛舍

CASE 31
	COWSHED_NUM ++
	SIF COWSHED_NUM > ITEM:牛舍
		COWSHED_NUM = 1
	
CASE 99
	RETURN
ENDSELECT
RESTART



;牛舎に入れる
@COWSHED_MANAGE_PUTIN
#DIM DYNAMIC PAGE
#DIM DYNAMIC HIDE_CATTLE = 1

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML 请选择放入%COWSHED_NAME:COWSHED_NUM%的乳牛。{COWSHED_SLAVE,3}／{COWSHED_CAPACITY,3}匹 
PRINTL （已经在其他牛舍的乳牛名字变成浅蓝色）
DRAWLINE

;あんまり多くてもなので20匹ずつ表示
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	IF CFLAG:追踪对象
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(6)%：未捕获","灰"
		CONTINUE
	ELSEIF CSTR:住处 == "体内"
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(6)%：体内","灰"
		CONTINUE
	ELSEIF !MARK:母乳体质
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(6)%：非【母乳体质】","灰"
		CONTINUE
	ELSEIF CFLAG:牛舍号码 == COWSHED_NUM
		PRINTFORML %CALLNAME_DIGIT(6)%：%COWSHED_NAME:(CFLAG:牛舍号码)%
		CONTINUE
	ELSEIF HIDE_CATTLE && CFLAG:牛舍号码
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(6)%：%COWSHED_NAME:(CFLAG:牛舍号码)%","灰"
		CONTINUE
	ENDIF
	SIF CFLAG:牛舍号码
		SETCOLOR 0x50C0FF
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	RESETCOLOR
	CALL PRINT_POST_C
	CALL TABLE_STATUS("放入牛舍")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  7] 其他的牛舍 当前：\@ HIDE_CATTLE ? 隐藏 # 显示 \@
PRINTFORMLC [  8] 更改显示项目
PRINTL [ 99] 完成
BINPUT
SELECTCASE RESULT
CASE 7
	INVERTBIT HIDE_CATTLE,0
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	TARGET = RESULT -100
	SIF !CFLAG:可以调教 || !MARK:母乳体质
		RESTART
	CFLAG:牛舍号码 = COWSHED_NUM
	
	;自室があれば解除
	CALL RESET_SLAVE_ROOM("牛舍")
	
	;牛舎での搾乳専用スケジュール
	CSTR:日程 = 牛舍
	
	;居場所を牛舎にする
	CALL CHARA_WHEREABOUTS_TARGET
	FLAG:(FLAG_REF:2 +COWSHED_NUM *10) ++
	COWSHED_SLAVE ++
	IF COWSHED_SLAVE >= COWSHED_CAPACITY
		PRINTW 牛舍满员了。
		RETURN
	ENDIF
ENDSELECT
RESTART



;牛舎から出す
@COWSHED_MANAGE_PUTOUT

;上手い方法が思いつかないので全員まとめて表示するよ
;30匹超えたあたりからそれはそれは大変になるけど一括とかでどうにか

CLEARLINE LINECOUNT
PRINTFORML 请选择从%COWSHED_NAME:COWSHED_NUM%中取出的乳牛。{COWSHED_SLAVE,3}／{COWSHED_CAPACITY,3}匹 
DRAWLINE
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CFLAG:牛舍号码 != COWSHED_NUM
		CONTINUE
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("牛舍")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTFORMLC [  8] 更改显示项目
PRINTLC 　
PRINTL [ 99] 完成
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 99
	RETURN
CASEELSE
	TARGET = RESULT -100
	SIF CFLAG:牛舍号码 != COWSHED_NUM
		RESTART
	CFLAG:牛舍号码 = 0
	CALL CHARA_WHEREABOUTS_TARGET
	CALL SCHEDULE_RESET_TARGET
	FLAG:(FLAG_REF:2 +COWSHED_NUM *10) --
	COWSHED_SLAVE --
	IF !COWSHED_SLAVE
		PRINTW 牛舍被清空了。
		RETURN
	ENDIF
ENDSELECT
RESTART



;まとめて移動
@COWSHED_MANAGE_MOVE
#DIM MOVE_COWSHED_NUM
#DIM MOVE_COWSHED_SLAVE
#DIM MOVE_COWSHED_CAPACITY
#DIM MOVE_COWSHED_DIFF

PRINTFORML 请选择%COWSHED_NAME:COWSHED_NUM%乳牛的移动地点。{COWSHED_SLAVE,3}／{COWSHED_CAPACITY,3}匹 
FOR LOCAL,1,11
	SIF LOCAL == COWSHED_NUM || LOCAL > ITEM:牛舍
		CONTINUE
	
	;移動先の乳牛頭数（現在・最大）を計算
	MOVE_COWSHED_SLAVE = CMATCH(CFLAG:牛舍号码,LOCAL)
	MOVE_COWSHED_CAPACITY = FLAG:(FLAG_REF +LOCAL *10) *10
	PRINTFORM [{LOCAL,2}] %COWSHED_NAME:LOCAL,20%：{MOVE_COWSHED_SLAVE,3}／{MOVE_COWSHED_CAPACITY,3}匹 
	
	;移動するスペースあるか計算
	MOVE_COWSHED_DIFF =  COWSHED_SLAVE +MOVE_COWSHED_SLAVE -MOVE_COWSHED_CAPACITY
	IF MOVE_COWSHED_DIFF <= 0
		CALL PRINTL_WORD_COLOR("可移动","浅蓝色")
	ELSE
		CALL PRINTL_WORD_COLOR,@"移动不可：{MOVE_COWSHED_DIFF}匹分不足","黄"
	ENDIF
NEXT
PRINTL [90] 全部出牛舍
PRINTL
PRINTL [99] 取消
BINPUT
PRINTL
IF RESULT == 90
	PRINTFORML 是否从%COWSHED_NAME:COWSHED_NUM%中移出所有乳牛？
	CALL ASK_YN
	SIF RESULT
		RETURN
	FOR TARGET_COUNT,1,CHARANUM
		TARGET = TARGET_COUNT
		SIF CFLAG:牛舍号码 != COWSHED_NUM
			CONTINUE
		CFLAG:牛舍号码 = 0
		CALL CHARA_WHEREABOUTS_TARGET
		CALL SCHEDULE_RESET_TARGET
	NEXT
ELSEIF RESULT > 0 && RESULT <= 11 && RESULT != COWSHED_NUM
	MOVE_COWSHED_NUM = RESULT
	SIF COWSHED_SLAVE +FLAG:(FLAG_REF:2 +MOVE_COWSHED_NUM *10) > (FLAG:(FLAG_REF +MOVE_COWSHED_NUM *10))*10
		RETURN
	PRINTFORML 是否将%COWSHED_NAME:COWSHED_NUM%的所有乳牛移动到%COWSHED_NAME:MOVE_COWSHED_NUM%？
	CALL ASK_YN
	SIF RESULT
		RETURN
	FOR TARGET_COUNT,1,CHARANUM
		TARGET = TARGET_COUNT
		SIF CFLAG:牛舍号码 != COWSHED_NUM
			CONTINUE
		CFLAG:牛舍号码 = MOVE_COWSHED_NUM
		CALL CHARA_WHEREABOUTS_TARGET
	NEXT
ENDIF



;牛舎内家畜のステータス
@COWSHED_MANAGE_STATUS

CLEARLINE LINECOUNT
PRINTL 请选择要查看状况的家畜。
DRAWLINE
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CFLAG:牛舍号码 != COWSHED_NUM
		CONTINUE
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("牛舍")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTFORMLC [  8] 更改显示项目
PRINTLC 　
PRINTL [ 99] 完成
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 99
	RETURN
CASEELSE
	TARGET = RESULT -100
	SIF CFLAG:牛舍号码 != COWSHED_NUM
		RESTART
	CALL SCHEDULE_PLAN("牛舍")
ENDSELECT
RESTART





