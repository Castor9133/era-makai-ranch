
;仕事能力増加
@SELECT_WISH_WORK_ABL

;ABL:酪農→20
ABL_REF = 20
ABL_MAX = 10
PRINTFORML 请选择要增加的%CALLNAME%的工作能力。
FOR LOCAL,ABL_REF,ABL_REF +ABL_MAX
	ABL_NAME = %ABLNAME:LOCAL%
	SIF ABL_NAME == ""
		CONTINUE
	IF ABL:LOCAL >= 99
		CALL PRINTL_WORD_COLOR,@"【%ABL_NAME%】已经达到最大值了","浅蓝色"
		CONTINUE
	ENDIF
	PRINTFORM [{LOCAL -ABL_REF,2}] 【%ABL_NAME%】：Lv{ABL:LOCAL}
	SELECTCASE ABL_NAME
	CASE "料理"
		SIF TALENT:不擅长料理
			CALL PRINT_WORD_COLOR("【不擅长料理】","黄")
	CASE "清洁"
		SIF TALENT:不擅长清洁
			CALL PRINT_WORD_COLOR("【不擅长清洁】","黄")
	CASE "接客"
		SIF TALENT:不擅长接客
			CALL PRINT_WORD_COLOR("【不擅长接客】","黄")
	ENDSELECT
	PRINTL
NEXT
PRINTL
PRINTL [99] 取消
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 9
	ABL_NUM = ABL_REF +RESULT
	ABL_NAME = %ABLNAME:ABL_NUM%
	IF ABL:ABL_NUM < 10
		PRINTFORML 要将%CALLNAME%的【%ABL_NAME%】增加到Lv10吗？
		
		;下手素質がある場合消去できる
		SELECTCASE ABL_NAME
		CASE "料理"
			SIF TALENT:不擅长料理
				CALL PRINTL_WORD_COLOR("同时素质【料理下手】也将被消除。","黄")
		CASE "清洁"
			SIF TALENT:不擅长清洁
				CALL PRINTL_WORD_COLOR("同时素质【清洁下手】也将被消除。","黄")
		CASE "接客"
			SIF TALENT:不擅长接客
				CALL PRINTL_WORD_COLOR("同时素质【接客下手】也将被消除。","黄")
		ENDSELECT
	ELSE
		PRINTFORML 要将%CALLNAME%的【%ABL_NAME%】的等级增加3吗？
	ENDIF
	CALL ASK_YN
	SIF RESULT
		RETURN
	IF ABL:ABL_NUM < 10
		ABL:ABL_NUM = 10
		CALL PRINTL_WORD_COLOR,@"%CALLNAME%的【%ABL_NAME%】等级已经提升至{ABL:ABL_NUM}！","黄"
		
		;EXPの番号も同じ
		EXP:ABL_NUM = 100000
		SELECTCASE ABL_NAME
		CASE "料理"
			IF TALENT:不擅长料理
				TALENT:不擅长料理 = 0
				CALL PRINTL_WORD_COLOR("素质【料理下手】已经消失！","黄")
			ENDIF
		CASE "清洁"
			IF TALENT:不擅长清洁
				TALENT:不擅长清洁 = 0
				CALL PRINTL_WORD_COLOR("素质【清洁下手】已经消失！","黄")
			ENDIF
		CASE "接客"
			IF TALENT:不擅长接客
				TALENT:不擅长接客 = 0
				CALL PRINTL_WORD_COLOR("素质【接客下手】已经消失！","黄")
			ENDIF
		ENDSELECT
	ELSE
		ABL:ABL_NUM = LIMIT(ABL:ABL_NUM +3,0,99)
		EXP:ABL_NUM = LIMIT(EXP:ABL_NUM +30000,0,990000)
		CALL PRINTL_WORD_COLOR,@"%CALLNAME%的【%ABL_NAME%】等级已经提升至{ABL:ABL_NUM}！","黄"
	ENDIF
	PRINTW
	ITEM:龙之珠 = 0
ENDSELECT





