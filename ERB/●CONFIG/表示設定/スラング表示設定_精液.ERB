
;精液スラング設定
@SLANG_CONFIG_SEMEN

CLEARLINE LINECOUNT
PRINTL 请选择用地文等表示的精液黑话的候选。
DRAWLINE
PRINTLC [ 0] 「精液」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／精液,0),1)
PRINTLC [ 1] 「白浊液」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／精液,1),1)
PRINTLC [ 2] 「精汁」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／精液,2),1)
PRINTLC [ 3] 「怀孕汁」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／精液,3),1)
PRINTLC [ 4] 「Sperm」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／精液,4),1)
PRINTLC [ 5] 「欲望汁」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／精液,5),1)
PRINTLC [ 6] 「种子」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／精液,6),1)
PRINTLC [ 7] 「怀孕牛奶」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／精液,7),1)
PRINTLC [ 8] 「大鸡鸡牛奶」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／精液,8),1)
PRINTLC [ 9] 「雄性牛奶」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／精液,9),1)
PRINTL
PRINTL 　《 前缀设置 》
PRINTL 　（扩张的话以主人公／竿役的状态附加条件的预定）
PRINTLC [10] 「浓厚的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／精液,0),1)
PRINTLC [11] 「粘稠的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／精液,1),1)
PRINTLC [12] 「炙热的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／精液,2),1)
PRINTLC [13] 「滚烫的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／精液,3),1)
PRINTL
PRINTL 　《 特殊替换设置 》
PRINTLC [20] 首选特殊替换
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／精液,0),0)
PRINTL 　…如果满足特殊替换条件，则显示优先级
PRINTLC [29] 地文的设定
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／精液,9),0)
PRINTFORML 　（当前设置：%SAVESTR:标识／精液%）
CALL SLANG_CONFIG_FOOTER
INPUT
SELECTCASE RESULT
CASE 0 TO 9
	INVERTBIT FLAG:黑话标识／精液,RESULT
CASE 10 TO 13
	INVERTBIT FLAG:黑话前缀／精液,(RESULT -10)
CASE 20
	INVERTBIT FLAG:黑话替换／精液,(RESULT -20)
CASE 29
	INVERTBIT FLAG:黑话替换／精液,(RESULT -20)
CASE 80
	FLAG:黑话标识／精液 = 65535
CASE 81
	FLAG:黑话前缀／精液 = 65535
CASE 82
	FLAG:黑话替换／精液 = 65535
CASE 90
	FLAG:黑话标识／精液 = 0
CASE 91
	FLAG:黑话前缀／精液 = 0
CASE 92
	FLAG:黑话替换／精液 = 0
CASE 98
	PRINTL 回复默认的精液黑话候选？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_SLANG_CONFIG_SEMEN
CASE 99
	IF !FLAG:黑话标识／精液
		PRINTW 必须至少设置一个候选黑话。
	ELSE
		RETURN
	ENDIF
ENDSELECT
RESTART


