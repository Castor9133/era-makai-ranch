; ARGS:0 场景；ARGS:1/2 用于更细分
@KOJO_GENERAL_ボーイッシュ口上1_EVENT(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:0

CASE "进入魔界的"
	SELECTCASE ARGS:1
	CASE "魔界水晶1"
		CALL MESSAGE_BOX,@"「ここが魔界か……更加荒れ放題な地方だと思ってたん但是な」"
	CASE "魔界水晶2"
		CALL MESSAGE_BOX,@"「近くの【魔界水晶】は採り尽くされてるみたいだな…」\n「まあそう簡単にはいかないか……気ぃ付けていかないと」"
	CASE "魔界植物1"
		CALL MESSAGE_BOX,@"「ここが魔界か……思ってたより草木が多いんだな…」"
	CASE "魔界植物2"
		CALL MESSAGE_BOX,@"「近くの【魔界植物】は採り尽くされてるみたいだな…」\n「まあそう簡単にはいかないか……気ぃ付けていかないと」"
	CASE "夺回1"
		CALL MESSAGE_BOX,@"「ここが魔界か……バケモンがうろついてる地方にしちゃ平和な感じだな…」"
	CASE "夺回2"
		CALL MESSAGE_BOX,@"（死んでも助けてやるからな…っ）\n「頼むから無事でいてくれよ……！」"
	CASE "声望1"
		CALL MESSAGE_BOX,@"「ここが魔界か……思ったより落ち着いた地方なんだな…」"
	CASE "声望2"
		CALL MESSAGE_BOX,@"「つっても魔界には違いないし、名を上げるのに不足なし…だな」\n（城の向こうの『あれ』には絶対に近寄りたくねえけど…）"
	CASE "大门事故1"
		CALL MESSAGE_BOX,@"「……っ！ ……ここは…？ %SELF_CALL()%、もしかして魔界に……！？」"
	CASE "大门事故2"
		CALL MESSAGE_BOX,@"「どうしたもんかな…… まさか頼れる地方なんかある应该ないし……」"
	CASE "大门事故3"
		CALL MESSAGE_BOX,@"「それでも街っぽい所はあるみたいだ…」\n「話せばなんとかなる也许……不要、それは甘いかぁ…？ でもなぁ…」"
	CASE "讨伐1"
		CALL MESSAGE_BOX,@"「ここが魔界か……とうとう魔族どもの土地に着いたな…」"
	CASE "讨伐2"
		CALL MESSAGE_BOX,@"「ヤツらの親玉は那个城にいるんだろうな……うし、行くか…！」"
	CASE "特殊种族1"
		CALL MESSAGE_BOX,@"「ここが魔界か……瘴気に満ちた土地とかって噂はデタラメじゃねえか」"
	CASE "特殊种族2"
		CALL MESSAGE_BOX,@"「うっし、%SELF_CALL()%の力を見せつけてやるぜ…！」"
	CASE "即将处置1"
		CALL MESSAGE_BOX,@"（ちっ…正直ナメてたぜ… 精鋭連中はザコとは段違いじゃんかよ…っ）"
	CASE "即将处置2"
		CALL MESSAGE_BOX,@"（期待してなかった【処女結界】に、結局守られちまった…）\n「でも、そしたらなんでコイツら%SELF_CALL()%を殺さないんだ…？」"
	CASE "拍卖1"
		CALL MESSAGE_BOX,@"（ニンゲンを売り買いするなんてよ……果然魔界の連中は許せねえ…）"
	CASE "异世界转移1"
		CALL MESSAGE_BOX,@"「……ん？…ここドコだ…？」"
	CASE "异世界转移2"
		CALL MESSAGE_BOX,@"「見たことない景色……ていうか映画のセットみたいだな…」"
	CASE "异世界转移3"
		CALL MESSAGE_BOX,@"「啊ちに見えるのは街…？ 話通じるんだろうな…」"
	ENDSELECT

CASE "事件"
	IF TFLAG:Ｍ装备
		CALL KOJO_PRINT("Ｍ装备中事件",ARGS:1,ARGS:2,ARGS:3)
		
		;CALLの関係でＭ装備中イベント呼び出した場合ここでリセットが必要
		MESSAGE_COUNT = 0
		RETURN
	ENDIF
	
	SELECTCASE ARGS:1
	CASE "领取奴隶"
		IF CFLAG:轮奸次数
			CALL MESSAGE_BOX,@"「咿……あ、あんな目にあわせて…今度は奴隶…？」"
		ELSE
			CALL MESSAGE_BOX,@"「…こ、ここは牧場…？」"
			CALL MESSAGE_BOX,@"「…こんな地方まで連れてきて何させるつもりだよ…」"
			CALL MESSAGE_BOX,@"「…今すぐ解放しろって言ってるだろ……っ」"
		ENDIF
		
	CASE "母乳体质化"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「へへ…♥ これからは%MASTER_CALL()%のために母乳が出せんだな…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「あ、啊啊… こんなこと、啊てたまるか…」"
		ENDIF
		
	CASE "魔力母乳体质化"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「んぁ…魔力が流れ出してく……さてはとことん搾取するつもりだな…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「っ！？ 魔力が抜けて…っ %SELF_CALL()%の胸に何したんだよ……！？」"
		ENDIF
		
	CASE "超乳化"
		IF CFLAG:乳牛
			CALL MESSAGE_BOX,@"「啊♥ こんな乳牛らしい身体にしてもらえて感動だ…♥♥」\n「これからは『奶子家畜』として一生飼ってくれるんだよな♥♥」"
		ELSEIF ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「ふ啊啊…♥ こんなどうしようもない胸にされちまったぁ♥♥」\n「已经%MASTER_CALL()%の奶子奴隶としてしか生きらんねぇ…♥♥」"
		ELSE
			CALL MESSAGE_BOX,@"「なっ…啊啊……こんな…う、嘘だ……っ」\n「%SELF_CALL()%の身体、元に戻してくれよぉ…！」"
		ENDIF
		
	CASE "崩坏"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"（あ…あ…%MASTER_CALL()%に……こわされ……）"
			ELSE
				CALL MESSAGE_BOX,@"（已经……なにも也许…どうでも……ひ咿……）"
			ENDIF
		CASEELSE
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"「啊…が……%MASTER_CALL()%……ゆ、許し……ぃ…」"
			ELSE
				CALL MESSAGE_BOX,@"「啊啊……あ…ぁ……っ…？」"
			ENDIF
		ENDSELECT
		
	CASE "反抗消除"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"（ここには誰も助けになんか来ない…っ 怖い…苦しい…っ）\n（反抗しないから…許してくれ…不要、許してください…っ！）"
		CASEELSE
			CALL MESSAGE_BOX,@"（怖い……こんなのが続くと、そのうち壊される…）\n「に、二度と逆らったりしないから…求求你です…許してください…」"
		ENDSELECT
	
	CASE "屈服"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"（どんな命令でも聞くからっ…ここから出してくれ…っ）"
		CASEELSE
			CALL MESSAGE_BOX,@"「はっ…ぐ…%SELF_CALL()%齿%MASTER_CALL()%のドレイです…」\n「……っ どんなことでも、言うこと聞きます…」"
		ENDSELECT
	
	CASE "陷落"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"（啊啊…地獄みたいな思いをしてようやく分かったよ…）\n（%SELF_CALL()%はコイツには逆らったり出来ないんだな…）"
		CASEELSE
			CALL MESSAGE_BOX,@"「なあ…%MASTER_CALL()%のこととか、いろいろ教えてくれよ…」\n「べ、別に少しは上手く立ち回ろうって只是だっての……」"
		ENDSELECT
	
	CASE "恋慕告白"
		SELECTCASE ARGS:2
		CASE "前"
			CALL MESSAGE_BOX,@"「な、なぁ…%MASTER_CALL()%は…誰かを好きになったこととか、あんのか…？」\n「不要、なんつーのかな……ちょっと気になってるヤツがいて……その…」"
		CASE "后"
			CALL MESSAGE_BOX,@"「そ、その…%MASTER_CALL()%に…ほ、ほ、惚れちまったみたいなんだ…っ♥」\n「迷惑かけたりはしないから……ただ、そばにさせてほしい…♥」"
		ENDSELECT
	
	CASE "隶属告白"
		SELECTCASE ARGS:2
		CASE "前"
			CALL MESSAGE_BOX,@"「%SWEET_MASTER_CALL()%…♥ %SELF_CALL()%さ、こんなに幸せにしてもらって、真的感謝してるんだ…♥♥」\n「それで%MASTER_CALL()%にどうやってお礼すればいいか考えたん但是…♥♥」"
		CASE "后"
			CALL MESSAGE_BOX,@"「%SELF_CALL()%にはこの身体くらいしかなくて……だったら『全部』あげちゃえばいいなって♥♥」\n「なるべく壊れないようにがんばるから…♥♥ いっぱい使ってくれよなっ♥♥♥」"
		ENDSELECT
	
	CASE "乳牛堕落"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"（啊啊♥ 好舒服…しあわせ…♥ 今までの人生でこんな幸せなことなかった…♥）\n（已经『人生』なんていらない…♥♥ これからは乳牛として幸せに生きてく…♥♥）"
		CASEELSE
			CALL MESSAGE_BOX,@"「啊啊～…♥♥ 好舒服♥ 好舒服♥ 奶子好舒服っ…！♥」\n「搾乳高潮の気持ちよさを、身体の芯まで刻み込まれちまった…♥」\n「乳牛として飼われる幸せを知っちまったら、已经人間になんて戻れない…♥♥」"
		ENDSELECT
	
	CASE "处女结界破坏"
		SIF TALENT:性知识贫乏
			RETURN
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「これまで%SELF_CALL()%を守ってくれた結界も、已经要らなくなったなぁ…♥♥」\n\d"
		ELSE
			CALL MESSAGE_BOX,@"「…っ！ 結界が壊れる……なんでだ…！？」"
		ENDIF
	
	CASE "处女丧失前"
		IF CFLAG:乳牛 || CFLAG:洗脑
			;乳牛状態で乙女心もないだろ、ということで素質：乙女心の判定はしない
			IF GETBIT(＃Ｐ使用／Ｖ插入＃)
				IF TFLAG:拘束BIT
					CALL MESSAGE_BOX,@"「あぅ…拘束されたまま初体験なんて♥ ちょっと怖いけど、それ以上に興奮してきた…♥」"
				ELSEIF TFLAG:眼罩
					CALL MESSAGE_BOX,@"「あぅ…目隠しされたまま初体験なんて♥ ちょっと怖いけど、それ以上に興奮してきた…♥」"
				ELSE
					CALL MESSAGE_BOX,@"「啊啊…♥ %SELF_CALL()%の処女、%MASTER_CALL()%が貰ってくれるんだな…♥♥」"
				ENDIF
			ELSEIF TFLAG:眼罩
				CALL MESSAGE_BOX,@"「%MASTER_CALL()%…？ 目隠しでよくわかんねぇけど…も、もしかして…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「啊咿嘻…♥ %SELF_CALL()%の処女、こんなモンに奪われるのかよ…♥♥」"
			ENDIF
		ELSEIF ＃陷落状态／恋慕以上＃
			;こちらは乙女心の判定あり
			IF GETBIT(＃Ｐ使用／Ｖ插入＃)
				IF TALENT:少女心
					CALL MESSAGE_BOX,@"「啊啊…♥ 初めての相手は絶対に%MASTER_CALL()%だって決めてた…♥♥」"
				ELSEIF TFLAG:眼罩
					CALL MESSAGE_BOX,@"「啊啊…♥ 目隠しするなら、せめて抱きしめながらシてくれ…♥♥\n　%MASTER_CALL()%の存在を有感觉たいよ…♥♥」"
				ELSE
					CALL MESSAGE_BOX,@"「啊♥ %MASTER_CALL()%…♥ この時が来たんだな…♥♥」"
				ENDIF
			ELSEIF TALENT:少女心
				CALL MESSAGE_BOX,@"「そんな……初めては%MASTER_CALL()%が貰ってくれるんじゃ……っ」"
			ELSEIF TFLAG:眼罩
				CALL MESSAGE_BOX,@"「%MASTER_CALL()%…？ 目隠しでよくわかんねぇけど…も、もしかして…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「啊啊…てっきり初めては%MASTER_CALL()%が貰ってくれるって……\n　い、不要…%MASTER_CALL()%がしたいならそれで……」"
			ENDIF
		ELSEIF TALENT:贞操观念 || TALENT:少女心
			CALL MESSAGE_BOX,@"「い、嫌だ…っ それ只是は…頼むからぁ…っ！ やめろぉっ！」"
		ELSEIF ＃陷落状态／陷落以上＃ || TALENT:不在乎贞操
			CALL MESSAGE_BOX,@"「う……いつかはこんな時が来るとは思ってたけどよ……」"
		ELSEIF V_PENIS == "触手"
			CALL MESSAGE_BOX,@"「いぃっ…！？ は、初めての相手が触手…！？ そんな…ひでえよ……っ」"
		ELSEIF V_PENIS == "妖精"
			CALL MESSAGE_BOX,@"「うぁぁっ！ ゴブリンなんかにっ……ぁぁああああ啊！」"
		ELSE
			CALL MESSAGE_BOX,@"「は、離せっ！ なに入れようとしてんだ…っ うぁぁっ！」"
		ENDIF
	
	CASE "处女丧失后"
		IF CFLAG:乳牛 || CFLAG:洗脑
			IF GETBIT(＃Ｐ使用／Ｖ插入＃)
				IF TFLAG:拘束BIT || TFLAG:眼罩
					CALL MESSAGE_BOX,@"「はぅっ♥ ……初めてがコレで、ヘンタイになっちまったら…♥♥\n　%MASTER_CALL()%に責任とってもらわないと…♥♥」"
				ELSE
					CALL MESSAGE_BOX,@"「ん…%MASTER_CALL()%に抱かれるのがこんなに幸せだなんてな…♥♥」"
				ENDIF
			ELSE
				IF TFLAG:眼罩
					CALL MESSAGE_BOX,@"「ふ咕呜っ♥…や、果然ぃ♥……なんてひでえヤツ…♥♥」"
				ELSE
					CALL MESSAGE_BOX,@"「は咕呜ぅ♥……あ、あれ…涙？……一定痛みのせい、だ…♥♥」"
				ENDIF
			ENDIF
		ELSEIF ＃陷落状态／恋慕以上＃
			IF GETBIT(＃Ｐ使用／Ｖ插入＃)
				IF TALENT:少女心
					CALL MESSAGE_BOX,@"「惚れた相手とひとつに結ばれて、嬉しすぎて怖いくらいだ…♥♥\n　%SELF_CALL()%、初めてがこんなに幸せでいいのかな…♥♥♥」"
				ELSEIF TFLAG:眼罩
					CALL MESSAGE_BOX,@"「%MASTER_CALL()%♥♥ %SWEET_MASTER_CALL()%…♥♥ 愛してるぅ♥♥」"
				ELSE
					CALL MESSAGE_BOX,@"「惚れた相手と結ばれるのがこんなに幸せだなんて…♥♥」"
				ENDIF
			ELSE
				IF TALENT:少女心
					CALL MESSAGE_BOX,@"「%SELF_CALL()%の想いを知っといて……%MASTER_CALL()%はヒド不要つだ……ぐすっ…」"
				ELSE
					CALL MESSAGE_BOX,@"「呜呜ぅ……こんな…こんな形で処女を捨てることに……」"
				ENDIF
			ENDIF
		ELSEIF TALENT:贞操观念 || TALENT:少女心
			CALL MESSAGE_BOX,@"「…こ、これは…一定夢なんだ……そう、ただの悪い…夢…」"
		ELSEIF ＃陷落状态／陷落以上＃ || TALENT:不在乎贞操
			IF V_PENIS == "妖精"
				CALL MESSAGE_BOX,@"「…初体験に理想なんかなかったけど…ゴブリン相手ってのは…流石に堪えるぜ……」"
			ELSEIF PALAM:Ｖ润滑 >= 10000
				CALL MESSAGE_BOX,@"「嗯……思ったほどは辛くないな…」"
			ELSE
				CALL MESSAGE_BOX,@"「咕呜…い、痛いに決まってんだろ…っ！\n　き、気遣うくらいなら早く抜いてくれ…っ」"
			ENDIF
		ELSE
			CALL MESSAGE_BOX,@"「あぐっ……ぐっ…ひぅ…」"
		ENDIF
	
	CASE "Ａ处女丧失前"
		IF TALENT:性知识贫乏
			CALL MESSAGE_BOX,@"「……？ 一体%ANAL_CALL()%に何をするつもりだ…？\n　…っ！？ %ANAL_CALL()%にっ…捻じ込まれてっ…！？」"
		ELSEIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			IF GETBIT(＃Ｐ使用／Ａ插入＃)
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「いてっ…！？　なのに…%ANAL_CALL()%の奥がジンジンして…変なの混ざってんじゃねえか…♥」"
					CALL MESSAGE_BOX,@"「%MASTER_CALL()%…尻まで好きにしていいって言ったのに…こんなの聞いてねえ…っ♥」"
				ELSE
					CALL MESSAGE_BOX,@"「%MASTER_CALL()%♥ 新品の%ANAL_CALL()%…自由に使っていいからな♥♥」"
				ENDIF
			ELSEIF A_PENIS == "触手"
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「痛っ…！？　でも…押し広げられながら…奥がムズムズ…気持ち悪…っ♥」"
				ELSE
					CALL MESSAGE_BOX,@"「触手が%ANAL_CALL()%に入ってくるのは…果然ちょっと怖い……っ」"
				ENDIF
			ELSE
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「痛ぇ…！？　なのに…%ANAL_CALL()%が勝手に…吸い付いてんの有感觉…マジかよ…♥」"
				ELSE
					CALL MESSAGE_BOX,@"「啊哈哈♥ %SELF_CALL()%的%ANAL_CALL()%でいっぱい遊んでくれよなぁ♥♥」"
				ENDIF
			ENDIF
		ELSEIF A_PENIS == "妖精"
			CALL MESSAGE_BOX,@"「……っ！？ %ANAL_CALL()%に触んじゃねえ…っ！？」"
		ELSE
			IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
				CALL MESSAGE_BOX,@"「そっちは違…っ！？　痛っ…！？　なのに…奥がぞわぞわ…っ、気持ち悪…！」"
			ELSE
				CALL MESSAGE_BOX,@"「そ、そっちは違っ…… っ～～～！」"
			ENDIF
		ENDIF
	
	CASE "Ａ处女丧失后"
		IF TALENT:性知识贫乏
			CALL MESSAGE_BOX,@"「か咿…%ANAL_CALL()%は…なんかを入れたりする地方じゃ……んぐっ…」"
		ELSEIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			IF GETBIT(＃Ｐ使用／Ａ插入＃)
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「…还ヒリヒリ…。でも…奥がうずいて…更加って言ってんのかよ…嫌な予感だ…♥」"
					CALL MESSAGE_BOX,@"「%MASTER_CALL()%のせいだ…尻まで変な癖つく…♥」"
				ELSE
					CALL MESSAGE_BOX,@"「…んおぉっ！？ ひ、一突きで…♥ %ANAL_CALL()%が%PENIS_CALL()%に屈服させられたぁ…♥♥」"
				ENDIF
			ELSE
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「痛みの奥に…妙な火種みたいなの残ってんじゃん…マジで最悪…♥」"
				ELSE
					CALL MESSAGE_BOX,@"「お、おぉ…っ♥ 腹が押し広げられて……っ♥」"
