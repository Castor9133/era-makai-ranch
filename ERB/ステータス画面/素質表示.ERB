
;持っている素質の簡易表示
@SHOW_TALENT_LIST_SIMPLE

BR = 0

;どのカテゴリか特に表示せず並べる
FOR LOCAL,50,700
	SIF !TALENT:LOCAL
		CONTINUE
	
	;シンプル表示のときは好き嫌いは飛ばす
	SIF LOCAL >= 500 && LOCAL < 650
		CONTINUE
	CALL BR_PLUS(6)
	PRINTFORM 【%TALENTNAME:LOCAL%】
NEXT
PRINTL

;先天素質があれば表示
SIF MAXARRAY(TALENT,30,50) || (CFLAG:妊娠日数 > 9 && CFLAG:妊娠日数 < 16) || CFLAG:妊娠日数 > 92
	CALL SHOW_TALENT_NASTY



;現在の素質を表示
@SHOW_TALENT_LIST

;ランダムキャラメイク中に来たとき隠蔽有効なら隠す
IF GETBIT(＃状态隐藏／素质＃) && !GETBIT(＃重新调整／性格素质＃) && FLAG:角色化妆隐蔽有效
	CALL PRINTL_WORD_COLOR("素质尚不明","灰")
	RETURN
ENDIF

;6つずつ改行
PRINTL 　《 素质 》
CALL SHOW_TALENT_LIST_TRIBE
CALL SHOW_TALENT_LIST_CONSTITUTION
CALL SHOW_TALENT_LIST_PERSONALITY
CALL SHOW_TALENT_LIST_LIKE
CALL SHOW_TALENT_LIST_DISLIKE
CALL SHOW_TALENT_LIST_SPECIAL



;種族系素質の表示
@SHOW_TALENT_LIST_TRIBE

BR = 0
PRINT 种族：
IF !MAXARRAY(TALENT,50,100)
	CALL PRINTL_WORD_COLOR("特别","灰")
	RETURN
ENDIF
FOR LOCAL,50,100
	SIF !TALENT:LOCAL
		CONTINUE
	CALL BR_PLUS(6,1)
	PRINTFORM 【%TALENTNAME:LOCAL%】
NEXT
PRINTL



;体質系素質の表示
;技能もここで出す
@SHOW_TALENT_LIST_CONSTITUTION

BR = 0
PRINT 体技：
IF !MAXARRAY(TALENT,100,300)
	CALL PRINTL_WORD_COLOR("特别","灰")
	RETURN
ENDIF
FOR LOCAL,100,300
	SIF !TALENT:LOCAL
		CONTINUE
	CALL BR_PLUS(6,1)
	PRINTFORM 【%TALENTNAME:LOCAL%】
NEXT
PRINTL


;性格素質
@SHOW_TALENT_LIST_PERSONALITY

BR = 0
PRINT 性格：
IF !MAXARRAY(TALENT,300,500)
	CALL PRINTL_WORD_COLOR("特别","灰")
	RETURN
ENDIF
FOR LOCAL,300,500
	SIF !TALENT:LOCAL
		CONTINUE
	CALL BR_PLUS(6,1)
	PRINTFORM 【%TALENTNAME:LOCAL%】
NEXT
PRINTL



;嗜好素質・好き
@SHOW_TALENT_LIST_LIKE

;STR:牛→8300
STR_REF = 8300 -500
BR = 0

;-1のとき苦手なので変化
PRINT 喜欢：
IF MAXARRAY(TALENT,500,600) < 1
	CALL PRINTL_WORD_COLOR("特别","灰")
	RETURN
ENDIF
FOR LOCAL,500,600
	SIF TALENT:LOCAL < 1
		CONTINUE
	CALL BR_PLUS(6,1)
	SIF BR >= 2
		PRINT ・
	PRINTFORM %STR:(STR_REF +LOCAL)%
NEXT
PRINTL



;嗜好・苦手
@SHOW_TALENT_LIST_DISLIKE

BR = 0
PRINT 苦手：
IF MINARRAY(TALENT,500,600) > -1
	CALL PRINTL_WORD_COLOR("特别","灰")
	RETURN
ENDIF
FOR LOCAL,500,600
	SIF TALENT:LOCAL > -1
		CONTINUE
	CALL BR_PLUS(6,1)
	SIF BR >= 2
		PRINT ・
	PRINTFORM %STR:(STR_REF +LOCAL)%
NEXT
PRINTL



;特殊素質の表示
@SHOW_TALENT_LIST_SPECIAL

BR = 0

;ここはなければそもそも表示しない
SIF MAXARRAY(TALENT,600,700) < 1
	RETURN
PRINT 特殊：
FOR LOCAL,600,700
	SIF !TALENT:LOCAL
		CONTINUE
	CALL BR_PLUS(6,1)
	PRINTFORM 【%TALENTNAME:LOCAL%】
NEXT
PRINTL



;性素質の表示
@SHOW_TALENT_NASTY

PRINT 女体：
IF MAXARRAY(TALENT,30,50) < 1 && (CFLAG:妊娠日数 <= 9 || CFLAG:妊娠日数 >= 16) && CFLAG:妊娠日数 <= 92
	CALL PRINTL_WORD_COLOR("特别","灰")
	RETURN
ENDIF
SETCOLOR 0xFF70FF

;性素質じゃないけどここで表示が一番よさそうなので
SIF (CFLAG:妊娠日数 > 9 && CFLAG:妊娠日数 < 16) || CFLAG:妊娠日数 > 92
	PRINTFORM ❤妊娠中❤ 
FOR LOCAL,30,50
	SIF TALENT:LOCAL
		PRINTFORM ❤%TALENTNAME:LOCAL%❤ 
NEXT
RESETCOLOR
PRINTL



