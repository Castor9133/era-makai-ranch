
;服装再シャッフル
@CHARA_MAKE_SLAVE_SHUFFLE_CLOTHE

CLEARLINE LINECOUNT
CALL PRINT_PORTRAIT(1)
PRINTL 重新调整候选奴隶的服装・内衣・配饰。
PRINTL （图案在角色化妆过程中不抽）
PRINTL
CALL SHOW_EQUIP
CALL PRINTL_ALIGN(-15)
CALL HALFLINE
SIF GETBIT(＃重新调整／服装＃)
	SETCOLOR 0x80FFFF
PRINTFORML 【%VALUE_DIGIT(SHUFFLE_AGAIN_PT:10)%pt】
PRINTL ＜服装的重新打乱＞
PRINTLC [ 0] 服装全部
PRINTLC [ 1] 仅内衣
PRINTLC [ 2] 仅装饰
CALL MANYL(2)
PRINTL ＜装备的颜色・形状调整＞
FOR LOCAL,1,20
	SIF !EQUIP:LOCAL || LOCAL == 5
		CONTINUE
	PRINTFORML [{LOCAL +10}] %EQUIPNAME:(EQUIP:LOCAL)%
NEXT
RESETCOLOR
CALL PRINTL_ALIGN
DRAWLINE
PRINTL [99] 完成
BINPUT
SELECTCASE RESULT
CASE 0
	CALL RANDOM_SLAVE_CLOTHE
CASE 1
	;下着をリセット→下着のみ再シャッフル
	FOR LOCAL,3,5
		SIF !EQUIP:LOCAL
			CONTINUE
		CSTR:(EQUIP:LOCAL) =
		EQUIP:(EQUIP:LOCAL) = 0
		EQUIP:LOCAL = 0
	NEXT
	CALL RANDOM_SLAVE_CLOTHE_LINGERIE
	CALL CHARA_MAKE_SLAVE_SHUFFLE_EQUIP_REGISTER
	CALL RANDOM_SLAVE_LINGERIE_COLOR
CASE 2
	;アクセサリーのみ
	FOR LOCAL,10,20
		SIF !EQUIP:LOCAL
			CONTINUE
		CSTR:(EQUIP:LOCAL) =
		EQUIP:(EQUIP:LOCAL) = 0
		EQUIP:LOCAL = 0
	NEXT
	CALL RANDOM_SLAVE_CLOTHE_ACCESSORY
	CALL CHARA_MAKE_SLAVE_SHUFFLE_EQUIP_REGISTER
	CALL RANDOM_SLAVE_ACCESSORY_COLOR
CASE 10 TO 29
	CALL CHARA_MAKE_SLAVE_SHUFFLE_CLOTHE_PART(RESULT -10)
CASE 99
	RETURN
ENDSELECT

;99以外ならここなので一括フラグONでOK
SETBIT ＃重新调整／服装＃
RESTART



;個別色シャッフル
;ARG→変更するEQUIP位置
@CHARA_MAKE_SLAVE_SHUFFLE_CLOTHE_PART(ARG)

;アイテム番号
ITEM_NUM = EQUIP:ARG
LAST_SHUFFLE_S = %CSTR:ITEM_NUM%

;参照STR変更
SELECTCASE ITEMNAME:ITEM_NUM
CASE "礼服","战斗礼服","淫乱礼服","哥特萝莉装","军服","斗篷"
	STR_REF = 6720
CASE "眼镜","伊达眼镜"
	;メガネの場合はメガネ用に移動しておわり
	CALL RANDOM_SLAVE_ACCESSORY_GLASSES(ITEM_NUM)
	RETURN
CASEELSE
	STR_REF = 6700
ENDSELECT
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE_S == RESULTS
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0
CSTR:ITEM_NUM = %RESULTS%





;再シャッフル用ID入れ
;説明は@CHARA_EQUIP_REGISTERで
@CHARA_MAKE_SLAVE_SHUFFLE_EQUIP_REGISTER
#DIMS CLOTHE_CATEGORY

FOR LOCAL,1000,2000
	SIF !EQUIP:LOCAL
		CONTINUE
	CALL CLOTHE_CATEGORY_CHECK(ITEMNAME:LOCAL)
	SELECTCASE RESULTS
	CASE "衣服"
		EQUIP:装备中ID／衣服 = LOCAL
		
		;こっちでは色柄を無視
	CASE "内衣上下装","内衣上下装／极小"
		EQUIP:装备中ID／内衣上装 = LOCAL
		EQUIP:装备中ID／内衣下装 = LOCAL
		
	{
	CASE "铠","内衣上装","内衣上装／极小","内衣上装／贴纸","内衣下装","内衣下装／极小","内衣下装／贴纸",
	"眼","头","腕","腿","颈","外衣"
	}
		;極小とシールは上書き必要
		IF GROUPMATCH(RESULTS,"内衣上装／极小","内衣上装／贴纸")
			RESULTS = 内衣上装
		ELSEIF GROUPMATCH(RESULTS,"内衣下装／极小","内衣下装／贴纸")
			RESULTS = 内衣下装
		ENDIF
		CLOTHE_CATEGORY = 装备中ID／%RESULTS%
		EQUIP:CLOTHE_CATEGORY = LOCAL
	ENDSELECT
NEXT



