
;名前変更
;ARG→貢献pt消費がそもそもなし
@CHARA_MAKE_SLAVE_SHUFFLE_NAME(ARG)

;一人称が名前の場合設定し直す　この関数中に分岐ある場合書き換え必要、今は大丈夫
SIF CFLAG:第一人称是名字
	CALL RANDOM_SLAVE_CALLPERSON

CLEARLINE LINECOUNT
CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT
PRINT 奴隶的名字将被打乱或手动输入。
SIF !ARG
	PRINT （该项目不使用贡献pt）
CALL MANYL(2)
PRINTFORML 姓名：%CALLNAME%
CALL NAME_DUPLICATE_CHECK
PRINT 全名：
IF NAME == ""
	CALL PRINTL_WORD_COLOR,@"(未设定)","灰"
ELSE
	PRINTFORML %NAME%
ENDIF
CALL HALFLINE
PRINTL 《 调整候选选择 》※与打乱同时，全名将被重置。
PRINTL [ 0] 日本系
PRINTL [ 1] 英系
PRINTL [ 2] 法系
PRINTL [ 3] 德系
PRINTL [ 4] 意大利系
PRINTL [ 5] 俄系
PRINTL [ 6] 幻想系
PRINTL
PRINTL [20] 来源作品信息重置
CALL PRINTL_ALIGN
DRAWLINE
PRINTLC [10] 手动输入
PRINTLC [11] 全名手动输入
PRINTL [99] 完成
BINPUT
PRINTL
SELECTCASE RESULT
CASE 10
	PRINTL 请输入您的姓名（空白取消）
	INPUTS
	SIF RESULTS != ""
		CALLNAME = %RESULTS%
CASE 11
	PRINTL 请输入全名（空白取消）
	INPUTS
	SIF RESULTS != ""
		NAME = %RESULTS%
CASE 20
	PRINTL 将角色的【来源作品名】【识别名】等信息重置，并将名字清空。
	PRINTL （如果来自随机角色，由于原本为空，故与此无关）
	PRINTL
	PRINTL 要重置吗？
	CALL ASK_YN
	SIF !RESULT
		CALL CSV_TITLE_SOURCE_RESET
CASE 99
	RETURN
CASEELSE
	;ランダムに来たらフルネームは消す
	NAME =
	FIX = RESULT
	STR_MAX = 999
	STR_REF = 10000 +FIX *1000
	CALL STR_REF_SHUFFLE(STR_REF)
	CALLNAME = %RESULTS%
ENDSELECT
RESTART



