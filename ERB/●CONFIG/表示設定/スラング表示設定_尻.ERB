
;察してもらえるだろうけどケツどう分けていいかピンとこないんだ
;もらったスラングをなるべく使わせていただいたよ
;ケツスラング設定
@SLANG_CONFIG_HIP

CLEARLINE LINECOUNT
PRINTL 请选择以地文等形式显示的屁股黑话候选词。
DRAWLINE
PRINTLC [ 0] 「尻」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／尻,0),1)
PRINTLC [ 1] 「桃臀」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／尻,1),1)
PRINTLC [ 2] 「屁股」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／尻,2),1)
PRINTLC [ 3] 「臀部」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／尻,3),1)
PRINTLC [ 4] 「Ass」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／尻,4),1)
PRINTL
PRINTL 　《 前缀设置 》
PRINTLC [10] 「丰满的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／尻,0),0)
PRINTL 　（丰腴、丰满、性感时）
PRINTLC [11] 「饱满的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／尻,1),0)
PRINTL 　（丰腴、丰满、性感时）
PRINTLC [12] 「肉感的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／尻,2),0)
PRINTL 　（丰腴、丰满、性感时）
PRINTLC [13] 「丰硕的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／尻,3),0)
PRINTL 　（丰腴、丰满时）
PRINTLC [14] 「瘦削的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／尻,4),0)
PRINTL 　（瘦弱时）
PRINTLC [15] 「紧绷的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／尻,5),0)
PRINTL 　（苗条时）
PRINTLC [16] 「安产型的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／尻,6),0)
PRINTL 　（丰腴、丰满时）
PRINTLC [17] 「大的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／尻,7),0)
PRINTL 　（丰腴、丰满、性感时）
PRINTLC [18] 「小的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／尻,8),0)
PRINTL 　（瘦弱、苗条时）
PRINTLC [19] 「弹力十足的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／尻,9),0)
PRINTL 　（非瘦弱）
PRINTLC [20] 「生机勃勃的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／尻,10),0)
PRINTL 　（非瘦弱）
PRINTLC [21] 「柔软的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／尻,11),0)
PRINTL 　（非瘦弱）
PRINTLC [22] 「形状好的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／尻,12),0)
PRINTL 　（非瘦弱）
PRINTL
PRINTL 　《 特殊替换设置 》
PRINTL 　无设置
;PRINTLC [20] 特殊置換を優先
;CALL PRINT_ONOFF(GETBIT(FLAG:スラング置換／尻,0),0)
;PRINTL 　…特殊置換の条件を満たす場合に優先して表示されます
CALL SLANG_CONFIG_FOOTER
INPUT
SELECTCASE RESULT
CASE 0 TO 6
	INVERTBIT FLAG:黑话标识／尻,RESULT
CASE 10 TO 22
	INVERTBIT FLAG:黑话前缀／尻,(RESULT -10)
CASE 80
	FLAG:黑话标识／尻 = 65535
CASE 81
	FLAG:黑话前缀／尻 = 65535
CASE 82
	FLAG:黑话替换／尻 = 65535
CASE 90
	FLAG:黑话标识／尻 = 0
CASE 91
	FLAG:黑话前缀／尻 = 0
CASE 92
	FLAG:黑话替换／尻 = 0
CASE 98
	PRINTL 回复默认的屁股黑话候选人？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_SLANG_CONFIG_HIP
CASE 99
	IF !FLAG:黑话标识／尻
		PRINTW 必须至少设置一个候选黑话。
	ELSE
		RETURN
	ENDIF
ENDSELECT
RESTART


