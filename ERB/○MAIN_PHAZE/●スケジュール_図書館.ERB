
;図書館
@VISIT_LIBRARY
#DIM SKILL_POINT

;あなたしか来ない
CALL MILESTONE_UNLOCK_CHECK("禁忌魔法","")
SIF CSTR:0:日程 != "图书馆" || !RESULT
	RETURN
TARGET = 0
PRINTL 　　　《 图书馆 》
PRINTFORML %CALLNAME%访问了图书馆，继续阅读＜阿尔・阿吉夫＞。

;100万MPにつき1AP
SKILL_POINT = MAXBASE:0:魔力
MONEY:禁断AP累积值 += SKILL_POINT
PRINTFORM 禁断AP累积+%VALUE_DIGIT(SKILL_POINT)%

;実際にAPになるほうを計算
;禁断AP：蓄積値100万→1AP
SKILL_POINT = MONEY:禁断AP累积值 /1000000
IF SKILL_POINT
	MONEY:禁断AP += SKILL_POINT
	MONEY:禁断AP累计值 += SKILL_POINT
	MONEY:禁断AP累积值 -= (SKILL_POINT *1000000)
	CALL PRINT_WORD_COLOR,@"【禁断AP+{SKILL_POINT}】","浅蓝色"
ENDIF
PRINTL
USE_MP = MAGIC_USE_MP:GETNUM(ITEM,"个人用传送门")
BASE:魔力 = LIMIT(BASE:魔力 -USE_MP,0,BASE:魔力)
PRINTFORML ＜个人用传送门＞消费：%VALUE_DIGIT(USE_MP)%MP
EXP:执行次数／图书馆 ++
EXP:区间执行次数／图书馆 ++
PRINTW
DRAWLINE


