
;衣服セット
;SELECT_ITEM指定中
@EQUIP_CLOTHE_SET_WEAR
#DIM SAVE_SELECT_ITEM

;常に確認
IF TARGET
	PRINTFORML 去掉眼部和颈部装备，给%CALLNAME%穿上＜%ITEMNAME:SELECT_ITEM%＞吗？
ELSE
	PRINTFORML 去掉眼部和颈部装备，%CALLNAME%会穿上＜%ITEMNAME:SELECT_ITEM%＞吗？
ENDIF
PRINTL ※如果角色没有拥有，颜色和图案将默认。
PRINTL 　如果包含眼部和颈部装备，则会覆盖。
CALL ASK_YN
SIF RESULT
	RETURN 1

;保存
SAVE_SELECT_ITEM = SELECT_ITEM

;共通で眼と首以外は脱ぐ
FOR LOCAL,0,20
	SIF GROUPMATCH(EQUIPNAME:LOCAL,"装备中ID／眼","装备中ID／颈")
		CONTINUE
	EQUIP:LOCAL = 0
NEXT

;一式着せる処理呼び出し
CALL EQUIP_CLOTHE_SET_COMMON("穿着")

;SELECT_ITEM自体を所持済みにする
SELECT_ITEM = SAVE_SELECT_ITEM

;未所持のときここで減らす必要がある
IF !EQUIP:SELECT_ITEM && !FLAG:正在化妆角色
	SETBIT EQUIP:SELECT_ITEM,0
	ITEM:SELECT_ITEM --
ENDIF

;キャラメイク中は終了
SIF FLAG:正在化妆角色
	RETURN
IF TARGET
	PRINTFORMW 已给%ITEMNAME:SELECT_ITEM%穿上。
ELSE
	PRINTFORMW 已穿上＜%ITEMNAME:SELECT_ITEM%＞。
ENDIF




