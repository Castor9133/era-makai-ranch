
;自室持ち／寮の部屋番号を表示する
@PRINT_ROOM_NUM

IF EQUIP:单间
	CALL PRINTL_WORD_COLOR("单间拥有","浅蓝色")
ELSEIF CFLAG:宿舍号
	CALL PRINT_DORMITORY_NUM(1)
ELSE
	CALL PRINTL_WORD_COLOR("　没有自室","灰")
ENDIF



;寮の部屋番号
;ARG→1なら改行
@PRINT_DORMITORY_NUM(ARG)
#DIM ROOMMATE

;同じ部屋に何人いるか出す
ROOMMATE = CMATCH(CFLAG:宿舍号,CFLAG:宿舍号)
PRINTFORM 宿舍{CFLAG:宿舍号 +100}号室（{ROOMMATE}／4）
SIF ARG
	PRINTL



;ルームメイトの表示
@PRINT_SLAVE_DORMITORY_ROOMMATE
#DIM DORMITORY_NUM

DORMITORY_NUM = CFLAG:宿舍号
PRINT 同屋：
SAVE_TARGET = TARGET
EXIST = 0
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	
	;寮番号が同じなら表示
	SIF TARGET == SAVE_TARGET || CFLAG:宿舍号 != DORMITORY_NUM
		CONTINUE
	SIF EXIST
		PRINT ・
	PRINTFORM %CALLNAME%
	EXIST ++
NEXT
SIF !EXIST
	CALL PRINT_WORD_COLOR("无","灰")
PRINTL
TARGET = SAVE_TARGET




