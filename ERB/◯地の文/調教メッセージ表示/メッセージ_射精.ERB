	CASEELSE
		PRINTFORM 在%CALLNAME%湿热的深喉里、
	ENDSELECT
ELSEIF ABL:精饮中毒 >= 8
	SELECTCASE RAND:4
	CASE 0
		PRINTFORM 在%CALLNAME%被操干的喉咙深处、
	CASE 1
		PRINTFORM 精液灌进喉管，%CALLNAME%边干呕边拼命吞咽，像怕浪费似的，
	CASE 2
