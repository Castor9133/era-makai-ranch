;嗜好
@SELF_CHARA_MAKE_TALENT_5

PRINTL 　《 嗜好 》
PRINTL （喜欢→青　苦手→赤　无所谓→灰色）
PRINTL ※每次选择时都会在＜喜欢→苦手→无→喜欢＞之间切换
CALL HALFLINE
BR = 0

;TALENT:牛好き→500
;STR:牛→8300
STR_REF = 8300 -500
FOR LOCAL,500,600
	SIF TALENTNAME:LOCAL == ""
		CONTINUE
	
	;嗜好だけ+-で色変更
	IF TALENT:LOCAL > 0
		SETCOLOR 0x80FFFF
	ELSEIF TALENT:LOCAL < 0
		SETCOLOR 0xEF857D
	ELSE
		SETCOLOR 0x606060
	ENDIF
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL,3}] %STR:(LOCAL +STR_REF)%
NEXT



