SELECTCASE INPUT_NUM
CASE 0
	PRINTL 当身高抽选到【标准】【矮小】【娇小】时，将转换为【高挑】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／龙人"),INPUT_NUM)
