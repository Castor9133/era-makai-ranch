
;戦闘開始前
;ARG→CHR：戦闘に向かったキャラ
@MASTER_BATTLE_MAIN_BEFORE(ARG)

;BATTLE_CHARAに入れる
BATTLE_CHARA = ARG

;あなた以外を送ったなら転送に要する魔力２倍
BASE:0:魔力 -= MAGIC_USE_MP:GETNUM(ITEM,"传送")
SIF BATTLE_CHARA != 0
	BASE:0:魔力 -= MAGIC_USE_MP:GETNUM(ITEM,"传送")

;攻撃回数を計算
CALL ATTACK_TIMES_CALC
CSTR:0:日程 = 行动完毕
CALL MASTER_BATTLE_MAIN_BEFORE_MESSAGE

;とりあえず当日に戦闘したフラグON
CFLAG:当日战斗完毕 = 1

;降参フラグをOFF
TFLAG:投降 = 0

;戦闘開始前の口上・地の文と降参処理
CALL BATTLE_BEFORE_ACTION

;降参した場合そのまま敗北時処理へ
IF TFLAG:投降
	CALL MASTER_BATTLE_WIN
	RETURN
ENDIF
PRINTL 《 战斗开始 》
FORCEWAIT

;戦闘開始　1ターン目とする
TURN = 1
CALL MANYL(5)
CALL MASTER_BATTLE_MAIN



;本処理
@MASTER_BATTLE_MAIN

;傭兵戦闘との違い→・先制攻撃しない・逃がすのを許さない
CALL MASTER_BATTLE_STATUS
CALL MASTER_BATTLE_TARGET_ACTION_COMMON
PRINTW
SIF BASE:BATTLE_CHARA:战斗力 && BASE:同伴战斗力1
	CALL MASTER_BATTLE_TARGET_GROUP_ATTACK
SIF BASE:BATTLE_CHARA:战斗力
	CALL MASTER_BATTLE_MASTER_ATTACK

;プレイヤーダウン、ターゲット全滅のどれかで終了
IF !BASE:BATTLE_CHARA:战斗力
	CALL TARGET_WIN
	
	;倒された場合は戦ったキャラのHP0
	CALL PLAYER_DEFEAT_CALC
	
ELSEIF !BASE:战斗力
	CALL MASTER_BATTLE_WIN
	BASE:体力 = 0

;戦闘継続
ELSE
	TURN ++
	RESTART
ENDIF



