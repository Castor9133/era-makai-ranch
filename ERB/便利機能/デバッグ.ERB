
;デバッグコマンド用
;実装したイベントを試したいときとかに使えるぞ
;終了でSHOPに戻る


;デバッグ関数で行う処理をここに書く
@DEBUG_FILE
ITEM:魔力枷锁 += 100


;牛舎増築段階を+
;FLAG:第1牛舎増築段階→500
FLAG_REF = 490
FOR LOCAL,0,ITEM:牛舍
	SIF !FLAG:(FLAG_REF +LOCAL *10)
		FLAG:(FLAG_REF +LOCAL *10) ++
NEXT



@DEBUG

;フリー以外だと帰る
IF !FLAG:开发者模式
	PRINTL 除＜开发者模式＞外无法使用调试指令。
	CALL CONFIG_DIFFICULTY_FREE_MODE_CHECK
	
	;ここでONにしたらそのまま下へ
	SIF !FLAG:开发者模式
		RETURN
ENDIF

CLEARLINE LINECOUNT
PRINTL 　《 调试菜单 》
PRINTLC [ 0] 重命名牧场
PRINTLC [ 1] 重命名角色等
PRINTLC [ 2] 重命名宠物等
PRINTL
PRINTL
PRINTL 　《 秘密指令 》
PRINTLC [10] 资金增加
PRINTLC [11] 主人公灵力增加
PRINTLC [12] 主人公魔力增加
PRINTLC [13] 储备灵力增加
PRINTLC [14] 贡献pt增加
PRINTLC [15] 全部物品收购
PRINTLC [16] 捕获追踪中的角色
PRINTLC [17] 收集齐＜龙之珠＞
PRINTLC [18] 各种技能点增加
PRINTLC [19] 储存魔力增加
PRINTL

;emueraのデバッグモード以外だと表示しないで誤操作防止したほうがよさげ
;#;PRINTL
;#;PRINTL [90] デバッグ関数呼び出し（開発用およびERBファイルいじれる人向け）
DRAWLINE
PRINTL [99] 完成
INPUT
SELECTCASE RESULT
CASE 0
	CALL NEWGAME_RANCH_NAME_BEFORE
	
CASE 1
	CALL DEBUG_CHARA_NAME_EDIT_SELECT

CASE 2
	CALL DEBUG_PET_NAME_EDIT

CASE 10
	MONEY += 1000000
	MONEY *= 2
	CALL RESOURCE_LIMIT
	PRINTFORMW 资金增加至%VALUE_DIGIT(MONEY)%G。
	
CASE 11
	MAXBASE:0:灵力 += 1000000
	MAXBASE:0:灵力 *= 2
	BASE:0:灵力 = MAXBASE:0:灵力
	CALL RESOURCE_LIMIT
	PRINTFORMW %CALLNAME:0%的灵力增加至%VALUE_DIGIT(MAXBASE:0:灵力)%EP。
	
CASE 12
	MAXBASE:0:魔力 += 1000000
	MAXBASE:0:魔力 *= 2
	BASE:0:魔力 = MAXBASE:0:魔力
	CALL RESOURCE_LIMIT
	PRINTFORMW %CALLNAME:0%的魔力增加至%VALUE_DIGIT(MAXBASE:0:魔力)%MP。
	
CASE 13
	MONEY:储存灵力 += 1000000
	MONEY:储存灵力 *= 2
	CALL RESOURCE_LIMIT
	PRINTFORMW 储存灵力增加至%VALUE_DIGIT(MONEY:储存灵力)%EP。
	
CASE 14
	MONEY:贡献PT += 1000000
	MONEY:贡献PT *= 2
	CALL RESOURCE_LIMIT
	PRINTFORMW 贡献PT增加至%VALUE_DIGIT(MONEY:贡献PT)%pt。

CASE 15
	;ペットは外す
	FOR LOCAL,0,100
		SIF ITEMNAME:LOCAL != ""
			ITEM:LOCAL += 1
	NEXT
	FOR LOCAL,120,2000
		SIF ITEMNAME:LOCAL != ""
			ITEM:LOCAL += 1
	NEXT
	;ふたなり持ってなかった=ペニスサイズ0の場合設定
	IF !ABL:0:阴茎尺寸
		ABL:0:阴茎尺寸 = CFLAG:0:身高 / 50 + RAND:6 + 15
		ABL:0:初始值／阴茎尺寸 = ABL:0:阴茎尺寸
	ENDIF
	;触手も追加(最初からITEMで設定すればよかったかな？)
	FLAG:触手出产合计 ++
	PRINTW 非宠物的名称设置项・魔法・设备的所持数为+1做了。
	
	;マイルストーン回す
	CALL MILESTONE_CHECK_ALL
	
	;牛舎増築段階を+
	;FLAG:第1牛舎増築段階→500
	FLAG_REF = 490
	FLAG:(FLAG_REF +ITEM:牛舍 *10) ++
	
CASE 16
	EXIST = 0
	FOR TARGET_COUNT,0,CHARANUM
		TARGET = TARGET_COUNT
		SIF !CFLAG:追踪对象
			CONTINUE
		CALL SLAVE_RECEIVE_COMMON
		EXIST ++
	NEXT
	SIF !EXIST
		PRINTW 没有追踪目标角色。

CASE 17
	ITEM:龙之珠 = 7
	PRINTW 手里已经集齐了7个＜龙之珠＞。

CASE 18
	FOR LOCAL,20,25
		MONEY:LOCAL += 10000
		MONEY:LOCAL *= 2
	NEXT
	CALL RESOURCE_LIMIT
	PRINTW 各种技能点进行+10000→翻倍。

CASE 19
	MONEY:储存魔力 = FLAG:储存魔力上限值
	PRINTW 储存魔力调整至当前上限值。

CASE 90
	;#;CALL DEBUG_FILE
	;#;PRINTW デバッグ関数終了

CASE 99
	RETURN

ENDSELECT
RESTART


