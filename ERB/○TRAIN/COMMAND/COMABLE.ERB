;--------------------------------------------------,
;乳揉み
@COM_ABLE10
SIF !GETBIT(＃表示指令／Ｂ刺激＃)
	RETURN 0

;口に挿れながらは無理
SIF GETBIT(＃Ｐ使用／Ｍ插入＃)
	RETURN 0
RETURN 1



;乳搾り
@COM_ABLE11
SIF !GETBIT(＃表示指令／Ｂ刺激＃)
	RETURN 0
SIF GETBIT(＃Ｐ使用／Ｍ插入＃)
	RETURN 0

;巨乳以上ないと搾れない
SIF ABL:胸围大小 < BUSTSIZE_巨乳
	RETURN 0

;乳首露出の時だけ
SIF TFLAG:Ｎ露出
	RETURN 1



;乳首つまみ
@COM_ABLE12
SIF !GETBIT(＃表示指令／Ｎ刺激＃)
	RETURN 0
SIF GETBIT(＃Ｐ使用／Ｍ插入＃)
	RETURN 0

;乳首になにかついてると乳首責め不可
SIF TFLAG:Ｎ装备
	RETURN 0
SIF TFLAG:Ｎ露出
	RETURN 1

;横乳露出かＢ露出かつ、Ｎ露出できる場合でも横から手を入れて乳首責めできるようにする
{
SIF (TFLAG:侧乳露出 || TFLAG:Ｂ露出) && (!EQUIP:装备中ID／内衣上装 || GETBIT(＃半脱／内衣上装＃) ||
TFLAG:临时脱衣／内衣上装 || ＃穿着内衣上装／名称＃ == "乳头露出胸罩" || ＃穿着内衣上装／名称＃ == "授乳开口胸罩")
}
	RETURN 1

;授乳スリット状態でもできる分岐
;ブラ判定まで来ないとフラグが立たないので服の上ということはないはず
;次服の上から可能なようにしようかな？
SIF TFLAG:授乳开口
	RETURN 1



