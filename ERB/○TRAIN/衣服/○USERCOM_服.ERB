
;USERCOMから飛ばす用
;服入り口　処理が面倒だし使う？という感じなので着せる処理はないよ
@TRAIN_CLOTHES_COMMON

;もう全裸なら帰る　という処理だったんだけどいろいろ組んだので無効
VARSET COMMAND_OK
CALL TRAIN_STRIP_COMMAND_CLOTHE
CALL TRAIN_STRIP_LINGERIE_BUST
CALL TRAIN_STRIP_LINGERIE_VAGINA
CALL TRAIN_STRIP_JACKET
CALL TRAIN_STRIP_ACCESSORY
CALL TRAIN_STRIP_BULK
PRINTL [99] 取消
BINPUT
SOURCE:脱衣消息显示 = 1
SELECTCASE RESULT
CASE 0
	CALL TRAIN_CLOTHE_STRIP("衣服","上半脱衣")
CASE 1
	;衣服破る前の確認
	CALL CONFIRM_TRAIN_CLOTHE_BREAK
	SIF RESULT
		RETURN
	CALL TRAIN_CLOTHE_STRIP("衣服","上部撕裂")
CASE 2
	CALL TRAIN_CLOTHE_STRIP("衣服","下半脱衣")
CASE 3
	CALL CONFIRM_TRAIN_CLOTHE_BREAK
	SIF RESULT
		RETURN
	CALL TRAIN_CLOTHE_STRIP("衣服","下部撕裂")

CASE 10
	CALL TRAIN_CLOTHE_STRIP("内衣","上身脱衣")
CASE 11
	CALL TRAIN_CLOTHE_STRIP("内衣","上半脱衣")
CASE 12
	CALL TRAIN_CLOTHE_STRIP("内衣","下身脱衣")
CASE 13
	CALL TRAIN_CLOTHE_STRIP("内衣","下半脱衣")

CASE 14
	CALL TRAIN_CLOTHE_STRIP("外衣","半脱")

CASE 20 TO 29
	CALL TRAIN_CLOTHE_STRIP("饰品","",RESULT -10)

CASE 30
	CALL TRAIN_CLOTHE_STRIP("衣服","脱衣")
CASE 31
	CALL TRAIN_CLOTHE_STRIP("衣服","一件半脱")
CASE 32
	CALL CONFIRM_TRAIN_CLOTHE_BREAK
	SIF RESULT
		RETURN
	CALL TRAIN_CLOTHE_STRIP("衣服","批量撕掉")
CASE 33
	CALL TRAIN_CLOTHE_STRIP("总计","上半脱衣")
CASE 34
	CALL TRAIN_CLOTHE_STRIP("总计","下半脱衣")
CASE 35
	CALL TRAIN_CLOTHE_STRIP("内衣","脱衣")
CASE 36
	CALL TRAIN_CLOTHE_STRIP("内衣","一件半脱")
CASE 37
	CALL TRAIN_CLOTHE_STRIP("总计","全半脱衣")
CASE 38
	CALL TRAIN_CLOTHE_STRIP("总计","全脱衣")
CASE 39
	CALL TRAIN_CLOTHE_STRIP("饰品","批量删除")
CASE 99
	RETURN 1
ENDSELECT

;ここ来てる場合脱がしたので止める
PRINTW

;SOURCEをリセットしないと脱衣メッセージが重複した
VARSET SOURCE



;衣服破る前の確認
@CONFIRM_TRAIN_CLOTHE_BREAK

;従順な場合だけ聞くようにする
SIF !CFLAG:无抵抗
	RETURN
PRINTFORML %CALLNAME%很顺从，没有必要把衣服撕破，即使那样也要撕破衣服吗？
CALL ASK_YN
SIF RESULT
	RETURN 1


