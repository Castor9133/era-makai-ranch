
;自動スケジュール
;「現在できるか」ではなく「体力回復したらできる」も見るので別フラグ使用
@AUTO_SCHEDULE
#DIM DYNAMIC WEEK

CLEARLINE LINECOUNT
CALL SHOW_STATUS_SIMPLE
PRINTFORML 请选择要自动分配给%CALLNAME%的日程。
PRINTL ・在选择的星期中，将设置下方选择的日程
CALL HALFLINE

;STR:曜日→3900
;CSTR:自動スケジュール／月→350
STR_REF = 3900
FLAG_REF = 350
FOR LOCAL,0,7
	;設定する曜日に→で印
	PRINTFORML \@ WEEK == LOCAL ? → # 　 \@[{LOCAL,3}] %STR:(STR_REF +LOCAL)%：%CSTR:(FLAG_REF +LOCAL)%
NEXT
CALL AUTO_SCHEDULE_LIST

;搾乳優先
IF MARK:母乳体质
	PRINTL 　《 搾乳优先设定 》
	PRINT [ 50] 朝
	CALL PRINT_ONOFF(GETBIT(＃搾乳优先／朝＃))
	PRINT 　　[ 51] 昼
	CALL PRINT_ONOFF(GETBIT(＃搾乳优先／昼＃))
	PRINT 　　[ 52] 夕
	CALL PRINT_ONOFF(GETBIT(＃搾乳优先／夕＃))
ENDIF
CALL PRINTL_ALIGN
PRINTL [ 60] 批量设置
DRAWLINE

;恋慕以上・従業員(またはあなた)ならカスタムを組めるようにする
IF ((＃陷落状态／恋慕以上＃ || CSTR:状态／主人公的孩子 == "成长后") && CFLAG:日程设定可能／事务) || TALENT:业主
	PRINTLC [ 90] 自定义管理
ELSE
	PRINTLC 　
ENDIF
PRINTLC [ 98] 提示
PRINTLC [ 99] 完成
BINPUT

;渡す関数でINPUT_NUMを使いたい
INPUT_NUM = RESULT

;分割→直接RETURNとかある部分
SELECTCASE INPUT_NUM
CASE 0 TO 9
	WEEK = INPUT_NUM
CASE 50,51,52
	INVERTBIT CFLAG:日程／搾乳优先BIT,INPUT_NUM -50
CASE 60
	CALL AUTO_SCHEDULE_BULK
CASE 90
	CALL AUTO_SCHEDULE_CUSTOM
CASE 98
	CALL BROWSE_HINT("自动日程")
CASE 99
	;勝手にセットすることにした
	CALL SCHEDULE_RESET_TARGET
	RETURN
CASEELSE
	CALL AUTO_SCHEDULE_LIST_SET(INPUT_NUM,WEEK)
	
	;WEEKを移動する
	WEEK ++
	SIF WEEK >= 7
		WEEK = 0
ENDSELECT
RESTART



;一括設定
@AUTO_SCHEDULE_BULK

CALL MANYL(3)
PRINTFORML %CALLNAME%将自动分配的日程汇总设定到所有星期。
CALL AUTO_SCHEDULE_LIST
PRINTL
PRINTL [ 99] 取消
BINPUT
SIF RESULT == 99
	RETURN
CALL AUTO_SCHEDULE_LIST_SET(RESULT,99)


