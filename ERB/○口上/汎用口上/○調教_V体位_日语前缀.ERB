; 阴道／肛门插入时的体位差分前缀（日语泛用口上）
; ARGS:0 = TRAINNAME（正常位／Ａ正常位 等）。恋慕・乳牛・洗脑・隶属 时额外一句，避免九体位同一套话。
; 由 *_TRAIN_INSIDE に ARGS:3 として渡す

@KOJO_JP_VPOS_HINT_慇懃1(ARGS:0)
SIF !(CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃ || ＃陷落状态／隶属＃)
	RETURN
SELECTCASE ARGS:0
CASE "正常位"
	CALL MESSAGE_BOX,@"「正面から…♥ 見つめ合うと、素直になるでしょ…♥」"
CASE "后背位"
	CALL MESSAGE_BOX,@"「後ろは…♥ 見えない分だけ、声が正直で…っ♥」"
CASE "对面坐位"
	CALL MESSAGE_BOX,@"「座って抱えるの…♥ 太ももが熱くなるの分かる…♥」"
CASE "背面坐位"
	CALL MESSAGE_BOX,@"「背中で感じるの…♥ 逃げ場ないのに安心しちゃう…♥」"
CASE "骑乘位"
	CALL MESSAGE_BOX,@"「上に跨るの…♥ これ、主導権もらってるみたい…♥」"
CASE "背面骑乘位","强制骑乘位"
	CALL MESSAGE_BOX,@"「逆さまになんて…♥ 恥ずかしいのに腰が止まらないの…♥」"
CASE "对面立位"
	CALL MESSAGE_BOX,@"「立ったまま正面…♥ 足首が震えちゃう…♥」"
CASE "背面立位"
	CALL MESSAGE_BOX,@"「後ろから立って…♥ 壁、かして…っ♥」"
CASE "Ａ正常位","Ａ后背位","Ａ对面坐位","Ａ背面坐位","Ａ骑乘位","Ａ对面立位","Ａ背面立位","强制Ａ骑乘位","Ａ背面骑乘位"
	CALL MESSAGE_BOX,@"「お尻の体勢で入り角が違うの…♥ ばれるからね…っ♥」"
ENDSELECT
RETURN

