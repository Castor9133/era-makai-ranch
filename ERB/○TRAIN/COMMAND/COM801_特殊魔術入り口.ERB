
;特殊魔術入り口
@COM801

PRINTFORML %CALLNAME:0%的魔力：%VALUE_DIGIT(BASE:0:魔力)%MP 
COST = MAGIC_USE_MP:GETNUM(ITEM,"淫纹赋予")
IF MARK:淫纹
	CALL PRINTL_WORD_COLOR("已经被赋予【淫纹】了","桃")
ELSEIF !ITEM:淫纹赋予
	CALL PRINTL_WORD_COLOR(" 　　淫纹赋予","灰")
ELSEIF BASE:0:魔力 < COST
	CALL PRINTL_WORD_COLOR,@"MP不足（%VALUE_DIGIT(COST)%MP必要）","灰"
ELSE
	PRINTFORML [ 0] 淫纹付与：%VALUE_DIGIT(COST)%MP
ENDIF

;時間圧縮中ならOK
COST = MAGIC_USE_MP:GETNUM(ITEM,"时间压缩")
IF TFLAG:压缩时间中
	PRINTFORML [ 1] 时间压缩解除
ELSEIF !ITEM:时间压缩
	CALL PRINTL_WORD_COLOR(" 　　时间压缩","灰")
ELSEIF BASE:0:魔力 < COST *(TFLAG:时间压缩有效回合数 +1)
	CALL PRINTL_WORD_COLOR,@"MP不足（%VALUE_DIGIT(COST *(TFLAG:时间压缩有效回合数 +1))%MP必要）","灰"
ELSE
	PRINTFORML [ 1] 时间压缩：%VALUE_DIGIT(COST *(TFLAG:时间压缩有效回合数 +1))%MP／ターン
ENDIF

COST = MAGIC_USE_MP:GETNUM(ITEM,"阴茎变化")
IF !ITEM:阴茎变化
	CALL PRINTL_WORD_COLOR,@" 　　阴茎変化(%CALLNAME:PLAYER%)","灰"
ELSEIF BASE:0:魔力 < COST
	CALL PRINTL_WORD_COLOR,@"MP不足（%VALUE_DIGIT(COST)%MP必要）","灰"
ELSE
	PRINTFORML [ 2] 阴茎変化(%CALLNAME:PLAYER%)：%VALUE_DIGIT(COST)%MP
ENDIF

COST = MAGIC_USE_MP:GETNUM(ITEM,"痛苦快乐变换")
IF !ITEM:痛苦快乐变换
	CALL PRINTL_WORD_COLOR,@" 　　痛苦快乐变换","灰"
ELSEIF BASE:0:魔力 < COST
	CALL PRINTL_WORD_COLOR,@"MP不足（%VALUE_DIGIT(COST)%MP必要）","灰"
ELSE
	PRINTFORML [ 3] 痛苦快乐转换：%VALUE_DIGIT(COST)%MP
ENDIF

;これ以下はアル・アジフ必要
COST = MAGIC_USE_MP:GETNUM(ITEM,"洗脑")
IF !ITEM:洗脑
	CALL PRINTL_WORD_COLOR(" 　　洗脑","灰")
ELSEIF BASE:0:魔力 < COST
	CALL PRINTL_WORD_COLOR,@"MP不足（%VALUE_DIGIT(COST)%MP必要）","灰"
ELSEIF !(CFLAG:无抵抗 || TFLAG:拘束BIT || !BASE:体力)
	CALL PRINTL_WORD_COLOR("不是顺从的奴隶的话，不是拘束状态或者HP为0就不能使用魔法","黄")
ELSE
	PRINTFORML [10] 洗脑：%VALUE_DIGIT(COST)%MP
ENDIF

COST = MAGIC_USE_MP:GETNUM(ITEM,"绝顶魔力回复淫纹")
IF MARK:绝顶魔力回复淫纹
	CALL PRINTL_WORD_COLOR("已经赋予【绝顶魔力回复淫纹】了","桃")
ELSEIF !ITEM:绝顶魔力回复淫纹
	CALL PRINTL_WORD_COLOR(" 　　绝顶魔力回复淫纹","灰")
ELSEIF BASE:0:魔力 < COST
	CALL PRINTL_WORD_COLOR,@"MP不足（%VALUE_DIGIT(COST)%MP必要）","灰"
ELSEIF !MARK:魔力母乳体质
	CALL PRINTL_WORD_COLOR("【魔力母乳体质】必要","灰")
ELSEIF !MARK:淫纹
	CALL PRINTL_WORD_COLOR("【淫纹】授予必要","灰")
ELSE
	PRINTFORML [11] 绝顶魔力回复淫纹：%VALUE_DIGIT(COST)%MP
ENDIF
PRINTL
PRINTL [99] 取消
BINPUT
SELECTCASE RESULT
CASE 0
	CALL COM502
CASE 1
	CALL COM505
CASE 2
	CALL COM504
	SIF !RESULT
		RETURN
CASE 3
	CALL COM503
CASE 10
	CALL COM580
CASE 11
	CALL COM582
CASE 99
	RETURN
ENDSELECT
RETURN 1


