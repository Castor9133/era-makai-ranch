
;魔界乳牛用の設備設置
@AGRI_COOP_COWSHED_DEVICE_SELECT

;ITEM:牛床マット→40
ITEM_REF = 40
ITEM_MAX = 10
CALL ITEM_SHOP_BUDGET_MONEY_JUDGE
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP
PRINTL 　《 魔界乳牛设备安装 》
FOR LOCAL,ITEM_REF,ITEM_REF +ITEM_MAX
	SIF ITEMNAME:LOCAL == ""
		CONTINUE
	PRINTFORM [{LOCAL -ITEM_REF,2}] %ITEMNAME:LOCAL,20%＜{ITEMPRICE:LOCAL}G／天＞：
	IF !ITEM:LOCAL
		CALL PRINTL_WORD_COLOR("残余 0天","灰")
	ELSE
		PRINTFORML 剩余{ITEM:LOCAL,2}天
	ENDIF
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 9
	CALL AGRI_COOP_COWSHED_DEVICE_ORDER(RESULT)
CASE 98
	CALL BROWSE_HINT("魔界奶牛设备")
CASE 99
	RETURN
ENDSELECT
RESTART



;購入処理
;ARG→INPUT
@AGRI_COOP_COWSHED_DEVICE_ORDER(ARG)
#DIM ITEM_MAX_BUY
#DIM ITEM_BUY_PRICE
#DIM ITEM_MAX_PRICE

;USE_MONEYをどっち参照するか
IF FLAG:购物／开销记账
	USE_MONEY = FLAG:最大日销售额 -MONEY:经费计上
ELSE
	USE_MONEY = MONEY
ENDIF
ITEM_NUM = ARG +ITEM_REF
SIF ITEMNAME:ITEM_NUM == ""
	RETURN
IF ITEMPRICE:ITEM_NUM *COWSHED_DEVICE_DAY > MONEY && !FLAG:购物／开销记账
	PRINTFORMW 资金不足。（牛栏设备可从{COWSHED_DEVICE_DAY}日起订购）
	RETURN
ELSEIF ITEM:ITEM_NUM >= COWSHED_DEVICE_DAY_MAX
	PRINTFORMW 已达到最大库存。
	RETURN
ENDIF

;MAX購入の個数・金額
ITEM_MAX_BUY = COWSHED_DEVICE_DAY_MAX -ITEM:ITEM_NUM
ITEM_MAX_PRICE = ITEM_MAX_BUY *ITEMPRICE:ITEM_NUM

PRINTFORML 要为%ITEMNAME:ITEM_NUM%订购多少天的数量？（最小订购单位为{COWSHED_DEVICE_DAY}天）
FOR LOCAL,1,4
	;100日超える場合・お金ない場合はスキップ
	ITEM_BUY_PRICE = LOCAL *ITEMPRICE:ITEM_NUM *COWSHED_DEVICE_DAY
	SIF ITEM_MAX_BUY < LOCAL *COWSHED_DEVICE_DAY || (ITEM_BUY_PRICE > MONEY && !FLAG:购物／开销记账)
		CONTINUE
	PRINTFORML [{LOCAL,2}] {LOCAL *COWSHED_DEVICE_DAY}天分钟：{ITEM_BUY_PRICE}G 
	
	;これを買うと経費超えるところで終了
	SIF FLAG:购物／开销记账 && ITEM_BUY_PRICE >= USE_MONEY
		BREAK
NEXT
PRINTL

;条件的に経費のMAX買いができないけどまあ仕方なし
SIF ITEM_MAX_BUY >= COWSHED_DEVICE_DAY && ITEM_MAX_PRICE <= USE_MONEY
	PRINTFORML [ 9] 最大天数（{ITEM_MAX_BUY}）：{ITEM_MAX_PRICE}G
PRINTL [99] 取消
BINPUT
PRINTL
SELECTCASE RESULT
CASE 1 TO 3
	BUY_NUM = RESULT *COWSHED_DEVICE_DAY
	ITEM_BUY_PRICE = BUY_NUM *ITEMPRICE:ITEM_NUM
	ITEM:ITEM_NUM += BUY_NUM
	IF FLAG:购物／开销记账
		MONEY:经费计上 += ITEM_BUY_PRICE
	ELSE
		MONEY -= ITEM_BUY_PRICE
	ENDIF
	CALL PRINTW_WORD_COLOR,@"已订购了＜%ITEMNAME:ITEM_NUM%＞，为期{BUY_NUM}天。","浅蓝色"

CASE 9
	ITEM:ITEM_NUM += ITEM_MAX_BUY
	IF FLAG:购物／开销记账
		MONEY:经费计上 += ITEM_MAX_PRICE
	ELSE
		MONEY -= ITEM_MAX_PRICE
	ENDIF
	CALL PRINTW_WORD_COLOR,@"已经订购了＜%ITEMNAME:ITEM_NUM%＞，为期{ITEM_MAX_BUY}天。","浅蓝色"
ENDSELECT



