
;射精するまでピストン
@EJACULATION_PISTON

;ループ内部へ
CALL EJACULATION_PISTON_LOOP

;ペニス引き抜き
CALL COM890

;[おっぱい吸わせて]とかから来てる場合飛ばす
SIF !TFLAG:Ｐ抽出后等待跳过
	PRINTW



@EJACULATION_PISTON_LOOP
#DIM DYNAMIC KEEP_PISTON

;ピストン8回しても射精しないのはなんか変なので帰っとく
;射精していたら終わり
SIF KEEP_PISTON >= 8 || TFLAG:指令中射精次数
	RETURN
IF GETBIT(＃Ｐ使用／Ｖ插入＃)
	CALL EJACULATION_PISTON_V
ELSEIF GETBIT(＃Ｐ使用／Ａ插入＃)
	CALL EJACULATION_PISTON_A
ELSEIF GETBIT(＃Ｐ使用／乳交＃)
	CALL EJACULATION_PISTON_B
ELSEIF TEQUIP:口交 || TEQUIP:深喉 || TEQUIP:触手口交 || TEQUIP:触手深喉
	CALL EJACULATION_PISTON_ORAL
ELSEIF TEQUIP:手淫
	CALL EJACULATION_PISTON_HAND

;ペニス使ってない場合終わり
ELSE
	RETURN
ENDIF
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
CALL SOURCE_CHECK
KEEP_PISTON ++

;回数数える必要が出てきた
TFLAG:亲密互动次数 ++
PRINTL
RESTART



