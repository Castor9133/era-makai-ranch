
;あなたとニンゲンの戦闘
@MASTER_BATTLE_CONFIRM
#DIM CHR

;テレポートを使える、行動済みでない、追跡者がいない
SIF !ITEM:传送 || BASE:0:魔力 < MAGIC_USE_MP:GETNUM(ITEM,"传送") || CSTR:0:日程 == "行动完毕" || CFLAG:追踪者
	RETURN
SAVE_TARGET = TARGET
CALL SELECT_BATTLE_CHARACTER

;キャンセルを選択
SIF RESULT == -1
	RETURN
TARGET = RESULT
CHR = RESULT

CALL MANYL(5)
PRINTFORML %CALLNAME%会直接前往战斗吗？
PRINTL
PRINTFORML %CALLNAME%　Lv{MAXBASE:等级}
PRINTFORML 　灵力：%VALUE_DIGIT(BASE:灵力)%EP　魔力：%VALUE_DIGIT(BASE:魔力)%MP　战斗适性：{BASE:战斗适性}\%

;戦闘可能キャラは@SELECT_BATTLE_CHARACTERで戦闘力・戦闘適性を計算している
PRINTFORM 　战斗力：%VALUE_DIGIT(BASE:战斗力)%
SIF TARGET != 0
	PRINTFORM ／%VALUE_DIGIT(MAXBASE:战斗力)%
PRINTL 

;戦闘適性によっては警告出す
IF !TARGET
	IF !EXP:执行次数／战斗训练
		CALL PRINTL_WORD_COLOR("　…因为没有进行战斗训练，所以不能很好地发挥力量。","黄")
		PRINTL 
	ELSEIF EXP:执行次数／战斗训练 < 6
		CALL PRINTL_WORD_COLOR("　…因为没怎么进行战斗训练，所以不能很好地发挥力量。","黄")
		PRINTL 
	ELSEIF BASE:战斗适性 < 30
		CALL PRINTL_WORD_COLOR("　…因为有点偷懒战斗训练，所以不能很好地发挥力量。","黄")
		PRINTL 
	ENDIF
ENDIF
PRINTL 
TARGET = SAVE_TARGET
PRINTFORML %CALLNAME%
CALL PRINT_TARGET_BATTLE_STATUS
DRAWLINE
PRINTLC [ 0] 投入战斗
PRINTLC [ 1] 取消
INPUT
SIF !RESULT
	CALL MASTER_BATTLE_MAIN_BEFORE(CHR)



;戦闘可能な味方キャラを抽出・選択する
@SELECT_BATTLE_CHARACTER
#DIMS BP
#DIMS BPMAX

CLEARLINE LINECOUNT
PRINTFORML 请选择前往捕获的角色。

;あなたを選択可にする、あなたを常に表示
DRAWLINE
TARGET = 0
CALL CALC_BATTLE_POWER
BP = %VALUE_DIGIT(BASE:战斗力)%
BPMAX = %VALUE_DIGIT(MAXBASE:战斗力)%

;あなたが戦闘できない状態のとき
IF !BASE:战斗力
	SETCOLORBYNAME GRAY
	PRINTFORM %CALLNAME_DIGIT(6)%　　　　
	PRINTFORML HP:{BASE:体力,4}/{MAXBASE:体力,4}　战斗力：%BP,10%/%BPMAX,10%　战斗适性:{BASE:战斗适性,3}\%　（无法战斗）
	RESETCOLOR
ELSE
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%　　　　
	PRINTFORML HP:{BASE:体力,4}/{MAXBASE:体力,4}　战斗力：%BP,10%/%BPMAX,10%　战斗适性:{BASE:战斗适性,3}\%
ENDIF
PRINTL

;魔力不足の場合は奴隷を送れない
IF BASE:0:魔力 < MAGIC_USE_MP:GETNUM(ITEM,"传送") *2
	CALL PRINTL_WORD_COLOR("　奴隶转移魔力不足","灰")
ELSE
	FOR TARGET_COUNT,1,CHARANUM
		TARGET = TARGET_COUNT
		CALL BATTLE_CHARACTER_CHECK
	NEXT
ENDIF
DRAWLINE
PRINTLC [ 98] 提示
PRINTLC 　
PRINTL [ 99] 取消
INPUT
SELECTCASE RESULT
CASE 98
	CALL BROWSE_HINT("玩家战斗")
CASE 99
	RETURN -1
CASEELSE
	SIF RESULT < 100 || RESULT > 100 +CHARANUM
		RESTART
	TARGET = RESULT -100
	{
	SIF CFLAG:追踪对象 || TARGET == SAVE_TARGET || CFLAG:牛舍号码 
	|| CSTR:住处 == "体内" || !BASE:战斗力 || !BASE:战斗适性
	}
		RESTART
	BP_BEFORE = BASE:战斗力
	RETURN TARGET
ENDSELECT
RESTART



;戦闘可能チェック
@BATTLE_CHARACTER_CHECK
#DIMS BP
#DIMS BPMAX

;隷属していない場合はダメ判定にした
SIF !＃陷落状态／隶属＃
	RETURN

;戦闘力と戦闘適性を計算して更新
CALL CALC_BATTLE_POWER
BP = %VALUE_DIGIT(BASE:战斗力)%
BPMAX = %VALUE_DIGIT(MAXBASE:战斗力)%

;出撃不可の条件があるとグレー
{
IF CFLAG:牛舍号码 || CSTR:住处 == "体内" || 
!CFLAG:可以调教 || !BASE:战斗力 || CFLAG:家畜 || CFLAG:虚脱
}
	SETCOLORBYNAME GRAY
	PRINTFORM %CALLNAME_DIGIT(6)%
ELSE
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
ENDIF
CALL PRINT_POST_C
PRINTFORM HP:{BASE:体力,4}/{MAXBASE:体力,4}　战斗力：%BP,10%/%BPMAX,10%　战斗适性:{BASE:战斗适性,3}\%

;出撃不可なら理由
IF CFLAG:家畜
	PRINT [家畜]
ELSEIF CSTR:住处 == "体内"
	PRINTFORM [%CALLNAME:0%体内]
ELSEIF CFLAG:牛舍号码
	PRINT [在牛舍里]
ELSEIF CFLAG:虚脱 || !CFLAG:可以调教 || !BASE:战斗力
	PRINT [不能战斗]
ENDIF
PRINTL
RESETCOLOR



;戦闘力計算
@CALC_BATTLE_POWER
#DIM BP_CALC

;MAXは100%計算
MAXBASE:战斗力 = MAXBASE:灵力 +MAXBASE:魔力

IF CFLAG:非战斗职业
	SIF !BASE:战斗适性
		BASE:战斗适性 = 1
ELSEIF BASE:战斗适性 < 80 && TARGET
	BASE:战斗适性 = 80
ENDIF

;現在戦闘力。膨大魔力の条件満たすと魔力1/10で計算(ドレインや注ぎ込みなどで変動するので現在値で判断)
IF BASE:灵力 * 10 <= BASE:魔力 && BASE:等级 < 30
	BASE:战斗力 = (BASE:灵力 + BASE:魔力 / 10)
ELSE
	BASE:战斗力 = (BASE:灵力 + BASE:魔力)
ENDIF
BP_CALC = BASE:体力 * 100 / MAXBASE:体力
BASE:战斗力 = BASE:战斗力 * BP_CALC / 100
BASE:战斗力 = BASE:战斗力 * BASE:战斗适性 / 100

