
;捕獲する
@SELECT_WISH_CAPTURE

PRINTFORML 无条件捕获%CALLNAME%吗？
CALL ASK_YN
SIF RESULT
	RETURN
CALL SLAVE_RECEIVE_COMMON
ITEM:龙之珠 = 0



;強くなりたい
@SELECT_WISH_STRONGER

PRINTFORML %CALLNAME%的灵力增加%VALUE_DIGIT(WISH_STRONGER_EP)%EP吗？
CALL ASK_YN
SIF RESULT
	RETURN
MAXBASE:灵力 += WISH_STRONGER_EP
BASE:灵力 = MAXBASE:灵力
CALL PRINTL_WORD_COLOR,@"%CALLNAME%的灵力增加了%VALUE_DIGIT(WISH_STRONGER_EP)%！ → %VALUE_DIGIT(MAXBASE:灵力)%","黄"
CALL MASTER_POWERUP_EP
PRINTW
ITEM:龙之珠 = 0





