
;楽々スタートキットのチェック
@GIFTSET_CONFIG_CHECK

SIF !FLAG:轻松启动包BIT
	RETURN

PRINTL 【轻松入门套件】
IF GETBIT(＃入门套装／衣服＃)
	;ITEM:作業着セット→1000
	;アイテム名が設定されているものを取得
	FOR LOCAL,1000,2000
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 100000
	NEXT
	CALL PRINTL_WORD_COLOR,@"获得全部10万件衣服","黄"
ENDIF

IF GETBIT(＃入门套装／消耗品＃)
	;ITEM:栄養ドリンク→200
	FOR LOCAL,200,350
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 100000
	NEXT
	CALL PRINTL_WORD_COLOR,@"获得全部10万个消耗品","黄"
ENDIF

IF GETBIT(＃入门套装／药品＃)
	;ITEM:母乳分泌促進薬→350
	FOR LOCAL,350,400
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 100000
	NEXT
	CALL PRINTL_WORD_COLOR,@"获得全部10万件药品","黄"
ENDIF

IF GETBIT(＃入门套装／搾乳器＃)
	;ITEM:搾乳カップ→900
	FOR LOCAL,900,920
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 100000
	NEXT
	CALL PRINTL_WORD_COLOR,@"获得全部10万个搾乳器","黄"
ENDIF

IF GETBIT(＃入门套装／龙珠＃)
	ITEM:龙之珠 = 7
	CALL PRINTL_WORD_COLOR,@"获得7个＜龙之玉＞","黄"
ENDIF

IF GETBIT(＃入门套装／魔力储存器＃)
	;ITEM:家庭用魔力貯蔵器→50
	FOR LOCAL,50,60
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 1
	NEXT
	CALL MAGIC_STORAGE
	MONEY:储存魔力 = FLAG:储存魔力上限值
ENDIF

IF GETBIT(＃入门套装／不动产＃)
	;ITEM:家族風呂→120
	FOR LOCAL,120,150
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 1
	NEXT
	ITEM:事务所扩建 = ESTATE_OFFICE_LIMIT
	ITEM:宠物小屋 = ESTATE_PETHOUSE_LIMIT
	ITEM:奴隶寮扩建 = ESTATE_DORMITORY_LIMIT
	ITEM:牛舍 = ESTATE_COWSHED_LIMIT
	
	;FLAG:第1牛舎増築段階→500
	FLAG_REF = 490
	FOR LOCAL,1,11
		FLAG:(FLAG_REF +LOCAL *10) = 10
	NEXT
	CALL PET_HOUSE_BLANC_CHECK
	CALL PRINTL_WORD_COLOR,@"不动产设备最大扩展","黄"
ENDIF

IF GETBIT(＃入门套装／调教・拘束＃)
	;ITEM:バイブ→500
	FOR LOCAL,500,600
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 1
	NEXT
	CALL PRINTL_WORD_COLOR,@"调教用品+获得全部拘束具","黄"
ENDIF

IF GETBIT(＃入门套装／魔法＃)
	;ITEM:個人用転移門→600
	FOR LOCAL,600,800
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 99
	NEXT
	CALL PRINTL_WORD_COLOR,@"所有魔法学习+等级为99的物品","黄"
ENDIF

IF GETBIT(＃入门套装／能力＃)
	;ITEM:汚れ無視→800
	FOR LOCAL,800,900
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 99
	NEXT
	CALL PRINTL_WORD_COLOR,@"所有能力学习+等级为99的物品","黄"
ENDIF
PRINTW

