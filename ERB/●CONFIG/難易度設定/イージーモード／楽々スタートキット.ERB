
;楽々スタートキット
@EASYMODE_GIFTSET_CONFIG

CLEARLINE LINECOUNT
PRINTL 携带选择类别的物品和升级开始游戏。
PRINTL ・在游戏开始时获取已设定名称的物品。
SIF DAY
	CALL PRINTL_WORD_COLOR,@"现在在这里操作没有特别的意义。","黄"
DRAWLINE
PRINTLC [ 0] 衣服　全部10万件。
CALL PRINT_ONOFF(GETBIT(＃入门套装／衣服＃),1)
PRINTLC [ 1] 消耗品全部10万个
CALL PRINT_ONOFF(GETBIT(＃入门套装／消耗品＃),1)
PRINTLC [ 2] 药品　全部10万个
CALL PRINT_ONOFF(GETBIT(＃入门套装／药品＃),1)
PRINTLC [ 3] 搾乳器全部10万个
CALL PRINT_ONOFF(GETBIT(＃入门套装／搾乳器＃),1)
PRINTLC [ 4] 龙珠7个
CALL PRINT_ONOFF(GETBIT(＃入门套装／龙珠＃),1)
PRINTL
PRINTLC [10] 魔改造魔力储存器+魔力补给装置魔力满
CALL PRINT_ONOFF(GETBIT(＃入门套装／魔力储存器＃),1)
PRINTLC [11] 不动产设备最大扩展
CALL PRINT_ONOFF(GETBIT(＃入门套装／不动产＃),1)
PRINTLC [12] 调教用品+所有拘束具
CALL PRINT_ONOFF(GETBIT(＃入门套装／调教・拘束＃),1)
PRINTLC [13] 所有魔法学习+等级为99的物品
CALL PRINT_ONOFF(GETBIT(＃入门套装／魔法＃),1)
PRINTLC [14] 所有能力学习+等级为99的物品
CALL PRINT_ONOFF(GETBIT(＃入门套装／能力＃),1)

CALL PRINTL_ALIGN(-5)
CALL DEFAULT_VOID_RETURN_BUTTON(1)
BINPUT
PRINTL
SIF !FLAG:开发者模式 && DAY
	RETURN
SELECTCASE RESULT
CASE 98
	PRINTL 是否将入门套装设定恢复为默认？
	CALL ASK_YN
	SIF !RESULT
		FLAG:轻松启动包BIT = 0
CASE 99
	RETURN
CASEELSE
	CALL CHANGE_GIFTSET_CONFIG(RESULT)
ENDSELECT
RESTART



;設定変更
;ARG→INPUT
@CHANGE_GIFTSET_CONFIG(ARG)

;ひっくり返すだけ
INVERTBIT FLAG:轻松启动包BIT,ARG




