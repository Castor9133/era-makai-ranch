
;保管中ミルク飲み自動選択肢
@DRINK_MILK_AUTO_SELECT

CALL MANYL(5)
PRINTL 早上或洗澡后饮用存放牛奶时，设置是否自动决定。
PRINTL
PRINTL [ 0] 每次提供选择（默认）
PRINTL [ 1] 每次随机
PRINTL [ 2] 始终不喝
PRINTL [ 3] 每次饮用指定奴隶的牛奶（无法饮用时请选择）
BINPUT
SELECTCASE RESULT
CASE 3
	CALL DRINK_MILK_AUTO_SELECT_CHARA
CASEELSE
	FLAG:自动选择／保管牛奶 = RESULT *-1
ENDSELECT



;自動選択／保管ミルク
;ARG→個人スケジュールor奴隷とお風呂上がり時
@DRINK_COLD_MILK_AUTO(ARG)

VARSET RANDOM_NO_BOX
VARSET BOX_COUNT
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	
	SIF CFLAG:预计出货母乳量 < CUP_MILK
		CONTINUE
	;条件満たした場合BOX入れ
	RANDOM_NO_BOX:BOX_COUNT = TARGET
	BOX_COUNT ++
NEXT
IF BOX_COUNT
	SELECTCASE FLAG:自动选择／保管牛奶
	CASE 0
		;選択
		IF ARG
			CALL DRINK_COLD_MILK_SELECT
		ELSE
			PRINTFORMLC [ 0] 喝着冰冷的%SAVESTR:标识／母乳%
			PRINTL [ 1] 这次不需要了
			BINPUT
			SIF !RESULT
				CALL DRINK_COLD_MILK_SELECT
		ENDIF
	
	CASE -1
		;ランダム
		TARGET = RANDOM_NO_BOX:RAND(BOX_COUNT)
		CALL DRINK_COLD_MILK
	CASE -2
		;飲まない
	
	CASEELSE
		;指定
		FINDCHARA CFLAG:ID,FLAG:自动选择／保管牛奶,1
		TARGET = RESULT
		IF CFLAG:预计出货母乳量 < CUP_MILK
			CALL DRINK_COLD_MILK_SELECT
		ELSE
			CALL DRINK_COLD_MILK
		ENDIF
	ENDSELECT
ELSE
	PRINTFORML 没有冷却的%SAVESTR:标识／母乳%，无法饮用。
	WAIT_ON ++
ENDIF
TARGET = -1



@DRINK_MILK_AUTO_SELECT_CHARA
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML 请选择指定的奴隶
PRINTL
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	
	;奴隷がどこにいても関係なく出荷用に保管しているミルクを見る
	IF !MARK:母乳体质
		SETCOLOR 0x606060
		PRINTFORM <{TARGET +100}> %CALLNAME_DIGIT()%
	ELSE
		PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	ENDIF
	CALL PRINT_POST_C
	IF CSTR:状态／主人公的孩子 == "成长中"
		PRINT 　【幼子】
		RESETCOLOR
	ELSE
		CALL TABLE_STATUS_BUST
		IF !MARK:母乳体质
			CALL PRINT_WORD_COLOR,@"　非【母乳体质】","灰"
		ELSE
			CALL PRINT_MILK_NAME
		ENDIF
	ENDIF
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
CALL RIGHT_RETURN_BUTTON(0,"キャンセル")
BINPUT
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	TARGET = -1
	RETURN

CASEELSE
	TARGET = RESULT -100
	SIF !MARK:母乳体质
		RESTART
	FLAG:自动选择／保管牛奶 = CFLAG:ID
	TARGET = -1
	RETURN
ENDSELECT
RESTART



