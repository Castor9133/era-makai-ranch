;一覧表示中身
@LEARNED_MAGIC_LIST_COMMON

BR = 0
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	;価格設定されていれば表示
	SIF !ITEMPRICE:LOCAL
		CONTINUE
	SIF !ITEM:LOCAL
		SETCOLOR 0x606060
	
	;1コ限定チェック
	CALL ITEM_GET_ONCE_CHECK(LOCAL)
	IF !FLAG:１个限定物品
		PRINTFORM 【%ITEMNAME:LOCAL%Lv{ITEM:LOCAL}】
		
		;一応MAXのとき表示
		SIF ITEM:LOCAL == 99
			CALL PRINT_WORD_COLOR,@"MAX","黄"
	ELSE
		PRINTFORM 【%ITEMNAME:LOCAL%】
	ENDIF
	RESETCOLOR
	CALL BR_PLUS(4)
NEXT
SIF !LINEISEMPTY()
	PRINTL
PRINTL

