
;各種回数制限撤廃設定
@EASYMODE_LIMIT_BREAK_CONFIG

CLEARLINE LINECOUNT
PRINTL 解除指令次数限制等。
DRAWLINE
CALL PRINTL_WORD_COLOR,@"解除指令次数限制可能会严重破坏游戏平衡。请自行负责。","黄"
PRINTLC [ 0] 调教没有时间限制。
CALL PRINT_ONOFF(GETBIT(＃限制解除／调教时间＃),1)
PRINTLC [ 1] ＜时间压缩＞不消耗MP。
CALL PRINT_ONOFF(GETBIT(＃限制解除／时间压缩＃),1)
PRINTLC [ 2] 在家庭浴池中不会中暑。
CALL PRINT_ONOFF(GETBIT(＃限制解除／家庭浴池＃),1)
PRINTLC [ 3] 没有访问次数限制。
CALL PRINT_ONOFF(GETBIT(＃限制解除／访问次数＃),1)
PRINTLC [ 4] 物品一次使用没有限制。
CALL PRINT_ONOFF(GETBIT(＃限制解除／物品使用＃),1)
PRINTLC [ 5] 亲密接触一次没有限制。
CALL PRINT_ONOFF(GETBIT(＃限制解除／亲密接触＃),1)
PRINTLC [ 6] 用药・提取物没有限制。
CALL PRINT_ONOFF(GETBIT(＃限制解除／肉体改造＃),1)

CALL PRINTL_ALIGN(-5)
CALL DEFAULT_VOID_RETURN_BUTTON(1)
BINPUT
PRINTL
SIF !FLAG:开发者模式 && DAY
	RETURN
SELECTCASE RESULT
CASE 98
	PRINTL 是否将指令次数限制设定恢复为默认？
	CALL ASK_YN
	SIF !RESULT
		FLAG:次数限制解除BIT = 0
CASE 99
	RETURN
CASEELSE
	CALL CHANGE_LIMIT_BREAK_CONFIG(RESULT)
ENDSELECT
RESTART



;設定変更
;ARG→INPUT
@CHANGE_LIMIT_BREAK_CONFIG(ARG)

;ひっくり返すだけ
INVERTBIT FLAG:次数限制解除BIT,ARG

