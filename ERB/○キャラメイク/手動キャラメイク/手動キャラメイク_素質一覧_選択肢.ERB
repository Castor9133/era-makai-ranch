
;リスト表示
@SELF_CHARA_MAKE_TALENT_LIST

FOR LOCAL,TALENT_REF,TALENT_REF +TALENT_MAX
	SIF TALENTNAME:LOCAL == ""
		CONTINUE
	IF TALENT:LOCAL
		SETCOLOR 0x80FFFF
	ELSE
		SETCOLOR 0x606060
	ENDIF
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL,3}] %TALENTNAME:LOCAL%
NEXT



