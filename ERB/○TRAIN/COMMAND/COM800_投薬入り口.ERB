
;肉体改造・投薬入り口
@COM800
#DIM TENTACLE_OK

;関数分けする
IF CFLAG:当日制限／肉体改造药
	CALL PRINTL_WORD_COLOR,@"每天最多使用药品药一次","灰"
ELSE
	CALL COM800_DOSAGE
ENDIF
PRINTL
TENTACLE_OK = FLAG:触手肉体改造可能次数 -CFLAG:当日限制／肉体改造精华
IF !ITEM:触手变化
	CALL PRINTL_WORD_COLOR,@"[触手变化]没有掌握","灰"
ELSEIF TENTACLE_OK <= 0
	CALL PRINTL_WORD_COLOR,@"在今天的触手调教中超过了肉体改造次数","灰"
ELSE
	CALL COM800_DOSAGE_TENTACLE(TENTACLE_OK)
ENDIF
PRINTL

;媚薬もここ
;調教以外からも来ることがあるようになったので飛ばす処理も入れる
SIF !TFLAG:日程外Ｈ
	CALL COM800_DOSAGE_APHRODISIAC
PRINTL
PRINTL [99] 取消
BINPUT
SELECTCASE RESULT
CASE 0
	CALL COM600
CASE 1
	CALL COM601
CASE 2
	CALL COM603
CASE 3
	CALL COM602
CASE 4
	CALL COM605
CASE 5
	CALL COM607
CASE 9
	CALL COM606
CASE 10
	CALL COM814
CASE 11
	CALL COM811
CASE 12
	CALL COM812
CASE 13
	CALL COM813
CASE 14
	CALL COM810
CASE 20
	CALL COM544
CASE 21
	CALL COM545
CASE 22
	CALL COM548
CASE 23
	CALL COM546
CASE 24
	CALL COM547
CASE 30
	CALL COM824
CASE 31
	CALL COM821
CASE 32
	CALL COM822
CASE 33
	CALL COM823
CASE 34
	CALL COM820
CASE 40
	CALL COM251
CASE 41
	CALL COM550
CASE 50
	CALL COM1000
CASE 51
	CALL COM1001
CASE 99
	RETURN
ENDSELECT
RETURN 1



;関数分け→薬品投与
@COM800_DOSAGE

PRINTL 　　　《 使用药品 》
IF !(CFLAG:无抵抗 || TFLAG:拘束BIT || !BASE:体力) && !TFLAG:日程外Ｈ
	CALL PRINTL_WORD_COLOR,@"不是顺从的奴隶的话，如果不是拘束状态或者HP为0的话，不能使用药品","黄"
	RETURN
ENDIF

;母乳関連
CALL COM800_DOSAGE_MILK

;膨乳薬
CALL COM800_DOSAGE_BUSTUP
PRINTL

;多臓器活性薬
SIF !TFLAG:日程外Ｈ
	CALL COM800_DOSAGE_ORGANS

;感度増加
CALL COM800_DOSAGE_SENSITIVE
PRINTL



;触手エキス
;ARG→肉体改造可能回数
@COM800_DOSAGE_TENTACLE(ARG)

;薬剤と同じ条件で触手も判定→NGの場合こっちはメッセージ出さずに帰る
SIF !(CFLAG:无抵抗 || TFLAG:拘束BIT || !BASE:体力) && !TFLAG:日程外Ｈ
	RETURN
PRINTFORML 　　　《 触手肉体改造 》 后{ARG}下　%CALLNAME:0%的魔力：%VALUE_DIGIT(BASE:0:魔力)%MP 

;母乳関連
CALL COM800_DOSAGE_TENTACLE_MILK

;膨乳薬
CALL COM800_DOSAGE_TENTACLE_BUSTUP
PRINTL

;感度増加
CALL COM800_DOSAGE_TENTACLE_SENSITIVE
PRINTL



;母乳関連
@COM800_DOSAGE_MILK

IF !TFLAG:Ｎ露出 && !TFLAG:日程外Ｈ
	CALL PRINTL_WORD_COLOR,@"如果不是乳头裸露状态，就不能注射母乳相关药品","黄"
	RETURN
ENDIF

IF MARK:母乳体质
	CALL PRINTL_WORD_COLOR,@"已经是【母乳体质】了","桃"
	PRINTL
ELSE
	;Ｎ注射共通部分
	CALL DOSAGE_ITEM_NIPPLE_COMMON(0,"母乳体质化药")
	IF !TFLAG:调教中
		CALL PRINTL_WORD_COLOR,@"调教中のみ使用可能","灰"
	ELSEIF GETBIT(＃有效药品／魔力母乳分泌促进药＃)
		CALL PRINTL_WORD_COLOR,@"＜魔力母乳分泌促进药＞使用中","黄"
	ELSEIF GETBIT(＃有效药品／母乳分泌促进药＃)
		CALL PRINTL_WORD_COLOR,@"＜母乳分泌促进药＞使用中","黄"
	ELSE
		CALL DOSAGE_ITEM_NIPPLE_COMMON(50,"母乳分泌促进药")
	ENDIF
ENDIF

IF MARK:魔力母乳体质
	CALL PRINTL_WORD_COLOR,@"已经是【魔力母乳体质】了","桃"
	PRINTL
ELSEIF !MAXBASE:魔力
	CALL PRINTL_WORD_COLOR,@"没有魔力","灰"
	PRINTL
ELSE
	CALL DOSAGE_ITEM_NIPPLE_COMMON(1,"魔力母乳体质化药")
	IF !TFLAG:调教中
		CALL PRINTL_WORD_COLOR,@"调教中のみ使用可能","灰"
	ELSEIF GETBIT(＃有效药品／魔力母乳分泌促进药＃)
		CALL PRINTL_WORD_COLOR,@"＜魔力母乳分泌促进药＞使用中","黄"
	ELSE
		CALL DOSAGE_ITEM_NIPPLE_COMMON(51,"魔力母乳分泌促进药")
	ENDIF
ENDIF

IF ABL:母乳浓度 >= 5
	CALL PRINTL_WORD_COLOR,@"母乳浓度已经是最优质的了","桃"
ELSEIF !MARK:母乳体质
	CALL PRINTL_WORD_COLOR,@"必须是母乳体质","灰"
ELSE
	CALL DOSAGE_ITEM_NIPPLE_COMMON(2,"母乳浓厚化药")
ENDIF



;Ｎ注射共通
;ARG→OK時の番号
;ARGS→アイテム名
@DOSAGE_ITEM_NIPPLE_COMMON(ARG,ARGS)

IF !ITEM:ARGS
	CALL PRINTL_WORD_COLOR,@"缺少%ARGS%","灰"
ELSEIF TFLAG:Ｎ装备
	CALL PRINTL_WORD_COLOR,@"需要取下Ｎ装备","黄"
ELSE
	PRINTFORM [{ARG,2}] %ARGS%　持有数量：{ITEM:ARGS}
	SIF ARGS == "母乳浓厚化药"
		PRINTFORM 　当前浓度：%PRINT_MILKWORD()%
	PRINTL
ENDIF



;膨乳薬
@COM800_DOSAGE_BUSTUP

IF ABL:胸围大小 >= BUSTSIZE_神乳
	CALL PRINTL_WORD_COLOR,@"膨乳药只能扩大到这种程度","灰"
ELSEIF !ITEM:膨乳药
	CALL PRINTL_WORD_COLOR,@"没有膨乳药","灰"
ELSE
	PRINTFORML [ 3] 膨乳药　持有数量：{ITEM:膨乳药}　当前胸围大小：%PRINT_BUSTSIZE(ABL:胸围大小)%
ENDIF

IF ABL:胸围大小 >= BUSTSIZE_MAX
	CALL PRINTL_WORD_COLOR,@"超乳药只能扩大到这种程度","桃"
ELSEIF !ITEM:超乳药
	CALL PRINTL_WORD_COLOR,@"没有超乳药","灰"
ELSE
	PRINTFORML [ 4] 超乳药　持有数量：{ITEM:超乳药}　当前胸围大小：%PRINT_BUSTSIZE(ABL:胸围大小)%
ENDIF



;多臓器活性薬
@COM800_DOSAGE_ORGANS
IF TFLAG:多器官活性药物使用中
	CALL PRINTL_WORD_COLOR,@"已经使用多器官活性药","桃"
ELSEIF !ITEM:多器官活性药
	CALL PRINTL_WORD_COLOR,@"没有多器官活性药","灰"
ELSEIF TFLAG:搾乳器
	CALL PRINTL_WORD_COLOR,@"使用多器官活性药的话不能榨出可以出售的%SAVESTR:标识／母乳%","黄"
ELSE
	PRINTFORML [ 5] 多器官活性药　持有数量：{ITEM:多器官活性药}
ENDIF



;浸透媚薬
@COM800_DOSAGE_SENSITIVE

{
IF ABL:Ｎ敏感度 >= SENSITIVE_MAX && ABL:Ｂ敏感度 >= SENSITIVE_MAX && ABL:Ｃ敏感度 >= SENSITIVE_MAX 
&& ABL:Ｖ敏感度 >= SENSITIVE_MAX && ABL:Ａ敏感度 >= SENSITIVE_MAX
}
	CALL PRINTL_WORD_COLOR,@"所有敏感度都不会再涨了","桃"
ELSEIF !ITEM:感受器敏感化药
	CALL PRINTL_WORD_COLOR,@"没有感受器敏感化药","灰"
ELSE
	PRINTFORML [ 9] 感受器敏感化药　持有数量：{ITEM:感受器敏感化药}　当前：Ｎ{ABL:Ｎ敏感度}\% Ｂ{ABL:Ｂ敏感度}\% Ｃ{ABL:Ｃ敏感度}\% Ｖ{ABL:Ｖ敏感度}\% Ａ{ABL:Ａ敏感度}\%
ENDIF

IF !ITEM:渗透媚药
	CALL PRINTL_WORD_COLOR,@"渗透媚药不存在","灰"
	RETURN
ENDIF
PRINTFORML 　　　《 渗透媚药 》　所持数：{ITEM:渗透媚药}
CALL DOSAGE_SENSITIVE_UP_COMMON(10,"Ｎ")
CALL DOSAGE_SENSITIVE_UP_COMMON(11,"Ｂ")
CALL DOSAGE_SENSITIVE_UP_COMMON(12,"Ｃ")
CALL DOSAGE_SENSITIVE_UP_COMMON(13,"Ｖ")
CALL DOSAGE_SENSITIVE_UP_COMMON(14,"Ａ")



;浸透媚薬・エキス共通
;ARG→OKのとき出すコマンド番号
;ARGS→部位
@DOSAGE_SENSITIVE_UP_COMMON(ARG,ARGS)
#DIMS JUDGE_PALAM,3

JUDGE_PALAM:0 = %ARGS%露出
JUDGE_PALAM:1 = %ARGS%敏感度
JUDGE_PALAM:2 = %ARGS%装备

;Ｖは処女結界判定する
IF ARGS == "Ｖ" && TALENT:处女结界
	CALL PRINTL_WORD_COLOR,@"【处女结界】不能触摸阴部","黄"

;露出じゃないとダメ
ELSEIF !TFLAG:(JUDGE_PALAM:0) && !TFLAG:日程外Ｈ
	CALL PRINTL_WORD_COLOR,@"不是露出状态","灰"

;感度MAXはダメ
ELSEIF ABL:(JUDGE_PALAM:1) >= SENSITIVE_MAX
	CALL PRINTL_WORD_COLOR,@"%JUDGE_PALAM:1%不会再上升","桃"

;装備あるとダメ
ELSEIF TFLAG:(JUDGE_PALAM:2)
	CALL PRINTL_WORD_COLOR,@"%JUDGE_PALAM:2%必须移除","黄"

;OKならボタン
ELSE
	PRINTFORML [{ARG,2}] %JUDGE_PALAM:1%上升　当前：{ABL:(JUDGE_PALAM:1)}\%
ENDIF



;母乳関連エキス
@COM800_DOSAGE_TENTACLE_MILK

IF !TFLAG:Ｎ露出 && !TFLAG:日程外Ｈ
	CALL PRINTL_WORD_COLOR,@"如果不是Ｎ裸露状态就不能注射母乳相关粘液","黄"
	RETURN
ENDIF

COST = MAGIC_USE_MP:GETNUM(ITEM,"母乳体质化精华")
IF MARK:母乳体质
	CALL PRINTL_WORD_COLOR,@"已经是【母乳体质】了","桃"
ELSE
	CALL DOSAGE_TENTACLE_NIPPLE_COMMON(20,"母乳体质化精华")
ENDIF

COST = MAGIC_USE_MP:GETNUM(ITEM,"魔力母乳体质化精华")
IF MARK:魔力母乳体质
	CALL PRINTL_WORD_COLOR,@"已经是【魔力母乳体质】了","桃"
ELSEIF !MAXBASE:魔力
	CALL PRINTL_WORD_COLOR,@"没有魔力","灰"
ELSE
	CALL DOSAGE_TENTACLE_NIPPLE_COMMON(21,"魔力母乳体质化精华")
ENDIF

COST = MAGIC_USE_MP:GETNUM(ITEM,"母乳浓厚化精华")
IF ABL:母乳浓度 >= 5
	CALL PRINTL_WORD_COLOR,@"母乳浓度已经是最优质的了","桃"
ELSEIF !MARK:母乳体质
	CALL PRINTL_WORD_COLOR,@"必须是母乳体质","灰"
ELSE
	CALL DOSAGE_TENTACLE_NIPPLE_COMMON(22,"母乳浓厚化精华")
ENDIF



;Ｎ触手注射共通
;ARG→OK時の番号
;ARGS→魔術名
@DOSAGE_TENTACLE_NIPPLE_COMMON(ARG,ARGS)

IF !ITEM:ARGS
	CALL PRINTL_WORD_COLOR,@"未掌握[%ARGS%]","灰"
ELSEIF BASE:0:魔力 < COST
	CALL PRINTL_WORD_COLOR,@"MP不足（%VALUE_DIGIT(COST)%MP必要）","灰"
ELSEIF TFLAG:Ｎ装备
	CALL PRINTL_WORD_COLOR,@"需要取下Ｎ装备","黄"
ELSE
	PRINTFORM [{ARG,2}] %ARGS%：%VALUE_DIGIT(COST)%MP
	SIF ARGS == "母乳浓厚化精华"
		PRINTFORM 　当前浓度：%PRINT_MILKWORD()%
	PRINTL
ENDIF



;膨乳エキス
@COM800_DOSAGE_TENTACLE_BUSTUP

COST = MAGIC_USE_MP:GETNUM(ITEM,"膨乳改造精华")
IF ABL:胸围大小 >= 26
	CALL PRINTL_WORD_COLOR,@"[膨乳改造精华]不能再大了","灰"
ELSEIF !ITEM:膨乳改造精华
	CALL PRINTL_WORD_COLOR,@"没有学习[膨乳改造精华]","灰"
ELSEIF BASE:0:魔力 < COST
	CALL PRINTL_WORD_COLOR,@"MP不足（%VALUE_DIGIT(COST)%MP必要）","灰"
ELSE
	PRINTFORML [23] 膨乳改造药剂：%VALUE_DIGIT(COST)%MP　当前胸围大小：%PRINT_BUSTSIZE(ABL:胸围大小)%
ENDIF

COST = MAGIC_USE_MP:GETNUM(ITEM,"淫乳改造精华")
IF ABL:胸围大小 >= BUSTSIZE_MAX
	CALL PRINTL_WORD_COLOR,@"[淫乳改造精华]也不能再大了","桃"
ELSEIF !ITEM:淫乳改造精华
	CALL PRINTL_WORD_COLOR,@"没有学习[淫乳改造精华]","灰"
ELSEIF BASE:0:魔力 < COST
	CALL PRINTL_WORD_COLOR,@"MP不足（%VALUE_DIGIT(COST)%MP必要）","灰"
ELSE
	PRINTFORML [24] 淫乳改造药剂：%VALUE_DIGIT(COST)%MP　当前胸围大小：%PRINT_BUSTSIZE(ABL:胸围大小)%
ENDIF



;感度上昇エキス
@COM800_DOSAGE_TENTACLE_SENSITIVE

COST = MAGIC_USE_MP:GETNUM(ITEM,"增敏粘液")
IF !ITEM:增敏粘液
	CALL PRINTL_WORD_COLOR,@"没有学习[敏感度上升粘液]","灰"
	RETURN
ELSEIF BASE:0:魔力 < COST
	CALL PRINTL_WORD_COLOR,@"MP不足（%VALUE_DIGIT(COST)%MP必要）","灰"
	RETURN
ENDIF
PRINTFORML 　　　《 增敏粘液 》：%VALUE_DIGIT(COST)%MP
CALL DOSAGE_SENSITIVE_UP_COMMON(30,"Ｎ")
CALL DOSAGE_SENSITIVE_UP_COMMON(31,"Ｂ")
CALL DOSAGE_SENSITIVE_UP_COMMON(32,"Ｃ")
CALL DOSAGE_SENSITIVE_UP_COMMON(33,"Ｖ")
CALL DOSAGE_SENSITIVE_UP_COMMON(34,"Ａ")



;媚薬
@COM800_DOSAGE_APHRODISIAC

PRINTL 　　　《 媚药 》
IF TFLAG:春药使用中
	CALL PRINTL_WORD_COLOR,@"已经使用了媚药","桃"
ELSEIF !ITEM:媚药
	CALL PRINTL_WORD_COLOR,@"没有媚药","灰"
ELSEIF TFLAG:Ｍ装备
	CALL PRINTL_WORD_COLOR,@"嘴被堵住的话就没办法使用媚药了","黄"
ELSEIF TFLAG:搾乳器
	CALL PRINTL_WORD_COLOR,@"使用媚药时出货用的%SAVESTR:标识／母乳%不能挤","黄"
ELSE
	PRINTFORML [40] 媚药　持有数量：{ITEM:媚药}
ENDIF

COST = MAGIC_USE_MP:GETNUM(ITEM,"媚药粘液")
IF TFLAG:媚药粘液使用中
	CLEARLINE 1
	CALL PRINTL_WORD_COLOR,@"已经用了媚药粘液","桃"
ELSEIF !ITEM:媚药粘液
	CALL PRINTL_WORD_COLOR,@"没学会媚药黏液","灰"
ELSEIF BASE:0:魔力 < COST
	CALL PRINTL_WORD_COLOR,@"MP不足（%VALUE_DIGIT(COST)%MP必要）","灰"
ELSEIF TFLAG:Ｍ装备
	CALL PRINTL_WORD_COLOR,@"嘴被堵住的话就没办法使用媚药粘液了","黄"
ELSEIF TFLAG:搾乳器
	CALL PRINTL_WORD_COLOR,@"使用媚药粘液的话不能榨出可以出售的%SAVESTR:标识／母乳%","黄"
ELSE
	PRINTFORML [41] 媚药粘液：%VALUE_DIGIT(COST)%MP
ENDIF






