
;絶頂メッセージ
@PRINT_ECSTASY_MESSAGE

;あなた主導かメッセージ表示状態の時だけ表示
SIF !TFLAG:调教中 && !TFLAG:日程外Ｈ && !TFLAG:循环中消息显示
	RETURN
SIF !NOWEX:总绝顶
	RETURN

;他の口上表示がなかった場合に口上表示
SIF !MESSAGE_EXIST
	CALL KOJO_PRINT("绝顶")
SETCOLOR 0xFF70FF
FOR LOCAL,0,5
	SIF NOWEX:LOCAL
		PRINTFORM %EXNAME:LOCAL%+{NOWEX:LOCAL} 
NEXT
SIF NOWEX:Ｕ绝顶
	PRINTFORM 尿道绝顶+{NOWEX:Ｕ绝顶} 
RESETCOLOR



;改行合わせ
@SOURCE_UP_AFTER_BR_FIX

SIF !TFLAG:调教中 && !TFLAG:日程外Ｈ && !TFLAG:循环中消息显示
	RETURN
SIF LINEISEMPTY()
	RETURN

;調教中なら改行　スケジュール中なら4部位絶頂で改行
IF TFLAG:调教中
	PRINTL
ELSE
	SIF MATCH(NOWEX,0,0,5) <= 2
		PRINTL
ENDIF



;HP増減メッセージ
@SOURCE_UP_AFTER_HP_MESSAGE

SIF !TFLAG:调教中 && !TFLAG:日程外Ｈ && !TFLAG:循环中消息显示
	RETURN
SIF !LOSEBASE:体力 && !SOURCE:调教对象体力回复
	RETURN
LOCAL = SOURCE:调教对象体力回复 -LOSEBASE:体力
IF LOCAL > 0
	PRINTFORM HP+{LOCAL} 
ELSEIF LOCAL < 0
	PRINTFORM HP-{LOCAL *-1} 
ENDIF
SIF !BASE:体力
	PRINT 【HP0】



;SP増減メッセージ
@SOURCE_UP_AFTER_SP_MESSAGE

SIF !TFLAG:调教中 && !TFLAG:日程外Ｈ && !TFLAG:循环中消息显示
	RETURN
SIF !LOSEBASE:气力 && !SOURCE:调教对象气力回复
	RETURN
LOCAL = SOURCE:调教对象气力回复 -LOSEBASE:气力
IF LOCAL > 0
	PRINTFORM SP+{LOCAL} 
ELSEIF LOCAL < 0
	PRINTFORM SP-{LOCAL *-1} 
ENDIF
SIF !BASE:气力
	PRINT 【SP0】



;経験値表示
@PRINT_EXP_MESSAGE
#DIMS SOURCEWORD

CALL HALFLINE
FOR LOCAL,0,5
	SIF SOURCE:LOCAL <= 0
		CONTINUE
	
	;絶頂した部位はピンク
	IF NOWEX:LOCAL
		CALL PRINTL_WORD_COLOR,@"%SOURCENAME:LOCAL%+{SOURCE:LOCAL} ","桃"
	ELSE
		PRINTFORML %SOURCENAME:LOCAL%+{SOURCE:LOCAL} 
	ENDIF
NEXT
SIF SOURCE:Ｖ润滑追加 || SOURCE:爱液
	PRINTFORML Ｖ润滑追加+{SOURCE:Ｖ润滑追加+SOURCE:爱液} 
SIF SOURCE:Ａ润滑追加
	PRINTFORML Ａ润滑追加+{SOURCE:Ａ润滑追加} 
FOR LOCAL,30,100
	SIF SOURCE:LOCAL <= 0
		CONTINUE
	SIF !GETBIT(＃上限到达后显示／性经验值＃) && EXP:LOCAL >= EXP_MAX
		CONTINUE
	SOURCEWORD = %SOURCENAME:LOCAL%+{SOURCE:LOCAL}
	PRINTFORM %SOURCEWORD,24,LEFT%
	SIF LOCAL >= 40
		PRINTFORM <EXP+{PALAM:LOCAL}> 
	PRINTL
NEXT
CALL HALFLINE



