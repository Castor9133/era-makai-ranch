
;奴隷候補のバストサイズ
@RANDOM_SLAVE_BUST

LAST_SHUFFLE = ABL:胸围大小
IF TALENT:绝壁
	ABL:胸围大小 = BUSTSIZE_绝壁
ELSEIF TALENT:贫乳
	ABL:胸围大小 = BUSTSIZE_贫乳 +RAND:(BUSTSIZE_普乳 -BUSTSIZE_贫乳)
ELSEIF TALENT:普乳
	ABL:胸围大小 = BUSTSIZE_普乳 +RAND:(BUSTSIZE_巨乳 -BUSTSIZE_普乳)
ELSEIF TALENT:巨乳
	ABL:胸围大小 = BUSTSIZE_巨乳 +RAND:(BUSTSIZE_丰乳 -BUSTSIZE_巨乳)
ELSEIF TALENT:丰乳
	ABL:胸围大小 = BUSTSIZE_丰乳 +RAND:(BUSTSIZE_爆乳 -BUSTSIZE_丰乳)
ELSEIF TALENT:爆乳
	ABL:胸围大小 = BUSTSIZE_爆乳 +RAND:(BUSTSIZE_神乳 -BUSTSIZE_爆乳)
ELSEIF TALENT:神乳
	ABL:胸围大小 = BUSTSIZE_神乳 +RAND:(BUSTSIZE_魔乳 -BUSTSIZE_神乳)
ELSEIF TALENT:魔乳
	ABL:胸围大小 = BUSTSIZE_魔乳 +RAND:(BUSTSIZE_超乳 -BUSTSIZE_魔乳)
ELSEIF TALENT:超乳
	ABL:胸围大小 = BUSTSIZE_超乳
ENDIF

IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE == ABL:胸围大小 && !TALENT:绝壁
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0



;基礎を変更したい場合、候補の抽選のコピペ
@RANDOM_SLAVE_BUST_BASE

;子供扱いする身長かチェック
IF CHILD_HEIGHT_CHECK(CSTR:身高)
	;FLAG:子供候補割合／バストサイズ／絶壁→3200
	FLAG_REF = 3200
ELSE
	;FLAG:候補割合／バストサイズ／絶壁→3110
	FLAG_REF = 3110
ENDIF
STR_REF = 6550
CALL RANDOM_BOX_LOTTERY(9)
VARSET TALENT,0,10,20
TALENT:RESULTS = 1

