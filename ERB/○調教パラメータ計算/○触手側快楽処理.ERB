
;触手側快楽処理
@T_SENSITIVE_CALC

;触手射精未取得か無効にしてるとおわり
SIF !ITEM:触手射精 || !GETBIT(＃有效／触手射精＃)
	RETURN

;時間経過なくても帰る
SIF !SOURCE:已用时间 && TFLAG:调教中
	RETURN

TFLAG:触手射精次数 = 0
TFLAG:触手射精量表MAX = 1000
TFLAG:触手射精増加合计 = 0

;挿入状態、奉仕系SOURCEのある場合計算
IF TEQUIP:触手Ｖ插入
	CALL T_SENSITIVE_CALC_V
	TFLAG:触手射精増加合计 += TFLAG:触手射精増加
ENDIF
IF TEQUIP:触手Ａ插入
	CALL T_SENSITIVE_CALC_A
	TFLAG:触手射精増加合计 += TFLAG:触手射精増加
ENDIF
IF TEQUIP:触手强制乳交
	CALL T_SENSITIVE_CALC_B
	TFLAG:触手射精増加合计 += TFLAG:触手射精増加
ENDIF
IF TEQUIP:触手口交 || TEQUIP:触手深喉
	CALL T_SENSITIVE_CALC_M
	TFLAG:触手射精増加合计 += TFLAG:触手射精増加
ENDIF
IF TEQUIP:触手强制手交
	CALL T_SENSITIVE_CALC_HAND
	TFLAG:触手射精増加合计 += TFLAG:触手射精増加
ENDIF

;0なら帰る
SIF !TFLAG:触手射精増加合计
	RETURN

;淫欲
IF PALAM:淫欲 >= 30000
	TIMES TFLAG:触手射精増加合计,1.50
ELSEIF PALAM:淫欲 >= 10000
	TIMES TFLAG:触手射精増加合计,1.20
ENDIF

;技巧補正+メッセージ
;CALL T_SENSITIVE_TECHNIQUE_FIX

;ランダム5%
CALL RANDOM_FIX(TFLAG:触手射精増加合计,5,"触手射精増加合计")
TFLAG:触手射精増加合计 += FIX

;射精メッセージだけはここに入る　射精によりSOURCEが増加するため
IF TFLAG:触手射精増加合计 && TFLAG:调教中 && !TFLAG:日程外Ｈ && !TFLAG:循环中消息显示 && !TFLAG:体内凌辱中
	CALL PRINT_WORD_COLOR,@"触手快感+{TFLAG:触手射精増加合计}","桃"
	PRINTFORML  ({TFLAG:触手射精量表 + TFLAG:触手射精増加合计}/{TFLAG:触手射精量表MAX})
	PRINTL 
ENDIF

;触手射精ゲージ増加、MAXを超えたら射精
TFLAG:触手射精量表 += TFLAG:触手射精増加合计

;射精値が最大値を上回ったら射精
SIF TFLAG:触手射精量表 >= TFLAG:触手射精量表MAX
	CALL T_EJACULATION



;Ｖ挿入射精増加計算
@T_SENSITIVE_CALC_V

;ここで汚れ移動処理もしてしまう
;CALL SWAP_STAIN("膣","ペニス")

;中毒値により情愛追加
SIF ABL:触手中毒
	SOURCE:爱情 += (ABL:膣内射精中毒 + ABL:触手中毒) * 10

;基準300
TFLAG:触手射精増加 = 300

;潤滑を見る
IF PALAM:Ｖ润滑 < 5000
	TIMES TFLAG:触手射精増加,0.50
ELSEIF PALAM:Ｖ润滑 < 10000
	TIMES TFLAG:触手射精増加,0.80
ENDIF

;膣内射精中毒により増加
FIX:2 = LIMIT(ABL:膣内射精中毒,0,10)
FIX:1 = FIX:2 *5 +ABL:膣内射精中毒 *3

;Ｖ感覚が少ないと増加
SIF ABL:Ｖ感觉 < 4
	FIX:1 += 10
	
;刻印による増加
SIF MARK:膣内射精中毒
	FIX:1 += 20
SIF MARK:榨精淫穴
	FIX:1 += 20
SIF MARK:精液便女
	FIX:1 += 20
SIF MARK:淫壶
	FIX:1 += 30
SIF MARK:肉便器
	FIX:1 += 30

FIX = 100 +FIX:1
TFLAG:触手射精増加 *= FIX
TFLAG:触手射精増加 /= 100
IF TALENT:名器
	TIMES TFLAG:触手射精増加,2.00
	;CALL SEX_GOOD_VAGINA_MESSAGE
ENDIF


;Ａ挿入射精増加計算
@T_SENSITIVE_CALC_A

;CALL SWAP_STAIN("アナル","ペニス")
SIF ABL:触手中毒
	SOURCE:爱情 += (ABL:尻穴射精中毒 + ABL:触手中毒) * 10

TFLAG:触手射精増加 = 300
IF PALAM:Ａ润滑 < 5000
	TIMES TFLAG:触手射精増加,0.50
ELSEIF PALAM:Ａ润滑 < 10000
	TIMES TFLAG:触手射精増加,0.80
ENDIF

;尻穴射精中毒により増加
FIX:2 = LIMIT(ABL:尻穴射精中毒,0,10)
FIX:1 = FIX:2 *5 +ABL:尻穴射精中毒 *3

;Ａ感覚が少ないと増加
SIF ABL:Ａ感觉 < 4
	FIX:1 += 10
SIF MARK:尻穴射精中毒
	FIX:1 += 20
SIF MARK:榨精尻穴
	FIX:1 += 20
SIF MARK:尻穴便器
	FIX:1 += 20
SIF MARK:肉便器
	FIX:1 += 30
SIF MARK:淫尻
	FIX:1 += 30

FIX = 100 +FIX:1
TFLAG:触手射精増加 *= FIX
TFLAG:触手射精増加 /= 100
IF TALENT:Ａ名器
	TIMES TFLAG:触手射精増加,2.00
	;CALL SEX_GOOD_ANAL_MESSAGE
ENDIF



;パイズリ射精増加計算
@T_SENSITIVE_CALC_B

;CALL SWAP_STAIN("乳房","ペニス")
SIF ABL:触手中毒
	SOURCE:爱情 += (ABL:乳内射精中毒 + ABL:触手中毒) * 10
TFLAG:触手射精増加 = 200

;バストサイズにより増加
FIX:2 = LIMIT(ABL:胸围大小,0,10)
FIX:1 = FIX:2 *5 +ABL:胸围大小 *2

;乳内射精中毒により増加
IF BASE:体力
	FIX:2 += LIMIT(ABL:乳内射精中毒,0,10)
	FIX:1 += (FIX:2 *5 +ABL:乳内射精中毒 *2)
ENDIF

;巨乳以上、爆乳以上で追加ボーナス
SIF ABL:胸围大小 >= BUSTSIZE_巨乳
	FIX:1 += 20
SIF ABL:胸围大小 >= BUSTSIZE_爆乳
	FIX:1 += 20
SIF MARK:淫乳
	FIX:1 += 30

FIX = 100 +FIX:1
TFLAG:触手射精増加 *= FIX
TFLAG:触手射精増加 /= 100
IF TALENT:极上乳压 && ABL:胸围大小 >= BUSTSIZE_巨乳
	TIMES TFLAG:触手射精増加,2.00
	;CALL SEX_GOOD_PAIZURI_MESSAGE
ENDIF

;ぬるぬる状態だと増加
IF GETBIT(STAIN:乳房,0)
	IF TFLAG:Ｂ润滑液
		TIMES TFLAG:触手射精増加,1.30
	ELSE
		TIMES TFLAG:触手射精増加,1.20
	ENDIF
	;CALL MILK_PAIZURI_MESSAGE
ELSEIF TFLAG:Ｂ润滑液
	TIMES TFLAG:触手射精増加,1.20
	;CALL LOTION_PAIZURI_MESSAGE
ENDIF



;フェラ・イラマ射精増加計算
@T_SENSITIVE_CALC_M

;CALL SWAP_STAIN("口","ペニス")
SIF ABL:触手中毒
	SOURCE:爱情 += (ABL:精饮中毒 + ABL:触手中毒) * 10
TFLAG:触手射精増加 = 200
FIX:1 = 0

;精飲中毒により増加
IF BASE:体力
	FIX:2 = LIMIT(ABL:精饮中毒,0,10)
	FIX:1 = (FIX:2 *5 +ABL:精饮中毒 *3)
ENDIF

;フェラチオは奉仕精神+技巧で増加
IF TEQUIP:口交
	FIX:2 = LIMIT(ABL:奉仕精神 +ABL:技巧,0,15)
	FIX:1 += (FIX:2 *5 +(ABL:奉仕精神 +ABL:技巧) *3)
ENDIF
FIX = 100 +FIX:1
TFLAG:触手射精増加 *= FIX
TFLAG:触手射精増加 /= 100
IF TALENT:口穴
	TIMES TFLAG:触手射精増加,2.00
	;CALL SEX_GOOD_MOUSE_MESSAGE
ENDIF



;手コキ射精増加計算
@T_SENSITIVE_CALC_HAND

;CALL SWAP_STAIN("手","ペニス")
TFLAG:触手射精増加 = 200

;奉仕精神+技巧で増加
FIX:2 = LIMIT(ABL:奉仕精神 +ABL:技巧,0,15)
FIX:1 += (FIX:2 *5 +(ABL:奉仕精神 +ABL:技巧) *3)
FIX = 100 +FIX:1
TFLAG:触手射精増加 *= FIX
TFLAG:触手射精増加 /= 100




;技巧補正判定
@T_SENSITIVE_TECHNIQUE_FIX

;体力0、拘束中、技巧2以下なら帰る
SIF !BASE:体力 || TFLAG:拘束BIT || ABL:技巧 <= 2
	RETURN
CALL SEX_TECHNIQUE_MESSAGE

;淫欲50000以上/恋慕/洗脳/奉仕精神のいずれかでRETURN1→技巧補正発生
SIF !RESULT
	RETURN

;既に技巧補正してるので少しだけ
FIX = 100 +ABL:技巧 *3
TFLAG:触手射精増加 *= FIX
TFLAG:触手射精増加 /= 100


