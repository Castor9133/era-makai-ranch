
;調教アビリティ
@ABILITY_GET
#DIM DYNAMIC PAGE

PAGE_MAX = 3
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_UPGRADE("调教AP")
PRINTL 使用【调教AP】学习调教能力。
PRINTL
BR = 0
TRYCALLFORM ABILITY_GET_LIST_{PAGE}
PRINTL
DRAWLINE
CALL ITEM_DETAIL_ABILITY(SELECT_ITEM)
CALL PRINTL_ALIGN
CALL ABILITY_GET_JUDGE(SELECT_ITEM,"调教能力")
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTLC [ 90] 批量学习
PRINTLC 　
PRINTL [ 99] 完成
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	;購入処理
	CALL ABILITY_GET_COST_CALC(SELECT_ITEM)
	ITEM:SELECT_ITEM ++
	MONEY:调教AP -= COST
	IF ITEM:SELECT_ITEM == 1
		CALL PRINTW_WORD_COLOR,@"学习了【%ITEMNAME:SELECT_ITEM%】。","浅蓝色"
	ELSE
		CALL PRINTW_WORD_COLOR,@"【%ITEMNAME:SELECT_ITEM%】LvUP！ → {ITEM:SELECT_ITEM}","浅蓝色"
	ENDIF
	
	;ふたなりにしたらペニスサイズ計算
	IF ITEMNAME:SELECT_ITEM == "扶她阴茎"
		ABL:0:阴茎尺寸 = CFLAG:0:身高 / 50 + RAND:6 + 15
		ABL:0:初始值／阴茎尺寸 = ABL:0:阴茎尺寸
	ENDIF
CASE 1
	;連続LvUP
	CALL ABILITY_GET_CONTINUE
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
	SELECT_ITEM = 0
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_ITEM = 0
CASE 90
	CALL ABILITY_GET_BULK
CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART



;連続習得
@ABILITY_GET_CONTINUE

;最大5まで一括増加
FOR LOCAL,0,5
	CALL ABILITY_GET_COST_CALC(SELECT_ITEM)
	SIF COST > MONEY:调教AP
		BREAK
	ITEM:SELECT_ITEM ++
	MONEY:调教AP -= COST
	CALL PRINTL_WORD_COLOR,@"【%ITEMNAME:SELECT_ITEM%】LvUP！ → Lv{ITEM:SELECT_ITEM}","浅蓝色"
NEXT
PRINTW



;一括習得
@ABILITY_GET_BULK

PRINTL 当前技能点可学习的页面内能力将从列表前方一次性学习。
PRINTL ・如果AP不足，将不再进行后续能力学习。
PRINTL ・仅学习Lv1。
PRINTL 执行批量学习？
CALL ASK_YN
SIF RESULT
	RETURN

;記録
AP_BEFORE = MONEY:调教AP
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	;習得前提アビリティも見る
	SIF !ITEMPRICE:LOCAL || ITEM:LOCAL || (MAGIC_GET_PREMISE:LOCAL && !ITEM:(MAGIC_GET_PREMISE:LOCAL))
		CONTINUE
	
	;習得不可APで終了
	SIF ITEMPRICE:LOCAL > MONEY:调教AP
		BREAK
	ITEM:LOCAL ++
	MONEY:调教AP -= ITEMPRICE:LOCAL
	CALL PRINTL_WORD_COLOR,@"学习了【%ITEMNAME:LOCAL%】。","浅蓝色"
	
	;ふたなりにしたらペニスサイズ計算
	IF ITEMNAME:SELECT_ITEM == "扶她阴茎"
		ABL:0:阴茎尺寸 = CFLAG:0:身高 / 50 + RAND:6 + 15
		ABL:0:初始值／阴茎尺寸 = ABL:0:阴茎尺寸
	ENDIF
NEXT
PRINTFORML 消费AP：%TOSTR(AP_BEFORE -MONEY:调教AP)%
IF AP_BEFORE == MONEY:调教AP
	PRINTW 无法学习能力。

;LOCALがITEM_ID_MAXなら全て習得した
ELSEIF LOCAL >= ITEM_ID_MAX
	PRINTW 《 已学习所有能力。 》
ELSE
	PRINTW
ENDIF
SELECT_ITEM = 0

