;上着情報
;ARGS→これだけ着てる場合の露出度
@JACKET_DETAIL_COMMON(ARGS)

PRINT 【外衣】
SELECTCASE ARGS
CASE "侧乳露出"
	CALL PRINT_WORD_COLOR,@"%ITEMNAME:SELECT_ITEM%只有的情况下：＜侧乳露出＞＜乳沟露出＞","桃"
CASE "全露出"
	CALL PRINT_WORD_COLOR,@"%ITEMNAME:SELECT_ITEM%只有的情况下：＜全身露出＞","桃"
ENDSELECT
CALL CHECK_EQUIP_DETAIL_CHANGE_LIST(ITEMNAME:SELECT_ITEM)


