
;スキルポイント蓄積値計算
@GET_SKILL_POINT_CALC
#DIM SKILL_POINT

;調教中だけ
SIF !TFLAG:调教中
	RETURN

;調教APで確定表示するからEXISTいらないや
;調教コマンドのたび調教AP+50+乱数,イかせたら部位*100,射精時回数*300
SKILL_POINT = 50 +RAND:10

;NOWEX:Ａ絶頂→0
FOR LOCAL,0,5
	;絶頂回数により+10
	SIF NOWEX:LOCAL
		SKILL_POINT += (90 +NOWEX:LOCAL *10)
NEXT
SKILL_POINT += (SOURCE:射精次数 *300)
MONEY:调教AP累积值 += SKILL_POINT
PRINTFORM 调教AP累积+{SKILL_POINT} 

;吸った魔力母乳の減衰前値をそのまま魔術APへ
SKILL_POINT = SOURCE:玩家增加魔力量／衰减前
IF SKILL_POINT
	MONEY:魔法AP累积值 += SKILL_POINT
	PRINTFORM 魔法AP累积+%VALUE_DIGIT(SKILL_POINT)% 
ENDIF

;触手魔力消費量*5を触手APへ
SKILL_POINT = SOURCE:触手魔力消耗量 *5
IF SKILL_POINT
	MONEY:触手AP累积值 += SKILL_POINT
	PRINTFORM 触手AP累积+%VALUE_DIGIT(SKILL_POINT)% 
ENDIF
PRINTL








