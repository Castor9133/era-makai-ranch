;自動スケジュールの設定
@PRINT_AUTO_SCHEDULE_PLAN

IF CFLAG:追踪对象
	CALL PRINTL_WORD_COLOR,@"没有日程设置，因为未捕获","灰"
	RETURN
ENDIF
PRINTL 　《 自动日程 》

;STR:曜日→3900
;CSTR:自動スケジュール／月→350
STR_REF = 3900
CSTR_REF = 350
FOR LOCAL,0,7
	PRINTFORML %STR:(STR_REF +LOCAL)%：%CSTR:(CSTR_REF +LOCAL)%
NEXT
PRINTL
IF MARK:母乳体质
	PRINTL 　《 搾乳优先设定 》
	PRINT 朝
	CALL PRINT_ONOFF(GETBIT(＃搾乳优先／朝＃))
	PRINT 　昼
	CALL PRINT_ONOFF(GETBIT(＃搾乳优先／昼＃))
	PRINT 　夕
	CALL PRINT_ONOFF(GETBIT(＃搾乳优先／夕＃))
	PRINTL
ENDIF
CALL PRINT_AUTO_SCHEDULE_PLAN_CUSTOM



;カスタム内部表示
@PRINT_AUTO_SCHEDULE_PLAN_CUSTOM

SIF !＃陷落状态／恋慕以上＃ && TARGET
	RETURN

;CSTR:自動スケジュール／カスタムＡ／朝→360
CSTR_REF = 360
FOR LOCAL,0,9
	SELECTCASE LOCAL
	CASE 0
		PRINT 【自定义Ａ】
	CASE 3
		PRINTL
		PRINT 【自定义Ｂ】
	CASE 6
		PRINTL
		PRINT 【自定义Ｃ】
	ENDSELECT
	SELECTCASE LOCAL %3
	CASE 0
		PRINT 朝：
	CASE 1
		PRINT 昼：
	CASE 2
		PRINT 夕：
	ENDSELECT
	PRINTFORM %CSTR:(CSTR_REF +LOCAL),10%　
NEXT
CALL MANYL(2)
IF !TARGET
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%无法自动安排调教。","灰"
ELSE
	CALL PRINT_AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_ID(0)
	CALL PRINT_AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_ID(1)
	CALL PRINT_AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_ID(2)
ENDIF



;調教対象IDから名前表示
