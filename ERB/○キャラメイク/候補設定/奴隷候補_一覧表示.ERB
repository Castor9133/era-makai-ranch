
;一覧表示
;ARGS→元関数　候補確認・候補選択
@PRINT_TRAVELLER_LIST(ARGS)

CALL MANYL(5)
SELECTCASE ARGS
CASE "候选确认"
	PRINTL ＜今日进入魔界的人类的特征＞
CASE "候选选择"
	PRINTL 选择要追踪的人类。
ENDSELECT

;色付けの条件表示
CALL PRINT_POSSESSION_TERM
DRAWLINE
FOR LOCAL,0,10
	SIF LOCAL == 6
		PRINTL
	IF LIST_TRIBE:LOCAL == ""
		CALL PRINTL_WORD_COLOR("EMPTY","灰")
		CONTINUE
	ENDIF
	
	;選択時はボタン出す
	SIF ARGS == "候选选择"
		PRINTFORM [{LOCAL,2}]
	
	;目的・種族
	CALL PRINT_PURPOSE(LOCAL)
	CALL PRINT_LIST_TRIBE(LOCAL)
	
	;おっぱい・身長
	PRINTFORMLC 【%LIST_BUST:LOCAL%／%LIST_HEIGHT:LOCAL%】
	
	;魔力・ランク・仲間ランク
	CALL SLAVE_LIST_MAGIC_POWER(LOCAL)
	PRINTFORM ★{LIST_RANK:LOCAL,2}
	SIF LIST_GROUP:LOCAL
		PRINTFORM ／{LIST_GROUP_RANK:LOCAL}
	PRINTL
NEXT
DRAWLINE



;色付け条件
@PRINT_POSSESSION_TERM

SELECTCASE FLAG:奴隶候选未拥有的强调显示形式
CASE 1
	PRINTL ＜如果没有将该【种族】作为奴隶，则显示为彩色＞
CASE 2
	PRINTL ＜如果没有将该【职业】作为奴隶，则显示为彩色＞
CASE 3
	PRINTL ＜未持有相应的【种族】，或者该种族的相应【职业】未作为奴隶时会显示为彩色＞
CASE 4
	PRINTL ＜未持有相应的【种族】，或者该种族的相应【身份】没有作为奴隶时会显示为彩色＞
ENDSELECT



;目的表示
