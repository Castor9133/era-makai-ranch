
;天使
@TRIBE_FEATURE_CONFIG_ANGEL

CLEARLINE LINECOUNT
PRINTL 请选择【天使】的种族设定。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL 固定：始终拥有魔力・素质【天界种族】
PRINTLC [ 0] 肤色变为【色白】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,0),1)
PRINTLC [ 1] 必定为【处女】【Ａ处女】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,1),1)
PRINTLC [ 2] 一定【处女结界】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,2),1)
PRINTLC [ 3] 【处女】的话会有素质【贞操观念】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,3),1)
PRINTLC [ 4] 素质【受动物喜欢】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,4),1)
PRINTLC [ 5] 素质【药毒耐性】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,5),1)
PRINTL
PRINTLC [10] 素质【坦率】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,10),1)
PRINTLC [11] 素质【不怕痛】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,11),1)
PRINTLC [12] 素质【自制力】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,12),1)
PRINTLC [13] 素质【难以越过的底线】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,13),1)
PRINTLC [14] 素质【害羞】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,14),1)
PRINTLC [15] 素质【献身的】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,15),1)
PRINTLC [16] 素质【否定快感】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,16),1)
PRINTLC [17] 素质【清纯】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,17),1)
PRINTLC [18] 素质【正义感】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／天使,18),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(18)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL 肤色选择种抽到【标准】、【褐色】、【小麦色】时将变为【色白】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
CASE 1
	PRINTL 将附加【处女】【Ａ处女】。
	PRINTL ※可以选择被赋予【处女结界】
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
	SIF GETBIT(FLAG:种族设定／天使,1) && GETBIT(FLAG:种族设定／天使,2)
		CLEARBIT FLAG:种族设定／天使,2
CASE 2
	PRINTL 体质【处女结界】（以及【处女】・【A处女】）被赋予
	PRINTL ※可以选择被赋予前后处女
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
	SIF GETBIT(FLAG:种族设定／天使,1) && GETBIT(FLAG:种族设定／天使,2)
		CLEARBIT FLAG:种族设定／天使,1
CASE 3
	PRINTL 拥有【处女】的话、会赋予【贞操观念】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
CASE 4
	PRINTL 被赋予素质【受动物喜欢】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
CASE 5
	PRINTL 被赋予素质【药毒耐性】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
CASE 10
	PRINTL 被赋予素质【坦率】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
CASE 11
	PRINTL 被赋予素质【不怕痛】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
CASE 12
	PRINTL 被赋予素质【自制力】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
CASE 13
	PRINTL 被赋予素质【难以越过的底线】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
CASE 14
	PRINTL 被赋予素质【害羞】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
CASE 15
	PRINTL 被授予素质【献身的】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
CASE 16
	PRINTL 被赋予素质【否定快感】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
CASE 17
	PRINTL 被赋予素质【清纯】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
CASE 18
	PRINTL 被赋予素质【正义感】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／天使"),INPUT_NUM)
CASE 98
	PRINTL 【天使】的种族设定回复到默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_ANGEL
CASE 99
	RETURN
ENDSELECT
RESTART


