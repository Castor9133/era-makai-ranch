
;ペットなでなで：地の文
;TARGET,ANIMAL,PET_NAME指定済み
@PET_COMMU_MESSAGE_STROKE

;【動物に好かれる／嫌われる】となつき度で変化
FLAG_NAME = 亲和度／%ANIMAL%
IF BASE:FLAG_NAME == MAXBASE:FLAG_NAME
	CALL PET_COMMU_MESSAGE_STROKE_MAX
ELSEIF TALENT:受动物喜欢 || BASE:FLAG_NAME >= 8000
	CALL PET_COMMU_MESSAGE_STROKE_LOVE
ELSEIF BASE:FLAG_NAME >= 4000
	CALL PET_COMMU_MESSAGE_STROKE_MEDIUM
ELSEIF !TALENT:被动物讨厌 && BASE:FLAG_NAME >= 2000
	CALL PET_COMMU_MESSAGE_STROKE_LOW
ELSE
	CALL PET_COMMU_MESSAGE_STROKE_HATE
ENDIF



;なつきMAX
@PET_COMMU_MESSAGE_STROKE_MAX

PRINTFORML %CALLNAME%决定抚摸%PET_NAME%的瞬间，%PET_NAME%主动过来了。
SELECTCASE ANIMAL
CASE "堕落天马","双头犬"
	SELECTCASE RAND:4
	CASE 0
		PRINTFORML 在抚摸%PET_NAME%的时候，脸被舔得湿漉漉的。
	CASE 1
		PRINTFORML %PET_NAME%在%CALLNAME%抚摸它时，把脸蹭到了%CALLNAME%的脸上。
	CASEELSE
		PRINTFORML 抚摸%PET_NAME%后，它摇着尾巴欢快地示意高兴。
	ENDSELECT
CASEELSE
	SELECTCASE RAND:4
	CASE 0
		PRINTFORML 尽情地抚摸着露出肚皮的%PET_NAME%。
	CASE 0
		PRINTFORML %PET_NAME%在%CALLNAME%抚摸它时，把脸蹭到了%CALLNAME%的脸上。
	CASEELSE
		PRINTFORML 抚摸%PET_NAME%后，它完全投入到这里，欢欣鼓舞。
	ENDSELECT
ENDSELECT



;【動物に好かれる】orなつき時
@PET_COMMU_MESSAGE_STROKE_LOVE

;尻尾とかなつき度とかで変えたい
PRINTFORML %CALLNAME%温柔地抚摸了%PET_NAME%。
SELECTCASE ANIMAL
CASE "堕落天马","双头犬"
	PRINTFORML %PET_NAME%似乎很满足，摇着尾巴高兴地示意…
CASEELSE
	PRINTFORML %PET_NAME%满意地眯起眼睛高兴着…
ENDSELECT



;なつき度ほどほど
@PET_COMMU_MESSAGE_STROKE_MEDIUM

PRINTFORML %CALLNAME%温柔地抚摸了%PET_NAME%。
SELECTCASE ANIMAL
CASE "堕落天马","双头犬"
	PRINTFORML %PET_NAME%似乎还不错地摇着尾巴…
CASEELSE
	PRINTFORML %PET_NAME%被大人抚摸着…
ENDSELECT



;【動物に嫌われる】ではなくなつき度低い
@PET_COMMU_MESSAGE_STROKE_LOW

SELECTCASE RAND:3
CASE 0
	PRINTFORML %CALLNAME%试图抚摸%PET_NAME%，但被避免了。
	PRINTL 也许不是那种心情…
CASEELSE
	PRINTFORML %CALLNAME%温柔地抚摸了%PET_NAME%。
	PRINTFORML %PET_NAME%没有特别抵抗…
ENDSELECT



;【動物に嫌われる】かなつき度すごく低い
@PET_COMMU_MESSAGE_STROKE_HATE

PRINTFORML %CALLNAME%尝试抚摸%PET_NAME%…
SELECTCASE ANIMAL
CASE "堕落天马"
	;蹴るのはだいぶ事故なので蹴っちゃダメと言っておきましょうね
	SELECTCASE RAND:8
	CASE 0
		PRINTFORML %PET_NAME%难得地被大人抚摸着…
	CASE 1
		PRINTL 被强有力的头锤撞飞…
	CASE 2
		PRINTL 被冷落了…
	CASE 3
		PRINTL 盯着你，不太适合抚摸…
	CASE 4
		PRINTL 用翅膀拍打你…
	CASEELSE
		PRINTL 摇摆头，将试图抚摸的手躲开…
	ENDSELECT

CASE "双头犬"
	SELECTCASE RAND:8
	CASE 0
		PRINTFORML %PET_NAME%难得地被大人抚摸着…
	CASE 1
		PRINTL 用两个头顶你两次，将你撞飞…
	CASE 2
		PRINTL 被冷落了…
	CASE 3
		PRINTL 盯着你，不太适合抚摸…
	CASE 4
		PRINTL 手被咬了…
	CASEELSE
		PRINTL 被吼了…
	ENDSELECT
CASEELSE
	SELECTCASE RAND:5
	CASE 0
		PRINTFORML %PET_NAME%难得地被大人抚摸着…
	CASE 1
		PRINTL 手被抓伤了…
	CASE 2
		PRINTL 被冷落了…
	CASEELSE
		PRINTL 逃掉了…
	ENDSELECT
ENDSELECT




