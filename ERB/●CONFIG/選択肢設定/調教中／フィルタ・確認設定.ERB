
;調教中／フィルタ・確認
@TRAIN_FILTER_CONFIG

CLEARLINE LINECOUNT
PRINTL 设置调教中的过滤器和确认选项。
DRAWLINE
PRINTL 　《 插入确认 》
PRINTLC [ 0] Ｖ处女時
CALL PRINT_ONOFF(GETBIT(＃Ｖ处女确认＃),1)
PRINTLC [ 1] Ａ处女時
CALL PRINT_ONOFF(GETBIT(＃Ａ处女确认＃),1)
PRINTFORMLC [ 2] Ｖ润滑不足時({NEED_LUBRICATION}未満)
CALL PRINT_ONOFF(GETBIT(＃Ｖ润滑确认＃),1)
PRINTFORMLC [ 3] Ａ润滑不足時({NEED_LUBRICATION}未満)
CALL PRINT_ONOFF(GETBIT(＃Ａ润滑确认＃),1)
PRINTLC [ 4] 【异种族怀孕】有效时的生插入
CALL PRINT_ONOFF(GETBIT(＃异种族怀孕确认＃),1)
PRINTLC [ 5] Ｖ尺寸确认
CALL PRINT_ONOFF(GETBIT(＃Ｖ尺寸确认＃),1)
PRINTLC [ 6] Ａ尺寸确认
CALL PRINT_ONOFF(GETBIT(＃Ａ尺寸确认＃),1)
PRINTL

PRINTL 　《 肛门过滤器：调教指令隐藏 》
PRINTLC [10] 各种Ａ插入
CALL PRINT_ONOFF(GETBIT(＃各种Ａ插入无效＃),1)
PRINTLC [11] Ａ指插入
CALL PRINT_ONOFF(GETBIT(＃Ａ指插入无效＃),1)
PRINTLC [12] Ａ舔舐
CALL PRINT_ONOFF(GETBIT(＃Ａ舔舐无效＃),1)
PRINTLC [13] 触手Ａ插入
CALL PRINT_ONOFF(GETBIT(＃触手Ａ插入无效＃),1)

CALL PRINTL_ALIGN(-5)
CALL DEFAULT_VOID_RETURN_BUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 98
	PRINTL 要将过滤器和确认设置恢复为默认吗？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRAIN_FILTER_CONFIG
CASE 99
	RETURN
CASEELSE
	CALL CHANGE_TRAIN_FILTER_CONFIG(RESULT)
ENDSELECT
RESTART



;設定変更
;ARG→INPUT
@CHANGE_TRAIN_FILTER_CONFIG(ARG)

;全部NUM
SELECTCASE ARG
CASE 0 TO 9
	INVERTBIT FLAG:插入确认BIT,ARG
CASE 10 TO 19
	INVERTBIT FLAG:肛门过滤BIT,ARG -10
ENDSELECT



