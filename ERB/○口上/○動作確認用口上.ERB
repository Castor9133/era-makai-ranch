	ENDIF
	SELECTCASE ARGS:1
	CASE "膨乳"
		IF !EXP:膨乳
			CALL MESSAGE_BOX,@"「test_%CALLNAME% 首次接受膨乳时的台词。」"
		ELSE
			CALL MESSAGE_BOX,@"「test_%CALLNAME% 再次接受膨乳（第 2 次及以后）时的台词。」"
		ENDIF
