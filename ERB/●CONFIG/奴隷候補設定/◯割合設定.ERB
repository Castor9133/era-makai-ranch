
;身体特徴の割合設定
@TENDENCY_CONFIG_COMMON

CLEARLINE LINECOUNT
PRINTL 请设定在随机角色创建时身体特征的比例。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL 　《 共通 》
PRINTL [ 0] 身高
PRINTL [ 1] 乳头颜色
PRINTL [ 2] 乳头颜色／褐色肌
PRINTL [ 3] 肤色
PRINTL
PRINTL 　《 一般使用 》
PRINTL [10] 胸围大小
PRINTL [11] 体型
PRINTL [12] 性经验
PRINTL [13] 阴毛
PRINTL
;STR:バストサイズ→3830
PRINTL 　《 儿童扱い时使用 》
STR_REF = 3830
FOR LOCAL,0,10
	SIF STR:(STR_REF +LOCAL) == ""
		CONTINUE
	IF GETBIT(FLAG:儿童对待时比例适用项目BIT,LOCAL)
		PRINTFORMLC [{LOCAL +20}] %STR:(STR_REF +LOCAL)%
	ELSE
		CALL PRINTLC_WORD_COLOR,@"<{(LOCAL +20)}> %STR:(STR_REF +LOCAL)%","灰"
	ENDIF
	PRINTFORM [{LOCAL +30}] 适用
	CALL PRINT_ONOFF(GETBIT(FLAG:儿童对待时比例适用项目BIT,LOCAL),1)
NEXT

PRINTLC [40] 儿童待遇身高范围
SELECTCASE FLAG:儿童待遇身高范围
CASE 0
	PRINT ：不使用
CASE 1
	PRINT ：【娇小】以下
CASE 2
	PRINT ：【矮小】以下
CASE 3
	PRINT ：【儿童体型】以下
ENDSELECT
PRINTL

CALL PRINTL_ALIGN(-5)
;CALL DEFAULT_VOID_RETURN_BUTTON(1)
DRAWLINE
IF !FLAG:可配置的候选奴隶
	IF ITEM:奴隶候补设定变更票
		PRINTLC [90] ＜奴隶候补设定变更票＞使用
	ELSE
		CALL PRINTLC_WORD_COLOR("　＜奴隶候补设定变更票据＞无","灰")
	ENDIF
ELSE
	PRINTLC [98] 回复默认值
ENDIF
PRINTLC 　
PRINTL [99] 完成

BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL TENDENCY_CONFIG_HEIGHT
CASE 1
	CALL TENDENCY_CONFIG_NIPPLE_COLOR
CASE 2
	CALL TENDENCY_CONFIG_NIPPLE_COLOR_DARKSKIN
CASE 3
	CALL TENDENCY_CONFIG_SKIN_COLOR
CASE 10
	CALL TENDENCY_CONFIG_BUST
CASE 11
	CALL TENDENCY_CONFIG_SHAPE
CASE 12
	CALL TENDENCY_CONFIG_VARGIN
CASE 13
	CALL TENDENCY_CONFIG_UNDERHAIR
CASE 20
	CALL TENDENCY_CONFIG_CHILD_BUST
CASE 21
	CALL TENDENCY_CONFIG_CHILD_SHAPE
CASE 22
	CALL TENDENCY_CONFIG_CHILD_VARGIN
CASE 23
	CALL TENDENCY_CONFIG_CHILD_UNDERHAIR
	
CASE 30 TO 39
	IF !FLAG:可配置的候选奴隶
		CALL PRINTL_WORD_COLOR("必须使用＜奴隶候补设定变更票＞。","黄")
		WAIT
		RESTART
	ENDIF
	INVERTBIT FLAG:儿童对待时比例适用项目BIT,RESULT -30
	
CASE 40	;子供扱い身長範囲
	IF !FLAG:可配置的候选奴隶
		CALL PRINTL_WORD_COLOR("必须使用＜奴隶候补设定变更票＞。","黄")
		WAIT
		RESTART
	ENDIF
	PRINTL 《 儿童扱い时使用 从》栏中设置参考体型等的奴隶候选者的身高。
	PRINTL
	PRINTL [ 0] 不使用
	PRINTL [ 1] 【娇小】以下
	PRINTL [ 2] 【身材矮小】以下（默认）
	PRINTL [ 3] 【儿童体型】以下
	BINPUT
	FLAG:儿童待遇身高范围 = RESULT
CASE 90
	SIF FLAG:可配置的候选奴隶 || !ITEM:奴隶候补设定变更票
		RETURN
	PRINTL 使用＜奴隶候补设定变更票＞吗？
	CALL PRINTL_WORD_COLOR("在找到下一个奴隶候选之前，设置将保持可更改状态。","黄")
	CALL ASK_YN
	IF !RESULT
		FLAG:奴隶候补设定变更票使用中 = 1
		ITEM:奴隶候补设定变更票 --
		PRINTW 使用了＜奴隶候补设定变更票＞。
	ENDIF
CASE 98
	IF !FLAG:可配置的候选奴隶
		CALL PRINTL_WORD_COLOR("必须使用＜奴隶候补设定变更票＞。","黄")
		WAIT
		RESTART
	ENDIF
	PRINTL 回复默认的身体特征比例设置？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TENDENCY_CONFIG_ALL
CASE 99
	RETURN
ENDSELECT
RESTART


