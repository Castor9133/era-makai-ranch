	ENDIF
	PRINTFORM 揉捏了%PRINT_BUST()%…
ELSE
	PRINTFORM 摩擦着%SLANG_PENIS()%…
ENDIF
PRINTL
CALL ONOMATOPOEIA("活塞运动","乳交")



