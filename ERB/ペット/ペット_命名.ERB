
;ペット設定前処理
@NAMING_PET_BEFORE

;STR_REFとFLAG_REFを持ってくる
;ANIMAL取得済み
CALL NAMING_PET_STR_GET

;名前リセット
VARSET PET_NAME

;毛並み初期入力
PET_COAT = %STR:(STR_REF +100 +RAND:5)%

;模様は単色にしとく
VARSET PET_PATTERN

;性別半々
PET_GENDER = RAND:2
CALL NAMING_PET

;RETURN1したらそのまま移す
SIF RESULT
	RETURN 1



;ペットに名付け
@NAMING_PET
#DIM DYNAMIC FUNNY_NAME

;今とりあえず「毛並み」でよさそう
CLEARLINE LINECOUNT
PRINTFORML 请选择要带进牧场的%ANIMAL%的名字・毛发・花纹・性别。
CALL HALFLINE

;名前参照
CALL NAMING_PET_NAME_LIST

;ヘンテコ名前を出すか
CALL NAMING_PET_FUNNY_NAME_LIST(FUNNY_NAME)
PRINTL [101] 手动输入名称

;オルトロスの場合のみ左右の名前対応
SIF ANIMAL == "双头犬"
	PRINTL [102] ＜双头犬＞限定：更改命名方式／更改连接词和名称。

;毛並み参照
CALL NAMING_PET_COAT_LIST

;模様参照
CALL NAMING_PET_PATTERN_LIST
PRINTL
PRINTL [400] 性别变更
CALL PRINTL_ALIGN(-5)

;現在の候補
PRINTFORM 名称：%PET_NAME%%PET_NAME:1%%PET_NAME:2%　毛发：%PET_COAT%%PET_PATTERN%　
CALL PRINT_PET_GENDER(PET_GENDER,1)
DRAWLINE
PRINTLC [900] 取消
PRINTLC [998] 提示

;全部入れてないとダメ
IF PET_NAME != "" && PET_COAT != ""
	PRINTLC [999] 完成
ELSE
	CALL PRINTLC_WORD_COLOR("　需要输入名称和毛发","灰")
ENDIF
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 99
	IF STR:(STR_REF +RESULT) != ""
		PET_NAME = %STR:(STR_REF +RESULT)%
		
		;名前による毛並みと性別補正
		CALL NAMING_PET_NAME_FIX
	ENDIF
CASE 100
	FUNNY_NAME ++
CASE 101
	CALL NAMING_PET_MANUAL("名称")
CASE 102
	CALL NAMING_PET_ORTHROS_NAME_METHOD(FUNNY_NAME)
CASE 200
	CALL NAMING_PET_SHUFFLE_COAT
CASE 201
	CALL NAMING_PET_SELECT_COAT
CASE 202
	CALL NAMING_PET_MANUAL("性格")
CASE 300
	CALL NAMING_PET_SHUFFLE_PATTERN
CASE 301
	CALL NAMING_PET_SELECT_PATTERN
CASE 302
	CALL NAMING_PET_MANUAL("花纹")
CASE 400
	INVERTBIT PET_GENDER,0
CASE 900
	RETURN 0
CASE 998
	CALL BROWSE_HINT("添加宠物")
CASE 999
	;名前など確定しておわり
	;FLAG_REF -100でペット種類のID取得できる
	CALL NAMING_PET_CONFIRM(FLAG_REF -100)
	RETURN 1
ENDSELECT
RESTART



;編集中のSTR_REFとFLAG_REFを持ってくる
@NAMING_PET_STR_GET

SELECTCASE ANIMAL
CASE "堕落天马"
	STR_REF = 20000
	FLAG_REF = 100
CASE "双头犬"
	STR_REF = 20200
	FLAG_REF = 101
CASE "魔界仓鼠"
	STR_REF = 20400
	FLAG_REF = 102
ENDSELECT



;名前など確定
;ARG→FLAG_REF -1：ペットID
@NAMING_PET_CONFIRM(ARG)

;ペット関係のフラグ番号一斉取得
CALL GET_PET_FLAG_REF

;ゲーム開始前なら一旦リセットかける
IF !DAY
	VARSET ITEM,0,ITEM_REF,ITEM_REF +10
	VARSET SAVESTR,"",STR_REF:0,STR_REF:0 +100
	VARSET FLAG,0,FLAG_REF:0,FLAG_REF:0 +100
ENDIF

;オルトロスの場合に入っていたら左右それぞれに名付ける
IF ANIMAL == "双头犬"
	SAVESTR:名称／双头犬／连接词 = %PET_NAME:1%
	SAVESTR:名称／双头犬／弟妹 = %PET_NAME:2%
ENDIF

;名前、毛並み、模様、性別、体型（標準から）
SAVESTR:(STR_REF:0 +ARG) = %PET_NAME%
SAVESTR:(STR_REF:1 +ARG) = %PET_COAT%
SAVESTR:(STR_REF:2 +ARG) = %PET_PATTERN%
FLAG:(FLAG_REF:0 +ARG) = PET_GENDER
FLAG:(FLAG_REF:1 +ARG) = 5000

;初期なつき度入れる
CALL PET_START_FRIENDLY_ADD_PET(ANIMAL)





