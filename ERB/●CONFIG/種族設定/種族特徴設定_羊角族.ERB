
;羊角族
@TRIBE_FEATURE_CONFIG_SHEEPHORN

CLEARLINE LINECOUNT
PRINTL 请选择【羊角族】的种族设定。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL 固定：素质【动物耳】【尾巴】【双角】
PRINTLC [ 0] 素质【老实】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／羊角族,0),1)
PRINTLC [ 1] 把头发染成白发
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／羊角族,1),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(12)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL 被赋予素质【老实】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／羊角族"),INPUT_NUM)
CASE 1
	PRINTL 发色变为【白色】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／羊角族"),INPUT_NUM)
CASE 98
	PRINTL 将【羊角族】的种族设定回复为默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_SHEEPHORN
CASE 99
	RETURN
ENDSELECT
RESTART


