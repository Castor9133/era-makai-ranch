
;レズ経験処理
@LESBIAN_EXP_CALC

;両方女じゃないならおわり
SIF PLAYER < 0
	RETURN
SIF TALENT:PLAYER:男性
	RETURN

;調教対象
;300 +イった回数*500 +調教者のレズっ気*200 +吸われたミルク
SOURCE:百合调教经验 = 300 +NOWEX:总绝顶 *500 +ABL:PLAYER:百合癖 *200 +NOWEX:直饮母乳

;スケジュールかつ女あなたの場合繰り返すので1/4くらいにしとく
SIF !TFLAG:调教中 && !TFLAG:日程外Ｈ && !PLAYER
	SOURCE:百合调教经验 /= 4

;調教者
;500 +対象レズっ気*100 +吸ったミルク
SOURCE:PLAYER:百合调教经验 = 500 +ABL:百合癖 *100 +NOWEX:直饮母乳

;女あなたは相手が多くて一気に上がりすぎるので1/10
SIF !TFLAG:调教中 && !TFLAG:日程外Ｈ && !PLAYER
	SOURCE:百合调教经验 /= 10



