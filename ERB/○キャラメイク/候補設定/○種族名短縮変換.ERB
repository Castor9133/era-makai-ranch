
;種族名短縮変換
@FONT_HARF(ARG)

;種族名が長い場合表示を短縮する　ジョブはやめとく
SELECTCASE LIST_TRIBE:ARG
CASE "半身人"
	LIST_TRIBE:ARG = Ｈ身人
CASE "半精灵"
	LIST_TRIBE:ARG = Ｈ精灵
CASE "暗精灵"
	LIST_TRIBE:ARG = Ｄ精灵
ENDSELECT



;戻す作業
@FONT_FULL

SELECTCASE CSTR:种族
CASE "Ｈ身人"
	CSTR:种族 = 半身人
CASE "Ｈ精灵"
	CSTR:种族 = 半精灵
CASE "Ｄ精灵"
	CSTR:种族 = 暗精灵
ENDSELECT

