
;アイテムとして所持orキャラが所持で着せられる
@CHANGE_CLOTHE_CHECK

;着替え可能なSELECT_ITEMかチェック
IF ITEMNAME:SELECT_ITEM == "" || SELECT_ITEM < 1000 || SELECT_ITEM >= 2000
	PRINTL
	RETURN
ENDIF

;0：所持中かのチェック
;着用中チェック
FOR LOCAL,0,20
	SIF EQUIP:LOCAL != SELECT_ITEM
		CONTINUE
	CALL PRINT_SELECT_ITEM_DETAIL(SELECT_ITEM,"穿着中")
	PRINTL
	RETURN
NEXT

;もう持ってる場合
IF EQUIP:SELECT_ITEM
	CALL PRINT_SELECT_ITEM_DETAIL(SELECT_ITEM,"所持中")

;持ってない服をプレゼントする場合→コマンド1に統合
;未所持
ELSE
	CALL PRINTLC_WORD_COLOR("　未持有　","浅蓝色")
ENDIF
PRINTL



;新しい衣服のプレゼントチェック
@NEW_CLOTHE_CHECK

IF ITEMNAME:SELECT_ITEM == "" || SELECT_ITEM < 1000 || SELECT_ITEM >= 2000
	PRINTL
	RETURN
ENDIF

;もう持ってる場合→色柄変更可能かチェック
IF EQUIP:SELECT_ITEM
	CALL CHECK_EQUIP_DETAIL_CHANGE(ITEMNAME:SELECT_ITEM)
	IF !RESULT
		CALL PRINTL_WORD_COLOR("　无法更变颜色的装备","灰")
	
	;セット自体は無理：一気に色変更とかする？
	ELSEIF SELECT_ITEM >= 1000 && SELECT_ITEM < 1050
		CALL PRINTL_WORD_COLOR("　需要单独更改颜色和图案。","灰")
	
	;デフォ状態なら消費なしで変更可能
	ELSEIF CSTR:SELECT_ITEM == "" && EQUIP:SELECT_ITEM == 1
		PRINTFORML [  1] 设定服装的颜色
	
	;アイテムとして所持していれば変更可能
	ELSEIF ITEM:SELECT_ITEM
		IF TARGET
			PRINTFORML [  1] 新的%ITEMNAME:SELECT_ITEM%作为礼物
		ELSE
			PRINTFORML [  1] 穿上新的%ITEMNAME:SELECT_ITEM%
		ENDIF
	ELSE
		CALL PRINTL_WORD_COLOR,@"没有替换%ITEMNAME:SELECT_ITEM%","灰"
	ENDIF
ELSEIF ITEM:SELECT_ITEM
	;メガネは元々持ってる場合のみ、伊達メガネは元々メガネだとダメ
	IF ITEMNAME:SELECT_ITEM == "眼镜"
		IF TARGET
			CALL PRINTL_WORD_COLOR,@"只有当你原本已经拥有%ITEMNAME:SELECT_ITEM%时才能够赠送","灰"
		ELSE
			CALL PRINTL_WORD_COLOR,@"只有原本就拥有的%ITEMNAME:SELECT_ITEM%才能穿戴","灰"
		ENDIF
		RETURN
	ELSEIF ITEMNAME:SELECT_ITEM == "伊达眼镜" && EQUIP:眼镜
		IF TARGET
			CALL PRINTL_WORD_COLOR,@"如果已经拥有眼镜，就无法赠送%ITEMNAME:SELECT_ITEM%","灰"
		ELSE
			CALL PRINTL_WORD_COLOR,@"如果已经戴着眼镜，则无法戴上%ITEMNAME:SELECT_ITEM%","灰"
		ENDIF
		RETURN
	ENDIF
	IF TARGET
		PRINTFORML [  1] %ITEMNAME:SELECT_ITEM%作为礼物
	ELSE
		PRINTFORML [  1] 穿上%ITEMNAME:SELECT_ITEM%
	ENDIF
ELSE
	CALL PRINTL_WORD_COLOR,@"没有%ITEMNAME:SELECT_ITEM%","灰"
ENDIF

