
;調教開始時に触手服を着ている場合
@BEFORE_TRAIN_T_CLOTHE

IF ＃穿着内衣下装／名称＃ == "触手服装"
	PALAM:Ｖ润滑 += 10000
	PALAM:Ａ润滑 += 10000
	FOR LOCAL,0,5
		PALAM:LOCAL += RAND:((ABL:LOCAL + 5) * ABL:(LOCAL + 10))
		SIF PALAM:LOCAL > 9999
			PALAM:LOCAL = 9999
	NEXT
	SETBIT STAIN:肛门,5
	SETBIT STAIN:乳房,5
	SETBIT STAIN:乳头,5
	SETBIT STAIN:尻,5
	IF TALENT:男性
		SETBIT STAIN:阴茎,5
	ELSE
		SETBIT STAIN:阴蒂,5
		SETBIT STAIN:膣,5
	ENDIF
ENDIF

;調教開始時にあなたが触手服を着ている場合
@BEFORE_TRAIN_T_CLOTHE_M

CALL PLAYER_PENIS_CHECK
IF ITEMNAME:(EQUIP:0:装备中ID／内衣下装) == "触手服装"
	SETBIT STAIN:0:肛门,5
	SETBIT STAIN:0:乳房,5
	SETBIT STAIN:0:乳头,5
	SETBIT STAIN:0:尻,5
	IF PLAYER_PENIS
		SETBIT STAIN:0:阴茎,5
	ELSE
		SETBIT STAIN:0:阴蒂,5
	ENDIF
	SIF !TALENT:0:男性
		SETBIT STAIN:0:膣,5
ENDIF



;触手服を着ている場合ブラシ触手効果
@TRAIN_T_CLOTHE

SIF ＃穿着内衣下装／名称＃ != "触手服装" || TFLAG:临时脱衣／内衣下装 || !BASE:0:魔力
	RETURN
TEQUIP:刷子触手 = 1
FOR LOCAL,150,155
	TEQUIP:LOCAL = 1
NEXT
SIF TALENT:处女结界
	TEQUIP:刷子触手Ｖ = 0
IF TFLAG:临时脱衣／内衣上装
	TEQUIP:刷子触手Ｂ = 0
	TEQUIP:刷子触手Ｎ = 0
ENDIF

FOR LOCAL,0,5
	SIF !TEQUIP:(LOCAL+150)
		CONTINUE
	;触手服を着ていて半脱ぎにもなってない場合はそのまま
	SIF (LOCAL == 1 || LOCAL == 4) && !GETBIT(＃半脱／内衣上装＃) && !TFLAG:临时脱衣／内衣上装
		CONTINUE
	SIF (LOCAL == 0 || LOCAL == 2 || LOCAL == 3) && !GETBIT(＃半脱／内衣下装＃)
		CONTINUE

	;尻撫で、お腹撫でのみの場合除外
	SIF SELECTCOM == 16 && LOCAL == 0 && !SOURCE:(LOCAL+10) && !TFLAG:(60+LOCAL)
		CONTINUE
	SIF SELECTCOM == 19 && LOCAL == 3 && !SOURCE:(LOCAL+10) && !TFLAG:(60+LOCAL)
		CONTINUE

	;Ａ装備→TFLAG:60
	SIF SOURCE:LOCAL || SOURCE:(LOCAL+10) || TFLAG:(60+LOCAL)
		TEQUIP:(LOCAL+150) = 0
NEXT

CALL EQUIP_155_CONTINUE
IF TFLAG:调教中 || TFLAG:日程外Ｈ || SOURCE:体内凌辱中继续显示信息
	TRYCALLFORM EQUIP_155_CONTINUE_MESSAGE
	CALL KOJO_PRINT("调教命令","触手服装","继续")
ENDIF
VARSET TEQUIP,0,150,156



;触手服を着ている場合時間経過で責め発生
@NO_TRAIN_T_CLOTHE
#DIM DISP_MESSAGE

SIF !BASE:0:魔力
	RETURN
DISP_MESSAGE = 0
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF !TARGET || CSTR:状态／主人公的孩子 == "成长中"
		CONTINUE
	SIF ＃穿着内衣下装／名称＃ != "触手服装" || GROUPMATCH(CSTR:日程,"搾乳","抽出","牛舍","体内凌辱","解放","触手刺激搾乳","调教对象") || CFLAG:追踪对象 == 2
		CONTINUE
	IF !DISP_MESSAGE
		DISP_MESSAGE = 1
		PRINTL 　　　《 触手服装 》
		PRINTL 触手服从内侧生出的无数触手，持续刺激着穿着者…
	ENDIF
	
	CALL TRAIN_T_CLOTHE_S
NEXT
SIF !DISP_MESSAGE
	RETURN
CALL SECTION_MP_COST
DRAWLINE
CALL RESET_TRAIN_PALAM
PLAYER = -1
WAIT



;触手服責め
@TRAIN_T_CLOTHE_S
#DIM DISP_COUNT
;今のところあなたは除外

CALL STATUS_BEFORE_RECORD
CALL RESET_TRAIN_PALAM
CALL BEFORE_TRAIN_T_CLOTHE

FOR LOCAL,0,10
	CALL SOURCE_CHECK
	VARSET LOSEBASE
NEXT
CALL SCHEDULE_ECSTASY_FIX
PRINTFORM %CALLNAME%　
CALL PRINT_TOTAL_GOBLINS
CALL TRAIN_END_PALAM_CALC
CALL ABL_UP
CALL MARK_GET

;陥落があったらWAIT
DISP_COUNT = LINECOUNT
CALL CAPITULATION_JUDGE
IF DISP_COUNT != LINECOUNT
	WAIT
	WAIT_ON = 0
ENDIF
PRINTL 

