
;あなたのアイテム使用
@USE_ITEM_PLAYER

PRINTFORML 选择%CALLNAME%使用的物品。
PRINTL
CALL USE_ITEM_PLAYER_CHECK
PRINTL [99] 取消
BINPUT
SELECTCASE RESULT
CASE 0
	CALL USE_ITEM_PLAYER_ENERGY_DRINK
CASE 1
	CALL USE_ITEM_PLAYER_DRAGON_BALL
CASE 2
	CALL VISIT_CHANGE_CHARA_CLOTHE
CASE 3
	CALL USE_ITEM_PLAYER_PILL_HP
CASE 4
	CALL USE_ITEM_PLAYER_PILL_VIGOR
CASE 5
	CALL USE_ITEM_PLAYER_PILL_SP
ENDSELECT



;選択肢チェック
@USE_ITEM_PLAYER_CHECK

IF CFLAG:当日制限／营养饮料
	CALL PRINTL_WORD_COLOR("　请限制每日饮用一瓶营养饮料","灰")
ELSEIF BASE:体力 == MAXBASE:体力
	CALL PRINTL_WORD_COLOR("　体力已满","灰")
ELSEIF !ITEM:营养饮料
	CALL PRINTL_WORD_COLOR("　＜营养饮料＞未所持","灰")
ELSE
	PRINTFORML [ 0] 营养饮料：持有数量{ITEM:营养饮料}瓶
ENDIF
IF ITEM:龙之珠 >= 7
	PRINTFORML [ 1] 用7个＜龙之珠＞召唤龙
ELSE
	CALL PRINTL_WORD_COLOR,@"　＜龙之珠＞不足：所持数{ITEM:龙之珠}个","灰"
ENDIF
PRINTFORML [ 2] 更改衣服
IF !ITEM:体力丸
	CALL PRINTL_WORD_COLOR("　＜体力丸＞未所持","灰")
ELSEIF BASE:0:体力 >= MAXBASE:0:体力
	CALL PRINTL_WORD_COLOR("　体力已满，无法服用体力丸","灰")
ELSE
	PRINTFORML [ 3] 体力丸：持有数量{ITEM:体力丸}个
ENDIF
IF !ITEM:精力丸
	CALL PRINTL_WORD_COLOR("　＜精力丸＞未所持","灰")
ELSEIF !MAXBASE:0:精力
	CALL PRINTL_WORD_COLOR("　当前无法使用精力丸","灰")
ELSEIF BASE:0:精力 >= MAXBASE:0:精力
	CALL PRINTL_WORD_COLOR("　精力已满，无法服用精力丸","灰")
ELSE
	PRINTFORML [ 4] 精力丸：持有数量{ITEM:精力丸}个
ENDIF
IF !ITEM:气力丸
	CALL PRINTL_WORD_COLOR("　＜气力丸＞未所持","灰")
ELSEIF BASE:0:气力 >= MAXBASE:0:气力
	CALL PRINTL_WORD_COLOR("　气力已满，无法服用气力丸","灰")
ELSE
	PRINTFORML [ 5] 气力丸：持有数量{ITEM:气力丸}个
ENDIF
PRINTL



;栄養ドリンク
@USE_ITEM_PLAYER_ENERGY_DRINK

;最大体力の20%か400の多いほうが回復量になる
HEAL = MAX(400,MAXBASE:体力 *20 /100)
PRINTFORML %CALLNAME%喝了营养饮料。
PRINTFORML %CALLNAME%体力有所回复！
CALL ITEM_USE_HEAL(HEAL)
CFLAG:当日制限／营养饮料 ++
ITEM:营养饮料 --
TRYCALL EXCRETION_BLADDER_ON_NUTRITION_DRINK
PRINTW


;牧场主用体力／精力／气力丸（回复量：上限≤25000 则 5000；否则上限的 20%；且不超过距上限的差额）
@USE_ITEM_PLAYER_PILL_COMMON(ARG)
#DIM PILL_HEAL
#DIM MAXV
#DIM PILL_GAP
#DIM CUR
#DIM OLD

SELECTCASE ARG
CASE 1
	MAXV = MAXBASE:0:体力
	CUR = BASE:0:体力
CASE 2
	MAXV = MAXBASE:0:精力
	CUR = BASE:0:精力
CASE 3
	MAXV = MAXBASE:0:气力
	CUR = BASE:0:气力
CASEELSE
	RETURN
ENDSELECT
SIF ARG == 2 && MAXV <= 0
	RETURN
PILL_GAP = MAXV - CUR
SIF PILL_GAP <= 0
	RETURN
PILL_HEAL = 5000
SIF MAXV > 25000
	PILL_HEAL = MAXV * 20 / 100
SIF PILL_HEAL > PILL_GAP
	PILL_HEAL = PILL_GAP
SIF PILL_HEAL < 1
	RETURN
OLD = CUR
SELECTCASE ARG
CASE 1
	BASE:0:体力 = LIMIT(BASE:0:体力 + PILL_HEAL, 0, MAXV)
	ITEM:体力丸 --
CASE 2
	BASE:0:精力 = LIMIT(BASE:0:精力 + PILL_HEAL, 0, MAXV)
	ITEM:精力丸 --
CASE 3
	BASE:0:气力 = LIMIT(BASE:0:气力 + PILL_HEAL, 0, MAXV)
	ITEM:气力丸 --
ENDSELECT
SELECTCASE ARG
CASE 1
	PRINTFORML %CALLNAME:0%服用了体力丸。
	PRINTFORML 体力恢复了{PILL_HEAL}（{OLD}→{BASE:0:体力}／上限{MAXV}）。
CASE 2
	PRINTFORML %CALLNAME:0%服用了精力丸。
	PRINTFORML 精力恢复了{PILL_HEAL}（{OLD}→{BASE:0:精力}／上限{MAXV}）。
CASE 3
	PRINTFORML %CALLNAME:0%服用了气力丸。
	PRINTFORML 气力恢复了{PILL_HEAL}（{OLD}→{BASE:0:气力}／上限{MAXV}）。
ENDSELECT
PRINTW


@USE_ITEM_PLAYER_PILL_HP

CALL USE_ITEM_PLAYER_PILL_COMMON(1)


@USE_ITEM_PLAYER_PILL_VIGOR

CALL USE_ITEM_PLAYER_PILL_COMMON(2)


@USE_ITEM_PLAYER_PILL_SP

CALL USE_ITEM_PLAYER_PILL_COMMON(3)

