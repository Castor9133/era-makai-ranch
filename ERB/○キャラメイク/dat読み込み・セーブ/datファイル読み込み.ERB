
;datから読み込み
@CHARA_DATA_LOAD

IF MONEY:贡献PT < CHARA_MAKE_COST && !FLAG:贡献pt零消费
	PRINTL 贡献PT不够。
	PRINTFORMW （为了从dat读取角色数据，需要贡献pt %VALUE_DIGIT(CHARA_MAKE_COST)%是必需的。）
	RETURN
ENDIF
PRINTL 导入角色数据？
IF FLAG:贡献pt零消费
	CALL PRINTL_WORD_COLOR,@"＜贡献pt零消费＞选项有效","黄"
ELSE
	CALL PRINTL_WORD_COLOR,@"（標目标确定时，贡献pt %VALUE_DIGIT(CHARA_MAKE_COST)%将被消费。目前：%VALUE_DIGIT(MONEY:贡献PT)%pt）","黄"
ENDIF
CALL ASK_YN
SIF !RESULT
	CALL CHARA_DATA_LOAD_LIST



;読み込みdat選択
@CHARA_DATA_LOAD_LIST
#DIM DYNAMIC PAGE

PAGE_MAX = 5
CLEARLINE LINECOUNT
SIF PAGE < 1
	PAGE = 1
PRINTL 请选择要加载的角色
DRAWLINE
FOR LOCAL,20 *(PAGE -1) +100,20 *PAGE +100
	IF FIND_CHARADATA(TOSTR(LOCAL))
		CHKCHARADATA RESULTS
		PRINTFORML [{LOCAL}] %RESULTS%
	ELSE
		CALL PRINTL_WORD_COLOR,@"<{LOCAL}> NO DATA","灰"
	ENDIF
NEXT
DRAWLINE
CALL PRINT_NOW_PAGE(PAGE)
CALL RIGHT_RETURN_BUTTON(0,"キャンセル")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	;CSV読み込み時と同じ画面へ
	LOADCHARA TOSTR(RESULT)
	TARGET = CHARANUM -1
	FLAG:正在化妆角色 = 1
	
	;datが対応前のとき確認メッセージ
	SIF CFLAG:dat创建版本 < CAVEAT_DAT_VERSION
		CALL PRINTW_WORD_COLOR,@"※dat文件的版本是在数据编号更改之前的版本。建议在加载后确认素质等。","黄"
	CALL CSV_CHARA_ADD_FIX
	CALL SELF_CHARA_MAKE
	RETURN
ENDSELECT
RESTART










