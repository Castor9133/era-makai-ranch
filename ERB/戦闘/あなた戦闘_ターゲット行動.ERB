
;戦闘のターゲット行動
;MODメモ
;20221101 - あなた以外も戦闘へ投入できるよう改造
@MASTER_BATTLE_TARGET_ACTION_COMMON

;テレポート使うということで逃げ判断不可
IF CFLAG:非战斗职业
	CALL TARGET_NODAMAGE_ACTION
	RETURN
ENDIF
IF BASE:大技次数 && (TURN > 4 || BASE:战斗力 < MAXBASE:战斗力 *20 /100)
	CALL MASTER_BATTLE_TARGET_SPECIAL_ATTACK
	RETURN
ENDIF

;回復行動は関数同じでOK
IF BASE:回复次数
	IF BASE:战斗力 < MAXBASE:战斗力 *40 /100
		CALL TARGET_SPECIAL_HEAL_SELF
		RETURN
	ELSEIF BASE:同伴战斗力1 < MAXBASE:同伴战斗力1 *40 /100 && BASE:同伴战斗力1 > 0
		CALL TARGET_SPECIAL_HEAL_GROUP
		RETURN
	ENDIF
ENDIF

;ダメージ・クリティカル判定計算
CALL TARGET_ATTACK_DAMAGE_CALC
CALL CRITICAL_CALC_TARGET

;ダメージ半減するとちょうどいい気がする
DAMAGE /= 2

CALL KOJO_PRINT("战斗","攻击")
PRINTFORM %CALLNAME%袭击！ 
CALL CRITICAL_CHECK_ATTACK
PRINTFORML %CALLNAME:BATTLE_CHARA%造成了%VALUE_DIGIT(DAMAGE)%伤害！ 
BASE:BATTLE_CHARA:战斗力 = LIMIT(BASE:BATTLE_CHARA:战斗力 -DAMAGE,0,MAXBASE:BATTLE_CHARA:战斗力)
RESETCOLOR



;大技
@MASTER_BATTLE_TARGET_SPECIAL_ATTACK

CALL KOJO_PRINT("战斗","大招")
CALL PRINTL_WORD_COLOR,@"%CALLNAME%放出大招！！","浅蓝色"
BASE:大技次数 --
CALL TARGET_ATTACK_DAMAGE_CALC
DAMAGE /= 2

;大技のダメージ増加：4ターン目以下なら2.5倍、5ターン目以降1.5倍
IF TURN < 5
	TIMES DAMAGE,2.50
ELSE
	TIMES DAMAGE,1.50
ENDIF
CALL CRITICAL_CALC_TARGET
CALL CRITICAL_CHECK_ATTACK("大招")
PRINTFORML %CALLNAME:BATTLE_CHARA%造成了%VALUE_DIGIT(DAMAGE)%伤害！ 
BASE:BATTLE_CHARA:战斗力 = LIMIT(BASE:BATTLE_CHARA:战斗力 -DAMAGE,0,MAXBASE:BATTLE_CHARA:战斗力)

;疲労度+10%
BASE:疲劳度 = LIMIT(BASE:疲劳度 +10,0,MAXBASE:疲劳度)
PRINTFORML 剩余大技次数：{BASE:大技次数} 疲劳度+10



;仲間攻撃
@MASTER_BATTLE_TARGET_GROUP_ATTACK

;仲間の規模=攻撃回数　2回以上は0.8倍補正
PRINTFORM 同伴们的攻击！ 
FOR LOCAL,0,CFLAG:同伴规模
	;ダメージ計算
	CALL GROUP_ATTACK_DAMAGE_CALC
	DAMAGE /= 2
	
	;2回目以降追撃
	SIF LOCAL
		PRINT 追击！ 
	
	;仲間のクリティカル判定計算
	CALL CRITICAL_CALC_GROUP
	CALL CRITICAL_CHECK_ATTACK
	PRINTFORML %CALLNAME:BATTLE_CHARA%造成了%VALUE_DIGIT(DAMAGE)%伤害！ 
	BASE:BATTLE_CHARA:战斗力 = LIMIT(BASE:BATTLE_CHARA:战斗力 -DAMAGE,0,MAXBASE:BATTLE_CHARA:战斗力)
	RESETCOLOR
	
	;倒したらループ終了
	SIF !BASE:BATTLE_CHARA:战斗力
		RETURN
NEXT
PRINTW


