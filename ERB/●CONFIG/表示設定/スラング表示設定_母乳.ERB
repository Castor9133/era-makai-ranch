
;母乳スラング設定
@SLANG_CONFIG_MILK

CLEARLINE LINECOUNT
PRINTL 请选择以地文等显示的母乳黑话候选。
DRAWLINE
PRINTLC [ 0] 「母乳」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／母乳,0),1)
PRINTLC [ 1] 「奶」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／母乳,1),1)
PRINTLC [ 2] 「milk」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／母乳,2),1)
PRINTLC [ 3] 「牛奶」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／母乳,3),1)
PRINTLC [ 4] 「欧派牛奶」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／母乳,4),1)
PRINTL
PRINTL 　《 前缀设置 》
PRINTLC [10] 《营养》
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／母乳,0),0)
PRINTL 　（母乳浓度1级以上时，如「营养满分」）
PRINTLC [11] 《母乳浓度》
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／母乳,1),0)
PRINTL 　（母乳浓度1级以上时，如「浓厚」）
PRINTLC [12] 「好吃的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／母乳,2),0)
PRINTL 　（母乳浓度1级以上时）
PRINTLC [13] 「浓稠的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／母乳,3),0)
PRINTL 　（母乳浓度2级以上时）
PRINTLC [14] 「最高级的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／母乳,4),0)
PRINTL 　（母乳浓度4级以上时）
PRINTLC [15] 「天然的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／母乳,5),0)
PRINTL 　（没有肉体改造经验时）
PRINTLC [16] 「皇家的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／母乳,6),0)
PRINTL 　（初始身份[王族]时）
PRINTLC [17] 「ＪＳ」／「ＪＣ」／「ＪＫ」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／母乳,7),0)
PRINTL 　（对应素质时）
PRINTL
PRINTL 　《 特殊替换设置 》
PRINTLC [20] 首选特殊替换
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／母乳,0),0)
PRINTL 　…如果满足特殊替换条件，则显示优先级
PRINTLC [21] 「处女乳」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／母乳,1),0)
PRINTL 　（处女时）
PRINTLC [22] 「处女母乳」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／母乳,2),0)
PRINTL 　（处女时）
PRINTLC [23] 「魔力母乳」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／母乳,3),0)
PRINTL 　（【魔力母乳体质】＋魔力1以上时）
PRINTLC [24] 「萝莉母乳」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／母乳,4),0)
PRINTL 　（儿童标准身高时）
PRINTLC [29] 地文的设定
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／母乳,9),0)
PRINTFORML 　（当前设置：%SAVESTR:标识／母乳%）
PRINTLC [30] 魔力母乳时地文设定，
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／母乳,10),0)
PRINTFORML 　（当前设置：%SAVESTR:标识／魔力母乳%）
CALL SLANG_CONFIG_FOOTER
INPUT
SELECTCASE RESULT
CASE 0 TO 4
	INVERTBIT FLAG:黑话标识／母乳,RESULT
CASE 10 TO 17
	INVERTBIT FLAG:黑话前缀／母乳,(RESULT -10)
CASE 20 TO 24
	INVERTBIT FLAG:黑话替换／母乳,(RESULT -20)
CASE 29,30
	INVERTBIT FLAG:黑话替换／母乳,(RESULT -20)
CASE 80
	FLAG:黑话标识／母乳 = 65535
CASE 81
	FLAG:黑话前缀／母乳 = 65535
CASE 82
	FLAG:黑话替换／母乳 = 65535
CASE 90
	FLAG:黑话标识／母乳 = 0
CASE 91
	FLAG:黑话前缀／母乳 = 0
CASE 92
	FLAG:黑话替换／母乳 = 0
CASE 98
	PRINTL 回复默认候选母乳黑话？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_SLANG_CONFIG_MILK
CASE 99
	IF !FLAG:黑话标识／母乳
		PRINTW 必须至少设置一个候选黑话。
	ELSE
		RETURN
	ENDIF
ENDSELECT
RESTART


