
;CSV読み込み後の身長補正
@CSV_CHARA_HEIGHT_FIX

;オトコの場合オトコ用へ
IF TALENT:男性
	CALL CSV_CHARA_HEIGHT_FIX_MALE
	RETURN
ENDIF

;身長の数値が入ってる場合が基本
SELECTCASE CFLAG:身高

;身長数値が入ってない場合→身長ランダム処理に飛ぶ
;CSTRが入ってる場合はその範囲のランダム数値が入る
;CSTRもない場合は[標準]にするので身長入れ忘れ対策にもなってる
CASE 0
	CALL RANDOM_SLAVE_HEIGHT
CASE IS <= HEIGHT_MAX_妖精体型
	CSTR:身高 = 妖精体型
CASE IS <= HEIGHT_MAX_幼儿体型
	CSTR:身高 = 幼儿体型
CASE IS <= HEIGHT_MAX_儿童体型
	CSTR:身高 = 儿童体型
CASE IS <= HEIGHT_MAX_矮小
	CSTR:身高 = 矮小
CASE IS <= HEIGHT_MAX_娇小
	CSTR:身高 = 娇小
CASE IS <= HEIGHT_MAX_标准
	CSTR:身高 = 标准
CASE IS <= HEIGHT_MAX_高挑
	CSTR:身高 = 高挑
CASE IS <= HEIGHT_MAX_高大
	CSTR:身高 = 高大
CASEELSE
	CSTR:身高 = 巨躯
ENDSELECT



;オトコ用
@CSV_CHARA_HEIGHT_FIX_MALE

SELECTCASE CFLAG:身高
CASE 0
	CALL RANDOM_SLAVE_HEIGHT
CASE IS <= HEIGHT_MAX_妖精体型
	CSTR:身高 = 妖精体型
CASE IS <= HEIGHT_MAX_幼儿体型
	CSTR:身高 = 幼儿体型
CASE IS <= HEIGHT_MAX_儿童体型
	CSTR:身高 = 儿童体型
CASE IS <= HEIGHT_MAX_矮小
	CSTR:身高 = 矮小
CASE IS <= MALE_HEIGHT_MAX_娇小
	CSTR:身高 = 娇小
CASE IS <= MALE_HEIGHT_MAX_标准
	CSTR:身高 = 标准
CASE IS <= MALE_HEIGHT_MAX_高挑
	CSTR:身高 = 高挑
CASE IS <= MALE_HEIGHT_MAX_高大
	CSTR:身高 = 高大
CASEELSE
	CSTR:身高 = 巨躯
ENDSELECT



