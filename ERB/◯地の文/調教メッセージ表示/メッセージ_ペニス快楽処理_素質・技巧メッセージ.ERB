;技巧メッセージ
@SEX_TECHNIQUE_MESSAGE

;関数呼ばんでもここでピンクにした
SETCOLOR 0xFF70FF
IF GETBIT(＃Ｐ使用／Ｖ插入＃) || GETBIT(＃Ｐ使用／Ａ插入＃)
	IF CFLAG:洗脑
		PRINTFORM %CALLNAME%在%CALLNAME:PLAYER%的命令下淫荡地扭动着腰…
	ELSEIF (＃陷落状态／恋慕以上＃ && !PLAYER) || ABL:奉仕精神 >= 10
		PRINTFORM %CALLNAME%为了取悦%CALLNAME:0%而不断的扭动着腰…
	ELSEIF GETBIT(＃Ｐ使用／Ｖ插入＃) && ABL:膣内射精中毒 >= 10
		PRINTFORM %CALLNAME%的%SLANG_V()%渴求着腔内中出，不受控制的扭动着腰渴求射精…
	ELSEIF GETBIT(＃Ｐ使用／Ａ插入＃) && ABL:尻穴射精中毒 >= 10
		PRINTFORM %CALLNAME%的%SLANG_A()%渴求着精液，不受控制的扭动着腰渴求射精…
	ELSEIF PALAM:淫欲 >= 50000
		PRINTFORM %CALLNAME%像贪图快感一样自己扭动着腰…
	ELSE
		RESETCOLOR
		RETURN
	ENDIF
ELSEIF GETBIT(＃Ｐ使用／乳交＃)
	IF CFLAG:洗脑
		PRINTFORM %CALLNAME%在%CALLNAME:PLAYER%的命令下用%SLANG_B()%为%SLANG_PENIS()%服务…
	ELSEIF (＃陷落状态／恋慕以上＃ && !PLAYER) || ABL:奉仕精神 >= 10
		PRINTFORM %CALLNAME%为了取悦%CALLNAME:0%，一脸淫靡的表情用%SLANG_B()%侍奉着的%SLANG_PENIS()%…
	ELSEIF ABL:乳内射精中毒 >= 10
		PRINTFORM %CALLNAME%的%SLANG_B()%无法忘记乳内射精的快感，不受控制地侍奉着渴求射精…
	ELSEIF PALAM:淫欲 >= 50000
		PRINTFORM %CALLNAME%就像贪图快感一样主动奉仕…
	ELSE
		RESETCOLOR
		RETURN
	ENDIF
ELSEIF TEQUIP:口交
	IF CFLAG:洗脑
		PRINTFORM %CALLNAME%在%CALLNAME:PLAYER%的命令下用嘴为%SLANG_PENIS()%服务…
	ELSEIF (＃陷落状态／恋慕以上＃ && !PLAYER) || ABL:奉仕精神 >= 10
		PRINTFORM %CALLNAME%为了取悦%CALLNAME:0%，一脸淫靡的表情用嘴侍奉着的%SLANG_PENIS()%…
	ELSEIF ABL:精饮中毒 >= 10
		PRINTFORM %CALLNAME%无法忘记%SAVESTR:标识／精液%的味道，不受控制地侍奉着渴求射精…
	ELSEIF PALAM:淫欲 >= 50000
		PRINTFORM %CALLNAME%就像贪图快感一样主动奉仕…
	ELSE
		RESETCOLOR
		RETURN
	ENDIF
ELSEIF TEQUIP:手淫 || TEQUIP:授乳手交 || TEQUIP:素股
	IF CFLAG:洗脑
		PRINTFORM %CALLNAME%在%CALLNAME:PLAYER%的命令下为%SLANG_PENIS()%服务…
	ELSEIF (＃陷落状态／恋慕以上＃ && !PLAYER) || ABL:奉仕精神 >= 10
		PRINTFORM %CALLNAME%为了取悦%CALLNAME:0%而用手侍奉着%SLANG_PENIS()%…
	ELSEIF PALAM:淫欲 >= 50000
		PRINTFORM %CALLNAME%就像贪图快感一样主动奉仕…
	ELSE
		RESETCOLOR
		RETURN
	ENDIF
ENDIF
RESETCOLOR
CALL HEARTCB(0xD02830)
PRINTL
RETURN 1


