;フェラ／深喉／触手口のピストン
@EJACULATION_PISTON_ORAL

SOURCE:耻辱 += 700
SOURCE:爱情 += 1700
SOURCE:屈辱 += 900
SOURCE:不洁 += 400
SOURCE:支配 += 700
SOURCE:学习 += 800
IF TEQUIP:触手深喉
	SELECTCOM = 109
	CALL SEX_MESSAGE("触手深喉")
	CALL ONOMATOPOEIA_DEEP_THROAT
ELSEIF TEQUIP:触手口交
	SELECTCOM = 108
	CALL SEX_MESSAGE("触手口交")
ELSEIF TEQUIP:深喉
	SELECTCOM = 52
	CALL SEX_MESSAGE("深喉")
	CALL ONOMATOPOEIA_DEEP_THROAT
ELSE
	SELECTCOM = 51
	CALL SEX_MESSAGE("口交")
ENDIF


