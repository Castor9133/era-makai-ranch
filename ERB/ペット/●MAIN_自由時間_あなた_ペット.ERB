
;ペットと過ごす選択後
;ARG→RESULT-1
@MASTER_PLAY_ANIMAL_SELECT(ARG)

;ITEM:堕天馬→100
ANIMAL = %ITEMNAME:(100 +ARG)%
PET_NAME = %PET_NAME_REF(ANIMAL)%
CALL MANYL(3)
PRINTFORML 您想对%PET_NAME%做什么？　今天的天气：【%SAVESTR:天气／今天%】
CALL MASTER_PLAY_ANIMAL_LIST
BINPUT
IF RESULT == 98
	CALL BROWSE_HINT("和宠物玩")
	RESTART
ENDIF
CALL FREE_TIME_PLAY_ANIMAL(RESULT)
CALL MASTER_REWORD_ANIMAL_SELECT

;回復入れる
PRINTFORM %CALLNAME%和%PET_NAME%一起度过被治愈了…　
CALL PLAY_ANIMAL_AFTER_HEAL
PRINTW



;選択肢
;TARGET,ANIMAL,PET_NAME指定済み
@MASTER_PLAY_ANIMAL_LIST

;天気悪いなら外出るのはやめとく
IF !GROUPMATCH(SAVESTR:天气／今天,＃恶劣天气＃)
	PRINTLC [ 0] 散步
ELSE
	CALL PRINTL_WORD_COLOR("因为天气恶劣，就不要外出了。","灰")
ENDIF
PRINTLC [ 1] 洗
PRINTL [ 2] 刷毛
IF !GROUPMATCH(SAVESTR:天气／今天,＃恶劣天气＃)
	CALL MASTER_PLAY_ANIMAL_TOY(3,"飞盘")
	SELECTCASE ANIMAL
	CASE "堕落天马"
	CASE "双头犬"
		CALL MASTER_PLAY_ANIMAL_TOY(4,"趁手的棍子")
	CASE "魔界仓鼠"
	ENDSELECT
ENDIF
PRINTL
PRINTL [98] 提示



;遊び道具選択肢
;ARG→出す選択肢番号
;ARGS→遊び道具
@MASTER_PLAY_ANIMAL_TOY(ARG,ARGS)

IF ITEM:ARGS
	PRINTFORML [{ARG,2}] 使用<%ARGS%>进行游戏：拥有数量{ITEM:ARGS}个
ELSE
	CALL PRINTL_WORD_COLOR,@"　　 %ARGS%","灰"
ENDIF


