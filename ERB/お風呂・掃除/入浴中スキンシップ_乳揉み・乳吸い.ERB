
;風呂場で乳揉み
;ARG→1なら止めない（挿入中呼び出し）
@BATHLOOM_BUST_MASSAGE(ARG)

SELECTCOM = 10
LOSEBASE:体力 += 20
LOSEBASE:气力 += 20
SOURCE:Ｂ快感／主人公刺激 = 2000
SOURCE:耻辱 = 1000
SOURCE:屈辱 = 300
SOURCE:爱情 = 2000
SOURCE:调教者习得 = 400
SOURCE:揉胸 = 1
CALL PRINT_IMAGE("调教执行")
CALL TRAIN_INSERT_MESSAGE
CALL BATHLOOM_BUST_MASSAGE_MESSAGE
EXP:(SELECTCOM +1000) ++
SELECTCOM = 0
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++
SIF !ARG
	PRINTW



;風呂場で乳吸い
;ARG→1なら止めない（挿入中呼び出し）
@BATHLOOM_BUST_SUCK(ARG)

SELECTCOM = 20
LOSEBASE:体力 += 20
LOSEBASE:气力 += 30
SOURCE:Ｂ快感／主人公刺激 = 500
SOURCE:Ｎ快感／主人公刺激 = 2000
SOURCE:耻辱 = 2000
SOURCE:爱情 = 5000
SOURCE:屈辱 = 2000
SOURCE:不洁 = 500
SOURCE:支配 = 2000
SOURCE:授乳 = 2000
SOURCE:调教者习得 = 400
TFLAG:搾乳刺激 = 1
TFLAG:吸奶 = 1
SIF ITEM:搾乳能量吸收 && GETBIT(＃个人有效／搾乳能量吸收＃) && GETBIT(＃有效／搾乳能量吸取＃)
	TFLAG:能量吸收 = 1
CALL PRINT_IMAGE("调教执行")
CALL TRAIN_INSERT_MESSAGE
CALL BATHLOOM_BUST_SUCK_MESSAGE
EXP:(SELECTCOM +1000) ++
SELECTCOM = 0
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++
SIF !ARG
	PRINTW


