
;外見再シャッフル
@CHARA_MAKE_SLAVE_SHUFFLE_APPEARAINCE

CLEARLINE LINECOUNT
CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT
PRINTL 重新调整候选奴隶的外表项。
PRINTL
CALL PRINT_EXTERIOR
CALL HALFLINE
SIF GETBIT(＃重新调整／身体特征＃)
	SETCOLOR 0x80FFFF
PRINTFORML 【%VALUE_DIGIT(SHUFFLE_AGAIN_PT:2)%pt】
PRINTL [ 0] 身高数值
PRINTFORML ※【%CSTR:身高%】将条目添加到文档注册表。
PRINTL
PRINTL [ 1] 体型
PRINTL [ 2] 肤色
PRINTL [ 3] 阴毛
RESETCOLOR
PRINTL
SIF GETBIT(＃重新调整／发型＃)
	SETCOLOR 0x80FFFF
PRINTFORML 【%VALUE_DIGIT(SHUFFLE_AGAIN_PT:3)%pt】
PRINTL 发型打乱
PRINTLC [10] 发色
PRINTLC [11] 头发特征
PRINTLC [12] 发型
PRINTL
PRINTL [13] 发型批量更改
RESETCOLOR
PRINTL
SIF GETBIT(＃重新调整／目特征＃)
	SETCOLOR 0x80FFFF
PRINTFORML 【%VALUE_DIGIT(SHUFFLE_AGAIN_PT:4)%pt】
PRINTL 眼睛相关打乱
PRINTLC [20] 瞳色
PRINTL [21] 异色瞳调整
PRINTLC [22] 瞳孔形状
PRINTL [23] 眼睛特征
RESETCOLOR
CALL PRINTL_ALIGN
DRAWLINE
PRINTL [99] 完成
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL RANDOM_SLAVE_HEIGHT
	SETBIT ＃重新调整／身体特征＃
CASE 1
	CALL RANDOM_SLAVE_SHAPE
	SETBIT ＃重新调整／身体特征＃
CASE 2
	CALL RANDOM_SLAVE_SKIN_COLOR
	SETBIT ＃重新调整／身体特征＃
CASE 3
	CALL RANDOM_SLAVE_UNDERHAIR
	SETBIT ＃重新调整／身体特征＃
CASE 10
	CALL RANDOM_SLAVE_HAIR_COLOR
	SETBIT ＃重新调整／发型＃
CASE 11
	CALL RANDOM_SLAVE_HAIR_FEATURE
	SETBIT ＃重新调整／发型＃
CASE 12
	CALL RANDOM_SLAVE_HAIR_STYLE
	SETBIT ＃重新调整／发型＃
CASE 13
	CALL RANDOM_SLAVE_HAIR
	SETBIT ＃重新调整／发型＃
CASE 20
	CALL RANDOM_SLAVE_EYE_COLOR
	SETBIT ＃重新调整／目特征＃
CASE 21
	CALL RANDOM_SLAVE_EYE_COLOR(1)
	SETBIT ＃重新调整／目特征＃
CASE 22
	CALL RANDOM_SLAVE_PUPIL
	SETBIT ＃重新调整／目特征＃
CASE 23
	CALL RANDOM_SLAVE_EYE_FEATURE
	SETBIT ＃重新调整／目特征＃
CASE 99
	RETURN
ENDSELECT
RESTART

