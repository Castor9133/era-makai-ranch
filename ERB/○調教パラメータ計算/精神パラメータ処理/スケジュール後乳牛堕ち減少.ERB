
;スケジュール後乳牛堕ち減少
@SCHEDULE_AFTER_CATTLE_MIND_MINUS

;乳牛堕ちしてない時に少しだけ減少
SIF CFLAG:乳牛 || !BASE:乳牛堕落
	RETURN

;今の数値で変化
SELECTCASE BASE:乳牛堕落
CASE IS < 1000
	CALL MIND_BASE_DIRECT_MINUS("乳牛堕落",200 +RAND:100)
CASE IS < 3000
	CALL MIND_BASE_DIRECT_MINUS("乳牛堕落",100 +RAND:100)
CASE IS < BASE_ENDURE_COW
	CALL MIND_BASE_DIRECT_MINUS("乳牛堕落",50 +RAND:50)
CASEELSE
	CALL MIND_BASE_DIRECT_MINUS("乳牛堕落",10 +RAND:5)
ENDSELECT




