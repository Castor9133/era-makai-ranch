
;ダークエルフ
@TRIBE_FEATURE_CONFIG_DARKELF

CLEARLINE LINECOUNT
PRINTL 选择【暗精灵】中的种族设定。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL 固定：素质【精灵耳】
PRINTLC [ 0] 把身高向【高挑】靠拢
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／暗精灵,0),1)
PRINTLC [ 1] 肤色变为【褐色】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／暗精灵,1),1)
PRINTLC [ 2] 把体型向【苗条】靠拢
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／暗精灵,2),1)
PRINTLC [ 3] 体型变为【丰腴】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／暗精灵,3),1)
PRINTLC [ 4] 发色变为【银色】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／暗精灵,4),1)
PRINTLC [ 5] 即使不是魔法师职业，也拥有魔力
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／暗精灵,5),1)
PRINTLC [ 6] 基础体力-200
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／暗精灵,6),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(2)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL 当身高抽选到【标准】【矮小】【娇小】时，将转换为【高挑】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／暗精灵"),INPUT_NUM)
CASE 1
	PRINTL 肤色选择抽到【标准】、【色白】、【美白】、【白化】时将变为【褐色】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／暗精灵"),INPUT_NUM)
CASE 2
	PRINTL 体型从【苗条】和【瘦弱】中抽选。
	PRINTL ※体型【丰腴】的选项
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／暗精灵"),INPUT_NUM)
	SIF GETBIT(FLAG:种族设定／暗精灵,2) && GETBIT(FLAG:种族设定／暗精灵,3)
		CLEARBIT FLAG:种族设定／暗精灵,3
CASE 3
	PRINTL 【丰满】和【丰腴】体型。
	PRINTL ※体型【苗条】的选项
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／暗精灵"),INPUT_NUM)
	SIF GETBIT(FLAG:种族设定／暗精灵,2) && GETBIT(FLAG:种族设定／暗精灵,3)
		CLEARBIT FLAG:种族设定／暗精灵,2
CASE 4
	PRINTL 使发色变成【银发】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／暗精灵"),INPUT_NUM)
CASE 5
	PRINTL 即使不是魔法师职业也有魔力。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／暗精灵"),INPUT_NUM)
CASE 6
	PRINTL 在普通状态计算后体力减少200。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／暗精灵"),INPUT_NUM)
CASE 98
	PRINTL 将【暗精灵】的种族设定回复为默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_DARKELF
CASE 99
	RETURN
ENDSELECT
RESTART


