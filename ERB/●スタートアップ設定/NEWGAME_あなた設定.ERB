
;あなたデータの変更
@NEWGAME_PLAYER_DATA
#DIM DYNAMIC PAGE

PAGE_MAX = 3
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL PRINT_PORTRAIT
PRINTFORM 姓名：%CALLNAME%　全名：
IF NAME == ""
	CALL PRINTL_WORD_COLOR,@"(未设定)","灰"
ELSE
	PRINTFORML %NAME%
ENDIF
CALL PRINT_AFFILIATION_DATA
CALL PRINT_VISUAL_AGE
SIF !TALENT:男性
	CALL PRINT_BUST_DETAIL
CALL PRINT_EXTERIOR_PLAYER
CALL PRINT_VIRGIN_PLAYER
CALL SHOW_EQUIP
DRAWLINE
TRYCALLFORM NEWGAME_PLAYER_DATA_INDEX{PAGE}
CALL PRINTL_ALIGN(2)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORML [89] 选择方式切换：\@ SELF_CHARA_MAKE_RANDOM ? 调整 # 手动输入 \@
PRINTLC [90] 默认／EX模式。
PRINTLC [98] 提示
PRINTL [99] 完成
BINPUT
PRINTL
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 89
	INVERTBIT SELF_CHARA_MAKE_RANDOM,0
CASE 90
	CALL NEWGAME_PLAYER_DATA_EXMODE
CASE 98
	CALL BROWSE_HINT("主人公设置")
CASE 99
	RETURN
CASEELSE
	CALL PLAYER_DATA_CONFIG_INPUT(PAGE,RESULT)
ENDSELECT
RESTART




