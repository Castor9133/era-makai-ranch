	PRINTFORMW 没有持有＜灌肠工具套装＞。（成人商店·调教用品页）
	RETURN
ENDIF
IF !ITEM:灌肠技术
	PRINTFORMW 尚未习得调教能力＜灌肠技术＞（开发·习得·调教 AP）。
	RETURN
ENDIF
IF ABL:Ａ扩张 < 2
	PRINTFORMW %CALLNAME%的%SAVESTR:标识／肛门%尚紧，至少需要＜Ａ扩张 2＞后再尝试灌肠。
	RETURN
ENDIF

PRINTL 灌肠——请选择灌入液体。
PRINTFORML [0] 灌肠油（所持 {ITEM:灌肠油}）
IF CFLAG:预计出货母乳量 >= CUP_MILK
	PRINTFORML [1] 出货冷藏母乳（该奴隶可扣 {CUP_MILK}%MILK_COUNTING()% ，余 {CFLAG:预计出货母乳量}%MILK_COUNTING()%）
ENDIF
PRINTL [99] 取消
BINPUT
LOCAL:10 = -1
SELECTCASE RESULT
CASE 0
	IF !ITEM:灌肠油
		PRINTFORMW 没有＜灌肠油＞。
		RETURN
	ENDIF
	LOCAL:10 = 0
CASE 1
	IF CFLAG:预计出货母乳量 < CUP_MILK
		PRINTFORMW 出货冷藏母乳不足{CUP_MILK}%MILK_COUNTING()%。
		RETURN
	ENDIF
	LOCAL:10 = 1
CASEELSE
	RETURN 1
ENDSELECT

; 孕早期（妊娠超 30 日后排泄加重段）：为胎儿求饶，玩家可选择是否继续（未扣液体前可安全中止）
IF EXCRETION_IS_EARLY_PREG_EXCRETION()
	PRINTL
	PRINTFORML %CALLNAME%护着小腹，声音发颤……似乎非常担心灌肠会伤到腹中的孩子。
	TRYCALL KOJO_PRINT("身体", "灌肠妊娠求饶", "", "")
	PRINTL [0] 中止灌肠（不消耗灌肠油／母乳）
	PRINTL [1] 仍要灌肠
	BINPUT
	SIF !RESULT
		RETURN 1
ENDIF

SELECTCASE LOCAL:10
CASE 0
	ITEM:灌肠油 --
	CFLAG:排泄_灌肠液种类 = 0
CASE 1
	CFLAG:预计出货母乳量 -= CUP_MILK
	CFLAG:排泄_灌肠液种类 = 1
	SIF MARK:魔力母乳体质
		CFLAG:排泄_灌肠液种类 = 2
	; 母乳灌肠：微量气力／魔力回复（奴隶）
	FIX = 100 + ABL:母乳浓度 * 50
	HEAL = CUP_MILK * FIX / 1000
	HEAL -= HEAL % 10
	BASE:气力 = LIMIT(BASE:气力 + HEAL, 0, MAXBASE:气力)
	IF CFLAG:排泄_灌肠液种类 == 2
		HEAL = CUP_MILK * (ABL:母乳浓度 + 1)
		BASE:灵力 = LIMIT(BASE:灵力 + HEAL, 0, MAXBASE:灵力)
	ENDIF
ENDSELECT

SOURCE:已用时间 = 1
LOSEBASE:气力 += 18
LOSEBASE:体力 += 25
