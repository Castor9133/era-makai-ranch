
;髪色・髪型変更
@VISIT_HAIR_STYLE_CHANGE_BEFORE

CHANGE_PLANS:0 = %CSTR:发色%
CHANGE_PLANS:1 = %CSTR:头发特征%
CHANGE_PLANS:2 = %CSTR:发型%
CHANGE_PLANS:3= %CSTR:颜色类别／发色%
CHANGE_PLANS:4= %CSTR:颜色类别／发特征%
CHANGE_PLANS:5= %CSTR:颜色类别／发型%
CHANGE_PLAN:0 = CFLAG:颜色编码／发
CALL VISIT_HAIR_STYLE_CHANGE

VARSET CHANGE_PLANS
VARSET CHANGE_PLAN



;ここで設定
@VISIT_HAIR_STYLE_CHANGE

CLEARLINE LINECOUNT
CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT
CALL MANYL(3)
PRINT 　初始发型：
SIF CFLAG:初始值／颜色编码／头发
	SETCOLOR CFLAG:初始值／颜色编码／头发
PRINTFORML 【%CSTR:初始值／发色%%CSTR:初始值／发特征%%CSTR:初始值／发型%】
RESETCOLOR
PRINT 当前发型：
SIF CHANGE_PLAN:0
	SETCOLOR CHANGE_PLAN:0
PRINTFORML 【%CHANGE_PLANS:0%%CHANGE_PLANS:1%%CHANGE_PLANS:2%】
RESETCOLOR
PRINTL
PRINTFORMLC 发色　：%CSTR:发色%
IF ITEM:染发剂
	PRINTL [ 0] 发色变更
ELSE
	CALL PRINTL_WORD_COLOR("没有＜发色＞","灰")
ENDIF
PRINTLC 　
PRINTL [ 1] 发色颜色编码更改
IF CSTR:头发特征 == ""
	PRINTLC 头发特征：（未指定）
ELSE
	PRINTFORMLC 头发特征：%CSTR:头发特征%
ENDIF
PRINTL [ 2] 头发特征变更
PRINTFORMLC 发型　：%CSTR:发型%
PRINTL [ 3] 改变发型
PRINTL
PRINT 更改后：
CALL PRINT_HAIR_STYLE
PRINTL
DRAWLINE
PRINTLC [90] 取消
IF CFLAG:正在改变发型
	PRINTLC [91] 回复原始发型
ELSE
	PRINTLC 　
ENDIF
PRINTL [99] 完成
INPUT
PRINTL

SELECTCASE RESULT
CASE 0
	SIF !ITEM:染发剂
		RESTART
	
	;STR:黒髪→200
	STR_REF = 200
	PRINTL 选择发色。
	FOR LOCAL,STR_REF,STR_REF+50
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL-STR_REF,3}] %STR:LOCAL%
	NEXT
	CALL INPUTBUTTON
	BINPUT
	IF RESULT >= 0 && RESULT < 50
		CSTR:发色 = %STR:(RESULT+STR_REF)%
		CALL AUTOSET_HAIR_COLOR_CODE
	ELSEIF RESULT == 901
		PRINTL 请输入发色。
		INPUTS
		CSTR:发色 = %RESULTS%
	ENDIF
	CALL CATEGORY_HAIR_COLOR
	
CASE 1
	CALL EDIT_COLOR_CODE(CFLAG:颜色编码／发,1)
	SIF RESULT
		CFLAG:颜色编码／发 = RESULT
	
CASE 2
	;STR:ぱっつん→300
	STR_REF = 300
	PRINTL 选择头发特征。
	FOR LOCAL,STR_REF,STR_REF+100
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL-STR_REF,3}] %STR:LOCAL%
	NEXT
	CALL INPUTBUTTON(1)
	BINPUT
	IF RESULT >= 0 && RESULT < 100
		CSTR:头发特征 = %STR:(RESULT+STR_REF)%
	ELSEIF RESULT == 900
		CSTR:头发特征 =
	ELSEIF RESULT == 901
		PRINTL 请输入头发特征。
		INPUTS
		CSTR:头发特征 = %RESULTS%
	ENDIF
	CALL CATEGORY_HAIR_FEATURE
	
CASE 3
	;STR:ロング→500
	STR_REF = 500
	PRINTL 选择发型。
	FOR LOCAL,STR_REF,STR_REF+100
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL-STR_REF,3}] %STR:LOCAL%
	NEXT
	CALL INPUTBUTTON
	BINPUT
	IF RESULT >= 0 && RESULT < 100
		CSTR:发型 = %STR:(RESULT+STR_REF)%
	ELSEIF RESULT == 901
		PRINTL 请输入发型。
		INPUTS
		CSTR:发型 = %RESULTS%
	ENDIF
	CALL CATEGORY_HAIR_STYLE

CASE 90
	CSTR:发色 = %CHANGE_PLANS:0%
	CSTR:头发特征 = %CHANGE_PLANS:1%
	CSTR:发型 = %CHANGE_PLANS:2%
	CSTR:颜色类别／发色 = %CHANGE_PLANS:3%
	CSTR:颜色类别／发特征 = %CHANGE_PLANS:4%
	CSTR:颜色类别／发型 = %CHANGE_PLANS:5%
	CFLAG:颜色编码／发 = CHANGE_PLAN:0
	RETURN
	
CASE 91
	SIF !CFLAG:正在改变发型
		RESTART
	PRINTL 换回原始发型？
	CALL ASK_YN
	IF !RESULT
		CFLAG:正在改变发型 = 0
		CSTR:发色 = %CSTR:初始值／发色%
		CFLAG:颜色编码／发 = CFLAG:初始值／颜色编码／头发
		CSTR:头发特征 = %CSTR:初始值／发特征%
		CSTR:发型 = %CSTR:初始值／发型%
		CALL CATEGORY_HAIR_COLOR
		CALL CATEGORY_HAIR_FEATURE
		CALL CATEGORY_HAIR_STYLE
		PRINTW 回复了原始发型。
		RETURN
	ENDIF
	
CASE 99
	PRINT 要更改成
	CALL PRINT_HAIR_STYLE
	RESETCOLOR
	PRINTL 发色吗？
	SIF CHANGE_PLANS:0 != CSTR:发色
		CALL PRINTL_WORD_COLOR("由于正在更改发色，将消耗1个＜发色＞。","黄")
	CALL ASK_YN
	IF !RESULT
		SIF CHANGE_PLANS:0 != CSTR:发色
			ITEM:染发剂 --
		CFLAG:正在改变发型 = 1
		PRINTFORML 改变了%CALLNAME%的发型。
		CALL KOJO_PRINT("访问","更改发型")
		PRINTW
		RETURN
	ENDIF
ENDSELECT
RESTART

