@KOJO_GENERAL_慇懃口上1_SCHEDULE(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:1
CASE "奶农"
	SELECTCASE ARGS:2
	CASE "初次"
		IF CFLAG:总搾乳量
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「%SELF_CALL()%也是奶牛，感觉可以与其他家畜心意相通呢♥♥」"
			ELSEIF ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
				CALL MESSAGE_BOX,@"「我一定会为%MASTER_CALL()%尽全力效劳…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「这也是我的职责，只能完成它了」"
			ENDIF
		ELSE
			IF ABL:奶农 >= 5
				CALL MESSAGE_BOX,@"「是要照顾家畜吗…？ 我有一些经验哦」"
			ELSE
				CALL MESSAGE_BOX,@"「是要照顾家畜吗…？ 我会先试试看…」"
			ENDIF
		ENDIF
	CASE "普通"
		IF TIME == 0 || TIME == 2
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"「来吧，挤出大量牛奶为%MASTER_CALL()%做贡献吧…♥♥」"
				CALL MESSAGE_BOX,@"「嘻嘻♥ 好好照顾它们，让%MASTER_CALL()%表扬我…！」"
