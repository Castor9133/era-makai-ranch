
;奴隷候補を作成する
@ORDER_CHARACTER

IF MONEY:贡献PT < CHARA_MAKE_COST && !FLAG:贡献pt零消费
	PRINTL 贡献PT不够。
	PRINTFORMW （为了从CSV读取人物数据，贡献pt %VALUE_DIGIT(CHARA_MAKE_COST)%是必需的。）
	RETURN
ENDIF
CALL MANYL(5)
ALIGNMENT CENTER
PRINTL --- ！保护 ---
ALIGNMENT LEFT
DRAWLINE
PRINTL 使用[特殊门解放]后，通过从CSV文件读取预设
PRINTL 可以自由记述[种族]和[职业]等各种各样的项目来塑造角色。
PRINTL 无论版权还是原创角色的再现度都会提高。如果您喜欢，请自由选择。
PRINTL 因为基本上都是以自由记述形式进行，所以比较麻烦。
PRINTL 在系统上过于有利的角色化的话，难易度会锐减，当然一切都由您自由选择。
PRINTL 
PRINTL 但是，在保存数据的上传和错误报告等中
PRINTL ・就算是在era这小地方，也请不要给伦理上不好的东西。
PRINTL ・请不要把官方限制二次创作的版权作品的数据提高。
PRINTL （如果您想要用文本进行错误报告，请适当替换名称）
DRAWLINE
PRINTL 导入角色数据？
IF FLAG:贡献pt零消费
	CALL PRINTL_WORD_COLOR,@"＜贡献pt零消费＞选项有效","黄"
ELSE
	CALL PRINTL_WORD_COLOR,@"（標目标确定时，贡献pt %VALUE_DIGIT(CHARA_MAKE_COST)%将被消费。目前：%VALUE_DIGIT(MONEY:贡献PT)%pt）","黄"
ENDIF
CALL ASK_YN
SIF !RESULT
	CALL CSV_CHARA_LIST_TABLE



;読み込むキャラのカテゴリ
@CSV_CHARA_LIST_TABLE
#DIM SAVE_CHARANUM
#DIM CHARA_NUMBER
#DIM CHARA_COUNT
#DIM TABLE

CLEARLINE LINECOUNT
PRINTFORML 请选择来源作品类别。

FOR TABLE,0,100
	SIF STR:(6400+TABLE) == ""
		BREAK
	;枠に何人いるか
	CHARA_COUNT = 0
	FOR LOCAL,0,100
		CHARA_NUMBER = LOCAL+TABLE*100
		EXISTCSV CHARA_NUMBER
		SIF RESULT
			CHARA_COUNT ++
	NEXT
	PRINTFORMLC [{TABLE,2}] %STR:(6400+TABLE)%　：{CHARA_COUNT}人 
NEXT
CALL MANYL(3)
PRINTL [99] 取消
BINPUT
IF RESULT == 99
	RETURN
	
ELSEIF RESULT < 100
	SAVE_CHARANUM = CHARANUM
	CALL CSV_CHARA_LIST(RESULT)
	
	;キャラを呼び出していたらSAVE_CHARANUMとCHARANUMが異なるのでRETURNする
	SIF SAVE_CHARANUM != CHARANUM
		RETURN
ENDIF

;キャンセルで戻ってきたらRESTART
RESTART




;読み込むキャラを選択する
@CSV_CHARA_LIST(ARG)
#DIM CHARA_NUMBER
#DIM DYNAMIC PAGE
#DIM DYNAMIC STATUS_TOGGLE
#DIMS SOURCE_PRODUCTS
#DIMS DISPNAME

PAGE_MAX = 5
CLEARLINE LINECOUNT
SIF PAGE < 1
	PAGE = 1
VARSET CSVLOAD_OK

PRINTL 请选择角色预设
PRINTL ·有专属口上的情况下会以浅蓝色表示
DRAWLINE

FOR LOCAL,20 *(PAGE -1),20 *PAGE
	;選択カテゴリ番号*100 +LOCALが存在するか見る
	CHARA_NUMBER = LOCAL +ARG *100
	EXISTCSV CHARA_NUMBER
	IF RESULT
		EXIST = 0
		;era魔界牧場枠はマイルストーン進行具合で不可能にする（予定がある）ので別関数を呼ぶ
		SIF !ARG
			CALL CHARA_LIST_MAKAIBOKUJO(CHARA_NUMBER)
		SIF EXIST
			CONTINUE
		
		;被りの場合はカスタム前に出典・名前を消す形式にした
		CSVLOAD_OK:CHARA_NUMBER = 1
		
		;専用口上がある場合水色表示
		SIF CSVCFLAG(CHARA_NUMBER,GETNUM(CFLAG,"专用设置／口上"))
			SETCOLOR 0x70FFFF
		IF CSVNAME(CHARA_NUMBER) != ""
			PRINTFORM [{CHARA_NUMBER+100,3}] %CSVNAME(CHARA_NUMBER),16,LEFT%：
		ELSE
			PRINTFORM [{CHARA_NUMBER+100,3}] %CSVCALLNAME(CHARA_NUMBER),16,LEFT%：
		ENDIF
		RESETCOLOR
		SELECTCASE STATUS_TOGGLE
		CASE 0
			PRINTFORML %CSVCSTR(CHARA_NUMBER,GETNUM(CSTR,"角色介绍"))% 
		CASE 1
			CALL CSV_HEIGHT_BUST(CHARA_NUMBER)
		CASE 2
			CALL CSV_AFFILIATION_DATA(CHARA_NUMBER)
			PRINTL
		ENDSELECT
	ELSE
		CALL PRINTL_WORD_COLOR,@"<{CHARA_NUMBER+100,3}>：NODATA ","灰"
	ENDIF
NEXT
DRAWLINE
CALL PRINT_NOW_PAGE(PAGE)
PRINTFORMLC [  8] 显示切换（{STATUS_TOGGLE +1}／3）
PRINTLC 　
PRINTL [ 99] 取消
BINPUT
PRINTL
SELECTCASE RESULT
CASE 8
	STATUS_TOGGLE ++
	SIF STATUS_TOGGLE > 2
		STATUS_TOGGLE = 0
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	CHARA_NUMBER = RESULT-100
	ADDCHARA CHARA_NUMBER
	TARGET = CHARANUM -1
	CALL CSV_CHARA_ADD_FIX
	CALL SELF_CHARA_MAKE
	RETURN
ENDSELECT
RESTART



