
;衣服説明目次：衣服は別関数
;ARG→PAGE
;ARGS→店
;ITEM_ID_MIN,ITEM_ID_MAX指定済み
@CLOTHE_LIST_COMMON(ARG,ARGS)

;ページごとの商品説明を呼ぶ
SELECTCASE ARG
CASE 0
	CALL CLOTHE_LIST_INDEX(ARGS)
CASE 1
	CALL CLOTHE_LIST_CLOTHESET(ARGS)
CASE 2
	CALL CLOTHE_LIST_WORK(ARGS)
CASE 3
	CALL CLOTHE_LIST_LINGERIE(ARGS)
CASE 4
	CALL CLOTHE_LIST_ACCESSORY(ARGS)
CASE 5
	CALL CLOTHE_LIST_ADULT_LINGERIE(ARGS)
CASE 6
	CALL CLOTHE_LIST_ADULT_CLOTHE(ARGS)
CASE 7
	CALL CLOTHE_LIST_HUMAN_REPLICA(ARGS)
CASE 8
	CALL CLOTHE_LIST_OTHER_WORLD(ARGS)
CASE 9
	CALL CLOTHE_LIST_OTHER_WORLD_LINGERIE(ARGS)
CASE 10
	CALL CLOTHE_LIST_ARMOR(ARGS)
CASE 11
	CALL CLOTHE_LIST_TENTACLE(ARGS)
ENDSELECT



;目次
;ARGS→どの画面から参照するか
@CLOTHE_LIST_INDEX(ARGS)

PRINTL 　《 目录 》
PRINTL [  1] 服装套装
PRINTL [  2] 工作衣服
PRINTL [  3] 内衣
PRINTL [  4] 饰品

;買い物時はマイルストーンによるアンロック
IF ARGS == "购物"
	CALL MILESTONE_UNLOCK_CHECK("成人装束","")
	RESULT:1 = RESULT
	CALL MILESTONE_UNLOCK_CHECK("乳牛套装服装","")
	
	;どっちかが開いてるならOK
	IF RESULT || RESULT:1
		PRINTL [  5] 奶牛服装・成人内衣
	ELSE
		CALL PRINTL_WORD_COLOR,@"<  5> 奶牛服装・成人内衣","灰"
	ENDIF
	CALL MILESTONE_UNLOCK_CHECK("成人装束","")
	IF !RESULT
		CALL PRINTL_WORD_COLOR,@"<  6> 成人装束","灰"
	ELSE
		PRINTL [  6] 成人装束
	ENDIF
	CALL MILESTONE_UNLOCK_CHECK("衣服复制品","")
	IF !RESULT
		CALL PRINTL_WORD_COLOR,@"<  7> 人类服装","灰"
	ELSE
		PRINTL [  7] 人类服装
	ENDIF
	CALL MILESTONE_UNLOCK_CHECK("异世界衣服","")
	IF !RESULT
		CALL PRINTL_WORD_COLOR,@"<  8> 异世界衣服","灰"
		CALL PRINTL_WORD_COLOR,@"<  9> 异世界内衣","灰"
	ELSE
		PRINTL [  8] 异世界衣服
		PRINTL [  9] 异世界内衣
	ENDIF

ELSE
	PRINTL [  5] 奶牛服装・成人内衣
	PRINTL [  6] 成人装束
	PRINTL [  7] 人类服装
	PRINTL [  8] 异世界衣服
	PRINTL [  9] 异世界内衣
ENDIF

;キャラメイク中だけ
IF ARGS == "造型"
	PRINTL [ 10] 铠
ELSE
	CALL PRINTL_WORD_COLOR,@"< 10> 铠","灰"
ENDIF

;着替えだけ
IF ARGS == "更衣"
	PRINTL [ 11] 特殊调教服
ELSE
	CALL PRINTL_WORD_COLOR,@"< 11> 特殊调教服","灰"
ENDIF



