CASE "事务"
	SELECTCASE ARGS:2
	CASE "初次"
		IF ABL:事务 >= 8
			CALL MESSAGE_BOX,@"「事务工作的话…这是我以前的老本行了」"
		ELSEIF ABL:事务 >= 4
			CALL MESSAGE_BOX,@"「事务工作……如果能像在地上那样顺利就好了……」"
		ELSE
			CALL MESSAGE_BOX,@"「事务工作……那个…实在不好意思，我从未涉及过…」"
		ENDIF
	CASE "普通"
		IF ABL:事务 >= 8
			CALL MESSAGE_BOX,@"「事务处理的话，请交给%SELF_CALL()%吧」"
		ELSEIF ABL:事务 >= 4
			CALL MESSAGE_BOX,@"「虽说谈不上擅长……但我会尽力而为…」"
		ELSE
			CALL MESSAGE_BOX,@"「啊……那个，我想交给别人或许能避免麻烦…」"
		ENDIF
		SIF FLAG:事务工作量 >= 20
			CALL MESSAGE_BOX,@"「真是麻烦的人……竟然积了这么多文件……」"
		IF CSTR:日程 == CSTR:0:日程
			IF ABL:事务 >= 8
				CALL MESSAGE_BOX,@"「难得如此，不如先处理一下未来的工作吧」"
			ELSEIF ABL:事务 >= 4
				CALL MESSAGE_BOX,@"「与地上的文件有些相似，所以还算应付得来…」"
			ELSE
				CALL MESSAGE_BOX,@"「之前那凄惨的样子……您已经忘了吗…」"
			ENDIF
		ENDIF
	ENDSELECT
	
