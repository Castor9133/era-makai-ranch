;指定アイテムを着せるか渡す
;ARGS→処理
;ARGS:1→アイテム名
;ARGS:2→アイテムの概要変更
;ARG→一式表示での改行
@EQUIP_CLOTHE_SET_COMBI(ARGS,ARGS:1,ARGS:2,ARG)

SELECT_ITEM = GETNUM(ITEM,ARGS:1)

;処理を呼ぶ
SELECTCASE ARGS
CASE "穿着"
	CALL WEAR_CHARA_CLOTHE(0,1)
	SIF EQUIP:SELECT_ITEM
		RETURN
	SETBIT EQUIP:SELECT_ITEM,0

	;概要指定されていたら変更
	SELECTCASE ARGS:2
	CASE "授乳开口"
		;置換できなかった
		SETBIT EQUIP:SELECT_ITEM,10

	CASE "心形"
		CSTR:SELECT_ITEM = 哈特
	ENDSELECT

CASE "物品检查"
	;持ってないときEXIST = 0にする
	SIF !EQUIP:SELECT_ITEM
		EXIST = 0

CASE "合计金额"
	;COSTに金額を加算
	COST += ITEMPRICE:SELECT_ITEM

CASE "一套显示"
	;表示していく
	IF ARGS:2 == ""
		PRINTFORM ＜%ARGS:1%＞
	ELSE
		PRINTFORM ＜%ARGS:1%（%ARGS:2%）＞
	ENDIF
	SIF ARG
		PRINTL
ENDSELECT

