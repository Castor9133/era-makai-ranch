;参照するメニューに合わせて色とか変更
;ARGS→今のメニュー
;ARG→アイテムID
@CLOTHE_LIST_MENU(ARGS,ARG)

;アイテム名がないならおわり
SIF ITEMNAME:ARG == ""
	RETURN
SELECTCASE ARGS

;所持キャラの衣服変更→アイテムとして持っているかどうかなど
CASE "更衣"
	CALL CLOTHE_LIST_COLOR_TAG(ARG)

;買い物中→購入可能かなど
CASE "购物"
	CALL ITEM_SHOP_LOOP_JUDGE(ARG)

;キャラメイク中→特に制限なし
CASE "造型"
	CALL BR_PLUS(3)
	PRINTFORMLC [{ARG,3}] %ITEMNAME:ARG% 
ENDSELECT



;衣服変更の色分け
;ARG→アイテムID
@CLOTHE_LIST_COLOR_TAG(ARG)

EXIST = 0

;アイテムとしてもキャラも持ってない場合灰色
IF !EQUIP:ARG && !ITEM:ARG
	SETCOLOR 0x606060

;メガネを元々持ってない、メガネを持ってて伊達メガネ選択中の場合も灰色
ELSEIF (ITEMNAME:ARG == "眼镜" && !EQUIP:ARG) || (ITEMNAME:ARG == "伊达眼镜" && EQUIP:眼镜)
	SETCOLOR 0x606060

;キャラが持ってるなら水色
ELSEIF EQUIP:ARG
	;装備中なら桃
	FOR LOCAL,0,20
		SIF EQUIP:LOCAL != ARG
			CONTINUE
		EXIST ++
	NEXT
	IF EXIST
		SETCOLOR 0xFF70FF
	ELSE
		SETCOLOR 0x50C0FF
	ENDIF
ENDIF
CALL BR_PLUS(3)
PRINTFORMLC [{ARG,3}] %ITEMNAME:ARG% 
RESETCOLOR




