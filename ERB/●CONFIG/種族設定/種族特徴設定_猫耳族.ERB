
;猫耳族
@TRIBE_FEATURE_CONFIG_CATEAR

CLEARLINE LINECOUNT
PRINTL 请选择【猫耳族】的种族设定。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL 固定：素质【动物耳】【尾巴】
PRINTLC [ 0] 素质【猫舌】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／猫耳族,0),1)
PRINTLC [ 1] 素质【讨厌泡澡】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／猫耳族,1),1)
PRINTLC [ 2] 素质【喜怒无常】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／猫耳族,2),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(7)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL 被赋予素质【猫舌】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／猫耳族"),INPUT_NUM)
CASE 1
	PRINTL 被赋予素质【讨厌泡澡】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／猫耳族"),INPUT_NUM)
CASE 2
	PRINTL 被赋予素质【喜怒无常】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／猫耳族"),INPUT_NUM)
CASE 98
	PRINTL 将【猫耳族】的种族设定回复为默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_CATEAR
CASE 99
	RETURN
ENDSELECT
RESTART


