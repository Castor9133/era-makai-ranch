
;反抗削除
@CAPITULATION_DELETE_RESIST

;心境変化の共通処理
CALL MIND_CHANGE_CALC("反抗消除")

;体内凌辱中はメッセージを変える
;地の文で分けてもらうほうがいい気がする
IF CSTR:日程 == "体内凌辱"
	CALL KOJO_PRINT("事件","反抗消除","体内凌辱中")
ELSE
	CALL KOJO_PRINT("事件","反抗消除")
ENDIF
CALL CAPITULATION_DELETE_RESIST_MESSAGE

;目的変更
CALL PURPOSE_CHANGE_CALC("不放弃")



;屈服
@CAPITULATION_SUCCUMB

CALL MIND_CHANGE_CALC("屈服")
IF CSTR:日程 == "体内凌辱"
	CALL KOJO_PRINT("事件","屈服","体内凌辱中")
ELSE
	CALL KOJO_PRINT("事件","屈服")
ENDIF
CALL CAPITULATION_SUCCUMB_MESSAGE
CALL PURPOSE_CHANGE_CALC("屈服状态")



;陥落
@CAPITULATION_FALLING

CALL MIND_CHANGE_CALC("陷落")
IF CSTR:日程 == "体内凌辱"
	CALL KOJO_PRINT("事件","陷落","体内凌辱中")
ELSE
	CALL KOJO_PRINT("事件","陷落")
ENDIF
CALL CAPITULATION_FALLING_MESSAGE
CALL PURPOSE_CHANGE("陷落状态")



;乳牛
@CAPITULATION_CATTLE

CALL MIND_CHANGE_CALC("乳牛")
BASE:精神力 = MAXBASE:精神力
MAXBASE:乳牛堕落 = BASE_LOVESLAVE_FAV
BASE:乳牛堕落 ++
PRINTL
IF CSTR:日程 == "体内凌辱"
	CALL KOJO_PRINT("事件","乳牛堕落","体内凌辱中")
ELSE
	CALL KOJO_PRINT("事件","乳牛堕落")
ENDIF
CALL CAPITULATION_CATTLE_MESSAGE

;苦痛・恐怖刻印の消去
CALL DELETE_BAD_MARK

;乳責め嫌悪の消去
IF TALENT:乳房刺激厌恶感
	TALENT:乳房刺激厌恶感 = 0
	MARK:消除乳房刺激厌恶感 = 1
	CALL CAPITULATION_CATTLE_LOVE_BUST_MESSAGE
ENDIF
CALL PURPOSE_CHANGE_CALC("乳牛")



;崩壊
@CAPITULATION_MIND_BREAK

CALL MIND_CHANGE_CALC("崩坏")
MARK:绝望刻印 = 1
IF CSTR:日程 == "体内凌辱"
	CALL KOJO_PRINT("事件","崩坏","体内凌辱中")
ELSE
	CALL KOJO_PRINT("事件","崩坏")
ENDIF
CALL CAPITULATION_MIND_BREAK_MESSAGE
CALL CAPITULATION_MIND_BREAK_DELETE_TALENT
PRINTFORML %CALLNAME%　好感度-20\% 乳牛堕落-20\%
BASE:好感度 = LIMIT(BASE:好感度 -2000,0,MAXBASE:好感度)
BASE:乳牛堕落 = LIMIT(BASE:乳牛堕落 -2000,0,MAXBASE:乳牛堕落)

;メッセージで赤に変えたままをここで戻す
RESETCOLOR
CALL PURPOSE_CHANGE("崩坏")



;恋慕
@CAPITULATION_LOVE

CALL MIND_CHANGE_CALC("恋慕")
MAXBASE:好感度 = BASE_FALLINLOVE_FAV -1
BASE:好感度 ++
CALL KOJO_PRINT("事件","恋慕告白","前")
CALL CAPITULATION_LOVE_MESSAGE_BEFORE
CALL KOJO_PRINT("事件","恋慕告白","后")
CALL CAPITULATION_LOVE_MESSAGE_AFTER
CALL PURPOSE_CHANGE_CALC("恋慕")



;隷属
@CAPITULATION_LOVE_SLAVE

CALL MIND_CHANGE_CALC("隶属")
BASE:精神力 = MAXBASE:精神力
MAXBASE:好感度 = BASE_LOVESLAVE_FAV
BASE:好感度 ++
CALL KOJO_PRINT("事件","隶属告白","前")
CALL CAPITULATION_LOVE_SLAVE_MESSAGE_BEFORE
CALL KOJO_PRINT("事件","隶属告白","后")
CALL CAPITULATION_LOVE_SLAVE_MESSAGE_AFTER
CALL DELETE_BAD_MARK
CALL PURPOSE_CHANGE_CALC("隶属")
CALL DELETE_VARGIN_BARRIER




