
;乳首の色割合設定（褐色肌）
@TENDENCY_CONFIG_NIPPLE_COLOR_DARKSKIN

;FLAG:候補割合／乳首の色／褐色肌／ピンク→3170
FLAG_REF = 3170
STR_REF = 6570
FLAG:(FLAG_REF +9) = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +9)
CLEARLINE LINECOUNT
PRINTL 请设置肤色为【褐色】【小麦色】时的人类的乳头颜色比例。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
TOTAL_RATIO = FLAG:(FLAG_REF +9)
FOR LOCAL,0,9
	SIF FLAGNAME:(LOCAL +FLAG_REF) == ""
		BREAK
	
	;色つけたいので他と変える
	PRINTFORM [{LOCAL,3}] 
	SELECTCASE LOCAL
	CASE 0
		SETCOLOR NIPPLE_COLOR_CODE_PINK
		PRINT 　　　　　粉红色
	CASE 1
		SETCOLOR NIPPLE_COLOR_CODE_DEEPPINK
		PRINT 　深粉色
	CASE 2
		SETCOLOR NIPPLE_COLOR_CODE_HOTPINK
		PRINT 　　亮粉色
	CASE 3
		SETCOLOR NIPPLE_COLOR_CODE_CHERRYPINK
		PRINT 　樱桃粉
	CASE 4
		SETCOLOR NIPPLE_COLOR_CODE_LIGHTPINK
		PRINT 　　浅粉色
	CASE 5
		SETCOLOR NIPPLE_COLOR_CODE_RUBYRED
		PRINT 　　宝石红
	CASE 6
		SETCOLOR NIPPLE_COLOR_CODE_RUSSETBROWN
		PRINT 栗棕色
	CASE 7
		SETCOLOR NIPPLE_COLOR_CODE_BROWN
		PRINT 　　　　棕色
	ENDSELECT
	PRINTFORM 　%UNICODE(0x2586)%%UNICODE(0x2586)%：
	SIF !FLAG:(LOCAL +FLAG_REF)
		SETCOLOR 0x606060
	PRINTFORM ：{FLAG:(LOCAL +FLAG_REF),4}
	PRINTPLAIN 　
	RESETCOLOR
	PRINTBUTTON "[+10]",LOCAL +100
	PRINTBUTTON "[-10]",LOCAL +200
	PRINTPLAIN 　
	PRINTBUTTON "[×2]",LOCAL +300
	PRINTBUTTON "[÷2]",LOCAL +400
	PRINTPLAIN 　
	IF !TOTAL_RATIO
		SIF !LOCAL
			CALL PRINT_WORD_COLOR("！比率合计为0","黄")
		PRINTL
		CONTINUE
	ENDIF
	CONFIG_RATIO = FLAG:(FLAG_REF +LOCAL) *100
	CONFIG_RATIO /= TOTAL_RATIO
	IF !CONFIG_RATIO && FLAG:(FLAG_REF +LOCAL)
		PRINT 接近0% 
	ELSE
		PRINTFORM 　{CONFIG_RATIO,3}\% 
	ENDIF
	PRINTL
NEXT
CALL PRINTL_ALIGN(-10)
PRINTL [90] 与白色系肌肤保持相同比例
CALL TENDENCY_CONFIG_FOOTER
CALL TENDENCY_INPUT
SELECTCASE RESULT
CASE 90
	PRINTL 是否从「白色系的乳头颜色比例」复制比例？
	CALL ASK_YN
	IF !RESULT
		;FLAG:候補割合／乳首の色／ピンク→3150,-20
		FOR LOCAL,0,10
			FLAG:(FLAG_REF +LOCAL) = FLAG:(FLAG_REF +LOCAL -20)
		NEXT
	ENDIF

CASE 98
	PRINTL 将乳头颜色比例回复为默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TENDENCY_CONFIG_NIPPLE_COLOR_DARKSKIN
CASE 99
	RETURN
ENDSELECT
RESTART



