CASE "奶牛隶属家畜"
	CALL PRINT_WORD_COLOR,@"%CSTR:第一人称%真心爱着教会我家畜幸福的%CSTR:主人公的称呼／陷落后%。","桃"
	CALL HEARTCB(0xD02830,3)
	
CASE "报恩"
	PRINTFORM 想要对%CSTR:主人公的称呼／陷落后%回报恩情。

CASE "儿童"
	PRINTFORM 努力帮助%CSTR:主人公的称呼／陷落前%。

CASE "儿童调教后"
	PRINTFORM %CSTR:主人公的称呼／陷落前%怎么会…？
	
ENDSELECT
RESETCOLOR
PRINTL



;場合による変化　ARGS：変更後の目的
@PURPOSE_CHANGE_CALC(ARGS)

SELECTCASE ARGS
CASE "肉体陷落"
	;快楽刻印取得
	SIF CFLAG:家畜 || CFLAG:乳牛 || ＃陷落状态／陷落以上＃
		RETURN
	SIF GROUPMATCH(CSTR:心境,"崩坏","超乳状态","绝望","搾乳家畜","搾乳奴隶")
		RETURN
	CALL PURPOSE_CHANGE(ARGS)

CASE "超乳状态"
	;超乳化
	SIF ＃陷落状态／恋慕以上＃ || CFLAG:乳牛
		RETURN
	SIF GROUPMATCH(CSTR:心境,"崩坏","绝望","搾乳家畜","搾乳奴隶","报恩")
		RETURN
	CALL PURPOSE_CHANGE(ARGS)

CASE "不放弃"
	;反抗0
	SIF GROUPMATCH(CSTR:心境,"崩坏","绝望","肉体陷落","搾乳家畜","搾乳奴隶","报恩")
		RETURN
	IF MARK:恐怖刻印 || MARK:痛苦刻印
		CALL PURPOSE_CHANGE("屈服状态")
		
	ELSEIF CSTR:心境 == "使身体回复原状态"
		CALL PURPOSE_CHANGE("回复身体原状")
	
	ELSE
		CALL PURPOSE_CHANGE(ARGS)
	ENDIF
	
CASE "屈服状态"
	;精神ギリギリ
	SIF CSTR:心境 == ARGS
		RETURN
	SIF GROUPMATCH(CSTR:心境,"崩坏","绝望","肉体陷落","搾乳家畜","搾乳奴隶","报恩")
		RETURN
	CALL PURPOSE_CHANGE(ARGS)

CASE "乳牛"
	IF ＃陷落状态／隶属＃
		IF MARK:搾乳家畜
			CALL PURPOSE_CHANGE("奶牛隶属家畜")
		ELSEIF MARK:搾乳奴隶
			CALL PURPOSE_CHANGE("奶牛隶属奴隶")
		ELSE
			CALL PURPOSE_CHANGE("奶牛隶属")
		ENDIF
	ELSEIF ＃陷落状态／恋慕以上＃
		IF MARK:搾乳家畜
			CALL PURPOSE_CHANGE("奶牛爱慕家畜")
		ELSEIF MARK:搾乳奴隶
			CALL PURPOSE_CHANGE("奶牛恋慕奴隶")
		ELSE
			CALL PURPOSE_CHANGE("乳牛恋慕")
		ENDIF
	ELSE
		IF MARK:搾乳家畜
			CALL PURPOSE_CHANGE("奶牛家畜")
		ELSEIF CFLAG:乳牛
			CALL PURPOSE_CHANGE("奶牛奴隶")
		ELSE
			CALL PURPOSE_CHANGE("乳牛")
		ENDIF
	ENDIF

CASE "搾乳奴隶"
	;搾乳奴隷の刻印
	SIF CFLAG:崩坏
		RETURN
	IF ＃陷落状态／隶属＃
		CALL PURPOSE_CHANGE("奶牛隶属奴隶")
	ELSEIF ＃陷落状态／恋慕以上＃
		CALL PURPOSE_CHANGE("奶牛恋慕奴隶")
	ELSEIF CFLAG:乳牛
		CALL PURPOSE_CHANGE("奶牛奴隶")
	ELSE
		CALL PURPOSE_CHANGE("搾乳奴隶")
	ENDIF

CASE "搾乳家畜"
	;搾乳家畜の刻印
	SIF CFLAG:崩坏
		RETURN
	IF ＃陷落状态／隶属＃
		CALL PURPOSE_CHANGE("奶牛隶属家畜")
	ELSEIF ＃陷落状态／恋慕以上＃
		CALL PURPOSE_CHANGE("奶牛爱慕家畜")
	ELSEIF CFLAG:乳牛
		CALL PURPOSE_CHANGE("奶牛家畜")
	ELSE
		CALL PURPOSE_CHANGE("搾乳家畜")
	ENDIF

CASE "回复身体原状"
	;母乳体質化
	SIF CFLAG:家畜 || CFLAG:乳牛 || ＃陷落状态／屈服以上＃
		RETURN
	SIF GROUPMATCH(CSTR:心境,"回复身体原状","崩坏","绝望","不放弃","肉体陷落","搾乳家畜","搾乳奴隶")
		RETURN
	SIF CSTR:心境 == "使身体回复原状态" && !MARK:绝望刻印
		RETURN
	SIF TALENT:母性本能
		RETURN

	IF TALENT:高傲 || TALENT:自尊心高 || TALENT:坚强 || CSTR:性格 == "强势"
		CALL PURPOSE_CHANGE("使身体回复原状态")
	ELSE
		CALL PURPOSE_CHANGE("回复身体原状")
	ENDIF

CASE "绝望"
	;崩壊から復帰
	IF ＃陷落状态／恋慕以上＃
		CALL PURPOSE_CHANGE("恋慕")
	ELSEIF ＃陷落状态／陷落以上＃
		CALL PURPOSE_CHANGE("屈服状态")
	ELSE
		CALL PURPOSE_CHANGE("绝望")
	ENDIF

CASE "恋慕"
	IF CFLAG:乳牛
		IF MARK:搾乳家畜
			CALL PURPOSE_CHANGE("奶牛爱慕家畜")
		ELSEIF MARK:搾乳奴隶
			CALL PURPOSE_CHANGE("奶牛恋慕奴隶")
		ELSE
			CALL PURPOSE_CHANGE("乳牛恋慕")
		ENDIF
	ELSE
		CALL PURPOSE_CHANGE("恋慕")
	ENDIF

CASE "隶属"
	IF CFLAG:乳牛
		IF MARK:搾乳家畜
			CALL PURPOSE_CHANGE("奶牛隶属家畜")
		ELSEIF MARK:搾乳奴隶
			CALL PURPOSE_CHANGE("奶牛隶属奴隶")
		ELSE
			CALL PURPOSE_CHANGE("奶牛隶属")
		ENDIF
	ELSE
		CALL PURPOSE_CHANGE("隶属")
	ENDIF
	
ENDSELECT


