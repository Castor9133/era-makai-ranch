
;隣接キャラをTARGETに指定し直す
;ARG→後ろ検索
;ARGS→元ページ
@CHANGE_TARGET_CHARA(ARG,ARGS)
#DIMS PLACE
#DIM LOOP_BASE

SELECTCASE ARGS
CASE "主菜单","结算详情"
	;あなた→侍従（拡張予定）→お気に入り→自室→奴隷寮→家畜小屋→体内→牧場外→あなた　の順
	PLACE = %CSTR:住处%
	
	;行動済みは判定だけ事務所に戻す
	SIF PLACE == "行动完毕"
		PLACE = 事务所
	
	;お気に入りの場合は居場所に「お気に入り」上書き→そんな場所はないのでこれでOK
	SIF CFLAG:收藏夹
		PLACE = 收藏夹
	
	;基点はTARGET番号+-1
	IF ARG
		LOOP_BASE = TARGET +1
	ELSE
		LOOP_BASE = TARGET -1
	ENDIF
	CALL CHANGE_TARGET_MAIN_MENU(ARG,LOOP_BASE,PLACE)
	
	;精算詳細の場合は当日に出荷した奴隷だけ
	SIF !CFLAG:母乳出荷金额／当日 && ARGS == "结算详情"
		RESTART

CASE "角色配置","愿望选择"
	IF ARG
		;どこにいるか気にせずに+1
		TARGET ++
		SIF TARGET >= CHARANUM
			TARGET = 0
	ELSE
		;逆順
		TARGET --
		SIF TARGET < 0
			TARGET = CHARANUM -1
	ENDIF

CASE "全奴隶"
	IF ARG
		TARGET ++
		
		;全奴隷はあなたを飛ばす
		SIF TARGET >= CHARANUM
			TARGET = 1
	ELSE
		TARGET --
		SIF TARGET < 1
			TARGET = CHARANUM -1
	ENDIF

CASE "牛舍"
	;牛舎番号保存
	COWSHED_NUM = CFLAG:牛舍号码
	IF ARG
		LOOP_BASE = TARGET +1
	ELSE
		LOOP_BASE = TARGET -1
	ENDIF
	CALL CHANGE_TARGET_COWSHED(ARG,LOOP_BASE)
	
;他は何もしない
ENDSELECT



;メイン画面検索
;ARG→後ろ検索
@CHANGE_TARGET_MAIN_MENU(ARG,LOOP_BASE,PLACE)
#DIMS DYNAMIC PLACE
#DIM DYNAMIC LOOP_BASE

;後ろ検索
IF ARG
	FOR TARGET_COUNT,LOOP_BASE,CHARANUM
		TARGET = TARGET_COUNT
		
		;SHOPは非表示の場合飛ばす
		SIF FLAG:主要／奴隶隐藏 && CFLAG:表示OFF／主要画面
			CONTINUE
		
		;お気に入り検索中の場合だけCFLAGを見るので異なる
		IF PLACE == "收藏夹" && CFLAG:收藏夹
			RETURN
		
		;同じ場所に見つけたらTARGET切り替えしてRETURN
		;お気に入り検索中以外はお気に入り指定中の奴隷は飛ばす
		ELSEIF PLACE == CSTR:住处 && !CFLAG:收藏夹
			RETURN
		
		;行動済みを飛ばさないように対応
		ELSEIF PLACE == "事务所" && CSTR:住处 == "行动完毕" && !CFLAG:收藏夹
			RETURN
		
		ENDIF
	NEXT
	
	;見つからないなら検索場所変更
	SELECTCASE PLACE
	CASE "事务所"
		PLACE = 收藏夹
	CASE "收藏夹"
		PLACE = 自室
	CASE "自室"
		PLACE = 奴隶寮
	CASE "奴隶寮"
		PLACE = 家畜小屋
	CASE "家畜小屋"
		PLACE = 体内
	CASE "体内"
		PLACE = 牧场外
	CASE "牧场外"
		PLACE = 事务所
	ENDSELECT
	
	;場所変更後は基点0に
	LOOP_BASE = 0

;前検索：逆順FORループ
ELSE
	FOR TARGET_COUNT,LOOP_BASE,-1,-1
		TARGET = TARGET_COUNT
		SIF FLAG:主要／奴隶隐藏 && CFLAG:表示OFF／主要画面
			CONTINUE
		IF PLACE == "收藏夹" && CFLAG:收藏夹
			TARGET = TARGET_COUNT
			RETURN
		ELSEIF PLACE == CSTR:住处 && !CFLAG:收藏夹
			TARGET = TARGET_COUNT
			RETURN
		ENDIF
	NEXT
	
	;場所変更も逆順
	SELECTCASE PLACE
	CASE "牧场外"
		PLACE = 体内
	CASE "体内"
		PLACE = 家畜小屋
	CASE "家畜小屋"
		PLACE = 奴隶寮
	CASE "奴隶寮"
		PLACE = 自室
	CASE "自室"
		PLACE = 收藏夹
	CASE "收藏夹"
		PLACE = 事务所
	CASE "事务所"
		PLACE = 牧场外
	ENDSELECT
	
	;基点をCHARANUM -1にする
	LOOP_BASE = CHARANUM -1
ENDIF
RESTART



;牛舎内で検索
@CHANGE_TARGET_COWSHED(ARG,LOOP_BASE)
#DIM DYNAMIC LOOP_BASE

;同じ牛舎内の次のキャラ
IF ARG
	FOR TARGET_COUNT,LOOP_BASE,CHARANUM
		TARGET = TARGET_COUNT
		
		;牛舎番号一致したらTARGET変更
		SIF CFLAG:牛舍号码 != COWSHED_NUM
			CONTINUE
		RETURN
	NEXT
	
	;見つからなければ基点0にして再検索
	LOOP_BASE = 0

;逆順FORループ
ELSE
	FOR TARGET_COUNT,LOOP_BASE,-1,-1
		TARGET = TARGET_COUNT
		SIF CFLAG:牛舍号码 != COWSHED_NUM
			CONTINUE
		RETURN
	NEXT
	
	;基点をCHARANUM -1にする
	LOOP_BASE = CHARANUM -1
ENDIF
RESTART


