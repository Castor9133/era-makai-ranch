
;料理個人設定
@SLAVE_CONFIG_COOKING

CLEARLINE LINECOUNT
CALL SHOW_SLAVE_STATE
PRINTLC [ 0] 即使没有自室也会有相同的晚餐。
CALL PRINT_ONOFF(CFLAG:晚餐许可,1)
PRINTFORMLC [ 1] %SAVESTR:标识／母乳%料理
SELECTCASE CFLAG:母乳料理／委托
CASE -1
	PRINTL ：普通菜单
CASE 0
	PRINTL ：每次选择
CASE 1
	PRINTFORML ：%SAVESTR:标识／母乳%菜单
ENDSELECT
PRINTFORMLC [ 2] %SAVESTR:标识／母乳%料理时的搾乳协助
SELECTCASE CFLAG:母乳料理／搾乳辅助
CASE -1
	PRINTL ：不进行
CASE 0
	PRINTL ：每次选择
CASE 1
	PRINTL ：始终协助
ENDSELECT

CALL PRINTL_ALIGN
DRAWLINE
PRINTL [99] 完成
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	INVERTBIT CFLAG:晚餐许可,0
CASE 1
	PRINTFORML 当您让%CALLNAME:0%准备夕食时，是否选择使用%SAVESTR:标识／母乳%制作的菜单？
	PRINTL
	PRINTLC [ 0] 每次选择
	PRINTFORMLC [ 1] %SAVESTR:标识／母乳%菜单
	PRINTLC [ 2] 常规菜单
	INPUT
	SELECTCASE RESULT
	CASE 0
		CFLAG:母乳料理／委托 = 0
	CASE 1
		CFLAG:母乳料理／委托 = 1
	CASE 2
		CFLAG:母乳料理／委托 = -1
	ENDSELECT
CASE 2
	PRINTFORML 请选择在%SAVESTR:标识／母乳%制作料理时%CALLNAME:0%是否会协助搾乳。
	PRINTL
	PRINTLC [ 0] 每次选择
	PRINTLC [ 1] 协助
	PRINTLC [ 2] 不协助
	INPUT
	SELECTCASE RESULT
	CASE 0
		CFLAG:母乳料理／搾乳辅助 = 0
	CASE 1
		CFLAG:母乳料理／搾乳辅助 = 1
	CASE 2
		CFLAG:母乳料理／搾乳辅助 = -1
	ENDSELECT
CASE 99
	RETURN
ENDSELECT
RESTART


