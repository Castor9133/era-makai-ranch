
;ペニス引き抜き
@COM890

;引き抜く場所でフラグ立て→リセット
SELECTCOM = 890

;BITで合わせたのでそのままコピーでOK
TFLAG:Ｐ解除BIT = TFLAG:Ｐ使用BIT
CALL PENIS_RESET
TRYCALLFORM COM{SELECTCOM}_MESSAGE

;口内に精液ある場合に特定条件で飲み干す
;隷属・精液中毒・恐怖刻印のどれか
IF TFLAG:口内精液
	SIF ＃陷落状态／隶属＃ || ABL:精液中毒 >= 10 || MARK:恐怖刻印
		TFLAG:咽下精液量 ++
ENDIF

;メッセージ表示したら精液溜めのリセット
CALL SEMEN_RESET
TFLAG:Ｐ使用BIT = 0

;SELECTCOMを戻す
SELECTCOM = 0
RETURN 1



;精液溜めのリセット
@SEMEN_RESET

;引き抜きフラグに対応してリセット：触手射精とか追加したときに楽かなと
;TFLAG:Ｐ解除BIT→200
;TFLAG:膣内精液→210
FLAG_REF = 210
FOR LOCAL,0,4
	SIF !GETBIT(TFLAG:Ｐ解除BIT,LOCAL)
		CONTINUE
	TFLAG:(FLAG_REF +LOCAL) = 0
	CLEARBIT TFLAG:Ｐ解除BIT,LOCAL
NEXT



;搾乳器取り外し
@COM891
#DIMS LACTATION_TOOL

;搾乳器名取得
FOR LOCAL,60,70
	SIF !TEQUIP:LOCAL
		CONTINUE
	LACTATION_TOOL = %TEQUIPNAME:LOCAL%
	BREAK
NEXT
SELECTCOM = 891
VARSET TEQUIP,0,60,70
TFLAG:Ｎ装备 = 0
TFLAG:搾乳器 = 0
TRYCALLFORM COM{SELECTCOM}_MESSAGE(LACTATION_TOOL)

;ここは直接呼ぶ必要ある
SIF BASE:母乳容量
	CALL SET_STAIN_TARGET("乳房","母乳")
SELECTCOM = 0
RETURN 1



;搾乳触手外し
@COM892
#DIMS LACTATION_TENTACLE

;搾乳触手名取得
FOR LOCAL,102,105
	SIF !TEQUIP:LOCAL
		CONTINUE
	LACTATION_TENTACLE = %TEQUIPNAME:LOCAL%
	BREAK
NEXT
SELECTCOM = 892
VARSET TEQUIP,0,102,105
TFLAG:Ｎ装备 = 0
TFLAG:搾乳触手 = 0
TRYCALLFORM COM{SELECTCOM}_MESSAGE(LACTATION_TENTACLE)
SIF BASE:母乳容量
	CALL SET_STAIN_TARGET("乳房","母乳")
SELECTCOM = 0
RETURN 1



;胸汚れ拭き取り
@COM893

