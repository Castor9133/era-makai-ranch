			ELSE
				CALL MESSAGE_BOX,@"「哈啊…哈啊… お、おわったか……」"
			ENDIF
		ENDIF
	ENDSELECT
	
CASE "抽出"
	SELECTCASE ARGS:2
	CASE "执行前"
		SELECTCASE ARGS:3
		CASE "初次"
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"「なんだこの機械…？ とりあえず入ればいいのか…？」"
			ELSEIF ＃陷落状态／屈服以上＃
				CALL MESSAGE_BOX,@"「この大げさな機械は……なんか嫌な予感が……」"
