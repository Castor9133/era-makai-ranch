
;ジョブ・身分・所属・種族などの元々を参照
@PRINT_ORIGINAL_AFFILIATION_DATA
#DIMS AFFILIATION

CALL PRINT_TRIVE

;ここで帰る場合
SIF CSTR:初始值／职业 == "" && CSTR:初始值／身分 == "" && CSTR:初始值／所属 == ""
	RETURN

AFFILIATION = 【
EXIST = 0
IF CSTR:初始值／所属 != ""
	AFFILIATION += CSTR:初始值／所属
	EXIST = 1
ENDIF
IF CSTR:初始值／身分 != ""
	AFFILIATION += CSTR:初始值／身分
	EXIST = 1
ENDIF
IF CSTR:初始值／职业 != ""
	SIF EXIST
		AFFILIATION += "・"
	AFFILIATION += CSTR:初始值／职业
ENDIF
AFFILIATION += "】"
PRINTFORM %AFFILIATION%



;元の肩書き
@PRINT_ORIGINAL_SECOND_NAME

IF CSTR:头衔 == CSTR:初始值／头衔
	CALL PRINTL_WORD_COLOR("保持原始头衔　","灰")
ELSE
	PRINTFORML 原始头衔：%CSTR:初始值／头衔%
ENDIF



;元のヘアスタイル　変更してる場合だけ表示
@PRINT_ORIGINAL_HAIR_STYLE

SIF CFLAG:初始值／颜色编码／头发
	SETCOLOR CFLAG:初始值／颜色编码／头发
PRINTFORM 【%CSTR:初始值／发色%%CSTR:初始值／发特征%%CSTR:初始值／发型%】
RESETCOLOR
SIF !(CSTR:发色 == CSTR:初始值／发色 && CSTR:头发特征 == CSTR:初始值／发特征 && CSTR:发型 == CSTR:初始值／发型)
	PRINT <更改>



;元の目の色
@PRINT_ORIGINAL_EYE_COLOR

PRINT 瞳色：
SIF CFLAG:初始值／颜色编码／右眼
	SETCOLOR CFLAG:初始值／颜色编码／右眼
PRINTFORM %CSTR:初始值／右瞳色%

;左が黒の時に対応
SIF CSTR:初始值／左瞳色 != ""
	RESETCOLOR
SIF CFLAG:初始值／颜色编码／左眼
	SETCOLOR CFLAG:初始值／颜色编码／左眼
SIF CSTR:初始值／左瞳色 != ""
	PRINTFORM ／%CSTR:初始值／左瞳色%
RESETCOLOR
IF CSTR:初始值／瞳孔形状 != ""
	SIF CFLAG:初始值／颜色编码／右眼
		SETCOLOR CFLAG:初始值／颜色编码／右眼
	PRINTFORM 【%CSTR:初始值／瞳孔形状%】
ENDIF
SIF CSTR:眼睛特征 != ""
	PRINTFORM 【%CSTR:眼睛特征%】
RESETCOLOR
SIF !(CSTR:右瞳色 == CSTR:初始值／右瞳色 && CSTR:左瞳色 == CSTR:初始值／左瞳色 && CSTR:瞳孔形状 == CSTR:初始值／瞳孔形状)
	PRINT <更改>



;元のおっぱい
@PRINT_ORIGINAL_BUST

IF ABL:胸围大小 == ABL:初始值／胸围大小
	PRINTFORM 胸围大小：%PRINT_BUSTSIZE(ABL:胸围大小)%
ELSE
	PRINTFORM 胸围大小：%PRINT_BUSTSIZE(ABL:初始值／胸围大小)%
	CALL PRINT_BUSTSIZE_SPECIFY(1,1,ABL:初始值／胸围大小)
	PRINTFORM →%PRINT_BUSTSIZE(ABL:胸围大小)%
ENDIF
CALL PRINT_BUST_C(1,1,1)

;バストサイズ不変で弾力が変化ありの場合あるか不明だけど一応
SIF ABL:胸围大小 == ABL:初始值／胸围大小 && CSTR:乳房弹性 != CSTR:初始值／乳弾力
	PRINTFORM %SAVESTR:标识／乳房%弾力：%CSTR:初始值／乳弾力% → %CSTR:乳房弹性% 
SETCOLOR CFLAG:初始值／颜色编码／乳头
PRINTFORM [乳头：%CSTR:初始值／乳头颜色%] 
RESETCOLOR

;カラーコードでは変更してる判定しなくていいかな
SIF CSTR:乳头颜色 != CSTR:初始值／乳头颜色
	PRINT <更改>
PRINTL



;元々のレベル・HPSPEPMP
@PRINT_ORIGINAL_LEVEL_POWER

PRINTFORML 　Lv{MAXBASE:初始值／等级} → {BASE:等级}
PRINTFORML 　HP：{MAXBASE:初始值／体力,4} → {MAXBASE:体力,4} 
PRINTFORML 　SP：{MAXBASE:初始值／气力,4} → {MAXBASE:气力,4} 
PRINTFORML 灵力：%VALUE_DIGIT(MAXBASE:初始值／灵力)% → %VALUE_DIGIT(MAXBASE:灵力)%EP 
PRINTFORML 魔力：%VALUE_DIGIT(MAXBASE:初始值／魔力)% → %VALUE_DIGIT(MAXBASE:魔力)%MP 
