
;現在の陥落状態を表示
;ARG→改行
@PRINT_CAPITULATION(ARG)

IF !BASE:抵抗心
	CALL PRINT_WORD_COLOR,@"抵抗心：%PRINT_PALAM_PERCENT(BASE:抵抗心)%　","黄"
ELSE
	CALL PRINT_WORD_COLOR,@"抵抗心：%PRINT_PALAM_PERCENT(BASE:抵抗心)%　"
ENDIF

IF !BASE:尊严
	CALL PRINT_WORD_COLOR,@"　尊严：%PRINT_PALAM_PERCENT(BASE:尊严)%　","淡蓝色"
ELSE
	CALL PRINT_WORD_COLOR,@"　尊严：%PRINT_PALAM_PERCENT(BASE:尊严)%　"
ENDIF

IF CFLAG:家畜 || CFLAG:乳牛
	CALL PRINTL_WORD_COLOR,@"精神力：%PRINT_PALAM_PERCENT(BASE:精神力)%　","浅蓝色"
ELSEIF BASE:精神力 < BASE_LIMITER_HEAL_MIND
	CALL PRINTL_WORD_COLOR,@"精神力：%PRINT_PALAM_PERCENT(BASE:精神力)%　","红"
ELSE
	CALL PRINTL_WORD_COLOR,@"精神力：%PRINT_PALAM_PERCENT(BASE:精神力)%　"
ENDIF

IF !BASE:厌恶感
	CALL PRINT_WORD_COLOR,@"厌恶感：%PRINT_PALAM_PERCENT(BASE:厌恶感)%　","淡蓝色"
ELSE
	CALL PRINT_WORD_COLOR,@"厌恶感：%PRINT_PALAM_PERCENT(BASE:厌恶感)%　"
ENDIF

IF BASE:好感度 >= BASE_FIRST_MAX
	CALL PRINT_WORD_COLOR,@"好感度：%PRINT_PALAM_PERCENT(BASE:好感度)%　","桃"
ELSE
	CALL PRINT_WORD_COLOR,@"好感度：%PRINT_PALAM_PERCENT(BASE:好感度)%　"
ENDIF

IF !BASE:理性
	CALL PRINT_WORD_COLOR,@"　理性：%PRINT_PALAM_PERCENT(BASE:理性)%　","桃"
ELSE
	CALL PRINT_WORD_COLOR,@"　理性：%PRINT_PALAM_PERCENT(BASE:理性)%　"
ENDIF

IF BASE:乳牛堕落 >= BASE_FIRST_MAX
	CALL PRINTL_WORD_COLOR,@"乳牛堕落：%PRINT_PALAM_PERCENT(BASE:乳牛堕落)%　","桃"
ELSE
	CALL PRINTL_WORD_COLOR,@"乳牛堕落：%PRINT_PALAM_PERCENT(BASE:乳牛堕落)%　"
ENDIF
SIF ARG
	PRINTL



;簡易版
@PRINT_CAPITULATION_SIMPLE

SIF !TARGET
	RETURN
IF BASE:抵抗心 || BASE:尊严
	PRINTFORM 抵抗心：%PRINT_PALAM_PERCENT(BASE:抵抗心)%　
	PRINTFORM 尊严：%PRINT_PALAM_PERCENT(BASE:尊严)%　
	PRINTFORM 厌恶感：%PRINT_PALAM_PERCENT(BASE:厌恶感)%　
	
ELSE
	IF !CFLAG:家畜 && !CFLAG:乳牛
		IF  BASE:精神力 < BASE_LIMITER_HEAL_MIND
			CALL PRINT_WORD_COLOR,@"精神力：%PRINT_PALAM_PERCENT(BASE:精神力)%　","红"
		ELSE
			CALL PRINT_WORD_COLOR,@"精神力：%PRINT_PALAM_PERCENT(BASE:精神力)%　"
		ENDIF
	ENDIF
	IF BASE:厌恶感
		PRINTFORM 厌恶感：%PRINT_PALAM_PERCENT(BASE:厌恶感)%　
	ELSE
		IF BASE:好感度 >= BASE_FIRST_MAX
			CALL PRINT_WORD_COLOR,@"好感度：%PRINT_PALAM_PERCENT(BASE:好感度)%　","桃"
		ELSE
			CALL PRINT_WORD_COLOR,@"好感度：%PRINT_PALAM_PERCENT(BASE:好感度)%　"
		ENDIF
	ENDIF
	IF BASE:理性
		PRINTFORM 理性：%PRINT_PALAM_PERCENT(BASE:理性)%　
	ELSE
		IF BASE:乳牛堕落 >= BASE_FIRST_MAX
			CALL PRINTL_WORD_COLOR,@"乳牛堕落：%PRINT_PALAM_PERCENT(BASE:乳牛堕落)%　","桃"
		ELSE
			CALL PRINTL_WORD_COLOR,@"乳牛堕落：%PRINT_PALAM_PERCENT(BASE:乳牛堕落)%　"
		ENDIF
	ENDIF
ENDIF



;キャラ一覧
@PRINT_CAPITULATION_LIST

SIF !TARGET
	RETURN
IF BASE:抵抗心 || BASE:尊严
	PRINTFORM 抵%PRINT_PALAM_PERCENT(BASE:抵抗心)%　
	PRINTFORM プ%PRINT_PALAM_PERCENT(BASE:尊严)%　
	PRINTFORM 嫌%PRINT_PALAM_PERCENT(BASE:厌恶感)%　
	
ELSE
	IF !CFLAG:家畜 && !CFLAG:乳牛
		IF  BASE:精神力 < BASE_LIMITER_HEAL_MIND
			CALL PRINT_WORD_COLOR,@"精%PRINT_PALAM_PERCENT(BASE:精神力)%　","红"
		ELSE
			CALL PRINT_WORD_COLOR,@"精%PRINT_PALAM_PERCENT(BASE:精神力)%　"
		ENDIF
	ENDIF
	IF BASE:厌恶感
		PRINTFORM 嫌%PRINT_PALAM_PERCENT(BASE:厌恶感)%　
	ELSE
		IF BASE:好感度 >= BASE_FIRST_MAX
			CALL PRINT_WORD_COLOR,@"好%PRINT_PALAM_PERCENT(BASE:好感度)%　","桃"
		ELSE
			CALL PRINT_WORD_COLOR,@"好%PRINT_PALAM_PERCENT(BASE:好感度)%　"
		ENDIF
	ENDIF
	IF BASE:理性
		PRINTFORM 理%PRINT_PALAM_PERCENT(BASE:理性)%　
	ELSE
		IF BASE:乳牛堕落 >= BASE_FIRST_MAX
			CALL PRINT_WORD_COLOR,@"奶%PRINT_PALAM_PERCENT(BASE:乳牛堕落)%　","桃"
		ELSE
			CALL PRINT_WORD_COLOR,@"奶%PRINT_PALAM_PERCENT(BASE:乳牛堕落)%　"
		ENDIF
	ENDIF
ENDIF

