				CALL MESSAGE_BOX,@"「まさか地上の技術が目当てだったのか…？」"
			ELSEIF ABL:药学 >= 4
				CALL MESSAGE_BOX,@"「もしかして%SELF_CALL()%の薬で他のニンゲンが苦しむんじゃ…？」"
			ELSE
				CALL MESSAGE_BOX,@"「さっきの惨状……已经忘れたのか…？」"
				CALL MESSAGE_BOX,@"「また調合かよ……今度こそ死人が出るだろうな」"
			ENDIF
		ENDIF
	ENDSELECT

CASE "搾乳"
	SELECTCASE ARGS:2
	CASE "执行前"
		SELECTCASE ARGS:3
		CASE "初次"
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「はーっ♥ はーっ♥ 搾乳されたい…♥ 已经待ちきれない…♥♥」"
			ELSEIF ＃陷落状态／隶属＃ || CFLAG:洗脑
