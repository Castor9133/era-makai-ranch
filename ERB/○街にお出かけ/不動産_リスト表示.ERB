
;不動産リスト
@ESTATE_LIST

;他の店とは違い一括判定しづらいので個別に
FOR LOCAL,10,11 +ESTATE_LIST_NUM
	CALL ESTATE_LIST_COLOR(LOCAL)
	CALL ESTATE_LIST_PART(LOCAL)
	RESETCOLOR
NEXT
PRINTL



;色変更するかの個別判定
;ARG→選択肢番号
@ESTATE_LIST_COLOR(ARG)
#DIM COLOR_SET

COLOR_SET = 0
SELECTCASE ARG
CASE 10
	SIF ITEM:牛舍 >= ESTATE_COWSHED_LIMIT || CAN_LOAN_MONEY +MONEY < ITEMPRICE:牛舍
		COLOR_SET ++
CASE 11
	SIF !ITEM:牛舍 || CAN_LOAN_MONEY +MONEY < ESTATE_COWSHED_EXTENSION
		COLOR_SET ++
CASE 12
	SIF ITEM:事务所扩建 >= ESTATE_OFFICE_LIMIT || CAN_LOAN_MONEY +MONEY < ITEMPRICE:事务所扩建
		COLOR_SET ++
CASE 13
	SIF ITEM:家庭浴池 || CAN_LOAN_MONEY +MONEY < ITEMPRICE:家庭浴池 || !ITEM:事务所扩建
		COLOR_SET ++
CASE 14
	SIF ITEM:大浴场 || CAN_LOAN_MONEY +MONEY < ITEMPRICE:大浴场 || !ITEM:家庭浴池
		COLOR_SET ++
CASE 15
	SIF ITEM:宠物小屋 >= ESTATE_PETHOUSE_LIMIT || CAN_LOAN_MONEY +MONEY < ITEMPRICE:宠物小屋 || !ITEM:事务所扩建
		COLOR_SET ++
CASE 16
	SIF ITEM:奴隶寮 || CAN_LOAN_MONEY +MONEY < ITEMPRICE:奴隶寮 || !ITEM:事务所扩建
		COLOR_SET ++
CASE 17
	;元が建ってないとダメ
	;10回くらいにしとく
	SIF !ITEM:奴隶寮 || ITEM:奴隶寮扩建 >= ESTATE_DORMITORY_LIMIT || CAN_LOAN_MONEY +MONEY < ITEMPRICE:奴隶寮扩建
		COLOR_SET ++
CASE 18
	SIF ITEM:系统化厨房 || CAN_LOAN_MONEY +MONEY < ITEMPRICE:系统化厨房 || !ITEM:事务所扩建
		COLOR_SET ++
	
ENDSELECT
SIF COLOR_SET
	SETCOLOR 0x606060



;選択肢表示
;ARG→選択肢番号
@ESTATE_LIST_PART(ARG)

SELECTCASE ARG
CASE 10
	PRINTLC [10] 新牛舍建造
CASE 11
	PRINTLC [11] 牛舍的扩建
CASE 12
	PRINTLC [12] 事务所的扩建
CASE 13
	PRINTLC [13] 改建成家庭浴室
CASE 14
	PRINTLC [14] 大浴场建造
CASE 15
	PRINTLC [15] 宠物小屋的扩建
CASE 16
	PRINTLC [16] 奴隶寮的建造
CASE 17
	PRINTLC [17] 奴隶寮的扩建
CASE 18
	PRINTLC [18] 系统化厨房改造
ENDSELECT
RESETCOLOR




