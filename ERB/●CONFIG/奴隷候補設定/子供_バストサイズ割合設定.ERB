
;子供バストサイズ割合設定
@TENDENCY_CONFIG_CHILD_BUST

;FLAG:子供候補割合／バストサイズ／絶壁→3200
FLAG_REF = 3200
STR_REF = 6550
FLAG:(FLAG_REF +9) = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +9)
CLEARLINE LINECOUNT
PRINTL 请设置儿童待遇的人类的胸围比例。
CALL CONFIG_CHANGE_FLAG_CHECK
CALL CHILD_HEIGHT_RANGE
CALL PRINT_TENDENCY_BUTTON
CALL PRINTL_ALIGN(-10)
PRINTL [90] 与成人保持相同比例
CALL TENDENCY_CONFIG_FOOTER
CALL TENDENCY_INPUT
SELECTCASE RESULT
CASE 90
	PRINTL 是否从「成人的胸围比例」复制比例？
	CALL ASK_YN
	IF !RESULT
		;FLAG:候補割合／バストサイズ／絶壁→3110,-90
		FOR LOCAL,0,10
			FLAG:(FLAG_REF +LOCAL) = FLAG:(FLAG_REF +LOCAL -90)
		NEXT
	ENDIF

CASE 98
	PRINTL 将胸围大小比例回复为默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TENDENCY_CONFIG_CHILD_BUST
CASE 99
	RETURN
ENDSELECT
RESTART


