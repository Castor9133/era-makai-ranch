CASE "奶牛隶属"
	CALL PRINT_WORD_COLOR,@"%CSTR:主人公的称呼／陷落后%心灵、身体和%SAVESTR:标识／母乳%都将奉献给您，%CSTR:第一人称%的全部。","桃"
	CALL HEARTCB(0xD02830)
	
CASE "奶牛爱慕家畜","奶牛隶属奴隶"
	CALL PRINT_WORD_COLOR,@"%CSTR:第一人称%是为了被%SAVESTR:标识／母乳%搾取而生。","桃"
