
;ペット性別表示
;ARG→性別
;ARG:1→改行
@PRINT_PET_GENDER(ARG,ARG:1)

IF ARG
	CALL PRINT_WORD_COLOR("♂ ","浅蓝色")
ELSE
	CALL PRINT_WORD_COLOR("♀ ","桃")
ENDIF
SIF ARG:1
	PRINTL



;ペット体型表示
;ARGS→種族名
;ARG→バー表示
;ARG:1→改行
@PRINT_PET_SHAPE(ARGS,ARG,ARG:1)

FLAG_NAME = 体型／%ARGS%
SELECTCASE FLAG:FLAG_NAME
CASE 0 TO 499
	CALL PRINT_WORD_COLOR("【过于瘦】 ","黄")
CASE 500 TO 1999
	CALL PRINT_WORD_COLOR("【稍显瘦】 ","黄")
CASE 2000 TO 2999
	PRINT 【苗条】
CASE 3000 TO 3999
	PRINT 【细身】
CASE 4000 TO 5999
	CALL PRINT_WORD_COLOR("【适中体重】 ","浅蓝色")
CASE 6000 TO 6999
	PRINT 【较大】
CASE 7000 TO 7999
	PRINT 【丰满】
CASE 8000 TO 9499
	CALL PRINT_WORD_COLOR("【稍显胖】 ","黄")
CASE 9500 TO 10000
	CALL PRINT_WORD_COLOR("【肥胖】 ","黄")
ENDSELECT
SIF ARG
	CALL PRINT_COLORBAR(FLAG:FLAG_NAME,ANIMAL_WEIGHT_MAX,8,BARCOLORSET("青绿"),RESULT:1)
SIF ARG:1
	PRINTL





