
;カスタムスケジュール管理
@AUTO_SCHEDULE_CUSTOM

CLEARLINE LINECOUNT
CALL SHOW_STATUS_SIMPLE
CALL HALFLINE
PRINTFORML 请设定%CALLNAME%的自定义日程。

;CSTR:自動スケジュール／カスタムＡ／朝→360
CSTR_REF = 360
FOR LOCAL,0,9
	SELECTCASE LOCAL
	CASE 0
		PRINTL 【自定义Ａ】
	CASE 3
		PRINTL
		PRINTL 【自定义Ｂ】
	CASE 6
		PRINTL
		PRINTL 【自定义Ｃ】
	ENDSELECT
	PRINTFORM [{LOCAL,2}] 
	SELECTCASE LOCAL %3
	CASE 0
		PRINT 朝：
	CASE 1
		PRINT 昼：
	CASE 2
		PRINT 夕：
	ENDSELECT
	PRINTFORM %CSTR:(CSTR_REF +LOCAL),15,LEFT%　
NEXT
CALL MANYL(2)
IF !TARGET
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%无法自动安排调教。","灰"
ELSE
	CALL AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_ID(0)
	CALL AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_ID(1)
	CALL AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_ID(2)
ENDIF
CALL PRINTL_ALIGN
DRAWLINE
PRINTLC [90] 回复默认值
PRINTLC 　
PRINTLC [99] 完成
BINPUT
SELECTCASE RESULT
CASE 0 TO 9
	CALL AUTO_SCHEDULE_CUSTOM_SELECT(RESULT)
CASE 10 TO 12
	SAVE_TARGET = TARGET
	CALL AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_SELECT(RESULT -10)
	TARGET = SAVE_TARGET
CASE 90
	;CSTR_REF = 360
	PRINTL 是否将所有自定义日程恢复为【自由】？
	CALL ASK_YN
	SIF !RESULT
		VARSET CSTR,"自由",CSTR_REF,CSTR_REF +9
CASE 99
	RETURN
ENDSELECT
RESTART



;調教対象IDから名前表示
@AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_ID(ARG)
#DIMS PATTERN

SELECTCASE ARG
CASE 0
	PATTERN = Ａ
CASE 1
	PATTERN = Ｂ
CASE 2
	PATTERN = Ｃ
ENDSELECT

;CFLAG:自動スケジュール／調教対象ID／Ａ→520
;IDのキャラを探す
FINDCHARA CFLAG:ID,CFLAG:(520 +ARG)
IF RESULT <= 0
	PRINTFORMLC [{10 +ARG}] 调教对象%PATTERN%：未设定
ELSE
	PRINTFORMLC [{10 +ARG}] 调教对象%PATTERN%：%CALLNAME:RESULT%
ENDIF



;カスタム中身の選択
;ARG→INPUT
@AUTO_SCHEDULE_CUSTOM_SELECT(ARG)

;STR:スケジュール→3960
STR_REF = 3960
CALL MANYL(3)
PRINTL 请选择日程。
FOR LOCAL,0,20
	STR_NAME = %STR:(STR_REF +LOCAL)%
	SIF STR_NAME == ""
		CONTINUE
	
	;可能か判定　恋慕以上かあなた前提になってる
	SELECTCASE STR_NAME
	
	;あなたのみ+マイルストーン
	CASE "训练"
		CALL MILESTONE_UNLOCK_CHECK("自己战斗","")
		SIF !RESULT || TARGET
			CONTINUE
	
	;上+朝はダメ
	CASE "图书馆"
		CALL MILESTONE_UNLOCK_CHECK("禁忌魔法","")
		SIF !RESULT || TARGET || ARG %3 == 0
			CONTINUE
	CASE "调教／对象A","调教／对象B","调教／对象C"
		SIF !TARGET
			CONTINUE
	CASE "搾乳"
		SIF !MARK:母乳体质
			CONTINUE
	CASE "抽出"
		SIF !MARK:母乳体质 || (!BASE:灵力 && !MARK:魔力母乳体质) || !ITEM:灵力抽出装置
			CONTINUE
	CASE "调剂"
		CALL MILESTONE_UNLOCK_CHECK("调合","")
		SIF !RESULT
			CONTINUE
	ENDSELECT
	PRINTFORMLC [{LOCAL,2}] %STR_NAME%
NEXT
PRINTL
PRINTL [99] 取消
BINPUT
SIF RESULT != 99
	CSTR:(CSTR_REF +ARG) = %STR:(STR_REF +RESULT)%


