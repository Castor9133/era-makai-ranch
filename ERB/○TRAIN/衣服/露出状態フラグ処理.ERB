
;脱衣時のフラグ上書き、地の文
@AJUST_STRIP_FLAG

;地の文、口上を表示するフラグはSOURCE:脱衣メッセージ表示で判定する
CALL TRAIN_CLOTHE_STRIP_SENTENCE_FLAG

;衣服を再度着せる場合もあるのでここでTFLAGの140～154をリセット
VARSET TFLAG,0,140,155

;衣服なし扱いの場合そのまま露出判定へ
IF TFLAG:临时脱衣／衣服 || !EQUIP:装备中ID／衣服 || ＃穿着衣服／名称＃ == "反向兔女郎装"
	CALL AJUST_STRIP_FLAG_LINGERIE_BUST
	CALL AJUST_STRIP_FLAG_LINGERIE_VAGINA

;衣服による露出度の判定
ELSE
	;おっぱい露出判定　破け時、半脱ぎ時、そもそも丸出しは下着で判定
	IF ＃穿着衣服／胸部撕裂＃ || GETBIT(＃半脱／衣服上＃) || ＃穿着衣服／乳房露出＃
		CALL AJUST_STRIP_FLAG_LINGERIE_BUST
	ELSE
		CALL AJUST_STRIP_FLAG_CLOTHE_BUST
	ENDIF
	IF ＃穿着衣服／私处撕裂＃ || GETBIT(＃半脱／衣服下＃) || ＃穿着衣服／私处露出＃
		CALL AJUST_STRIP_FLAG_LINGERIE_VAGINA
	ELSE
		CALL AJUST_STRIP_FLAG_CLOTHE_VAGINA
	ENDIF
ENDIF

;上着での露出上書き
CALL AJUST_STRIP_FLAG_JACKET

;着衣パイズリ対応衣服判定
CALL WEAR_PAIZURI_CHECK

;フラグ被り防止
CALL STRIP_FLAG_FIX

;露出地の文表示フラグによる表示
CALL TRAIN_CLOTHE_STRIP_SENTENCE

;露出フラグにより経験追加
CALL ADD_STRIP_EXP



;衣服着衣時のおっぱい露出度判定
@AJUST_STRIP_FLAG_CLOTHE_BUST

;改造している場合それに準ずる
;乳出しだとここ来ないで下着で判定するよ
;乳暖簾→Ｂ露出になってあとで[横乳露出]消すので不要
SIF ＃穿着衣服／侧乳露出＃
	TFLAG:侧乳露出 = 1

;[谷間露出]を作る
SIF ＃穿着衣服／乳沟露出＃
	TFLAG:露出乳沟 = 1

;乳暖簾のときＢ露出
IF ＃穿着衣服／乳暖簾＃
	TFLAG:Ｂ露出 = 1
	TFLAG:乳暖簾 = 1
ENDIF

;乳出し衣服はここに来ないはず
;Ｂ露出かつ通常下着不可
SIF GROUPMATCH(＃穿着内衣上装／名称＃,"舞女的服装","淫乱巫女服","淫乱修女服","淫乱女仆装","淫乱旗袍","淫乱礼服")
	TFLAG:Ｂ露出 = 1

;衣服が授乳スリットで下着ないか授乳スリットブラなら対応
IF ＃穿戴服装／授乳开口＃
	;開いている場合Ｎ露出
	SIF TFLAG:授乳开口开放
		TFLAG:Ｎ露出 = 1
	SIF !EQUIP:装备中ID／内衣上装
		TFLAG:授乳开口 = 1
	
	SELECTCASE ＃穿着内衣上装／名称＃
	CASE "授乳开口胸罩"
		TFLAG:授乳开口 = 1
	CASE "乳头露出胸罩"
		TFLAG:Ｎ露出 = 1
	ENDSELECT
ENDIF



;大きめの上着なら露出度上書き
@AJUST_STRIP_FLAG_JACKET

SIF TFLAG:临时脱衣／外衣
	RETURN
SELECTCASE ＃穿着外衣／名称＃
CASE "连体背带裤"
	TFLAG:Ａ露出 = 0
	TFLAG:Ｃ露出 = 0
	TFLAG:Ｖ露出 = 0
	
	;半脱ぎなら下半身上書きまで
	SIF GETBIT(＃半脱／外衣＃)
		RETURN
	TFLAG:授乳开口 = 0
	TFLAG:乳暖簾 = 0
	TFLAG:Ｎ露出 = 0
	IF TFLAG:Ｂ露出
		TFLAG:侧乳露出 = 1
		TFLAG:露出乳沟 = 1
		TFLAG:Ｂ露出 = 0
	ENDIF

CASE "围裙装"
	SIF GETBIT(＃半脱／外衣＃)
		RETURN
	TFLAG:授乳开口 = 0
	TFLAG:乳暖簾 = 0
	TFLAG:Ｎ露出 = 0
	IF TFLAG:Ｂ露出
		TFLAG:侧乳露出 = 1
		TFLAG:露出乳沟 = 1
		TFLAG:Ｂ露出 = 0
	ENDIF

ENDSELECT



;衣服にズリ穴がある場合の着衣パイズリ判定
;谷間露出・乳暖簾・乳出しの場合もON
@WEAR_PAIZURI_CHECK

IF ＃穿着衣服／乳沟穴＃ || ＃穿着衣服／乳沟露出＃ || ＃穿着衣服／乳暖簾＃
	SIF !EQUIP:装备中ID／内衣上装
		TFLAG:穿衣乳交可能 = 1
	{
	SIF GROUPMATCH(＃穿着内衣上装／名称＃,"猫娘胸罩","乳贴","微型比基尼","乳牛微型比基尼","牛柄洞口比基尼","绳",
	"比基尼","细带胸罩","眼罩胸罩","弹弓比基尼","牛纹弹弓比基尼")
	}
		TFLAG:穿衣乳交可能 = 1
ENDIF





;衣服着衣時の下半身露出判定
@AJUST_STRIP_FLAG_CLOTHE_VAGINA

;前掛けくらいしかなくなった
SIF ＃穿着衣服／围裙＃
	TFLAG:围裙 = 1



;下着でのおっぱい露出判定
@AJUST_STRIP_FLAG_LINGERIE_BUST

;ノーブラ時は露出
IF !EQUIP:装备中ID／内衣上装 || GETBIT(＃半脱／内衣上装＃) || TFLAG:临时脱衣／内衣上装
	TFLAG:Ｂ露出 = 1
	TFLAG:Ｎ露出 = 1
	RETURN
ENDIF

;ブラ種類による分岐
SELECTCASE ＃穿着内衣上装／名称＃
CASE "授乳开口胸罩"
	TFLAG:授乳开口 = 1
	
	;開いている場合Ｎ露出
	SIF TFLAG:授乳开口开放
		TFLAG:Ｎ露出 = 1

CASE "乳头露出胸罩"
	TFLAG:Ｎ露出 = 1

CASE "乳贴","微型比基尼","乳牛微型比基尼","绳","眼罩胸罩","弹弓比基尼","乳头牌","牛纹弹弓比基尼"
	TFLAG:Ｂ露出 = 1

CASE "牛柄洞口比基尼"
	TFLAG:Ｎ露出 = 1
	TFLAG:Ｂ露出 = 1
ENDSELECT



;下着での下半身露出判定
@AJUST_STRIP_FLAG_LINGERIE_VAGINA

;ノーパン時は露出
IF !EQUIP:装备中ID／内衣下装 || GETBIT(＃半脱／内衣下装＃) || TFLAG:临时脱衣／内衣下装
	TFLAG:Ａ露出 = 1
	TFLAG:Ｃ露出 = 1
	TFLAG:Ｖ露出 = 1
	RETURN
ENDIF

;ショーツ種類による分岐
SELECTCASE ＃穿着内衣下装／名称＃
CASE "局部露出内裤","牛柄洞口比基尼"
	TFLAG:Ａ露出 = 1
	TFLAG:Ｃ露出 = 1
	TFLAG:Ｖ露出 = 1
CASE "私处贴纸","胯部牌"
	TFLAG:Ａ露出 = 1
ENDSELECT



;フラグ被り防止
@STRIP_FLAG_FIX

;Ｂ露出のときフラグ被り防止
IF TFLAG:Ｂ露出
	TFLAG:侧乳露出 = 0
	TFLAG:露出乳沟 = 0
	TFLAG:穿衣乳交可能 = 0
ENDIF

;Ｎ露出も同様
IF TFLAG:Ｎ露出
	TFLAG:授乳开口 = 0
	TFLAG:乳暖簾 = 0
ENDIF

;Ｖだけ判断でOK
SIF TFLAG:Ｖ露出
	TFLAG:围裙 = 0

;元々着ていない場合半脱ぎ、一時的脱衣フラグはOFF
IF !EQUIP:装备中ID／衣服
	TFLAG:临时脱衣／衣服 = 0
	CLEARBIT ＃半脱／衣服上＃
	CLEARBIT ＃半脱／衣服下＃
ENDIF
IF !EQUIP:装备中ID／内衣上装
	TFLAG:临时脱衣／内衣上装 = 0
	CLEARBIT ＃半脱／内衣上装＃
ENDIF
IF !EQUIP:装备中ID／内衣下装
	TFLAG:临时脱衣／内衣下装 = 0
	CLEARBIT ＃半脱／内衣下装＃
ENDIF
IF !EQUIP:装备中ID／外衣
	TFLAG:临时脱衣／外衣 = 0
	CLEARBIT ＃半脱／外衣＃
ENDIF



;露出フラグにより経験追加
@ADD_STRIP_EXP

;全裸になった場合あなたに裸を見られた経験を追加
;TFLAG:140～144が露出フラグ,最小値を取って1なら全部位露出
SIF MINARRAY(TFLAG,140,145)
	EXP:被看见全裸 ++
SIF TFLAG:Ｂ露出
	EXP:乳房被看见 ++
SIF TFLAG:Ｎ露出
	EXP:被看见乳头 ++
SIF TFLAG:Ｃ露出
	EXP:被看见阴蒂 ++
SIF TFLAG:Ｖ露出
	EXP:膣被看见 ++
SIF TFLAG:Ａ露出
	EXP:肛门被看见 ++

