
;ペット名など変更
@DEBUG_PET_NAME_EDIT

;ペット関係のフラグ番号一斉取得
CALL GET_PET_FLAG_REF
CLEARLINE LINECOUNT
CALL RANCH_STATUS_PET
PRINTL
FOR LOCAL,0,10
	SIF !ITEM:ITEM_REF
		CONTINUE
	PRINTFORML [{LOCAL,2}] %ITEMNAME:(LOCAL +ITEM_REF)%
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTL [99] 完成
INPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 9
	CALL DEBUG_PET_NAME_EDIT_MENU(RESULT)
CASE 99
	RETURN
ENDSELECT
RESTART



;ペット選択後
;ARG→INPUT
@DEBUG_PET_NAME_EDIT_MENU(ARG)

ANIMAL = %ITEMNAME:(ARG +ITEM_REF)%
PET_NAME = %PET_NAME_REF(ANIMAL)%
SIF PET_NAME == ""
	RETURN
PRINTFORML 请为%PET_NAME%选择要修改的内容。
PRINTFORML [ 0] 　名称：%SAVESTR:(ARG +STR_REF)%
PRINTFORML [ 1] 毛发：%SAVESTR:(ARG +STR_REF:1)%
PRINTFORML [ 2] 　花纹：%SAVESTR:(ARG +STR_REF:2)%
PRINT [ 3] 　性别：
CALL PRINT_PET_GENDER(FLAG:(FLAG_REF +ARG),1)
PRINT [ 4] 　体型：
CALL PRINT_PET_SHAPE(ANIMAL,1,1)
PRINTL [ 5] 对各个角色的亲近度
SIF ANIMAL == "双头犬"
	PRINTL [ 6] ＜双头犬＞限定：更改命名方式／更改连接词和名称。
PRINTL
PRINTL [99] 完成
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	PRINTL 请输入名称。
	INPUTS
	SIF RESULTS != ""
		SAVESTR:(ARG +STR_REF) = %RESULTS%
CASE 1
	PRINTL 请输入毛发。
	INPUTS
	SIF RESULTS != ""
		SAVESTR:(ARG +STR_REF:1) = %RESULTS%
CASE 2
	PRINTL 请输入花纹。
	INPUTS
	SIF RESULTS != ""
		SAVESTR:(ARG +STR_REF:2) = %RESULTS%
CASE 3
	INVERTBIT FLAG:(FLAG_REF +ARG),0
	PRINTW 翻转了性别。
CASE 4
	FLAG_NAME = 体型／%ANIMAL%
	PRINTFORML 请输入介于0到{ANIMAL_WEIGHT_MAX}之间的类型值。（当前值：{FLAG:FLAG_NAME}）
	INPUT
	SIF RESULT >= 0 && RESULT <= ANIMAL_WEIGHT_MAX
		FLAG:FLAG_NAME = RESULT
CASE 5
	CALL DEBUG_PET_NAME_EDIT_FRIENDRY(ARG)
CASE 6
	SIF ANIMAL != "双头犬"
		RETURN
	PRINTL 请选择命名方法。
	PRINTLC [ 0] 起一个名字
	PRINTLC [ 1] 给左右头分别起个名儿
	PRINTL [99] 取消
	INPUT
	SELECTCASE RESULT
	CASE 0
		PRINTL 请输入名称。
		INPUTS
		IF RESULTS != ""
			SAVESTR:名称／双头犬 = %RESULTS%
			SAVESTR:名称／双头犬／弟妹 =
			SAVESTR:名称／双头犬／连接词 =
		ENDIF
	CASE 1
		PRINTL 请输入哥哥／姐姐的名字。
		INPUTS
		SIF RESULTS == ""
			RETURN
		SAVESTR:名称／双头犬 = %RESULTS%
		PRINTL
		PRINTL 请输入地文・标识上的连接词。
		CALL PRINTL_WORD_COLOR("半角的「&」可能会引发bug，因此建议避免使用。","黄")
		INPUTS
		SIF RESULTS == ""
			RETURN
		SAVESTR:名称／双头犬／连接词 = %RESULTS%
		PRINTL
		PRINTL 请输入弟弟／妹妹的名字。
		INPUTS
		SAVESTR:名称／双头犬／弟妹 = %RESULTS%
	ENDSELECT
ENDSELECT



;なつき度デバッグ
;PET_NAME指定済み
;ARG→INPUT
@DEBUG_PET_NAME_EDIT_FRIENDRY(ARG)
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML 请选择要更改%PET_NAME%的亲和度的角色。
FOR TARGET_COUNT,0,20
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	PRINTFORML [{TARGET +100}] %CALLNAME_DIGIT()%：{BASE:(BASE_REF +ARG) /100,3}\%
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTL [ 99] 取消
BINPUT
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	TARGET = RESULT -100
	{
	PRINTFORML %CALLNAME%对%PET_NAME%的亲和度为0～{MAXBASE:(BASE_REF +ARG)}请输入。
	（当前值：{BASE:(BASE_REF +ARG)}）
	}
	INPUT
	SIF RESULT >= 0 && RESULT <= MAXBASE:(BASE_REF +ARG)
		BASE:(BASE_REF +ARG) = RESULT
ENDSELECT
RESTART




