
;街での行動
@TOWN

;店から戻ったら毎回リセット
FLAG:１个限定物品 = 0
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP
SELECT_ITEM = 0
CALL MILESTONE_UNLOCK_CHECK("奴隶捕获","L")
SIF RESULT
	PRINTL [ 0] 魔族行会（目标角色的设定）
CALL MILESTONE_UNLOCK_CHECK("魔王军研究所","L")
SIF RESULT
	PRINTL [ 1] 魔王军研究所

;Lvで目安になるので表示変え
CALL MILESTONE_UNLOCK_CHECK("成人商店","")
IF !RESULT
	CALL PRINTL_WORD_COLOR("　冈地街Lv1","灰")
ELSE
	PRINTL [ 2] 成人商店
ENDIF
PRINTL [ 3] 家居中心
CALL MILESTONE_UNLOCK_CHECK("不动产","L")
SIF RESULT
	PRINTL [ 4] 不动产
PRINTL [ 5] 和服屋

CALL MILESTONE_UNLOCK_CHECK("家具店","")
IF !RESULT
	CALL PRINTL_WORD_COLOR("　冈地街Lv3","灰")
ELSE
	PRINTL [ 6] 家具店
ENDIF
PRINTL [ 7] 宠物商店
PRINTL [ 8] 魔界农协・冈地街分店
CALL PRINTL_ALIGN(-5)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(1,"牧場に戻る")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL TOWN_HALL
CASE 1
	CALL TOWN_INSTITUTE
CASE 2
	CALL ITEM_SHOP_ADULT
CASE 3
	CALL ITEM_SHOP_WORK
CASE 4
	CALL ITEM_SHOP_ESTATE
CASE 5
	CALL ITEM_SHOP_CLOTHE
CASE 6
	CALL ITEM_SHOP_FURNITURE
CASE 7
	CALL ITEM_SHOP_PET
CASE 8
	CALL TOWN_AGRI_COOP
CASE 98
	CALL BROWSE_HINT("街口")
CASE 99
	;個人用転移門以外で外出していたら予定を行動済みに変更
	SIF FLAG:已外出 != 20
		CSTR:0:日程 = 行动完毕
	CALL SCHEDULE_ADJUST
	RETURN
ENDSELECT
RESTART



