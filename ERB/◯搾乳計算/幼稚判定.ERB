
;幼稚乳吸いの母性処理
@CHILDISH_FIX_CHECK

;幼稚補正が入ってる、PLAYERが-1、乳吸いではない→おわり
SIF TFLAG:幼稚母性补正 || PLAYER < 0 || !TFLAG:吸奶
	RETURN

TFLAG:幼稚母性补正 = 0

;低身長以下かつ10cm以上低い、または【幼稚】で補正発生
;幼稚関係ないけど実の娘なら補正あり
IF CFLAG:PLAYER:母亲ID == CFLAG:ID && CFLAG:PLAYER:母亲ID != 0
	CALL PRINT_WORD_COLOR,@"%CALLNAME:PLAYER%吸着亲生女儿的%SAVESTR:标识／乳房%，刺激了%CALLNAME%的母性…","桃"
	SETBIT TFLAG:幼稚母性补正,2
ENDIF

;身長差による判定へ、外見年齢が14以下(ショタあなた判定)であることを追加。
IF CFLAG:PLAYER:身高 <= HEIGHT_MAX_矮小 && CFLAG:PLAYER:身高 < (CFLAG:身高 -100) && CFLAG:PLAYER:外表年龄 <= VISUAL_AGE_CHILD_MAX
	SIF !TFLAG:幼稚母性补正
		CALL PRINT_WORD_COLOR,@"%CALLNAME:PLAYER%吸着小的%SAVESTR:标识／乳房%，刺激了%CALLNAME%的母性…","桃"
	SETBIT TFLAG:幼稚母性补正,0
ENDIF

;幼稚なら判定あり
IF TALENT:PLAYER:幼稚
	SIF !TFLAG:幼稚母性补正
		CALL PRINT_WORD_COLOR,@"%CALLNAME:PLAYER%吸着幼小的%SAVESTR:标识／乳房%，刺激了%CALLNAME%的母性…","桃"
	SETBIT TFLAG:幼稚母性补正,1
ENDIF
IF !TFLAG:幼稚母性补正
	;二回目以降スルーする用に
	TFLAG:幼稚母性补正 = -1
	RETURN
ENDIF
CALL HEARTCB(0xD02830)
PRINTL
