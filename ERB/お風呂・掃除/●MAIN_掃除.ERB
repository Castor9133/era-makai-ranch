
;掃除
@MAIN_CLEANING
#DIM DUTY

;掃除当番指定
CALL CLEANING_DUTY_SELECT
DUTY = RESULT

;指定しない場合適当に済ませておわり
IF DUTY < 0
	PRINTL 　　　《 清洁 》
	PRINTW 今天决定偷懒不打扫。
	RETURN
ENDIF
TARGET = DUTY

;EXP入れするときのバグ防止
FLAG:工作ABL最大值 = ABL:清洁
PRINTL 　　　《 清洁 》

IF !EXP:执行次数／清洁
	KOJO_TYPE = 初次
ELSE
	KOJO_TYPE = 普通
ENDIF
CALL WORK_CLEANING_BEGIN_MESSAGE
CALL WORK_CLEANING_ABL_MESSAGE

;掃除したキャラの体力減少+経験値増加
CALL CLEANING_WORK
PRINTW
DRAWLINE



;掃除したキャラの体力減少+経験値増加
@CLEANING_WORK
#DIM CLEANING_ROOM

;消費体力：50 +調教可能なキャラの数*5 -掃除Lv *10(30～300)
;0になってもできることにしとく
CLEANING_ROOM = 0
SAVE_TARGET = TARGET
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF !CFLAG:日程设定可能／调教
		CONTINUE
	CLEANING_ROOM ++
NEXT
TARGET = SAVE_TARGET
COST = LIMIT(50 +CLEANING_ROOM *5 -ABL:清洁 *10,30,300)
PRINTFORM %CALLNAME%：
CALL HP_COST(COST)
CALL EXP_UP("清洁")
CALL SCHEDULE_AFTER_CATTLE_MIND_MINUS
CALL MIND_PALAM_AFTER_PRINT(1)
CALL ABL_UP
PRINTL
EXP:执行次数／清洁 ++
EXP:区间执行次数／清洁 ++
FLAG:主人公的浴池清洁完毕 = 1
CALL WORK_CLEANING_COMPLETE_MESSAGE






