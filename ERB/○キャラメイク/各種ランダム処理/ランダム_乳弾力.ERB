
;奴隷候補のおっぱい弾力
@RANDOM_SLAVE_BUST_FEELING

LAST_SHUFFLE_S = %CSTR:乳房弹性%
STR_REF = 1300
STR_MAX = 30

;貧乳以下か大きいかで分ける
IF ABL:胸围大小 < BUSTSIZE_普乳
	CALL STR_REF_SHUFFLE(STR_REF)
ELSE
	CALL STR_REF_SHUFFLE(STR_REF +50)
ENDIF
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE_S == RESULTS
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0
CSTR:乳房弹性 = %RESULTS%

