
;ペット小屋の空きがあるか見る
@PET_HOUSE_BLANC_CHECK
#DIM USING_PET_HOUSE

;ペット小屋必要なペットがいるなら+1していく
;ITEM:堕天馬→100
USING_PET_HOUSE = 0
FOR LOCAL,100,110
	SIF ITEM:LOCAL
		USING_PET_HOUSE ++
NEXT

;フラグに入れておわり
FLAG:空闲宠物小屋数 = ITEM:宠物小屋 -USING_PET_HOUSE



;ペット名参照
;ARGS→ANIMAL
@PET_NAME_REF(ARGS)
#FUNCTIONS
#DIMS NAME_REF

;オルトロス以外はそのまま、オルトロスは接続詞も全部くっつける
IF ARGS == "双头犬"
	NAME_REF = %SAVESTR:名称／双头犬%%SAVESTR:名称／双头犬／连接词%%SAVESTR:名称／双头犬／弟妹%
	RETURNF NAME_REF
ELSE
	NAME_REF = 名称／%ARGS%
	RETURNF SAVESTR:NAME_REF
ENDIF



;ペット追加したときのなつき度初期値設定
;ARGS→ANIMAL
@PET_START_FRIENDLY_ADD_PET(ARGS)

FLAG_NAME = 亲和度／%ARGS%
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	MAXBASE:FLAG_NAME = 10000
	
	;ペットごとのTALENT補正込み初期値参照
	CALL PET_START_FRIENDLY_ADD_PET_TALENT(ARGS)
	BASE:FLAG_NAME = RESULT
NEXT



;キャラ追加したときのペットのなつき度初期値設定
@PET_START_FRIENDLY_ADD_CHARA

CALL GET_PET_FLAG_REF
FOR LOCAL,0,20
	SIF !ITEM:(ITEM_NUM +LOCAL)
		CONTINUE
	MAXBASE:(BASE_REF +LOCAL) = 10000
	CALL PET_START_FRIENDLY_ADD_PET_TALENT(ITEMNAME:(ITEM_NUM +LOCAL))
	BASE:(BASE_REF +LOCAL) = RESULT
NEXT



;ペットなつき度のTALENT補正込み初期値参照
;ARGS→ANIMAL
@PET_START_FRIENDLY_ADD_PET_TALENT(ARGS)
#DIM FRIENDLY

SELECTCASE ARGS
CASE "堕落天马"
	FRIENDLY = 3000
	SIF TALENT:受动物喜欢
		FRIENDLY += 3000
	
	;元々天界に嫌気が指した種族のため特に顕著
	SIF TALENT:天界种族
		FRIENDLY -= 2000
CASE "双头犬"
	FRIENDLY = 4000
	SIF TALENT:受动物喜欢
		FRIENDLY += 3000
	
	;なんとなく親近感が湧く
	SIF TALENT:尾巴
		FRIENDLY += 500
	
	;臭いは敏感
	SIF TALENT:喜欢泡澡 > 0
		FRIENDLY += 300
	SIF TALENT:喜欢清洁 > 0
		FRIENDLY += 300
	SIF TALENT:喜欢泡澡 < 0
		FRIENDLY -= 300
	SIF TALENT:喜欢清洁 < 0
		FRIENDLY -= 300
	
CASE "魔界仓鼠"
	FRIENDLY = 3000
	SIF TALENT:受动物喜欢
		FRIENDLY += 3000
	SIF TALENT:尾巴
		FRIENDLY += 500
	SIF TALENT:老实
		FRIENDLY += 500
ENDSELECT

;いろいろやっても嫌われる素質あれば台無しだよ
SIF TALENT:被动物讨厌
	FRIENDLY = 0
RETURN FRIENDLY






