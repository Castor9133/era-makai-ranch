
;ハーフリング
@TRIBE_FEATURE_CONFIG_HALFLING

CLEARLINE LINECOUNT
PRINTL 选择【半身人】中的种族设定。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTLC [ 0] 使身高达到【儿童体型】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／半身人,0),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(4)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL 身高【矮小】以上变为【儿童体型】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／半身人"),INPUT_NUM)
CASE 98
	PRINTL 将【半身人】的种族设定回复为默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_HALFLING
CASE 99
	RETURN
ENDSELECT
RESTART


