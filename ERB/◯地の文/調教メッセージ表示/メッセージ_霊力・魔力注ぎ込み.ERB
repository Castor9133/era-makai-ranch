
;霊力注入地の文
@POWER_INJECTION_EP_MESSAGE

SIF !LINEISEMPTY()
	PRINTL
PRINTFORML %CALLNAME% 灵力+%VALUE_DIGIT(SOURCE:注入灵力量)%EP



;最大霊力の増加
@SLAVE_MAX_EP_UP_MESSAGE(ARG)
;ARG→MAX_UP_EP

CALL PRINT_WORD_COLOR,@"被%CALLNAME:0%注入灵力，%CALLNAME%寄宿着魔界的灵力…","桃"
CALL HEARTCB(0xD02830)
PRINTL
CALL PRINTL_WORD_COLOR,@"%CALLNAME% 灵力最大值+%VALUE_DIGIT(ARG)% → %VALUE_DIGIT(MAXBASE:灵力)%EP","浅蓝色"



;奴隷が霊力注ぎ込まれてのレベルアップ
;ARG→NOW_LEVEL
@SLAVE_LEVELUP_MESSAGE(ARG)

CALL PRINTL_WORD_COLOR,@"LvUP！　%CALLNAME% Lv{BASE:等级} → {ARG}","浅蓝色"



;奴隷の体力増加
@SLAVE_HP_UP_MESSAGE

CALL PRINT_WORD_COLOR,@"%CALLNAME:0%的灵力注入，%CALLNAME%的体力增加了…","桃"
CALL HEARTCB(0xD02830)
PRINTFORML 　最大体力+50 → {MAXBASE:体力}





;魔力注入地の文
@POWER_INJECTION_MP_MESSAGE

SIF !LINEISEMPTY()
	PRINTL
PRINTFORML %CALLNAME% 魔力+%VALUE_DIGIT(SOURCE:注入魔力量)%MP



;魔力のない奴隷に魔力を注ぎ込む
@SLAVE_MP_INJECTION_MESSAGE

CALL PRINT_WORD_COLOR,@"被%CALLNAME:0%注入魔力，%CALLNAME%寄宿着魔界浓重的魔力…","桃"
CALL HEARTCB(0xD02830)
PRINTL
CALL PRINTL_WORD_COLOR,@"根据注入的魔力，%CALLNAME%的体内略微积攒了一些魔力！ → 魔力+{MAXBASE:魔力}","浅蓝色"



;最大魔力増加
;ARG→MAX_UP_MP
@SLAVE_MAX_MP_UP_MESSAGE(ARG)

CALL PRINT_WORD_COLOR,@"被%CALLNAME:0%注入魔力，%CALLNAME%寄宿着魔界浓重的魔力…","桃"
CALL HEARTCB(0xD02830)
PRINTL
CALL PRINTL_WORD_COLOR,@"%CALLNAME% 魔力最大值+%VALUE_DIGIT(ARG)% → %VALUE_DIGIT(MAXBASE:魔力)%MP","浅蓝色"

