
;目の色変更
@VISIT_EYE_COLOR_CHANGE_BEFORE

CHANGE_PLANS:0 = %CSTR:右瞳色%
CHANGE_PLANS:1 = %CSTR:左瞳色%
CHANGE_PLANS:2 = %CSTR:瞳孔形状%
CHANGE_PLANS:3= %CSTR:颜色类别／右瞳色%
CHANGE_PLANS:4= %CSTR:颜色类别／左瞳色%
CHANGE_PLAN:0 = CFLAG:颜色编码／右目
CHANGE_PLAN:1 = CFLAG:颜色编码／左目
CALL VISIT_EYE_COLOR_CHANGE

VARSET CHANGE_PLANS
VARSET CHANGE_PLAN



;本設定
@VISIT_EYE_COLOR_CHANGE
#DIM NO_COST

CLEARLINE LINECOUNT
CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT
CALL MANYL(3)
PRINT 　原始瞳色：
SIF CFLAG:初始值／颜色编码／右眼
	SETCOLOR CFLAG:初始值／颜色编码／右眼
PRINTFORM %CSTR:初始值／右瞳色%

SIF CFLAG:初始值／颜色编码／左眼
	SETCOLOR CFLAG:初始值／颜色编码／左眼
SIF CSTR:初始值／左瞳色 != ""
	PRINTFORM ／%CSTR:初始值／左瞳色%
RESETCOLOR

IF CSTR:初始值／瞳孔形状 != ""
	SIF CFLAG:初始值／颜色编码／右眼
		SETCOLOR CFLAG:初始值／颜色编码／右眼
	PRINTFORM 【%CSTR:初始值／瞳孔形状%】
	RESETCOLOR
ENDIF
PRINTL
PRINT 当前瞳色：
SIF CHANGE_PLAN:0
	SETCOLOR CHANGE_PLAN:0
PRINTFORM %CHANGE_PLANS:0%
SIF CHANGE_PLAN:1
	SETCOLOR CHANGE_PLAN:1
SIF CHANGE_PLANS:1 != ""
	PRINTFORM ／%CHANGE_PLANS:1%
RESETCOLOR

IF CHANGE_PLANS:2 != ""
	SIF CHANGE_PLAN:0
		SETCOLOR CHANGE_PLAN:0
	PRINTFORM 【%CHANGE_PLANS:2%】
	RESETCOLOR
ENDIF
PRINTL
PRINTL

IF !ITEM:彩色隐形眼镜
	CALL PRINTL_WORD_COLOR("　没有＜彩色隐形眼镜＞","灰")
	PRINTL
	PRINTL
ELSE
	PRINTL [ 0] 更改右瞳色
	PRINTL [ 1] 更改左瞳色
	PRINTL [ 2] 瞳孔形状变更
ENDIF
PRINTL [ 3] 更改右瞳色编码
PRINTL [ 4] 更改左瞳色编码
PRINTL
PRINT 修改后
CALL PRINT_EYE_COLOR
PRINTL
DRAWLINE
PRINTLC [90] 取消
IF EQUIP:彩色隐形眼镜
	PRINTLC [91] 回复原瞳色・瞳孔形状
ELSE
	PRINTLC 　
ENDIF
PRINTL [99] 完成
INPUT
PRINTL

SELECTCASE RESULT
CASE 0
	SIF !ITEM:彩色隐形眼镜
		RESTART
	PRINTL 请选择右瞳色。
	
	;150～,目の色
	STR_REF = 150
	FOR LOCAL,STR_REF,STR_REF+50
		SIF STR:LOCAL == ""
			BREAK
		PRINTFORMLC [{LOCAL-STR_REF,3}] %STR:LOCAL% 
	NEXT
	CALL INPUTBUTTON
	INPUT
	IF RESULT >= 0 && RESULT < 50 && STR:(RESULT+STR_REF) != ""
		CSTR:右瞳色 = %STR:(RESULT+STR_REF)%
	ELSEIF RESULT == 901
		PRINTL 请输入右瞳色。
		INPUTS
		SIF RESULTS != ""
			CSTR:右瞳色 = %RESULTS%
	ELSE
		RESTART
	ENDIF
	CALL CATEGORY_EYE_COLOR
	CALL AUTOSET_EYE_COLOR_CODE
	
CASE 1
	SIF !ITEM:彩色隐形眼镜
		RESTART
	PRINTL 请选择左瞳色。
	
	;150～,目の色
	STR_REF = 150
	FOR LOCAL,STR_REF,STR_REF+50
		SIF STR:LOCAL == ""
			BREAK
		PRINTFORMLC [{LOCAL-STR_REF,3}] %STR:LOCAL% 
	NEXT
	CALL INPUTBUTTON(1)
	INPUT
	IF RESULT >= 0 && RESULT < 50 && STR:(RESULT+STR_REF) != ""
		CSTR:左瞳色 = %STR:(RESULT+STR_REF)%
	ELSEIF RESULT == 900
		CSTR:左瞳色 = 
	ELSEIF RESULT == 901
		PRINTL 请输入左瞳色。
		INPUTS
		SIF RESULTS != ""
			CSTR:左瞳色 = %RESULTS%
	ELSE
		RESTART
	ENDIF
	CALL CATEGORY_EYE_COLOR
	CALL AUTOSET_EYE_COLOR_CODE

CASE 2
	SIF !ITEM:彩色隐形眼镜
		RESTART
	PRINTL 选择瞳孔形状。
	
	;800～,瞳の形
	STR_REF = 800
	FOR LOCAL,STR_REF,STR_REF+50
		SIF STR:LOCAL == ""
			BREAK
		PRINTFORMLC [{LOCAL-STR_REF,3}] %STR:LOCAL% 
	NEXT
	CALL INPUTBUTTON(1)
	INPUT
	IF RESULT >= 0 && RESULT < 50 && STR:(RESULT+STR_REF) != ""
		CSTR:瞳孔形状 = %STR:(RESULT+STR_REF)%
	ELSEIF RESULT == 900
		CSTR:瞳孔形状 = 
	ELSEIF RESULT == 901
		PRINTL 请输入瞳孔形状。
		INPUTS
		SIF RESULTS != ""
			CSTR:瞳孔形状 = %RESULTS%
	ELSE
		RESTART
	ENDIF
	
CASE 3
	CALL EDIT_COLOR_CODE(CFLAG:颜色编码／右目,1)
	SIF RESULT
		CFLAG:颜色编码／右目 = RESULT

CASE 4
	CALL EDIT_COLOR_CODE(CFLAG:颜色编码／左目,1)
	SIF RESULT
		CFLAG:颜色编码／左目 = RESULT
	
CASE 90
	CSTR:右瞳色 = %CHANGE_PLANS:0%
	CSTR:左瞳色 = %CHANGE_PLANS:1%
	CSTR:瞳孔形状 = %CHANGE_PLANS:2%
	CSTR:颜色类别／右瞳色 = %CHANGE_PLANS:3%
	CSTR:颜色类别／左瞳色 = %CHANGE_PLANS:4%
	CFLAG:颜色编码／右目 = CHANGE_PLAN:0
	CFLAG:颜色编码／左目 = CHANGE_PLAN:1
	RETURN
	
CASE 91
	SIF !EQUIP:彩色隐形眼镜
		RESTART
	PRINTL 把瞳色・瞳孔形状回复到原始颜色・形状吗？
	CALL ASK_YN
	IF !RESULT
		EQUIP:彩色隐形眼镜 = 0
		CSTR:右瞳色 = %CSTR:初始值／右瞳色%
		CSTR:左瞳色 = %CSTR:初始值／左瞳色%
		CSTR:瞳孔形状 = %CSTR:初始值／瞳孔形状%
		CFLAG:颜色编码／右目 = CFLAG:初始值／颜色编码／右眼
		CFLAG:颜色编码／左目 = CFLAG:初始值／颜色编码／左眼
		PRINTFORMW 摘掉了%CALLNAME%的[彩色隐形眼镜]。
		RETURN
	ENDIF
	
CASE 99
	CALL ONLY_EYE_COLOR_CODE
	NO_COST = RESULT
	;変更ないならキャンセルと同じ
	SIF NO_COST == 2
		RETURN
	PRINT 瞳色・瞳孔形状 
	CALL PRINT_EYE_COLOR(1)
	PRINTL 发色吗？
	IF NO_COST
		CALL PRINTL_WORD_COLOR("由于仅更改颜色编码，不会消耗＜彩色隐形眼镜＞。","黄")
	ELSE
		CALL PRINTL_WORD_COLOR("将消耗1个＜彩色隐形眼镜＞。","黄")
	ENDIF
	CALL ASK_YN
	IF !RESULT
		IF NO_COST
			PRINTL 已更改颜色编码。
		ELSE
			ITEM:彩色隐形眼镜 --
			EQUIP:彩色隐形眼镜 = 1
			PRINTFORML 已为%CALLNAME%佩戴了[彩色隐形眼镜]。
			CALL KOJO_PRINT("访问","彩色隐形眼镜")
		ENDIF
		PRINTW
		RETURN
	ENDIF
ENDSELECT
RESTART



;カラーコードだけ変更したか判定
@ONLY_EYE_COLOR_CODE

IF CSTR:右瞳色 != CHANGE_PLANS:0
	RETURN
ELSEIF CSTR:左瞳色 != CHANGE_PLANS:1
	RETURN
ELSEIF CSTR:瞳孔形状 != CHANGE_PLANS:2
	RETURN
ELSEIF CFLAG:颜色编码／右目 != CHANGE_PLAN:0
	RETURN 1
ELSEIF CFLAG:颜色编码／左目 != CHANGE_PLAN:1
	RETURN 1
ENDIF
RETURN 2

