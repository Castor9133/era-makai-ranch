
;动作确认用口上（进入魔界／事件）
;真的是调试专用，几乎没有色情内容。
;只有这套口上会走「把候选全部显示出来」的处理。
;不必把所有分支都填满；标几个容易空窗的关键点即可。
;没有也不会坏的分支也很多，看个人兴趣。

; 以下多为每名角色一生一次的触发点

; ======================================

;动作确认用口上
;口上识别名：动作确认用口上（见 Str.csv）
;写好口上后请在 Str.csv 6100 段附近登记识别名
;口上作者：polt
;本口上内容遵循 CC BY-NC（非商用可自由改造）
;（creativecommons.org/licenses/by-nc/4.0/deed.ja）

;加笔者：
;（暂无）
; ======================================

; ARGS:0 场景；ARGS:1/2 用于更细分
@KOJO_GENERAL_操作确认口上_EVENT(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

; 本函数需先按 ARGS:0 分支
SELECTCASE ARGS:0

; 捏人结束进入魔界
; 每名角色仅走其一，重要度可低
CASE "进入魔界的"
	SELECTCASE ARGS:1
	CASE "魔界水晶1"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[魔界水晶]1」"
	CASE "魔界水晶2"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[魔界水晶]2」"
		
	CASE "魔界植物1"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[魔界植物]1」"
	CASE "魔界植物2"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[魔界植物]2」"
	
	CASE "夺回1"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[夺回]1」"
	CASE "夺回2"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[夺回]2」"
		
	CASE "声望1"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[声望]1」"
	CASE "声望2"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[声望]2」"
	
	CASE "大门事故1"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[大门事故]1」"
	CASE "大门事故2"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[大门事故]2」"
	CASE "大门事故3"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[大门事故]3」"
	
	CASE "讨伐1"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[讨伐]1」"
	CASE "讨伐2"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[讨伐]2」"
	
	CASE "特殊种族1"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_【特殊种族】1」"
	CASE "特殊种族2"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_【特殊种族】2」"
	
	CASE "即将处置1"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[即将处置]1」"
	CASE "即将处置2"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[即将处置]2」"
	
	CASE "拍卖1"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[拍卖]1」"
	
	CASE "异世界转移1"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[异世界转移]1」"
	CASE "异世界转移2"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[异世界转移]2」"
	CASE "异世界转移3"
		CALL MESSAGE_BOX,@"「test_奴隶候选确定后的台词_[异世界转移]3」"
	ENDSELECT

; 多为每人一次；无口上也能过流程，重要度中等
CASE "事件"
	; 口枷生效时建议转专用分支
	IF TFLAG:Ｍ装备
		CALL KOJO_PRINT("Ｍ装备中事件",ARGS:1,ARGS:2,ARGS:3)
		
		; 因 CALL 关系，口枷中事件返回后需在此清空
		MESSAGE_COUNT = 0
		RETURN
	ENDIF
	
	SELECTCASE ARGS:1
	CASE "领取奴隶"
		CALL MESSAGE_BOX,@"「test_领取已捕获奴隶时的台词。」"
	CASE "母乳体质化"
		CALL MESSAGE_BOX,@"「test_获得【母乳体质】时的台词。」"
	CASE "魔力母乳体质化"
		CALL MESSAGE_BOX,@"「test_获得【魔力母乳体质】时的台词。」"
	CASE "超乳化"
		CALL MESSAGE_BOX,@"「test_因膨乳变为【超乳】时的台词。」"
	CASE "崩坏"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"「test_[体内凌辱]中精神归零触发【崩坏】时的台词。」"
		CASEELSE
			CALL MESSAGE_BOX,@"「test_非[体内凌辱]中精神归零触发【崩坏】时的台词。」"
		ENDSELECT
	CASE "反抗消除"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"「test_[体内凌辱]中反抗心归零、移除【反抗】时的台词。」"
		CASEELSE
			CALL MESSAGE_BOX,@"「test_非[体内凌辱]中反抗心归零、移除【反抗】时的台词。」"
		ENDSELECT
	
	CASE "屈服"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"「test_[体内凌辱]中精神 ≤10\% 触发【屈服】时的台词。」"
		CASEELSE
			CALL MESSAGE_BOX,@"「test_非[体内凌辱]中精神 ≤10\% 触发【屈服】时的台词。」"
		ENDSELECT
	
	CASE "陷落"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"「test_[体内凌辱]中好感 ≥50\% 触发【陷落】时的台词。」"
		CASEELSE
			CALL MESSAGE_BOX,@"「test_非[体内凌辱]中好感 ≥50\% 触发【陷落】时的台词。」"
		ENDSELECT
	
	CASE "恋慕告白"
		SELECTCASE ARGS:2
		CASE "前"
			; 已乳牛堕却过于乖巧时的区分
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「test_调教结束后：已【乳牛堕落】且好感 100\% 触发【恋慕】——前置台词。」"
			ELSE
				CALL MESSAGE_BOX,@"「test_调教结束后：未【乳牛堕落】且好感 100\% 触发【恋慕】——前置台词。」"
			ENDIF
		CASE "后"
			CALL MESSAGE_BOX,@"「test_调教结束后：好感 100\% 触发【恋慕】——后置台词。」"
		ENDSELECT
	
	CASE "隶属告白"
		SELECTCASE ARGS:2
		CASE "前"
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「test_调教结束后：已【乳牛堕落】且好感 200\% 触发【隶属】——前置台词。」"
			ELSE
				CALL MESSAGE_BOX,@"「test_调教结束后：未【乳牛堕落】且好感 200\% 触发【隶属】——前置台词。」"
			ENDIF
		CASE "后"
			CALL MESSAGE_BOX,@"「test_调教结束后：好感 200\% 触发【隶属】——后置台词。」"
		ENDSELECT
	
	CASE "乳牛堕落"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"「test_[体内凌辱]中[乳牛堕落]达 100\% 触发【乳牛堕落】时的台词。」"
		CASEELSE
			CALL MESSAGE_BOX,@"「test_非[体内凌辱]中[乳牛堕落]达 100\% 触发【乳牛堕落】时的台词。」"
		ENDSELECT
	
	CASE "处女结界破坏"
		; 紧接着还会播处女丧失口上
		CALL MESSAGE_BOX,@"「test_【处女结界】即将被破坏前的台词。」"
		CALL MESSAGE_BOX,@"「test_随后会继续显示处女丧失相关口上。」"
	
	CASE "处女丧失前"
		; 主角阴茎插入时
		IF GETBIT(＃Ｐ使用／Ｖ插入＃)
			CALL MESSAGE_BOX,@"「test_%CALLNAME:0% 的阴茎导致处女丧失——直前台词。」"
			CALL MESSAGE_BOX,@"「%PENIS_CALL()% ← 阴茎称呼；%VAGINA_CALL()% ← 该奴隶阴道称呼。」"
		ELSE
			CALL MESSAGE_BOX,@"「test_非 %CALLNAME:0% 阴茎导致的处女丧失——直前台词。」"
		ENDIF
	
	CASE "处女丧失后"
		IF GETBIT(＃Ｐ使用／Ｖ插入＃)
			CALL MESSAGE_BOX,@"「test_%CALLNAME:0% 的阴茎导致处女丧失——直后台词。」"
		ELSEIF V_PENIS == "妖精"
			CALL MESSAGE_BOX,@"「test_因 %V_PENIS% 失去处女——直后台词。」"
		ELSE
			CALL MESSAGE_BOX,@"「test_非 %CALLNAME:0% 阴茎导致处女丧失——直后台词。」"
		ENDIF
	
	CASE "Ａ处女丧失前"
		IF GETBIT(＃Ｐ使用／Ａ插入＃)
			CALL MESSAGE_BOX,@"「test_%CALLNAME:0% 的阴茎导致 A 处女丧失——直前台词。」"
			CALL MESSAGE_BOX,@"「%PENIS_CALL()% ← 阴茎称呼；%ANAL_CALL()% ← 该奴隶肛门称呼。」"
		ELSE
			CALL MESSAGE_BOX,@"「test_非 %CALLNAME:0% 阴茎导致 A 处女丧失——直前台词。」"
		ENDIF
	
	CASE "Ａ处女丧失后"
		IF GETBIT(＃Ｐ使用／Ａ插入＃)
			CALL MESSAGE_BOX,@"「test_%CALLNAME:0% 的阴茎导致 A 处女丧失——直后台词。」"
		ELSE
			CALL MESSAGE_BOX,@"「test_非 %CALLNAME:0% 阴茎导致 A 处女丧失——直后台词。」"
		ENDIF
	
	CASE "初吻"
		IF KISS_PLAYER == CALLNAME:0
			CALL MESSAGE_BOX,@"「test_初吻对象 %CALLNAME:0% 时的台词。」"
		ELSE
			CALL MESSAGE_BOX,@"「test_初吻对象 %KISS_PLAYER% 时的台词。」"
		ENDIF
	
	CASE "初次乳交"
		IF PAIZURI_PENIS == CALLNAME:0
			CALL MESSAGE_BOX,@"「test_首次乳交由 %CALLNAME:0% 完成时的台词。」"
		ELSE
			CALL MESSAGE_BOX,@"「test_首次乳交由 %PAIZURI_PENIS% 完成时的台词。」"
		ENDIF
	
	CASE "初Ｍ性交"
		; 嘴被堵住时通常不进此分支
	
	CASE "主人公童贞毕业"
		IF SOURCE:处女丧失
			CALL MESSAGE_BOX,@"「test_%CALLNAME:0% 童贞毕业且与 %CALLNAME% 处女丧失同时发生时的台词。」"
		ELSEIF TALENT:贞操观念
			CALL MESSAGE_BOX,@"「test_%CALLNAME:0% 童贞毕业且 %CALLNAME% 拥有【贞操观念】时的台词。」"
		ELSEIF TALENT:不在乎贞操
			CALL MESSAGE_BOX,@"「test_%CALLNAME:0% 童贞毕业且 %CALLNAME% 拥有【不在乎贞操】时的台词。」"
		ELSE
			CALL MESSAGE_BOX,@"「test_%CALLNAME:0% 童贞毕业且 %CALLNAME% 本非处女时的台词。」"
		ENDIF
	
	CASE "主人公初吻"
		IF SOURCE:初吻
			CALL MESSAGE_BOX,@"「test_%CALLNAME:0% 献出初吻且与 %CALLNAME% 初吻同时时的台词。」"
		ELSE
			CALL MESSAGE_BOX,@"「test_%CALLNAME:0% 献出初吻且 %CALLNAME% 已非初吻时的台词。」"
		ENDIF
	
	CASE "主人公初次被乳交"
		IF SOURCE:初次乳交
			CALL MESSAGE_BOX,@"「test_%CALLNAME:0% 首次乳交且与 %CALLNAME% 首次乳交同时时的台词。」"
		ELSE
			CALL MESSAGE_BOX,@"「test_%CALLNAME:0% 首次乳交且 %CALLNAME% 已有乳交经验时的台词。」"
		ENDIF
	
	CASE "主人公初授乳"
		CALL MESSAGE_BOX,@"「test_%CALLNAME:0% 首次饮用人类母乳时的台词。」"
	
	CASE "主人公初次被口交"
		; 主角阴茎在嘴内时多半不会走这里
	
	CASE "去掉枷锁"
		SELECTCASE ARGS:2
		CASE "超乳"
			CALL MESSAGE_BOX,@"「test_因【超乳】为 %CALLNAME% 卸下＜魔力枷＞时的台词。」"
		CASE "超乳隶属"
			CALL MESSAGE_BOX,@"「test_因【超乳】且【隶属】或【乳牛堕落】为 %CALLNAME% 卸下＜魔力枷＞时的台词。」"
		CASE "完堕"
			CALL MESSAGE_BOX,@"「test_因【隶属】【恋慕】【乳牛堕落】为 %CALLNAME% 卸下＜魔力枷＞时的台词。」"
		CASE "崩坏"
			; 当前分支树下通常不会进入
		CASE "陷落"
			CALL MESSAGE_BOX,@"「test_因【陷落】为 %CALLNAME% 卸下＜魔力枷＞时的台词。」"
		CASE "屈服"
			CALL MESSAGE_BOX,@"「test_因【屈服】为 %CALLNAME% 卸下＜魔力枷＞时的台词。」"
		CASE "非战斗职业"
			CALL MESSAGE_BOX,@"「test_因【非战斗职】为 %CALLNAME% 卸下＜魔力枷＞时的台词。」"
		CASE "灵力0"
			CALL MESSAGE_BOX,@"「test_因灵力被吸干为 %CALLNAME% 卸下＜魔力枷＞时的台词。」"
		CASE "处女结界破坏"
			CALL MESSAGE_BOX,@"「test_破坏【处女结界】且非【上位种族】失力，为 %CALLNAME% 卸下＜魔力枷＞时的台词。」"
		CASE "魔力母乳体质"
			CALL MESSAGE_BOX,@"「test_变为【魔力母乳体质】、无魔力难以战斗，为 %CALLNAME% 卸下＜魔力枷＞时的台词。」"
		CASE "反抗消除"
			CALL MESSAGE_BOX,@"「test_移除【反抗】变为【拒绝】，为 %CALLNAME% 卸下＜魔力枷＞时的台词。」"
		ENDSELECT
	
	CASE "处女结界解除"
		SELECTCASE ARGS:2
		CASE "前"
			CALL MESSAGE_BOX,@"「test_保持【处女结界】状态下【隶属】并自愿解除结界——前置台词。」"
		CASE "后"
			CALL MESSAGE_BOX,@"「test_保持【处女结界】状态下【隶属】并自愿解除结界——后置台词。」"
		ENDSELECT
	ENDSELECT

; 嘴被堵住时触发事件的专用分支；未列出的 ARGS 在口枷下不应出现
CASE "Ｍ装备中事件"
	SELECTCASE ARGS:1
	CASE "母乳体质化"
		CALL MESSAGE_BOX,@"（test_嘴被堵住时获得【母乳体质】的台词。）"
		CALL MESSAGE_BOX,@"（test_口枷台词除「嗯嗯」类闷声外，建议多用括号内心独白形式。）"
	CASE "魔力母乳体质化"
		CALL MESSAGE_BOX,@"（test_嘴被堵住时获得【魔力母乳体质】的台词。）"
	CASE "超乳化"
		CALL MESSAGE_BOX,@"（test_嘴被堵住时因膨乳变为【超乳】的台词。）"
	CASE "崩坏"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"（test_嘴被堵住且在[体内凌辱]中精神归零【崩坏】的台词。）"
		CASEELSE
			CALL MESSAGE_BOX,@"（test_嘴被堵住且非[体内凌辱]中精神归零【崩坏】的台词。）"
		ENDSELECT
	
	CASE "处女结界破坏"
		CALL MESSAGE_BOX,@"（test_嘴被堵住时【处女结界】即将被破坏前的台词。）"
		CALL MESSAGE_BOX,@"（test_随后会继续显示处女丧失相关口上。）"
	
	CASE "处女丧失前"
		IF GETBIT(＃Ｐ使用／Ｖ插入＃)
			CALL MESSAGE_BOX,@"（test_嘴被堵住且 %CALLNAME:0% 阴茎导致处女丧失——直前。）"
			CALL MESSAGE_BOX,@"（%PENIS_CALL()% ← 阴茎称呼；%VAGINA_CALL()% ← 该奴隶阴道称呼。）"
		ELSE
			CALL MESSAGE_BOX,@"（test_嘴被堵住且非 %CALLNAME:0% 阴茎导致处女丧失——直前。）"
		ENDIF
	
	CASE "处女丧失后"
		IF GETBIT(＃Ｐ使用／Ｖ插入＃)
			CALL MESSAGE_BOX,@"（test_嘴被堵住且 %CALLNAME:0% 阴茎导致处女丧失——直后。）"
		ELSEIF V_PENIS == "妖精"
			CALL MESSAGE_BOX,@"（test_嘴被堵住且因 %V_PENIS% 失去处女——直后。）"
		ELSE
			CALL MESSAGE_BOX,@"（test_嘴被堵住且非 %CALLNAME:0% 阴茎导致处女丧失——直后。）"
		ENDIF
	
	CASE "Ａ处女丧失前"
		IF GETBIT(＃Ｐ使用／Ａ插入＃)
			CALL MESSAGE_BOX,@"（test_嘴被堵住且 %CALLNAME:0% 阴茎导致 A 处女丧失——直前。）"
			CALL MESSAGE_BOX,@"（%PENIS_CALL()% ← 阴茎称呼；%ANAL_CALL()% ← 该奴隶肛门称呼。）"
		ELSE
			CALL MESSAGE_BOX,@"（test_嘴被堵住且非 %CALLNAME:0% 阴茎导致 A 处女丧失——直前。）"
		ENDIF
	
	CASE "Ａ处女丧失后"
		IF GETBIT(＃Ｐ使用／Ａ插入＃)
			CALL MESSAGE_BOX,@"（test_嘴被堵住且 %CALLNAME:0% 阴茎导致 A 处女丧失——直后。）"
		ELSE
			CALL MESSAGE_BOX,@"（test_嘴被堵住且非 %CALLNAME:0% 阴茎导致 A 处女丧失——直后。）"
		ENDIF
	
	CASE "初次乳交"
		IF PAIZURI_PENIS == CALLNAME:0
			CALL MESSAGE_BOX,@"（test_嘴被堵住且首次乳交由 %CALLNAME:0% 完成时的台词。）"
		ELSE
			CALL MESSAGE_BOX,@"（test_嘴被堵住且首次乳交由 %PAIZURI_PENIS% 完成时的台词。）"
		ENDIF
	
	CASE "初Ｍ性交"
		IF GETBIT(＃Ｐ使用／Ｍ插入＃)
			CALL MESSAGE_BOX,@"（test_嘴被堵住且首次被 %CALLNAME:0% 含住阴茎时的台词。）"
		ELSE
			CALL MESSAGE_BOX,@"（test_嘴被堵住且首次被 %M_PENIS% 含住阴茎时的台词。）"
		ENDIF
	ENDSELECT
ENDSELECT

