
;簡易ステータス表示
@SHOW_STATUS_SIMPLE

CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT
IF !TARGET
	CALL SHOW_STATUS_PLAYER_SIMPLE
	RETURN
ENDIF
CALL PRINT_ALL_STATE
PRINTFORM %CALLNAME%
CALL PRINT_AFFILIATION_DATA
SIF !CFLAG:非战斗职业 || BASE:等级 > 1
	PRINTFORM Lv{BASE:等级} 
PRINTL
PRINTFORM 【%CSTR:身高%】胸围大小：%PRINT_BUSTSIZE(ABL:胸围大小)%
CALL PRINT_BUST_C(1,1,1)
CALL PRINT_VIRGIN_SIMPLE
CALL ABL_WORK_LIST(0)
CALL PRINT_SOME_DRINK
PRINTL



;あなたのステータス
@SHOW_STATUS_PLAYER_SIMPLE

CALL PRINT_POST_C
PRINTFORM %CALLNAME%
CALL PRINT_AFFILIATION_DATA
SIF BASE:等级 > 1
	PRINTFORM Lv{BASE:等级} 
PRINTL
CALL ABL_WORK_LIST(0)
PRINTFORM  灵力：%VALUE_DIGIT(BASE:灵力)% 
CALL PRINT_COLORBAR(BASE:灵力,MAXBASE:灵力,8,BARCOLORSET(""),RESULT:1)
PRINTFORM  魔力：%VALUE_DIGIT(BASE:魔力)% 
CALL PRINT_COLORBAR(BASE:魔力,MAXBASE:魔力,8,BARCOLORSET("深紫"),RESULT:1)
PRINTFORML  <{BASE:魔力恢复率,2}\%\/day>

IF ITEM:绝伦 && GETBIT(＃有效／绝伦＃)
	CALL PRINT_WORD_COLOR,@"【绝伦】","桃"
ELSE
	PRINTFORM  精力：%VALUE_DIGIT(BASE:精力)% 
	CALL PRINT_COLORBAR(BASE:精力,MAXBASE:精力,8,BARCOLORSET(""),RESULT:1)
ENDIF
PRINTL



