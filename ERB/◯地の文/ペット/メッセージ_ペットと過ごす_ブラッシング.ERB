
;ペットをブラッシング：地の文
;TARGET,ANIMAL,PET_NAME指定済み
@PET_COMMU_MESSAGE_BRUSHING

FLAG_NAME = 亲和度／%ANIMAL%
IF TALENT:受动物喜欢 || BASE:FLAG_NAME >= 8000
	CALL PET_COMMU_MESSAGE_BRUSHING_LOVE
	DAMAGE = 100
ELSEIF !TALENT:被动物讨厌 || BASE:FLAG_NAME >= 5000
	CALL PET_COMMU_MESSAGE_BRUSHING_LOW
	DAMAGE = 100
ELSE
	CALL PET_COMMU_MESSAGE_BRUSHING_HATE
	DAMAGE = 150
ENDIF



;【動物に好かれる】orなつき時
@PET_COMMU_MESSAGE_BRUSHING_LOVE

PRINTFORML %CALLNAME%决定给%PET_NAME%梳毛。
SELECTCASE ANIMAL
CASE "堕落天马","魔界仓鼠"
	PRINTFORML %PET_NAME%把身体趴下，乖巧地使劲，以便更容易地梳理。
CASEELSE
	PRINTFORML %PET_NAME%伸展身体，乖巧地使劲，以便更容易地梳理。
ENDSELECT
PRINTL ………
PRINTFORML %PET_NAME%的体毛整齐了！%PET_NAME%也满足！



;【動物に嫌われる】ではないor嫌われるけどなつき程々
@PET_COMMU_MESSAGE_BRUSHING_LOW

;上と同じ
CALL PET_COMMU_MESSAGE_BRUSHING_LOVE



;【動物に嫌われる】
@PET_COMMU_MESSAGE_BRUSHING_HATE

PRINTFORML %CALLNAME%试图给%PET_NAME%梳理毛发…
PRINTL ………
PRINTL 虽然梳理过程中遇到了一些抵触，但终于设法完成了。
PRINTL 有一点点得到信任的感觉。




