; ======================================
; 泛用口上・调教命令（性格：大和抚子）
; ======================================

@KOJO_GENERAL_大和抚子口上1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:2
CASE "执行"
	SELECTCASE ARGS:1
	CASE "揉胸","育乳按摩","浓厚母乳按摩","乳罐按摩","胸爱抚","拧乳头"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「请、请轻些……♥ ……是，这样就好……♥」"
			CALL MESSAGE_BOX,@"「……胸口发热……%MASTER_CALL()%的手……很温柔……♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……请别太粗鲁……这、这样会……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「请住手……那里……不成体统……」"
		ENDIF

	CASE "接吻"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……吻……是礼……亦是私心……♥ ……此际……请纵容妾……♥」"
			CALL MESSAGE_BOX,@"「……请再近些……妾想……把您看清……♥」"
			CALL MESSAGE_BOX,@"「……若以舌续礼……♥ ……妾自敛声……只随您引……♥」"
			CALL MESSAGE_BOX,@"「……牙齿……勿相磕碰……♥ 嗯……嗯……舌尖……请再缠绵些……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……请别这样……太近了……」"
		ENDIF
	CASE "舔舐脸"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……以舌洁面……失礼至极……♥ ……却……想让您留下印记……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……脸……请止步……」"
		ENDIF
	CASE "舔舐耳","舔舐腋"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……耳际……乃礼崩之处……♥ ……腋下……更……更不成体统……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……请……勿近……」"
		ENDIF

	CASE "口交","触手口交"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……我会好好含住……若不舒服，请您示意……♥」"
			CALL MESSAGE_BOX,@"「……请交给我……我会温柔侍奉……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……要我……用嘴……？ 这、这太……」"
		ENDIF

	CASE "深喉","触手深喉"
		CALL KOJO_SHARE_ADVANCED_TRAIN_DISPATCH(ARGS:1, ARGS:2)

	CASE "手淫","授乳手交"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……这样可以吗……♥ ……会更舒服吗……♥」"
			CALL MESSAGE_BOX,@"「……请别忍着……都交给我……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……用手……是么……我明白了……」"
		ENDIF

	CASE "足交"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「用脚……侍奉……失礼了……♥」"
			CALL MESSAGE_BOX,@"「……力度我会留意……请您放松……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……用脚……竟要如此……」"
		ENDIF

	CASE "舔阴蒂","舔阴道","刺激龟头","真空口交","肛门指揉按摩","玩弄阴唇","G点指压","阴道指奸","肛门指奸","尿道口指弄","尿道口指奸","口内搅舌","压舌探喉"
		CALL KOJO_SHARE_ADVANCED_TRAIN_DISPATCH(ARGS:1, ARGS:2)

	CASE "正常位","后背位","对面坐位","背面坐位","骑乘位","对面立位","背面立位","强制骑乘位","背面骑乘位"
		CALL KOJO_CHS_VPOS_大和抚子口上1(ARGS:1, ARGS:2)

	CASE "Ａ正常位","Ａ后背位","Ａ对面坐位","Ａ背面坐位","Ａ骑乘位","Ａ对面立位","Ａ背面立位","强制Ａ骑乘位","Ａ背面骑乘位"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……后面也……若您想要……我会配合……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……请别……那、那里……」"
		ENDIF

	CASE "肛塞"
		CALL MESSAGE_BOX,@"「……后面要放入么……请、请慢些……」"

	CASE "尿道塞"
		CALL MESSAGE_BOX,@"「……那里……请您务必温柔……」"

	CASE "肛勾"
		CALL MESSAGE_BOX,@"「……后面被牵住……口又合不拢……妾身……只能把羞耻一并承下……」"

	CASE "贞操带"
		CALL MESSAGE_BOX,@"「……此处被锁住……妾身明白……阴道一侧……不得妄动……」"

	CASE "尾塞"
		CALL MESSAGE_BOX,@"「……尾饰……太过显眼……请您……莫要取笑妾身……」"

	CASE "舌锻口塞"
		CALL MESSAGE_BOX,@"「……呜……嗯……唔……」（口塞封唇，言语不成句，妾身仅能自喉间漏出呜咽与湿喘，以应主上）"

	CASE "打屁股","皮鞭抽打"
		CALL MESSAGE_BOX,@"「……请别太重……我会……忍住……」"

	CASEELSE
		CALL MESSAGE_BOX,@"「……是。若这是您的命令……我会配合。」"
	ENDSELECT

CASE "继续"
	SELECTCASE ARGS:1
	CASE "肛勾","尾塞"
		CALL MESSAGE_BOX,@"「……后面……仍坠坠地疼……妾身……会敛声……」"
	CASE "贞操带"
		CALL MESSAGE_BOX,@"「……锁具磨着皮肉……妾身……不敢妄动……」"
	CASE "舌锻口塞"
		CALL MESSAGE_BOX,@"「……嗯咕……哈……呜……」（舌根酸麻，字句全堵在塞具之后，只剩断续呜咽）"
	CASE "正常位","后背位","对面坐位","背面坐位","骑乘位","对面立位","背面立位","强制骑乘位","背面骑乘位"
		CALL KOJO_CHS_VPOS_大和抚子口上1(ARGS:1, ARGS:2)
	CASE "足交"
		CALL MESSAGE_BOX,@"「……脚心发热……但我还能继续……♥」"
	CASE "手淫","授乳手交"
		CALL MESSAGE_BOX,@"「……在我手里……跳得很厉害……♥」"
	CASEELSE
		CALL MESSAGE_BOX,@"「……我明白……继续……」"
	ENDSELECT

CASE "移除"
	SELECTCASE ARGS:1
	CASE "肛塞"
		CALL MESSAGE_BOX,@"「……取下了么……呼……多谢……」"
	CASE "尿道塞"
		CALL MESSAGE_BOX,@"「……谢谢……稍微轻松些了……」"
	CASE "肛勾"
		CALL MESSAGE_BOX,@"「……链条解了……后面……先容妾身缓一缓……」"
	CASE "贞操带"
		CALL MESSAGE_BOX,@"「……锁开了……胯间……仍有些发烫……」"
	CASE "尾塞"
		CALL MESSAGE_BOX,@"「……尾饰卸去……妾身……总算敢把腰挺直些……」"
	CASE "舌锻口塞"
		CALL MESSAGE_BOX,@"「……舌……能动了……多谢……」"
	CASEELSE
		CALL MESSAGE_BOX,@"「……结束了么……辛苦您了……」"
	ENDSELECT

CASEELSE
ENDSELECT
RETURN

