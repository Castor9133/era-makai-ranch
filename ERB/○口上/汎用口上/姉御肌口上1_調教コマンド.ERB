CASE "Ｖ指插入"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「はぁっ♥ 指头进来了啦啦♥ %MASTER_CALL()%のゆびがなかにぃ♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「うあぁっ！♥ 指が中にぃっ…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「んなっ！？ 何挿れてんだい！」"
		ENDIF
		RETURN
	ENDIF
	; [%PENIS_CALL()%] / [%VAGINA_CALL()%] / [%ANAL_CALL()%]：阴茎、阴道、肛门称呼
	; 与直接读 CSTR 不同：绝顶次数超阈值会进入「融化」称呼
	
	SIF ABL:Ｖ敏感度 >= 200 || ABL:Ｖ感觉 >= 10
		CALL MESSAGE_BOX,@"「お゛ーっ♥ %VAGINA_CALL()%呃♥ ゆびでなかであばれてっ♥♥ イっイくぅ♥♥」"
		
