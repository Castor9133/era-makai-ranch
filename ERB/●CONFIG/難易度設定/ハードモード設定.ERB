
;ハードモード設定
@HARDMODE_CONFIG

CLEARLINE LINECOUNT
PRINTL 进行＜困难模式＞的设定。
CALL PRINTL_WORD_COLOR("《 困难模式设置 》在游戏开始前或开发者模式下才可以更改。","黄")
PRINTL 如果该画面有任意一项为ON，并且不是[DEVELOP][CUSTOM][EASY]中的任何一项，则难度显示为[HARD]。
CALL PRINT_DIFFICULTY
DRAWLINE
FLAG_REF = 3700

;半減の場合STRを使う
;STR:噴乳量 = 6860
STR_REF = 6860 -20
FOR LOCAL,0,70
	SIF FLAGNAME:(LOCAL +FLAG_REF) == ""
		CONTINUE
	IF LOCAL == 20
		PRINTL
		PRINTL 《 参数减半 》
	ENDIF
	CALL PRINT_CONFIG_HARDMODE(LOCAL)
NEXT
CALL PRINTL_ALIGN(-5)
CALL ON_OFF_BUTTON_FOOTER
BINPUT
PRINTL
SELECTCASE RESULT
CASE 82
	PRINTL 对于配置设置中被切换为ON/OFF的项目，设置[ON]会将其反转，而不给出解释
	CALL ASK_ONOFF
	FLAG:跳过ON／OFF项目的详细信息并反转 = RESULT
CASE 98
	;日付が1日目以降かつ開発者モード以外の場合RETURN
	SIF !FLAG:开发者模式 && DAY
		RETURN
	PRINTL 是否将＜困难模式＞的设定全部恢复为OFF？
	CALL ASK_YN
	SIF !RESULT
		VARSET FLAG,0,3700,3800
CASE 99
	RETURN
CASEELSE
	CALL CHANGE_HARDMODE_CONFIG(RESULT)
ENDSELECT
RESTART



;ARG→LOCAL　FLAG_REFを足すことでフラグ番号
@PRINT_CONFIG_HARDMODE(ARG)

FLAG_NAME = %FLAGNAME:(ARG +FLAG_REF)%
SELECTCASE FLAG_NAME
CASEELSE
	IF ARG >= 20
		PRINTFORM [{ARG,2}] %STR:(STR_REF +ARG),32%
	ELSE
		PRINTFORM [{ARG,2}] %FLAG_NAME,32%
	ENDIF
	CALL PRINT_ONOFF(FLAG:FLAG_NAME)
ENDSELECT
PRINTL



;ARG→INPUT
@CHANGE_HARDMODE_CONFIG(ARG)

SIF !FLAG:开发者模式 && DAY
	RETURN
FLAG_NUM = ARG +FLAG_REF
FLAG_NAME = %FLAGNAME:FLAG_NUM%
CALL CHANGE_CONFIG_INVERTBIT
SIF RESULT
	RETURN
SELECTCASE FLAG_NAME
CASE "仅允许随机角色"
	PRINTL 如果打开的话，就不能进行[魔族行会]的[特殊门解放]、[奴隶探索]、[调取过去的记忆]。
	PRINTL （虽说是「仅限随机角色」，但通过推进游戏不会影响可以固定输入的奴隶）
	PRINTL 只想玩随机角色以及固定加入角色的人，或者想留下捆绑游戏的记录的人请这样做。
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "减半／喷乳量"
	PRINTL 搾乳时的喷乳量减少一半。
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "减半／母乳容量・生产力"
	PRINTL 奴隶的母乳容量和生产力减少一半。
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "减半／母乳出货价格"
	PRINTL 母乳出货时获得的资金减少一半。
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "减半／业务EXP获得量"
	PRINTL 事务日程执行时获得的EXP减少一半。
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "减半／性EXP获得量"
	PRINTL 调教日程执行时获得的EXP减少一半。
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "减半／战斗与伤害"
	PRINTL 战斗时，盟友（魔族方）对人类方造成的伤害减少一半。
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "减半／快感值"
	PRINTL 调教日程执行时对部位的性快感减少一半。
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT
ENDSELECT



