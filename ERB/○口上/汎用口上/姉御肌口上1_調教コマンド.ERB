; ARGS:0 场景；ARGS:1～ 用于更细分
@KOJO_GENERAL_姉御肌1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

; 进入本函数时 ARGS:0 固定为「调教命令」
; 按命令与情境分支；名称见 TRAIN.csv
; 当前流程：@COM 地之文 → 口上

SELECTCASE ARGS:1
CASE "揉胸","育乳按摩","浓厚母乳按摩","乳罐按摩"
	; 从此处起按变体分支；分支越多越有趣也越费工。
	; 分支方式自定，常按好感/陷落等状态分较省事。
	
	; 先看是否「首次」：EXP:(SELECTCOM +1000)++ 放在口上显示**之后**执行
	; 故该值为 0 表示该角色尚未经历过本命令
	; 细节略，用下方 IF 做首次即可
	; 隶属乳牛从未揉胸只挤奶…倒也可能
	; 写 \n 会换行；源码里用 Enter 换行不符合规范
	; 连续两次 CALL 只会显示其一，故不能靠双 CALL 凑换行
	
	IF !EXP:(SELECTCOM+1000)
		; 不直接显示，先 CALL MESSAGE_BOX 把候选台词放进「箱子」
		; 参考了触手宫氏口上
		; [MASTER_CALL]：对主人的称呼（如「主人」）
		; [SWEET_MASTER_CALL]：撒娇式称呼（如「主银～」）
		; [SELF_CALL]：第一人称（如「我」）
		; ♥ 显示时会变成心形符号
		
		;乳牛、隶属、洗脑时
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「%SWEET_MASTER_CALL()%♥ %SELF_CALL()%のおっぱいもみたいのかい♥♥\n　すきかってに、めちゃめちゃにしとくれ♥ %SELF_CALL()%のカラダは%MASTER_CALL()%の『モノ』なんだからさ♥♥」"
		
		; 用 ELSE 则不会进入随机候选池
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%のおっぱい、自由にいじっていいんだよ…♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「んっ…こんなの揉んで…楽しいのかい…？♥」"
		; 也可按素质等再分支
		ELSE
			CALL MESSAGE_BOX,@"「くそっ、触るんじゃないよ！」"
		ENDIF
		; 首次分支为确保只显示上述内容，此处 RETURN
		RETURN
		
	ENDIF
	;乳牛、隶属、洗脑时
	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「喂，♥ %SWEET_MASTER_CALL()%♥ %SELF_CALL()%のおっぱいめちゃめちゃにしてぇ♥♥」"
		CALL MESSAGE_BOX,@"「気が済むまでやりな…♥ %SELF_CALL()%のおっぱいは、%MASTER_CALL()%の『モノ』さ…♥♥」"
		CALL MESSAGE_BOX,@"「哈啊啊♥ おっぱいもまれて、ごくらくぅぅ…♥♥」"
		
		; 即使连续写多条，一次口上调用也只会随机显示其中一条
		; MESSAGE_BOX：向箱中投放 → 从箱中抽一条显示
		; 可按条件追加候选，例如胸围达丰乳以上时追加
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%のたわわに育ったおっぱい、たんと収穫しとくれ♥♥」"
		; 还可追加其它条件分支
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「%SELF_CALL()%みたいなちいさいおっぱいでも愛でてくれるんだね…♥♥」"
		; 本次调教 B 绝顶累计 100 次以上
		; 注：NOWEX 写在「调教命令」段多为死分支，此处用 EX 累计更合适
		; 适合写「再被○○就不行了」类临场感台词
		SIF EX:Ｂ绝顶 >= 100
			CALL MESSAGE_BOX,@"「ああぁっ♥♥ キちまう♥♥ 今おっぱいイジられたら、%SELF_CALL()%トンじまうっ♥♥」"
	
	ELSEIF ＃陷落状态／恋慕以上＃
		; 恋慕线可比上面略矜持
		CALL MESSAGE_BOX,@"「%SELF_CALL()%のおっぱい、満足するまで楽しんでいいんだよ…？♥」"
		CALL MESSAGE_BOX,@"「呵呵…♥ おっぱい揉みたいのかい…？♥♥」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「へへ…♥ %SELF_CALL()%の自慢のおっぱい、%MASTER_CALL()%の好きにしていいんだよ♥♥」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「こんな%SELF_CALL()%の小ぶりなおっぱいでも、%MASTER_CALL()%はいいって言ってくれるのかい…♥♥」"
		
	ELSEIF ＃陷落状态／陷落以上＃
		; 宜先写苛刻条件，否则易总命中上方分支
		CALL MESSAGE_BOX,@"「嗯…%MASTER_CALL()%はホントに乳が好きだね…♥」"
		CALL MESSAGE_BOX,@"「はいはい…満足するまでやっとくれ…♥」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「んっ…ったく…男ってのはデカけりゃそれでいいのかい…？ …ま、%MASTER_CALL()%が嬉しいんならそれでいいけど…」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「男ってのはデカいのが好きなんじゃないのかい…？%SELF_CALL()%のじゃ満足できないだろうに…\n　…満足そうなツラしてるね… ならいいけど…」"
	
	ELSEIF ＃陷落状态／屈服以上＃
		; 比下段更「认命」
		CALL MESSAGE_BOX,@"「んっ…こんな脂肪のかたまり…何がいいんだい…」"
		CALL MESSAGE_BOX,@"「もう好きにしとくれ…」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「はぁ…ったく…男ってのはデカけりゃそれでいいのかい…？」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「%SELF_CALL()%の小ぶりな乳イジって楽しいのかい…？\n　…あ、そう…楽しいのかい…」"
	
	ELSE
		; 无反抗刻印/枷锁但性格反抗 → 傲娇口吻
		CALL MESSAGE_BOX,@"「くそっ、離せ！気安くイジるんじゃないよ！」"
		CALL MESSAGE_BOX,@"「何好き勝手に揉んでんだい！」"
		CALL MESSAGE_BOX,@"「ちっ、気色悪い！なんだってんだい…！」"
	ENDIF
	; 揉胸分支到此…不短吧？
	
; 以下继续其它调教命令
CASE "榨乳"
	IF !EXP:(SELECTCOM+1000)
		; 按是否母乳体质分支
		IF MARK:母乳体质
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「んお゛お゛ーっ♥♥ みるく♥ みるくしぼられるぅ♥♥」"
			ELSEIF ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
				CALL MESSAGE_BOX,@"「んはぁっ♥ おっぱいしぼられるぅ♥♥」"
			ELSEIF ＃陷落状态／屈服以上＃
				CALL MESSAGE_BOX,@"「ああっ…♥ こんな、まるで『家畜』扱い…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「やめっ、触るな！%SELF_CALL()%は家畜になったつもりはないよ！」"
			ENDIF
		ELSE
			IF ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
				CALL MESSAGE_BOX,@"「んんっ、あっ♥ おっぱいしぼっても母乳は出ないぞ♥」"
			ELSEIF ＃陷落状态／屈服以上＃
				CALL MESSAGE_BOX,@"「っ…ああっ♥ 『家畜』みたいにしぼられても何も出せないって…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「やめっ、触るな！%SELF_CALL()%は家畜になったつもりはないよ！」"
			ENDIF
		ENDIF
		RETURN
	ENDIF
	IF MARK:母乳体质
		IF ABL:搾乳中毒 >= 10
			CALL MESSAGE_BOX,@"「あ゛ーっ♥♥ んお゛っ♥ はへっ♥♥ 更多♥ もっとしぼってぇ♥♥」"
			CALL MESSAGE_BOX,@"「んあ゛っ♥♥ みるくだすぅ♥ だすのきもちいいっ♥ あああ゛っ♥♥」"
			CALL MESSAGE_BOX,@"「クるクるっ♥ クるぅぅっ♥♥ みるく出してイくぅっ♥♥」"
		ENDIF
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「はーっ♥ はーっ♥ さくにゅう♥ さくにゅうもっと♥♥ %SELF_CALL()%のみるく絞り尽くして♥♥」"
			CALL MESSAGE_BOX,@"「はへっ♥ はへっ♥♥ %SWEET_MASTER_CALL()%♥ しぼられるのすきぃ♥ ちくびからみるくだすのすきぃぃ♥♥」"
			CALL MESSAGE_BOX,@"「おねがいっ♥ しぼってっ♥ しぼられるのガマンできないっ♥ おっぱいガマンしてくれないのっ♥♥」"
			CALL MESSAGE_BOX,@"「哈啊啊♥ %SELF_CALL()%のおっぱいにっ♥ %MASTER_CALL()%のゆびがくいこんでくぅ♥♥」"
			SIF ABL:胸围大小 >= BUSTSIZE_爆乳
				CALL MESSAGE_BOX,@"「はぁーっ…はぁーっ♥ %SELF_CALL()%のたっぷりおっぱい、みるくだしたがっててガマンできないよ♥♥」"
			SIF EX:Ｂ绝顶 >= 100
				CALL MESSAGE_BOX,@"「嗯~~♥♥ おっぱいイくっ♥♥ おっぱいであたまいっぱいになるぅぅっ♥♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「%SELF_CALL()%のおっぱい、たくさんしぼっとくれ…♥」"
			CALL MESSAGE_BOX,@"「ほら…♥ 好きなだけしぼりな…♥♥」"
			SIF ABL:胸围大小 >= BUSTSIZE_丰乳
				CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%のいっぱい母乳詰まったおっぱい、好きなだけしぼりな♥♥」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「んっ…しぼるのかい…？♥」"
			CALL MESSAGE_BOX,@"「はいはい…好きなだけやりな…」"
			SIF ABL:胸围大小 >= BUSTSIZE_丰乳
				CALL MESSAGE_BOX,@"「んっ…ったく…男ってのはデカけりゃそれでいいのかい…？\n　…ま、%MASTER_CALL()%が嬉しいんならそれでいいけど…」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「んっ…少し苦しいよ…♥」"
			CALL MESSAGE_BOX,@"「いいさ…好きにしな…」"
			SIF ABL:胸围大小 >= BUSTSIZE_丰乳
				CALL MESSAGE_BOX,@"「はぁ…ったく…男ってのはデカけりゃそれでいいのかい…？」"
		ELSE
			CALL MESSAGE_BOX,@"「やめろっ！しぼるんじゃない！」"
			CALL MESSAGE_BOX,@"「くそっ離せ！%SELF_CALL()%は家畜になった覚えはないよ！」"
			CALL MESSAGE_BOX,@"「くっ…気色悪いね…！なんだってんだい！」"
		ENDIF
	ENDIF

CASE "拧乳头"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「啊♥ 哦呼呼♥ もっとちくびこりこりしてぇ♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「んっ！♥ ち、乳首そんなされると…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「嗯！ 何気安く乳首イジってんだい！」"
		ENDIF
		RETURN
	ENDIF
	IF ABL:Ｎ敏感度 >= 200 || ABL:Ｎ感觉 >= 10
		CALL MESSAGE_BOX,@"「啊♥ そこっ♥♥ びんかんなとこっ♥♥」"
		CALL MESSAGE_BOX,@"「ちくびぃ♥ ちくびくにくにってされてぇぇ♥♥ がまんできないぃぃ♥♥」"
		CALL MESSAGE_BOX,@"「嗯哦~♥♥ ちくびひっぱらないでぇぇ♥ あたまばかになるぅぅ♥♥」"
		CALL MESSAGE_BOX,@"「ちくびぃ♥ 啊♥ ちくびすきぃぃ♥ もっとちくびいじめてぇぇ♥♥」"
		SIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「%SWEET_MASTER_CALL()%♥ ちくびもっとこりこりしてぇぇ♥♥」"
	ENDIF
	
	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「はーっ♥ あーっ♥ もっと%SELF_CALL()%のちくびくにくにしてぇ♥♥」"
		CALL MESSAGE_BOX,@"「喂，♥ さきっぽがジンジンするぅ♥」"
	ELSEIF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「そんな乳首こりこりされると…疼くのガマンできないよ…♥」"
		CALL MESSAGE_BOX,@"「乳首ばっかりイジられると…切ないよ…♥」"
	ELSEIF ＃陷落状态／屈服以上＃
		CALL MESSAGE_BOX,@"「はぁっ♥ さっきから、乳首ばっか…んんっ♥」"
		CALL MESSAGE_BOX,@"「呼♥ ♥ 乳首っ転がされっ♥」"
	ELSE
		CALL MESSAGE_BOX,@"「なんだってんだい…乳首ばっかイジってぇ…♥」"
		CALL MESSAGE_BOX,@"「啊♥ ううっ♥ 乳首、つま、むなぁ…っ」"
	ENDIF

CASE "Ｃ爱抚"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「啊♥ クリトリスっ♥ びりってするぅ♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「んひっ！♥ クリトリスいじられると…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「なっ！？ どこ触ってんだい！」"
		ENDIF
		RETURN
	ENDIF
	SIF ABL:Ｃ敏感度 >= 200 || ABL:Ｃ感觉 >= 10
		CALL MESSAGE_BOX,@"「そこびんかんだってぇ♥ カラダはねちゃうぅ♥♥」"
		
	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「んんんっ♥ こりこりってぇ♥ くにくにってしてぇ♥ もっと%SELF_CALL()%のクリトリスイジってぇぇ♥♥」"
		CALL MESSAGE_BOX,@"「んおお♥ びんかんなとこ♥ くりくりされたらぁ♥ あ゛ひ♥♥」"
	ELSEIF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「クリトリス…イジられると気持ちいい…♥」"
		CALL MESSAGE_BOX,@"「啊♥ そこっ♥ もっとイジくり回してっ♥」"
	ELSEIF ＃陷落状态／屈服以上＃
		CALL MESSAGE_BOX,@"「んひっ♥ そこ敏感だってのにぃ…♥」"
		CALL MESSAGE_BOX,@"「う…っ♥ クリトリス…しびれる…♥」"
