
;事務作業
@WORK_FINANCE
#DIM FIRST_WORKLOAD

WORKER = CMATCH(CSTR:日程,"事务")
SIF !WORKER
	RETURN
PRINTL 　　　《 事务 》
FIRST_WORKLOAD = FLAG:事务工作量
CALL WORKER_ABL_SET("事务")
CALL RANDOM_CHARA_SCHEDULE_COMMON("事务")
FLAG:事务工作量 = LIMIT(FLAG:事务工作量,0,20)

;前後の事務作業量表示
PRINTFORML 事务工作量：{FIRST_WORKLOAD} → {FLAG:事务工作量}
CALL SCHEDULE_ABL_MARK_BULK(0,"事务")
PRINTW
DRAWLINE



;抽選したキャラの仕事表示
@WORK_FINANCE_ENTRANCE

IF !EXP:执行次数／事务
	KOJO_TYPE = 初次
ELSE
	KOJO_TYPE = 普通
ENDIF
CALL WORK_FINANCE_BEGIN_MESSAGE
CALL WORK_FINANCE_ABL_MESSAGE
CALL WORK_FINANCE_RUN
FLAG:上次显示角色ID／事务 = CFLAG:ID



;実行内容
@WORK_FINANCE_RUN

;夜に作業は別関数に飛ばすので考えなくて大丈夫
;体力が足りないとダメ
IF !BASE:体力
	PRINTFORML 积攒了很多疲劳的%CALLNAME%虽然还想工作，但不久就睡着了…
	HEAL_PRINT_DONE = 0
	CALL FALL_ASLEEP
	RETURN
ENDIF
CALL HP_COST(70,1)
FLAG:事务工作量 -= ABL:事务
PRINTFORM %CALLNAME_DIGIT()% HP-{COST} 事务工作-{ABL:事务,2} 
CALL EXP_UP("事务")
CALL WORK_LOVE_UP
CALL SCHEDULE_AFTER_CATTLE_MIND_MINUS
CALL MIND_PALAM_AFTER_PRINT(1)
EXP:执行次数／事务 ++
EXP:区间执行次数／事务 ++
CFLAG:行动完毕 = 1



