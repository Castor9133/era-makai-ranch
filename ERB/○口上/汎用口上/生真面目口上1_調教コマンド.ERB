; ARGS:0 场景；ARGS:1～ 用于更细分
@KOJO_GENERAL_生真面目1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

; 进入本函数时 ARGS:0 固定为「调教命令」
; 按命令与情境分支；名称见 TRAIN.csv
; 当前流程：@COM 地之文 → 口上

SELECTCASE ARGS:1
CASE "揉胸","育乳按摩","浓厚母乳按摩","乳罐按摩"
	; 从此处起按变体分支；分支越多越有趣也越费工。
	; 分支方式自定，常按好感/陷落等状态分较省事。
	
	; 先看是否「首次」：EXP:(SELECTCOM +1000)++ 放在口上显示**之后**执行
	; 故该值为 0 表示该角色尚未经历过本命令
	; 细节略，用下方 IF 做首次即可
	; 隶属乳牛从未揉胸只挤奶…倒也可能
	; 写 \n 会换行；源码里用 Enter 换行不符合规范
	; 连续两次 CALL 只会显示其一，故不能靠双 CALL 凑换行
	
	; 首次
	IF !EXP:(SELECTCOM+1000)
		; 不直接显示，先 CALL MESSAGE_BOX 把候选台词放进「箱子」
		; 参考了触手宫氏口上
		; [MASTER_CALL]：对主人的称呼（如「主人」）
		; [SWEET_MASTER_CALL]：撒娇式称呼（如「主银～」）
		; ↑ 用后常接 ♥；插在句中易显违和
		; [SELF_CALL]：第一人称（如「我」）
		; ♥ 显示时会变成心形符号
		
		;乳牛、隶属、洗脑时
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「%SWEET_MASTER_CALL()%♥♥ 你要摸%SELF_CALL()%的胸部呢♥♥♥\n　揉啊揉，随便玩弄吧♥ %SELF_CALL()%的胸部是%MASTER_CALL()%的东西哦♥♥♥」"
		
		; 用 ELSE 则不会进入随机候选池
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%的胸部，尽管随意抚摸…♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「嗯…摸胸这种事…开心吗…？♥」"
		; 也可按素质等再分支
		ELSEIF TALENT:害羞 && TFLAG:Ｎ露出
			CALL MESSAGE_BOX,@"「嘿呀！不、不行啦！别摸胸啦！！」"
		ELSE
			CALL MESSAGE_BOX,@"「不要，不要碰！」"
		ENDIF
		; 首次分支为确保只显示上述内容，此处 RETURN
		RETURN
		
	ENDIF
	
	; 第二次及以后
	;乳牛、隶属、洗脑时
	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「啊♥ %SWEET_MASTER_CALL()%♥♥ %SELF_CALL()%的胸部，请随意玩弄吧♥♥♥」"
		CALL MESSAGE_BOX,@"「请随意…♥ %SELF_CALL()%的胸部，属于%MASTER_CALL()%的…♥♥♥」"
		CALL MESSAGE_BOX,@"「呼呼♥ 摸摸胸部，感觉好爽…♥♥♥」"
		
		; 即使连续写多条，一次口上调用也只会随机显示其中一条
		; MESSAGE_BOX：向箱中投放 → 从箱中抽一条显示
		; 可按条件追加候选，例如胸围达丰乳以上时追加
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%的大胸部，为了%MASTER_CALL()%而成长啦♥♥」"
			
		; 还可追加其它条件分支
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「%MASTER_CALL()%…♥ %SELF_CALL()%的小胸部也受到你的爱戴…♥♥」"
			
		; 本次调教 B 绝顶累计 100 次以上
		; 注：NOWEX 写在「调教命令」段多为死分支，此处用 EX 累计更合适
		; 适合写「再被○○就不行了」类临场感台词
		SIF EX:Ｂ绝顶 >= 100
			CALL MESSAGE_BOX,@"「啊——♥♥♥ 不行了啦♥♥♥ 现在摸胸，%SELF_CALL()%♥♥♥」"
		
		; 调教中可查污渍：GETBIT(STAIN:乳房,4) 判定胸部是否附着润滑液
		; 详见 Stain.csv
		SIF GETBIT(STAIN:乳房,4)
			CALL MESSAGE_BOX,@"「哎呀♥ 润滑液弄得%SELF_CALL()%的胸部滑溜溜的，啊啊♥♥♥  发出淫靡的声音♥♥♥」"
	
	ELSEIF ＃陷落状态／恋慕以上＃
		; 恋慕线可比上面略矜持
		CALL MESSAGE_BOX,@"「%MASTER_CALL()%…♥ %SELF_CALL()%的胸部，喜欢吗…？♥」"
		CALL MESSAGE_BOX,@"「请尽情…♥ 喜欢的话，随意摸摸吧…♥♥」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%的大胸部，为了%MASTER_CALL()%而成长啦♥♥」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「%MASTER_CALL()%…♥ %SELF_CALL()%的小胸部也受到你的爱戴…♥♥」"
		
	ELSEIF ＃陷落状态／陷落以上＃
		; 宜先写苛刻条件，否则易总命中上方分支
		CALL MESSAGE_BOX,@"「嗯…光是胸部吗…♥」"
		CALL MESSAGE_BOX,@"「可以了，尽管随意…喜欢的话…」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「嗯…男人总是只看胸部… …不过，%MASTER_CALL()%的话还算不错…」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「%SELF_CALL()%的胸被摸… …开心吗…？…嗯…」"
	
	ELSEIF ＃陷落状态／屈服以上＃
		; 比下段更「认命」
		CALL MESSAGE_BOX,@"「嗯…光是胸部吗…♥」"
		CALL MESSAGE_BOX,@"「可以了，尽管随意…喜欢的话…」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「嗯…男人总是只看胸部…」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「%SELF_CALL()%的胸被摸… …开心吗…？…嘿嘿…」"
	
	ELSE
		; 无反抗刻印/枷锁但性格反抗 → 傲娇口吻
		; 也可按素质等再分支
		IF TALENT:害羞 && TFLAG:Ｎ露出
			CALL MESSAGE_BOX,@"「不行，不行！别摸胸部！」"
			CALL MESSAGE_BOX,@"「嗯呀！不、不可以啦！」"
			CALL MESSAGE_BOX,@"「呀！不要啦，被男人摸胸部了…！」"
		ELSE
			CALL MESSAGE_BOX,@"「不要，不要碰！」"
			; 曾写错：!NOWEX:总绝顶 易恒真；应看本次调教累计绝顶次数
			SIF EX:总绝顶 < 5
				CALL MESSAGE_BOX,@"「嗯…一点感觉都没有！」"
			SIF TFLAG:眼罩
				CALL MESSAGE_BOX,@"「嗯…用蒙眼这样做…是这样吗…」"
			SIF TFLAG:拘束BIT
				CALL MESSAGE_BOX,@"「嗯…束缚起来然后做这种事…是这样吗…」"
		ENDIF
	ENDIF
	; 揉胸分支到此…不短吧？
	
; 以下继续其它调教命令
CASE "榨乳"
	IF !EXP:(SELECTCOM+1000)
		; 按是否母乳体质分支
		IF MARK:母乳体质
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「奶奶♥♥♥ 乳汁流出来咯♥♥♥」"
			ELSEIF ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
				CALL MESSAGE_BOX,@"「哎呀♥ 像小牛一样咯♥♥」"
			ELSEIF ＃陷落状态／屈服以上＃
				CALL MESSAGE_BOX,@"「啊啊…♥ 明明这样很舒服……可是不行……啊啊…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「不、不要啊！%SELF_CALL()%可不是奶牛！」"
			ENDIF
		ELSE
			IF ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
				CALL MESSAGE_BOX,@"「啊呀♥ 像小牛一样这样弄，可是母乳还是不会流出来的哦♥」"
			ELSEIF ＃陷落状态／屈服以上＃
				CALL MESSAGE_BOX,@"「嘿呀♥ 摸胸部这样子，什么也不会流出来的哦…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「不、不要啊！%SELF_CALL()%可不是奶牛！」"
			ENDIF
		ENDIF
		RETURN
	ENDIF
	IF MARK:母乳体质
		IF ABL:搾乳中毒 >= 10
			CALL MESSAGE_BOX,@"「啊——♥♥♥ 呜♥♥ 呀呀♥♥♥ 挤奶…喜欢♥♥♥」"
			CALL MESSAGE_BOX,@"「奶、奶水♥♥♥ 流出来了♥♥♥ 啊——♥ 啊啊啊♥♥♥」"
			CALL MESSAGE_BOX,@"「来了来了来了来了♥♥♥ 乳房喷喷地喷出来了♥♥♥」"
		ENDIF
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「%SWEET_MASTER_CALL()%♥♥ 请从母牛%CALLNAME%那里挤出很多乳汁吧♥♥♥」"
			CALL MESSAGE_BOX,@"「啊——♥♥ %SWEET_MASTER_CALL()%♥♥ 我喜欢挤奶♥ %SELF_CALL()%很幸福哦♥♥♥」"
			CALL MESSAGE_BOX,@"「请随意…♥ %SELF_CALL()%的胸部，属于%MASTER_CALL()%的…♥♥♥」"
			CALL MESSAGE_BOX,@"「呼呼♥ 摸摸胸部，感觉好爽…♥♥♥」"
			SIF ABL:胸围大小 >= BUSTSIZE_爆乳
				CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%的大胸部，为了%MASTER_CALL()%而成长啦♥♥」"
			SIF EX:Ｂ绝顶 >= 100
				CALL MESSAGE_BOX,@"「啊——♥♥♥ 不行了啦♥♥♥ 现在摸胸，%SELF_CALL()%♥♥♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「%MASTER_CALL()%…♥ %SELF_CALL()%的胸部，喜欢吗…？♥」"
			CALL MESSAGE_BOX,@"「请尽情…♥ 请随便摸吧…♥♥」"
			SIF ABL:胸围大小 >= BUSTSIZE_丰乳
				CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%的大胸部，为了%MASTER_CALL()%而成长啦♥♥」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「嗯…光是胸部吗…♥」"
			CALL MESSAGE_BOX,@"「可以了，尽管随意…喜欢的话…」"
			SIF ABL:胸围大小 >= BUSTSIZE_丰乳
				CALL MESSAGE_BOX,@"「嗯…男人总是只看胸部… …不过，%MASTER_CALL()%的话还算不错…」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「嗯…光是胸部吗…♥」"
			CALL MESSAGE_BOX,@"「可以了，尽管随意…喜欢的话…」"
			SIF ABL:胸围大小 >= BUSTSIZE_丰乳
				CALL MESSAGE_BOX,@"「嗯…男人总是只看胸部…」"
		ELSE
			IF TALENT:害羞 && TFLAG:Ｎ露出
				CALL MESSAGE_BOX,@"「不行，不行！别摸胸部！」"
				CALL MESSAGE_BOX,@"「嗯呀！不、不可以啦！」"
				CALL MESSAGE_BOX,@"「呀！不，不要，男人在摸我的胸部…！」"
			ELSE
				CALL MESSAGE_BOX,@"「不要，不要碰！」"
				SIF EX:总绝顶 < 5
					CALL MESSAGE_BOX,@"「嗯…一点感觉都没有！」"
				SIF TFLAG:眼罩
					CALL MESSAGE_BOX,@"「嗯…用蒙眼这样做…是这样吗…」"
				SIF TFLAG:拘束BIT
					CALL MESSAGE_BOX,@"「嗯…束缚起来然后做这种事…是这样吗…」"
			ENDIF
		ENDIF
	ENDIF

CASE "拧乳头"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「啊♥ 哦呼呼♥ 乳头被揉捏的感觉好舒服哦♥♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「咿呀啊！♥ 请不要欺负我的乳头…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「呀啊！ 乳头不行…♥」"
		ENDIF
		RETURN
	ENDIF
	IF ABL:Ｎ敏感度 >= 200 || ABL:Ｎ感觉 >= 10
		CALL MESSAGE_BOX,@"「啊♥ 不要啦啦♥♥ 乳头好敏感哦♥♥♥」"
		CALL MESSAGE_BOX,@"「乳头啦啦♥♥ 乳头太过敏感了啦啦啦♥♥♥」"
		SIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「%SWEET_MASTER_CALL()%♥♥ 好狡猾♥♥ 你知道%CALLNAME%的弱点哦♥♥♥」"
	ENDIF
	
	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「咕噜咕噜，搓搓搓得舒服♥ 再多欺负%SELF_CALL()%的乳头吧♥♥♥」"
		CALL MESSAGE_BOX,@"「啊♥ 光是那里不行哦♥」"
	ELSEIF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「乳头被揉捏的感觉好舒服…♥」"
	ELSEIF ＃陷落状态／屈服以上＃
		CALL MESSAGE_BOX,@"「光是乳头的话，太…啊♥」"
	ELSE
		CALL MESSAGE_BOX,@"「停，停下…光是乳头不行…♥」"
	ENDIF

CASE "Ｃ爱抚"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「啊♥ 阴蒂好舒服啊♥ 太舒服了呀呀♥♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「咿呀啊！♥ 阴蒂不行…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「呼哇啊！？♥  不可以摸那里！♥」"
		ENDIF
		RETURN
	ENDIF
	SIF ABL:Ｃ敏感度 >= 200 || ABL:Ｃ感觉 >= 10
		CALL MESSAGE_BOX,@"「阴蒂被玩弄真是太过分了啦啦♥♥ 太敏感了哦♥♥♥」"
		
	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「咕噜咕噜，搓搓搓得舒服♥ 继续玩弄%SELF_CALL()%的私处吧啦啦♥♥♥」"
	ELSEIF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「阴蒂…好舒服…♥」"
	ELSEIF ＃陷落状态／屈服以上＃
		CALL MESSAGE_BOX,@"「那里不行哦…♥」"
	ELSE
		CALL MESSAGE_BOX,@"「攻击女人的弱点…真卑鄙…♥」"
	ENDIF

CASE "Ｖ指插入"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「嗯咿♥ 指头进来了啦啦♥ %MASTER_CALL()%的手指啦啦♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
