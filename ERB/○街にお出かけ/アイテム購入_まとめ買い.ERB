
;まとめ買い入り口
;ARG→ページ　0だとページなし
;ARGS→店
@BULK_BUYING_COMMON(ARG,ARGS)

;SELECT_ITEMは0に戻しておく
SELECT_ITEM = 0
PRINTL 使用当前开销／持有金购买可购买的物品，按照物品ID进行一次性购买。
PRINTFORML 当前：[\@ FLAG:购物／开销记账 ? 经费 # 持有金 \@]购买
PRINTL

;IDを消耗品と一点ものにしたせいで完全一括購入できそうにねえや
IF GROUPMATCH(ARGS,"家具店")
	CALL PRINTL_WORD_COLOR("　无消耗品库存","灰")
ELSE
	PRINTL [ 0] 指定数量一次性购买店内消耗品
ENDIF
IF GROUPMATCH(ARGS,"宠物","时尚")
	CALL PRINTL_WORD_COLOR("　单品商品无库存","灰")
ELSE
	PRINTL [ 1] 一次性购买店内单品商品
ENDIF
IF GROUPMATCH(ARGS,"时尚")
	PRINT [ 2] 
	CALL PRINT_CLOTHE_CATEGORY(ARG)
	PRINTL 指定数量一次性购买该类别服装
ENDIF
PRINTL

IF FLAG:最大日销售额 -MONEY:经费计上 > 0
	PRINTL [90] 切换开销／持有金
ELSE
	PRINTL （使用持有金购买）
ENDIF
PRINTL [99] 取消
BINPUT
INPUT_NUM = RESULT
CALL MANYL(3)
SELECTCASE INPUT_NUM
CASE 0
	CALL BULK_BUYING_USING(ARGS)
CASE 1
	CALL BULK_BUYING_ONES(ARGS)
CASE 2
	CALL BULK_BUYING_CLOTHE_CATEGORY(ARG)
CASE 90
	INVERTBIT FLAG:购物／开销记账,0
	CALL MANYL(5)
	RESTART
ENDSELECT



;衣服カテゴリ表示
;ARG→PAGE
@PRINT_CLOTHE_CATEGORY(ARG)

SELECTCASE ARG
CASE 1
	PRINT 《 工作衣服 》
CASE 2
	PRINT 《 内衣 》和《 饰品 》
CASE 3
	PRINT 《 成人内衣 》和《 乳牛服装 》
CASE 4
	PRINT 《 人类服装 》
CASE 5
	PRINT 《 异世界的服装 》
CASE 6
	PRINT 《 成人装束 》
ENDSELECT



;購入ID範囲取得
;ARG→ページ
;ARGS→店
;ARGS:1→消耗品or一点ものorページ内
@BULK_BUYING_GET_ITEMID(ARG,ARGS,ARGS:1)

;一旦10000にしてバグチェック
ITEM_ID_MIN = 10000
SELECTCASE ARGS
CASE "成人"
	SELECTCASE ARGS:1
	CASE "消耗品"
		ITEM_ID_MIN = 250
		ITEM_ID_MAX = 300
	CASE "独特的商品"
		ITEM_ID_MIN = 500
		ITEM_ID_MAX = 550
	ENDSELECT

CASE "家居中心"
	SELECTCASE ARGS:1
	CASE "消耗品"
		ITEM_ID_MIN = 200
		ITEM_ID_MAX = 250
	CASE "独特的商品"
		ITEM_ID_MIN = 70
		ITEM_ID_MAX = 80
	ENDSELECT

CASE "时尚"
	;ページ内の場合だけARG使う
	SELECTCASE ARGS:1
	CASE "消耗品"
		;要は全部
		ITEM_ID_MIN = 1000
		ITEM_ID_MAX = 2000
	CASE "独特的商品"		;ないです
	CASE "在页面内"
		SELECTCASE ARG
		CASE 0
			ITEM_ID_MIN = 1020
			ITEM_ID_MAX = 1100
		CASE 1
			ITEM_ID_MIN = 1100
			ITEM_ID_MAX = 1150
		CASE 2
			ITEM_ID_MIN = 1150
			ITEM_ID_MAX = 1200
		CASE 3
			ITEM_ID_MIN = 1200
			ITEM_ID_MAX = 1300
		CASE 4
			ITEM_ID_MIN = 1300
			ITEM_ID_MAX = 1350
		CASE 5
			ITEM_ID_MIN = 1350
			ITEM_ID_MAX = 1400
		CASE 6
			ITEM_ID_MIN = 1400
			ITEM_ID_MAX = 1450
		CASE 7
			ITEM_ID_MIN = 1450
			ITEM_ID_MAX = 1500
		CASE 8
			ITEM_ID_MIN = 1500
			ITEM_ID_MAX = 1600
		CASE 9
			ITEM_ID_MIN = 1600
			ITEM_ID_MAX = 1700
		ENDSELECT
	ENDSELECT

CASE "宠物"
	;消耗品だけ
	ITEM_ID_MIN = 300
	ITEM_ID_MAX = 350

CASE "家具店"
	;一点ものだけ
	ITEM_ID_MIN = 550
	ITEM_ID_MAX = 600
ENDSELECT
IF ITEM_ID_MIN == 10000
	CALL PRINTL_WORD_COLOR("！存在物品ID参考错误。如果看到此消息，请通知我，因为系统可能无法正常运作。","黄")
	WAIT
ENDIF



;一点もの一括購入
;ARGS→店
@BULK_BUYING_ONES(ARGS)

CALL BULK_BUYING_GET_ITEMID(0,ARGS,"独特的商品")
PRINTFORML 是否要按照列表前面的顺序一次性购买＜%ARGS%＞类别的独特物品？
SIF ARGS == "家居中心"
	PRINTL ·＜魔力储存器＞2种对象外。
PRINTL （如果开销／持有金不足，将不会进行后续购买）
CALL ASK_YN
SIF RESULT
	RETURN

;一括購入そのまま使える
IF FLAG:购物／开销记账
	CALL BULK_BUYING_NOEXIST_BUDGET
ELSE
	CALL BULK_BUYING_NOEXIST_MONEY
ENDIF

;RESULTでメッセージ変更
IF RESULT == 1
	PRINTL 无法购买物品。
ELSEIF RESULT == 2
	PRINTL 《 已购买所有物品 》
ENDIF
PRINTW



;経費計上未所持まとめ買い
@BULK_BUYING_NOEXIST_BUDGET

;記録
MONEY_BEFORE = MONEY:经费计上
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	SIF !ITEMPRICE:LOCAL || ITEM:LOCAL
		CONTINUE
	
	;衣服は購入可能か別に見る
	CALL CLOTHE_CAN_BUY_FLAG(LOCAL)
	SIF RESULT
		CONTINUE
	
	;予算不足のときおわり
	SIF MONEY:经费计上 +ITEMPRICE:LOCAL > FLAG:最大日销售额
		BREAK
	ITEM:LOCAL ++
	MONEY:经费计上 += ITEMPRICE:LOCAL
	CALL PRINTL_WORD_COLOR,@"已购买<%ITEMNAME:LOCAL%>。","浅蓝色"
NEXT
PRINTFORML 使用金额：%VALUE_DIGIT(MONEY:经费计上 -MONEY_BEFORE)%G

;RESULTを変えて元関数でメッセージ出す
IF MONEY_BEFORE == MONEY:经费计上
	RETURN 1

;LOCAL=ITEM_ID_MAXなら全部
ELSEIF LOCAL >= ITEM_ID_MAX
	RETURN 2
ENDIF



;所持金未所持まとめ買い
@BULK_BUYING_NOEXIST_MONEY

MONEY_BEFORE = MONEY
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	SIF !ITEMPRICE:LOCAL || ITEM:LOCAL
		CONTINUE
	CALL CLOTHE_CAN_BUY_FLAG(LOCAL)
	SIF RESULT
		CONTINUE
	
	;所持金不足のときおわり
	SIF ITEMPRICE:LOCAL > MONEY
		BREAK
	ITEM:LOCAL ++
	MONEY -= ITEMPRICE:LOCAL
	CALL PRINTL_WORD_COLOR,@"已购买<%ITEMNAME:LOCAL%>。","浅蓝色"
NEXT
PRINTFORML 使用金额：%VALUE_DIGIT(MONEY_BEFORE -MONEY)%G
IF MONEY_BEFORE == MONEY
	RETURN 1
ELSEIF LOCAL >= ITEM_ID_MAX
	RETURN 2
ENDIF



;消耗品まとめ買い
;ARGS→店
@BULK_BUYING_USING(ARGS)

CALL BULK_BUYING_GET_ITEMID(0,ARGS,"消耗品")
PRINTFORML 是否要按照列表前面的顺序一次性购买＜%ARGS%＞类别的消耗品？
PRINTL （如果开销／持有金不足，将不会进行后续购买）
PRINTLC [ 0] 取消
PRINTLC [ 5] 购买5个
PRINTL [10] 购买10个
PRINTL 或输入1～100之间的任意购买数量。
INPUT
SIF RESULT <= 0 || RESULT > 100
	RETURN
IF FLAG:购物／开销记账
	CALL BULK_BUYING_USING_BUDGET(RESULT,ARGS)
ELSE
	CALL BULK_BUYING_USING_MONEY(RESULT,ARGS)
ENDIF
IF RESULT == 1
	PRINTL 无法购买物品。
ELSEIF RESULT == 2
	PRINTL 《 已购买所有物品 》
ENDIF
PRINTW



;衣服のページ内でまとめ買い
;ARG→PAGE
@BULK_BUYING_CLOTHE_CATEGORY(ARG)

;ここでページ番号使う
CALL BULK_BUYING_GET_ITEMID(ARG,"时尚","在页面内")
CALL PRINT_CLOTHE_CATEGORY(ARG)
PRINTL 是否要按照列表前面的顺序一次性购买该类别的服装？
PRINTL （如果开销／持有金不足，将不会进行后续购买）
PRINTLC [ 0] 取消
PRINTLC [ 5] 购买5个
PRINTL [10] 购买10个
PRINTL 或输入1～100之间的任意购买数量。
INPUT
SIF RESULT <= 0 || RESULT > 100
	RETURN
IF FLAG:购物／开销记账
	CALL BULK_BUYING_USING_BUDGET(RESULT,"时尚")
ELSE
	CALL BULK_BUYING_USING_MONEY(RESULT,"时尚")
ENDIF
IF RESULT == 1
	PRINTL 无法购买物品。
ELSEIF RESULT == 2
	PRINTL 《 已购买所有物品 》
ENDIF
PRINTW



;経費計上消耗品まとめ買い
;ARG→購入数
;ARGS→店
@BULK_BUYING_USING_BUDGET(ARG,ARGS)

MONEY_BEFORE = MONEY:经费计上
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	SIF !ITEMPRICE:LOCAL
		CONTINUE
	CALL CLOTHE_CAN_BUY_FLAG(LOCAL)
	SIF RESULT
		CONTINUE
	
	;予算不足のときおわり
	SIF MONEY:经费计上 +ITEMPRICE:LOCAL *ARG > FLAG:最大日销售额
		BREAK
	ITEM:LOCAL += ARG
	MONEY:经费计上 += (ITEMPRICE:LOCAL *ARG)
	
	;衣服だと「着」にしとく
	IF ARGS == "时尚"
		CALL PRINTL_WORD_COLOR,@"购买了＜%ITEMNAME:LOCAL%＞{ARG}套。","浅蓝色"
	ELSE
		CALL PRINTL_WORD_COLOR,@"购买了＜%ITEMNAME:LOCAL%＞{ARG}件。","浅蓝色"
	ENDIF
NEXT
PRINTFORML 使用金额：%VALUE_DIGIT(MONEY:经费计上 -MONEY_BEFORE)%G
IF MONEY_BEFORE == MONEY:经费计上
	RETURN 1
ELSEIF LOCAL >= ITEM_ID_MAX
	RETURN 2
ENDIF



;所持金消耗品まとめ買い
@BULK_BUYING_USING_MONEY(ARG,ARGS)

MONEY_BEFORE = MONEY
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	SIF !ITEMPRICE:LOCAL
		CONTINUE
	CALL CLOTHE_CAN_BUY_FLAG(LOCAL)
	SIF RESULT
		CONTINUE
	
	;所持金不足のときおわり
	SIF ITEMPRICE:LOCAL *ARG > MONEY
		BREAK
	ITEM:LOCAL += ARG
	MONEY -= (ITEMPRICE:LOCAL *ARG)
	IF ARGS == "时尚"
		CALL PRINTL_WORD_COLOR,@"购买了＜%ITEMNAME:LOCAL%＞{ARG}套。","浅蓝色"
	ELSE
		CALL PRINTL_WORD_COLOR,@"购买了＜%ITEMNAME:LOCAL%＞{ARG}件。","浅蓝色"
	ENDIF
NEXT
PRINTFORML 使用金额：%VALUE_DIGIT(MONEY_BEFORE -MONEY)%G
IF MONEY_BEFORE == MONEY
	RETURN 1
ELSEIF LOCAL >= ITEM_ID_MAX
	RETURN 2
ENDIF






