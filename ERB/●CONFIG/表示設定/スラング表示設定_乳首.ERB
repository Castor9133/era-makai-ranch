
;乳首スラング設定
@SLANG_CONFIG_NIPPLE

CLEARLINE LINECOUNT
PRINTL 请选择以地文等形式显示的乳头黑话候选词。
DRAWLINE
PRINTLC [ 0] 「乳首」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／乳头,0),1)
PRINTLC [ 1] 「乳头」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／乳头,1),1)
PRINTLC [ 2] 「奶头」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／乳头,2),1)
PRINTLC [ 3] 「乳宝石」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／乳头,3),1)
PRINTLC [ 4] 「Nipple」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／乳头,4),1)
PRINTLC [ 5] 「葡萄」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／乳头,5),1)
PRINTL
PRINTL 　《 前缀设置 》
PRINTLC [10] 乳头颜色
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／乳头,0),1)
PRINTLC [11] 「淫乱」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／乳头,1),0)
PRINTL 　（淫乳时）
PRINTLC [12] 「淫荡的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／乳头,2),0)
PRINTL 　（淫乳时）
PRINTLC [13] 敏感
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／乳头,3),0)
PRINTL 　（Ｎ敏感度150%以上时）
PRINTL
PRINTL 　《 特殊替换设置 》
PRINTLC [20] 首选特殊替换
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／乳头,0),0)
PRINTL 　…如果满足特殊替换条件，则显示优先级
PRINTLC [21] 「《胸围大小》的尖端」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／乳头,1),0)
PRINTL 　（贫乳以下时为「乳房尖端」）
PRINTLC [22] 「《胸围大小》的尖尖」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／乳头,2),0)
PRINTL 　（贫乳以下时为「乳房尖尖」）
CALL SLANG_CONFIG_FOOTER
INPUT
SELECTCASE RESULT
CASE 0 TO 5
	INVERTBIT FLAG:黑话标识／乳头,RESULT
CASE 10 TO 13
	INVERTBIT FLAG:黑话前缀／乳头,(RESULT -10)
CASE 20 TO 22
	INVERTBIT FLAG:黑话替换／乳头,(RESULT -20)
CASE 80
	FLAG:黑话标识／乳头 = 65535
CASE 81
	FLAG:黑话前缀／乳头 = 65535
CASE 82
	FLAG:黑话替换／乳头 = 65535
CASE 90
	FLAG:黑话标识／乳头 = 0
CASE 91
	FLAG:黑话前缀／乳头 = 0
CASE 92
	FLAG:黑话替换／乳头 = 0
CASE 98
	PRINTL 回复默认乳头黑话候选吗？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_SLANG_CONFIG_NIPPLE
CASE 99
	IF !FLAG:黑话标识／乳头
		PRINTW 必须至少设置一个候选黑话。
	ELSE
		RETURN
	ENDIF
ENDSELECT
RESTART


