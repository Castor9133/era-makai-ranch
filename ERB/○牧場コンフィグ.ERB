
;魔力補給選択肢
@RANCH_STATUS_MPCHARGER
#DIM MPCHARGER

IF ITEM:魔力补给装置
	;手数料として魔力量を増やす（とりあえず二倍にする）
	MPCHARGER = (MAXBASE:0:魔力 -BASE:0:魔力)*2
	IF !MPCHARGER
		CALL PRINTL_WORD_COLOR,@"　不需要补充魔力","灰"
	ELSEIF MONEY:储存魔力 < 100
		CALL PRINTL_WORD_COLOR,@"　储存魔力不足","灰"
	ELSEIF MONEY:储存魔力 >= MPCHARGER
		PRINTFORML [ 3] 消耗储存魔力%VALUE_DIGIT(MPCHARGER)%MP，并向%CALLNAME:0%补充魔力
	ELSE
		;貯蔵魔力が0ではないけど足りてない
		MPCHARGER = MONEY:储存魔力
		PRINTFORML [ 3] 消耗储存魔力%VALUE_DIGIT(MPCHARGER)%MP，并向%CALLNAME:0%补充魔力
	ENDIF
ELSE
	CALL PRINTL_WORD_COLOR,@"　需要＜魔力补给装置＞","灰"
ENDIF



;外出手段デフォルト
@CONFIRM_SHOPPING_MOVE

PRINT [ 4] 外出方式：
SELECTCASE FLAG:外出方式默认值
CASE 0
	PRINTL 每次选择
CASE 1
	PRINTFORML %PET_NAME_REF("堕落天马")%
CASE 2
	PRINTFORML %PET_NAME_REF("双头犬")%
CASE 3
	PRINTFORML %PET_NAME_REF("魔界仓鼠")%
CASE 10
	PRINTL 个人用传送门
ENDSELECT



;選択後
;ARG→RESULT
@RANCH_SETTING(ARG)
#DIM MPCHARGER

SELECTCASE ARG
CASE 0
	CALL DRINK_MILK_AUTO_SELECT

CASE 1
	PRINTL [魔力储存器]积存的魔力，转到魔力电池上削减经费吗？
	PRINTFORML （不使用时：可用于药品开发或通过其他装置为%CALLNAME:0%补充魔力等用途）
	CALL ASK_YN
	IF !RESULT
		FLAG:魔力电池费用使用 = 1
	ELSE
		FLAG:魔力电池费用使用 = 0
	ENDIF
	
CASE 2
	PRINTFORML 正在调合%ITEMNAME:(FLAG:调合中药品ID)%，确定要取消吗？（进度将重置）
	CALL ASK_YN
	IF !RESULT
		MONEY:调合进行度 = 0
		FLAG:调合中药品ID = 0
	ENDIF
	
CASE 3
	PRINTFORML 给%CALLNAME:0%补充魔力？
	CALL ASK_YN
	SIF RESULT
		RETURN
	
	;ここでもう1度計算
	MPCHARGER = (MAXBASE:0:魔力 -BASE:0:魔力)*2
	SIF MONEY:储存魔力 < MPCHARGER
		MPCHARGER = MONEY:储存魔力
	PRINTFORM 消耗储存的魔力%VALUE_DIGIT(MPCHARGER)%MP → 
	MONEY:储存魔力 -= MPCHARGER
	
	;あなたに補給する量を正常に戻す（手数料を変更する場合ココも変える）
	MPCHARGER /= 2
	BASE:0:魔力 += MPCHARGER
	PRINTFORMW %CALLNAME:0%魔力：补充%VALUE_DIGIT(MPCHARGER)%MP
	
CASE 4
	CALL SHOPPING_MOVE_DEFAULT_SELECT
ENDSELECT



;外出手段デフォルトを選択
@SHOPPING_MOVE_DEFAULT_SELECT

CALL MANYL(3)
PRINTL 请选择默认的城市移动方式。
PRINTL [ 0] 每次选择
CALL SHOPPING_MOVE_LIST("設定")
PRINTL [99] 取消
BINPUT
SIF RESULT != 99
	FLAG:外出方式默认值 = RESULT




