
;アイテム購入可能判定
;ARGS→来た画面
@BUY_ITEM_JUDGE(ARGS)

;貯蔵器の関係でここだけ先にやる
SIF ARGS == "家居中心" && GROUPMATCH(ITEMNAME:SELECT_ITEM,"商用魔力储存器","大容量魔力储存器")
	GOTO BUY_ITEM_JUDGE_COMPLETE

;非対応IDならおわり
IF SELECT_ITEM < ITEM_ID_MIN || SELECT_ITEM >= ITEM_ID_MAX || ITEMNAME:SELECT_ITEM == ""
	PRINTL
	RETURN
ENDIF
$BUY_ITEM_JUDGE_COMPLETE

;特殊判定→RETURN1ならおわり
CALL BUY_ITEM_JUDGE_SPECIAL
SIF RESULT
	RETURN

;1限定アイテムのフラグありで所持済みなら帰る
IF FLAG:１个限定物品 && ITEM:SELECT_ITEM
	CALL PRINTL_WORD_COLOR("已持有","浅蓝色")
	RETURN
ENDIF

;値段を出す
CALL BUY_ITEM_PRICE_CALC

;ペットの場合ローン組むので特殊分岐
IF SELECT_ITEM >= 100 && SELECT_ITEM < 120
	CALL BUY_PET_COST
ELSEIF FLAG:购物／开销记账
	CALL BUY_ITEM_COST_BUDGET
ELSE
	CALL BUY_ITEM_COST_MONEY
ENDIF



;値段を出す
@BUY_ITEM_PRICE_CALC

;衣服一式は中身の合計を1割引
IF SELECT_ITEM >= 1000 && SELECT_ITEM < 1050
	COST = 0
	CALL EQUIP_CLOTHE_SET_COMMON("合计金额")
	COST *= 90
	COST /= 100
ELSE
	COST = ITEMPRICE:SELECT_ITEM
ENDIF



;経費計上
@BUY_ITEM_COST_BUDGET

;10万以上のアイテムは超過する場合資金に変更
IF COST >= BUDGET_CAP && COST > USE_MONEY
	CALL PRINT_WORD_COLOR,@"＜超过计上不可＞","黄"
	FLAG:购物／开销记账 = 0
	CALL BUY_ITEM_COST_MONEY
	RETURN
ENDIF

;経費計上は最低1コ購入可能
PRINTFORMLC [  0] 购入：%VALUE_DIGIT(COST)%G

;まとめ買いできるようにする
;いくつ買えるか計算　10コまで
BUY_NUM = LIMIT(USE_MONEY /COST,0,9) +1

;1コ限定じゃない+2コ以上買える場合出す
SIF !FLAG:１个限定物品 && BUY_NUM >= 2
	PRINTFORMLC [  1] {BUY_NUM}个购入：%VALUE_DIGIT(COST *BUY_NUM)%G
PRINTFORML （%VALUE_DIGIT(USE_MONEY)%G可计入） 



;資金
@BUY_ITEM_COST_MONEY

;財布は足りない場合がある
IF COST > MONEY
	PRINTFORML 　所持金不足。：%VALUE_DIGIT(COST)%G　（%VALUE_DIGIT(MONEY)%G持有） 
	RETURN
ENDIF
PRINTFORMLC [  0] 购入：%VALUE_DIGIT(COST)%G
BUY_NUM = LIMIT(MONEY /COST,1,10)
SIF !FLAG:１个限定物品 && BUY_NUM >= 2
	PRINTFORMLC [  1] {BUY_NUM}个购入：%VALUE_DIGIT(COST *BUY_NUM)%G
PRINTFORML （%VALUE_DIGIT(MONEY)%G持有） 



;購入不可特殊判定
@BUY_ITEM_JUDGE_SPECIAL

;下のグレードがないと買えない：今のとこ大容量魔力貯蔵器だけ
IF ITEMNAME:SELECT_ITEM == "大容量魔力储存器" && !ITEM:商用魔力储存器
	CALL PRINTL_WORD_COLOR("＜商用魔力储存器＞必须拥有","黄")
	RETURN 1
ENDIF

;ペット特殊判定
IF SELECT_ITEM >= 100 && SELECT_ITEM < 120

	;もう持ってる場合名前出しておわり
	IF ITEM:SELECT_ITEM
		CALL PRINTL_WORD_COLOR,@"【%PET_NAME_REF(ITEMNAME:SELECT_ITEM)%】正在饲养中","浅蓝色"
		RETURN 1
	
	;大型ペットはペット小屋に空きがないとダメ
	ELSEIF GROUPMATCH(ITEMNAME:SELECT_ITEM,"堕落天马","双头犬","魔界仓鼠")
		CALL PET_HOUSE_BLANC_CHECK
		IF !FLAG:空闲宠物小屋数
			CALL PRINTL_WORD_COLOR("＜宠物小屋＞没有空位","灰")
			RETURN 1
		ENDIF
	ENDIF
ENDIF



;ペットのローン用
;CAN_LOAN_MONEY計算済み
@BUY_PET_COST

;所持金足してもダメ
IF COST > CAN_LOAN_MONEY +MONEY
	PRINTFORMLC 　贷款上限加持有金不足：%VALUE_DIGIT(COST)%G
ELSE
	PRINTFORMLC [  0] 购买（贷款自动优先）：%VALUE_DIGIT(COST)%G
ENDIF
PRINTFORML （%VALUE_DIGIT(MONEY)%G持有／%VALUE_DIGIT(CAN_LOAN_MONEY)%G可贷款） 






