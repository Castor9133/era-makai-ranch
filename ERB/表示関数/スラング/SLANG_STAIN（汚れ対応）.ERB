
;汚れでの文章追加
;→ARGS:部位
@SLANG_STAIN(ARGS)
#DIM PART
#DIMS PART_LOTION
#FUNCTIONS

;部位により判定箇所変更　ＢＶＡ以外は今のところいいかな
SELECTCASE ARGS
CASE "Ｂ"
	PART = 1
CASE "Ｖ"
	PART = 3
CASE "Ａ"
	PART = 0
CASEELSE
	RETURNF
ENDSELECT
PART_LOTION = %ARGS%
PART_LOTION += "润滑液"

;初期化
SLANGWORD=

;母乳
IF GETBIT(STAIN:PART,0)
	IF ABL:胸围大小 >= BUSTSIZE_丰乳 && RAND:100 < 30
		IF MARK:乳罐 && RAND:100 < 50
			SLANGWORD += "从乳罐里溢出来了"
		ELSE
			SLANGWORD += "从奶罐溢出的"
		ENDIF
	ENDIF
	SLANGWORD += SAVESTR:标识／母乳
	
	;触手粘液・ローション→どっちか
	IF GETBIT(STAIN:PART,5)
		SLANGWORD += "与触手粘液"
	ELSEIF TFLAG:PART_LOTION
		SLANGWORD += "润滑液"
	ENDIF
ELSEIF GETBIT(STAIN:PART,1)
	SLANGWORD += "爱液"
	IF GETBIT(STAIN:PART,5)
		SLANGWORD += "与触手粘液"
	ELSEIF TFLAG:PART_LOTION
		SLANGWORD += "润滑液"
	ENDIF
ELSEIF GETBIT(STAIN:PART,5)
	SLANGWORD += "触手粘液"
	SIF TFLAG:PART_LOTION
		SLANGWORD += "润滑液"
ELSEIF TFLAG:PART_LOTION
	SLANGWORD += "润滑液"
ENDIF

IF SLANGWORD != ""
	SELECTCASE RAND:3
	CASE 0
		SLANGWORD += "滑溜溜的"
	CASE 1
		SLANGWORD += "变得湿湿的"
	CASE 2
		SLANGWORD += "沾满的"
	ENDSELECT
	RETURNF SLANGWORD
ENDIF



