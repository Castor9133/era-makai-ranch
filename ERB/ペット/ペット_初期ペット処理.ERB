
;初期ペット設定
@NEWGAME_FIRST_PET

CLEARLINE LINECOUNT
PRINTL 请选择在牧场中饲养的（兼具移动功能的）宠物。
CALL PRINTL_WORD_COLOR("在购买初始宠物时不会消耗持有金。","黄")
DRAWLINE
BR = 0
ITEM_ID_MIN = 100
ITEM_ID_MAX = 110
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	SIF !ITEMPRICE:LOCAL
		CONTINUE
	CALL BR_PLUS(3)
	
	;移動用ではないペットは選択不可にしとく
	PRINTFORMLC [{LOCAL}] %ITEMNAME:LOCAL% 
NEXT
PRINTL
DRAWLINE
CALL ITEM_SHOP_BIG_ANIMAL_DETAIL
CALL PRINTL_ALIGN
CALL FIRST_PET_SELECT_COM
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	;決定処理
	CALL FIRST_PET_NAMING
	
	;RETURN1してきたら完了
	SIF RESULT
		RETURN
CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART



;コマンド出すか
@FIRST_PET_SELECT_COM

DRAWLINE
IF !ITEMPRICE:SELECT_ITEM || SELECT_ITEM < ITEM_ID_MIN || SELECT_ITEM >= ITEM_ID_MAX
	CALL RIGHT_RETURN_BUTTON(0,"キャンセル")
	RETURN

;移動用に使えないペットは外す　今は全部OK
ENDIF
PRINTFORMLC [  0] 转到%ITEMNAME:SELECT_ITEM%的命名
PRINTLC 　
PRINTL [ 99] 取消



;ペット決定処理
@FIRST_PET_NAMING

;種族名をITEMから持ってくる
ANIMAL = %ITEMNAME:SELECT_ITEM%

;名前など決め
CALL NAMING_PET_BEFORE

;完了してきたら次へ
SIF !RESULT
	RETURN
ITEM:SELECT_ITEM ++
CALL PRINTW_WORD_COLOR,@"已将＜%ANIMAL%＞的%PET_NAME_REF(ANIMAL)%注册为初始宠物。","浅蓝色"

;初期ペットなつき度上げ→ラストに移動
RETURN 1




