CASE "战斗"
	SELECTCASE ARGS:1
	CASE "攻击"
		CALL MESSAGE_BOX,@"「交给我。您别往前靠。」"
	CASE "被击中"
		CALL MESSAGE_BOX,@"「……唔……不碍事，我还能护住您。」"
	CASEELSE
	ENDSELECT

CASEELSE
ENDSELECT
RETURN

