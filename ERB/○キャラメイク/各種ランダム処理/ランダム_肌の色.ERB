
;奴隷候補の肌の色
@RANDOM_SLAVE_SKIN_COLOR
#DIMS SKIN_COLOR

;FLAG:候補割合／肌の色／アルビノ→3160
FLAG_REF = 3160
STR_REF = 6580
LAST_SHUFFLE_S = %CSTR:肤色%
CALL RANDOM_BOX_LOTTERY(9)

;再シャッフルのカウントがなければ種族補正
SIF !SHUFFLE_COUNT
	CALL RANDOM_SLAVE_SKIN_COLOR_TRIBE_REVISION
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE_S == RESULTS
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0
CSTR:肤色 = %RESULTS%
CALL CATEGORY_SKIN_COLOR



;種族による補正　種族設定に合わせる
@RANDOM_SLAVE_SKIN_COLOR_TRIBE_REVISION

FLAG_NAME = 种族设定／%CSTR:种族%
TRIBE_FLAG_A = 外观反映率／%CSTR:种族%
SELECTCASE CSTR:种族
CASE "暗精灵"
	SIF GROUPMATCH(RESULTS,"标准","白皙","美白","白化") && GETBIT(FLAG:FLAG_NAME,1) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		RESULTS = 褐色
CASE "精灵","半精灵","仙人","妖狐"
	SIF GROUPMATCH(RESULTS,"标准","褐色","小麦色") && GETBIT(FLAG:FLAG_NAME,1) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		RESULTS = 白皙
CASE "翼人","吸血鬼","半吸血鬼","天使","天人","女神"
	SIF GROUPMATCH(RESULTS,"标准","褐色","小麦色") && GETBIT(FLAG:FLAG_NAME,0) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		RESULTS = 白皙
ENDSELECT

