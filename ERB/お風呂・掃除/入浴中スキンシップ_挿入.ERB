
;風呂場Ｖ挿入
@BATHLOOM_V_INSERT

;ここで処女結界破壊はできないことにする
SIF TALENT:处女结界
	RETURN

;対面座位
V_PENIS = %CALLNAME:0%
SELECTCOM = 32
CALL COM32
IF !RESULT
	PRINTW 决定不要插入了…
	RETURN
ENDIF
TFLAG:Ｖ装备 = 1
SETBIT ＃Ｐ使用／Ｖ插入＃
LOSEBASE:体力 += 20
LOSEBASE:气力 += 30
CALL PRINT_IMAGE("调教执行")
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
EXP:(SELECTCOM +1000) ++
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++
TFLAG:指令中射精次数 = 0
IF !BASE:0:精力
	RESULT = 3
ELSE
	;継続コマンド選択
	PRINTL
	PRINTFORML [ 0] 揉捏%SAVESTR:标识／乳房%
	PRINTFORML [ 1] 吸吮%SAVESTR:标识／母乳%
	PRINTFORML [ 2] %SAVESTR:标识／精液%注入
	PRINTFORML [ 3] 拔出%SAVESTR:标识／阴茎%
	INPUT
	PRINTL
ENDIF
SELECTCASE RESULT
CASE 0
	CALL BATHLOOM_BUST_MASSAGE(1)
CASE 1
	CALL BATHLOOM_BUST_SUCK(1)
;CASE 2
CASE 3
	WAIT_SKIP = 1
	CALL COM890
	WAIT_SKIP = 0
	PRINTW
	RETURN
ENDSELECT
CALL EJACULATION_PISTON
PRINTW



