@SENSITIVE_ORIGINAL(ARGS)
#DIMS S_ABL,2
#DIMS S_KANDO,2

S_ABL = %ARGS%感觉
S_KANDO = %ARGS%敏感度
S_ABL:1 = 初始值／%ARGS%感觉
S_KANDO:1 = 初始值／%ARGS%敏感度
CALL PRINTL_WORD_COLOR,@"%S_ABL%Lv{ABL:(S_ABL:1),2} → {ABL:S_ABL,2} <{ABL:(S_KANDO:1),3} → {ABL:S_KANDO,3}\%> ","桃"



