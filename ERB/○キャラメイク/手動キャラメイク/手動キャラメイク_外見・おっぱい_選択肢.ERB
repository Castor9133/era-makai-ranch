
;1ページ
@SELF_CHARA_MAKE_APPEARAINCE_1

PRINTL 　《 外表 》
CALL HALFLINE
PRINTLC [ 0] 身高
PRINTFORM ：%PRINT_HEIGHT()%

;シャッフルはCSTR内
SIF SELF_CHARA_MAKE_RANDOM
	PRINTFORM （【%CSTR:身高%】内重新调整）
PRINTL
PRINTLC [ 1] 体型
PRINTFORML ：%CSTR:体型%
PRINTLC [ 2] 肤色
PRINTFORML ：%CSTR:肤色%
PRINTL
CALL PRINT_HAIR_STYLE
PRINTL
PRINTLC [ 3] 发色
PRINTFORML ：%CSTR:发色%
PRINTLC [ 4] 头发特征
IF CSTR:头发特征 != ""
	PRINTFORML ：%CSTR:头发特征%
ELSE
	CALL PRINTL_WORD_COLOR,@"：未设定","灰"
ENDIF
PRINTLC [ 5] 发型
PRINTFORML ：%CSTR:发型%

IF !SELF_CHARA_MAKE_RANDOM
	CALL PRINTLC_WORD_COLOR,@"< 6> 批量更改：仅限随机","灰"
	PRINTL [ 7] 头发颜色编码
ELSE
	PRINTLC [ 6] 发型批量更改
	CALL PRINTL_WORD_COLOR,@"< 7> 发色编码：仅限手动","灰"
ENDIF
PRINTLC [ 8] 外表年龄
PRINTFORML ：{CFLAG:外表年龄}岁
PRINTLC [ 9] 阴毛
PRINTFORML ：%CSTR:阴毛%

PRINTL
PRINT 　
CALL PRINT_EYE_COLOR
PRINTL

;目は手動かどうかでだいぶ変更
IF !SELF_CHARA_MAKE_RANDOM
	PRINTL [10] 右瞳色
	PRINTL [11] 右瞳色编码
	PRINTL [12] 左瞳色
	IF CSTR:左瞳色 != ""
		PRINTL [13] 左瞳色编码
	ELSE
		CALL PRINTL_WORD_COLOR,@"　左瞳色编码","灰"
	ENDIF
ELSE
	PRINTL [10] 瞳色
	CALL PRINTL_WORD_COLOR,@"<11> 眼睛颜色编码：仅限手动","灰"
	PRINTL [12] 确定异色眼随机
	PRINTL
ENDIF
PRINTLC [14] 瞳孔形状
IF CSTR:瞳孔形状 != ""
	PRINTFORML ：%CSTR:瞳孔形状%
ELSE
	CALL PRINTL_WORD_COLOR,@"：未设定","灰"
ENDIF
PRINTLC [15] 眼睛特征
IF CSTR:眼睛特征 != ""
	PRINTFORML ：%CSTR:眼睛特征%
ELSE
	CALL PRINTL_WORD_COLOR,@"：未设定","灰"
ENDIF
PRINTL



@SELF_CHARA_MAKE_APPEARAINCE_2

PRINTFORML 　《 %SAVESTR:标识／乳房% 》
CALL HALFLINE
PRINTLC [ 0] 胸围大小
PRINTFORM ：%PRINT_BUSTSIZE(ABL:胸围大小)%
CALL PRINT_BUST_C(1,1)

;シャッフルはサイズ内
SIF SELF_CHARA_MAKE_RANDOM
	PRINTFORM （【%PRINT_BUSTSIZE_TALENT()%】内重新调整）
PRINTL
PRINTL
PRINTFORMLC [ 1] %SAVESTR:标识／乳房%弹力
PRINTFORML ：%CSTR:乳房弹性%
PRINTLC [ 2] 乳头颜色
SETCOLOR CFLAG:颜色编码／乳头
PRINTFORML ：%CSTR:乳头颜色%
RESETCOLOR

IF !SELF_CHARA_MAKE_RANDOM
	PRINTL [ 3] 乳头颜色编码
ELSE
	CALL PRINTL_WORD_COLOR,@"< 3> 乳头颜色编码：仅限手动","灰"
ENDIF
PRINTL
PRINTLC [ 4] Ｂ敏感度
PRINTFORML ：{ABL:Ｂ敏感度,3}\%
PRINTLC [ 5] Ｎ敏感度
PRINTFORML ：{ABL:Ｎ敏感度,3}\%
PRINTLC [ 6] 【陷没乳头】
CALL PRINT_ONOFF(TALENT:陷没乳头,1)
PRINTL
PRINTLC [10] 【母乳体质】
CALL PRINT_ONOFF(MARK:母乳体质)
IF MARK:母乳体质
	IF TALENT:先天母乳体质
		PRINTL [先天母乳体质]
	ELSE
		PRINTL [有出产经验]
	ENDIF
ELSE
	PRINTL
ENDIF
PRINTLC [11] 母乳容量修正值
PRINTFORML ：{CFLAG:母乳容量修正值}\%
PRINTLC [12] 母乳价格奖励
PRINTFORML ：{CFLAG:母乳价格奖励}\%
IF ABL:胸围大小 >= BUSTSIZE_巨乳
	PRINTLC [13] 【极上乳压】
	CALL PRINT_ONOFF(TALENT:极上乳压,1)
ELSE
	CALL PRINTL_WORD_COLOR,@"<14> 【极上乳压】…【巨乳】以上限定","灰"
ENDIF
PRINTL
PRINTFORMLC [20] 胸围大小+1（MAX{BUSTSIZE_超乳 -1}）
PRINTL [21] 胸围大小-1



