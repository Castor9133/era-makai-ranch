@COM904
;ペニス躾（呼び方変更）

;Ｖ挿入かＡ挿入
IF GETBIT(＃Ｐ使用／Ｖ插入＃)
	PRINTFORML 管教%SAVESTR:标识／阴茎%／%SAVESTR:标识／膣%的称呼吗？
	PRINTFORML [ 0] %SAVESTR:标识／阴茎%的称呼进行教导（当前：%CSTR:性器称呼／阴茎%）
	PRINTL
	PRINTFORML [ 1] %SAVESTR:标识／膣%的称呼进行教导（当前：%CSTR:性器称呼／膣%）
	PRINTL
	PRINTL [99] 取消
ELSEIF GETBIT(＃Ｐ使用／Ａ插入＃)
	PRINTFORML 管教%SAVESTR:标识／阴茎%／%SAVESTR:标识／肛门%的称呼吗？
	PRINTFORML [ 0] %SAVESTR:标识／阴茎%的称呼进行教导（当前：%CSTR:性器称呼／阴茎%）
	PRINTL
	PRINTFORML [ 2] %SAVESTR:标识／肛门%的称呼进行教导（当前：%CSTR:性器称呼／肛门%）
	PRINTL
	PRINTL [99] 取消
ELSE
	;一応
	RETURN
ENDIF
BINPUT
SELECTCASE RESULT
CASE 0
	CALL CHANGE_PERSONAL_CALL("阴茎称呼")
	
	;RETURN 1してきた→キャンセル
	SIF RESULT
		RETURN
	CALL KOJO_PRINT("阴茎称呼变更")

CASE 1
	CALL CHANGE_PERSONAL_CALL("膣称呼")
	SIF RESULT
		RETURN
	CALL KOJO_PRINT("膣称呼变更")
	
CASE 2
	CALL CHANGE_PERSONAL_CALL("肛门称呼")
	SIF RESULT
		RETURN
	CALL KOJO_PRINT("肛门称呼变更")

CASEELSE
	RETURN
ENDSELECT
CALL PISTON_SOURCE
RETURN 1



;霊力注入
@COM905
#DIM GIVE_EP
#DIM WANT_EP

;霊力の1%　1000～10000まで　大量は10万
GIVE_EP = BASE:0:灵力 /100
GIVE_EP -= (GIVE_EP %10)
GIVE_EP = LIMIT(GIVE_EP,1000,10000)
PRINTFORML 向%CALLNAME%注入灵力精液
PRINTL ・每给奴隶注入100EP回复10HP
PRINTL ・灵力减少时，会回复注入的灵力（和等级）
PRINTL
SIF BASE:0:体力 <= 1500
	SETCOLOR 0xFFFF70
PRINTFORM 　%CALLNAME:0%　HP：{BASE:0:体力,4} 
RESETCOLOR
CALL PRINT_COLORBAR(BASE:0:体力,MAXBASE:0:体力,8,BARCOLORSET("青绿"),RESULT:1)
PRINTFORM 　%CALLNAME:0%的灵力：%VALUE_DIGIT(BASE:0:灵力)%／%VALUE_DIGIT(MAXBASE:0:灵力)%EP 
CALL PRINT_COLORBAR(BASE:0:灵力,MAXBASE:0:灵力,8,BARCOLORSET(""),RESULT:1)
PRINTL
IF !EXP:灵力为零
	CALL PRINTL_WORD_COLOR("　因为没有吸尽过灵力，所以注入灵力不会积累","灰")
ELSEIF !＃陷落状态／隶属＃
	CALL PRINTL_WORD_COLOR("　因为还不是【隶属】，注入灵力不会积累","灰")
ELSE
	IF BASE:灵力 >= MAXBASE:灵力
		PRINTFORML ・注入的灵力的1/4最大值增加（上限%CALLNAME:0%的最大灵力）
		PRINTL （因抽取等原因导致灵力下降的情况除外）
		PRINTL
	ENDIF
	IF MAXBASE:体力 >= HP_MAX
		CALL PRINTL_WORD_COLOR,@"※%CALLNAME%的最大HP不会再增加","灰"
	ELSE
		WANT_EP = MAXBASE:体力 *50 -CFLAG:灵力蓄积量
		PRINTFORML ・再注入%VALUE_DIGIT(WANT_EP)%EP后，%CALLNAME%的最大HP将增加
	ENDIF
ENDIF
PRINTL
PRINTFORML [ 0] 适量注入（%VALUE_DIGIT(GIVE_EP)%EP）
PRINTFORML [ 1] 大量注入（%VALUE_DIGIT(GIVE_EP *10)%EP）
PRINTL [99] 取消
INPUT
IF RESULT == 0
	SOURCE:注入灵力量 = GIVE_EP
ELSEIF RESULT == 1
	GIVE_EP *= 10
	SOURCE:大量注入 = 1
	SOURCE:注入灵力量 = GIVE_EP
ELSE
	RETURN
ENDIF
CALL PISTON_SOURCE
RETURN 1



;魔力注入
@COM906
#DIM GIVE_MP
#DIM WANT_MP

;魔力の1%　1000～50000まで　大量は50万
GIVE_MP = BASE:0:魔力 /100
GIVE_MP -= (GIVE_MP %10)
GIVE_MP = LIMIT(GIVE_MP,1000,50000)
PRINTFORML 向%CALLNAME%注入魔力精液
PRINTL ・魔力减少的场合注入量的魔力回复
PRINTL
SIF BASE:0:体力 <= 1500
	SETCOLOR 0xFFFF70
PRINTFORM 　%CALLNAME:0%　HP：{BASE:0:体力,4} 
RESETCOLOR
CALL PRINT_COLORBAR(BASE:0:体力,MAXBASE:0:体力,8,BARCOLORSET("青绿"),RESULT:1)
PRINTFORM 　%CALLNAME:0%的魔力：%VALUE_DIGIT(BASE:0:魔力)%／%VALUE_DIGIT(MAXBASE:0:魔力)%MP 
CALL PRINT_COLORBAR(BASE:0:魔力,MAXBASE:0:魔力,8,BARCOLORSET("深紫"),RESULT:1)
PRINTL
IF !＃陷落状态／隶属＃
	CALL PRINTL_WORD_COLOR("因为不是【隶属】，注入魔力不会积蓄","灰")
ELSEIF !MAXBASE:魔力
	WANT_MP = MP_OCCUR_VALUE -CFLAG:魔力蓄积量
	PRINTFORML ・再注入%VALUE_DIGIT(WANT_MP)%MP后，%CALLNAME%将获得魔力
ELSEIF BASE:魔力 >= MAXBASE:魔力 *8 /10
	SOURCE:魔力上限可能增加 = 1
	PRINTFORML ・注入的魔力的1/5最大值增加（上限%CALLNAME:0%的最大魔力）
	PRINTL （喷乳发生魔力减少时可能不会增加）
	PRINTL
ELSE
	WANT_MP = MAXBASE:魔力 /2
	PRINTFORML ・一次性注入超过%VALUE_DIGIT(WANT_MP)%的MP后，%CALLNAME%的最大MP将增加
ENDIF
PRINTL
PRINTFORML [ 0] 适量注入（%VALUE_DIGIT(GIVE_MP)%MP）
PRINTFORML [ 1] 大量注入（%VALUE_DIGIT(GIVE_MP *10)%MP）
PRINTL [99] 取消
INPUT
IF RESULT == 0
	SOURCE:注入魔力量 = GIVE_MP
ELSEIF RESULT == 1
	GIVE_MP *= 10
	SOURCE:大量注入 = 1
	SOURCE:注入魔力量 = GIVE_MP
ELSE
	RETURN
ENDIF
CALL PISTON_SOURCE
RETURN 1



