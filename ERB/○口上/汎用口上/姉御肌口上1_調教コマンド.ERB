; ARGS:0 场景；ARGS:1～ 用于更细分
@KOJO_GENERAL_姉御肌1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

; 进入本函数时 ARGS:0 固定为「调教命令」
; 按命令与情境分支；名称见 TRAIN.csv
; 当前流程：@COM 地之文 → 口上

SELECTCASE ARGS:1
CASE "揉胸","育乳按摩","浓厚母乳按摩","乳罐按摩"
	; 从此处起按变体分支；分支越多越有趣也越费工。
	; 分支方式自定，常按好感/陷落等状态分较省事。
	
	; 先看是否「首次」：EXP:(SELECTCOM +1000)++ 放在口上显示**之后**执行
	; 故该值为 0 表示该角色尚未经历过本命令
	; 细节略，用下方 IF 做首次即可
	; 隶属乳牛从未揉胸只挤奶…倒也可能
	; 写 \n 会换行；源码里用 Enter 换行不符合规范
	; 连续两次 CALL 只会显示其一，故不能靠双 CALL 凑换行
	
	IF !EXP:(SELECTCOM+1000)
		; 不直接显示，先 CALL MESSAGE_BOX 把候选台词放进「箱子」
		; 参考了触手宫氏口上
		; [MASTER_CALL]：对主人的称呼（如「主人」）
		; [SWEET_MASTER_CALL]：撒娇式称呼（如「主银～」）
		; [SELF_CALL]：第一人称（如「我」）
		; ♥ 显示时会变成心形符号
		
		;乳牛、隶属、洗脑时
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「%SWEET_MASTER_CALL()%♥ %SELF_CALL()%的胸部想揉吗♥♥\n　随意尽情玩弄吧♥ %SELF_CALL()%的身体是%MASTER_CALL()%的『东西』嘛♥♥」"
		
		; 用 ELSE 则不会进入随机候选池
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%的胸部可以随便玩弄…♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「嗯…这样的揉着…快乐的吗…？♥」"
		; 也可按素质等再分支
		ELSE
			CALL MESSAGE_BOX,@"「可恶、别碰！」"
		ENDIF
		; 首次分支为确保只显示上述内容，此处 RETURN
		RETURN
		
	ENDIF
	;乳牛、隶属、洗脑时
	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「喂，♥ %SWEET_MASTER_CALL()%♥ %SELF_CALL()%的胸部尽情玩弄吧♥♥」"
		CALL MESSAGE_BOX,@"「做到心满意足为止…♥ %SELF_CALL()%的胸部是%MASTER_CALL()%的『东西』…♥♥」"
		CALL MESSAGE_BOX,@"「哈啊啊♥ 胸部被揉着、极乐呜呜…♥♥」"
		
		; 即使连续写多条，一次口上调用也只会随机显示其中一条
		; MESSAGE_BOX：向箱中投放 → 从箱中抽一条显示
		; 可按条件追加候选，例如胸围达丰乳以上时追加
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%的丰盈成长的胸部、尽情收获吧♥♥」"
		; 还可追加其它条件分支
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「%SELF_CALL()%像...一样的小胸部但是愛出来给我的呢…♥♥」"
		; 本次调教 B 绝顶累计 100 次以上
		; 注：NOWEX 写在「调教命令」段多为死分支，此处用 EX 累计更合适
		; 适合写「再被○○就不行了」类临场感台词
		SIF EX:Ｂ绝顶 >= 100
			CALL MESSAGE_BOX,@"「啊啊啊♥♥ 要去了就会♥♥ 今胸部被玩弄的话、%SELF_CALL()%飞走了呜♥♥」"
	
	ELSEIF ＃陷落状态／恋慕以上＃
		; 恋慕线可比上面略矜持
		CALL MESSAGE_BOX,@"「%SELF_CALL()%的胸部、直到满足享受着咿咿啊…？♥」"
		CALL MESSAGE_BOX,@"「呵呵…♥ 胸部揉想看吗…吗？♥♥」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「嘿嘿…♥ %SELF_CALL()%的自慢的胸部、%MASTER_CALL()%的喜欢做手咿咿啊♥♥」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「这样的%SELF_CALL()%的小巧的胸部但是、%MASTER_CALL()%哈咿咿说言说给我吗…♥♥」"
		
	ELSEIF ＃陷落状态／陷落以上＃
		; 宜先写苛刻条件，否则易总命中上方分支
		CALL MESSAGE_BOX,@"「嗯…%MASTER_CALL()%哈真的乳喜欢呢…♥」"
		CALL MESSAGE_BOX,@"「好好…直到满足尽管做吧…♥」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「嗯…真是的…男说的大就行了吗…？ …嘛、%MASTER_CALL()%高兴的话那就行…」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「男人就是只要大就行了吗…？%SELF_CALL()%的不满足吧…\n　…满足的脸…那就行吧…」"
	
	ELSEIF ＃陷落状态／屈服以上＃
		; 比下段更「认命」
		CALL MESSAGE_BOX,@"「嗯…这样的脂肪的堆积…什么好的…」"
		CALL MESSAGE_BOX,@"「已经随你喜欢…」"
		SIF ABL:胸围大小 >= BUSTSIZE_丰乳
			CALL MESSAGE_BOX,@"「哈啊…真是的…男说的大就行了吗…？」"
		SIF ABL:胸围大小 < BUSTSIZE_普乳
			CALL MESSAGE_BOX,@"「%SELF_CALL()%的小巧的乳玩弄快乐的吗…？\n　…啊、这样…快乐的吗…」"
	
	ELSE
		; 无反抗刻印/枷锁但性格反抗 → 傲娇口吻
		CALL MESSAGE_BOX,@"「可恶、放开！随便地玩弄吗！」"
		CALL MESSAGE_BOX,@"「随便揉什么呢！」"
		CALL MESSAGE_BOX,@"「啧、恶心！搞什么啊…！」"
	ENDIF
	; 揉胸分支到此…不短吧？
	
; 以下继续其它调教命令
CASE "榨乳"
	IF !EXP:(SELECTCOM+1000)
		; 按是否母乳体质分支
		IF MARK:母乳体质
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「嗯哦哦—♥♥ 牛奶♥ 牛奶被挤奶了♥♥」"
			ELSEIF ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
				CALL MESSAGE_BOX,@"「嗯哈啊♥ 胸部被挤奶了♥♥」"
			ELSEIF ＃陷落状态／屈服以上＃
				CALL MESSAGE_BOX,@"「啊啊…♥ 这样的、简直『家畜』对待…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「住手、别碰！%SELF_CALL()%哈家畜这种觉悟啊！」"
			ENDIF
		ELSE
			IF ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
				CALL MESSAGE_BOX,@"「嗯嗯、啊♥ 胸部挤也母乳哈出没有哦♥」"
			ELSEIF ＃陷落状态／屈服以上＃
				CALL MESSAGE_BOX,@"「…啊啊♥ 『家畜』像...一样被挤手也何也出不来说…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「住手、别碰！%SELF_CALL()%哈家畜这种觉悟啊！」"
			ENDIF
		ENDIF
		RETURN
	ENDIF
	IF MARK:母乳体质
		IF ABL:搾乳中毒 >= 10
			CALL MESSAGE_BOX,@"「啊—♥♥ 嗯哦♥ 哈嘿♥♥ 更多♥ 更多挤吧♥♥」"
			CALL MESSAGE_BOX,@"「嗯啊♥♥ 牛奶流出呜♥ 流出的舒服♥ 啊啊啊♥♥」"
			CALL MESSAGE_BOX,@"「来来♥ 来了呜♥♥ 牛奶出手高潮呜♥♥」"
		ENDIF
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「哈—♥ 哈—♥ 榨乳♥ 榨乳更多♥♥ %SELF_CALL()%的牛奶榨干♥♥」"
			CALL MESSAGE_BOX,@"「哈嘿♥ 哈嘿♥♥ %SWEET_MASTER_CALL()%♥ 喜欢被挤奶♥ 喜欢从乳头流出牛奶♥♥」"
			CALL MESSAGE_BOX,@"「哦呢咿♥ 挤压♥ 忍不住被挤奶了♥ 胸部忍不住了♥♥」"
			CALL MESSAGE_BOX,@"「哈啊啊♥ %SELF_CALL()%的胸部♥ %MASTER_CALL()%的手指陷入了嗯で咕呜♥♥」"
			SIF ABL:胸围大小 >= BUSTSIZE_爆乳
				CALL MESSAGE_BOX,@"「哈啊—…哈啊—♥ %SELF_CALL()%的充分胸部、牛奶だ流着忍耐做不到哟♥♥」"
			SIF EX:Ｂ绝顶 >= 100
				CALL MESSAGE_BOX,@"「嗯~~♥♥ 胸部高潮♥♥ 胸部得头满满了♥♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「%SELF_CALL()%的胸部、很多挤吧…♥」"
			CALL MESSAGE_BOX,@"「看…♥ 尽情挤吧…♥♥」"
			SIF ABL:胸围大小 >= BUSTSIZE_丰乳
				CALL MESSAGE_BOX,@"「呵呵…♥ %SELF_CALL()%的满满母乳詰又胸部、尽情挤吧♥♥」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「嗯…挤吗…？♥」"
			CALL MESSAGE_BOX,@"「好好…尽情做吧…」"
			SIF ABL:胸围大小 >= BUSTSIZE_丰乳
				CALL MESSAGE_BOX,@"「嗯…真是的…男说的大就行了吗…？\n　…嘛、%MASTER_CALL()%高兴的话那就行…」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「嗯…有点痛苦哦…♥」"
			CALL MESSAGE_BOX,@"「咿咿嘛…随你喜欢…」"
			SIF ABL:胸围大小 >= BUSTSIZE_丰乳
				CALL MESSAGE_BOX,@"「哈啊…真是的…男说的大就行了吗…？」"
		ELSE
			CALL MESSAGE_BOX,@"「住手！挤嗯不是吗！」"
			CALL MESSAGE_BOX,@"「可恶放开！%SELF_CALL()%哈家畜变得た记得鼻子/花哦！」"
			CALL MESSAGE_BOX,@"「咕…恶心呢…！搞什么啊！」"
		ENDIF
	ENDIF

CASE "拧乳头"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「啊♥ 哦呼呼♥ 更多乳头咯吱咯吱做♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「嗯！♥ 血、乳头那样的被做と…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「嗯！ 何随便地乳头玩弄吗！」"
		ENDIF
		RETURN
	ENDIF
	IF ABL:Ｎ敏感度 >= 200 || ABL:Ｎ感觉 >= 10
		CALL MESSAGE_BOX,@"「啊♥ 那里♥♥ 敏感呢地方♥♥」"
		CALL MESSAGE_BOX,@"「乳头咿♥ 乳头揉搓揉搓说被手诶诶♥♥ 忍耐做不到咿咿♥♥」"
		CALL MESSAGE_BOX,@"「嗯哦~♥♥ 乳头嘻啪ら不要诶诶♥ 头笨蛋了♥♥」"
		CALL MESSAGE_BOX,@"「乳头咿♥ 啊♥ 乳头喜欢咿♥ 更多乳头欺负我诶♥♥」"
		SIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
