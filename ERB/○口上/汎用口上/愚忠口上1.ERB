@KOJO_GENERAL_INDEX_愚忠1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

IF TFLAG:Ｍ装备
	CALL KOJO_GENERAL_MOUTH_SHACKLE_1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
	RETURN
ELSEIF CFLAG:崩坏 && !CFLAG:洗脑
	IF GROUPMATCH(ARGS:0,"例文")
	ELSEIF GROUPMATCH(ARGS:1,"洗脑触手","崩坏")
	ELSE
		IF NOWEX:总绝顶
			CALL MESSAGE_BOX,@"「……忠诚……♥ ……我会证明……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……命令……」"
		ENDIF
		RETURN
	ENDIF
ENDIF

SELECTCASE ARGS:0
CASE "身体"
	CALL KOJO_GENERAL_愚忠1_EXCRETION_BODY(ARGS:1, ARGS:2)
	RETURN
CASE "例文"
	CALL MESSAGE_BOX,@"「【愚忠1】已设置。\n不问对错只求服从；献身＝证明忠诚。」"

CASE "身体事件"
	SELECTCASE ARGS:1
	CASE "产後初调"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「产后的静养已结束。若这是主人为牧场而定的日程，%SELF_CALL()%的身心皆为主人与乳职所用。」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「被您召唤之时，%SELF_CALL()%就明白……产后第一次也要献给您。痛也好漏奶也好，都请您以主人之手验收。」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「这具身体在产后仍只配放在您的台子上……请随意检查，直到您满意。孩子之名……亦随您所赐。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……%SELF_CALL()%不逃。产后的头一回，也会遵命。只求主人别嫌……这具生养过的身体。」"
		ELSE
			CALL MESSAGE_BOX,@"「……%SELF_CALL()%是奴隶。生养之后仍是您的所有物。这条命……也继续献给您调遣。」"
		ENDIF
	CASE "妊娠性事初回"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「身孕已确……%SELF_CALL()%的子宫与身体亦为主人牧养所用。此际仍蒙主人唤来验身，是命令也便服从。」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「被您确认是有了之后……%SELF_CALL()%心口一直烫。您还要占有这份身子的话……请用手掌告诉%SELF_CALL()%，您不嫌弃。」"
		ELSE
			CALL MESSAGE_BOX,@"「……妊娠已明。%SELF_CALL()%会服从。但腹中之物……也请您一并发落。」"
		ENDIF
	CASE "妊娠性事"
		SIF RAND:2
			RETURN
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……体力和气力都不如从前……可只要主人继续命令，%SELF_CALL()%会把自己垫给您……」"
		ELSE
			CALL MESSAGE_BOX,@"「怀着的身子……会更容易累。若仍要行房，是命令……%SELF_CALL()%不逃。」"
		ENDIF
	CASE "妊娠调教谨慎开场"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「身孕在腹，若主人仍须验这具身子的服顺，%SELF_CALL()%愿伏于令。然母体与所孕……亦请主人在施令之时一并纳入权衡。」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「%MASTER_CALL()%，%SELF_CALL()%的忠诚不含欺瞒……求您以疼惜裁度：既疼%SELF_CALL()%，也疼这未问世之命。」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「是命令%SELF_CALL()%便承受。然……%SELF_CALL()%仍乞主人记得：这肚里，亦有主人可予之名。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……%SELF_CALL()%是奴隶，亦将为人母。若可……求主人勿令二者在疼痛里对撞。」"
		ELSE
			CALL MESSAGE_BOX,@"「……服从不变。%SELF_CALL()%只在此呈明：过当之令，不独%SELF_CALL()%一躯所承。」"
		ENDIF
	ENDSELECT

CASE "调教命令"
	CALL KOJO_GENERAL_愚忠1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

CASE "绝顶"
	;深喉中的高潮（新增：深喉性癖相关口上）
	SIF TEQUIP:深喉
		CALL MESSAGE_BOX,@"「……咳……♥ 喉咙……被命令占满……我会承受……但、但快要……♥」"
	SIF TEQUIP:深喉
		CALL MESSAGE_BOX,@"「……请下达命令……即使是喉咙的失态……我也会作为忠诚接受……♥」"
	IF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「啊……♥ 我、我会忍住……不行……♥」"
		CALL MESSAGE_BOX,@"「请命令我……我会顺从到最后……♥」"
	ELSE
		CALL MESSAGE_BOX,@"「……命令……我会照做……」"
	ENDIF
	SIF NOWEX:Ａ绝顶
		IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
			CALL MESSAGE_BOX,@"「……！？　%ANAL_CALL()%……痛……可是……深处……像被烙上……主人的……♥」"
			CALL MESSAGE_BOX,@"「……这也是……忠诚的考验吗……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……痛……！？　%ANAL_CALL()%……要裂开了……！」"
			CALL MESSAGE_BOX,@"「……命令……太痛了……」"
		ENDIF
	SIF NOWEX:Ｕ绝顶
		IF TEQUIP:尿道塞 || TFLAG:尿道装备
			SIF TALENT:尿道敏感 || EX:尿道调教经验 >= 15
				CALL MESSAGE_BOX,@"「……尿道塞……像烙印一样在里面……每次颤动都提醒我归属……♥」"
			SIF !(TALENT:尿道敏感 || EX:尿道调教经验 >= 15)
				CALL MESSAGE_BOX,@"「……命令……尿道里塞着……刺痛难忍……我仍会服从……」"
		ELSE
			SIF TALENT:尿道敏感 || EX:尿道调教经验 >= 15
				CALL MESSAGE_BOX,@"「……连这里……也被主人改写……发软得……无法否认……♥」"
			SIF !(TALENT:尿道敏感 || EX:尿道调教经验 >= 15)
				CALL MESSAGE_BOX,@"「……尿道承受不住……只有痛……但我会继续……」"
		ENDIF

CASE "射精"
	IF SOURCE:膣内射精经验
		CALL MESSAGE_BOX,@"「……已接受。忠诚会收下您的全部……♥」"
	ELSEIF SOURCE:尻穴射精经验
		CALL MESSAGE_BOX,@"「……后方已接受。命令已完成……♥」"
	ELSEIF SOURCE:精饮经验
		CALL MESSAGE_BOX,@"「……已咽下。若您需要，我还能继续。」"
	ELSEIF TEQUIP:手淫
		CALL MESSAGE_BOX,@"「……手部已弄脏。我会清理干净，等待下一道命令。」"
	ELSEIF SOURCE:股间射精
		CALL MESSAGE_BOX,@"「……股间射精确认。我会清理干净，继续待命。」"
	ELSEIF SOURCE:乳房射精
		CALL MESSAGE_BOX,@"「……乳房射精确认。我会清理干净，继续待命。」"
	ELSEIF SOURCE:颜面射精
		CALL MESSAGE_BOX,@"「……颜面射精确认。我会清理干净，继续待命。」"
	ENDIF

CASE "搾乳"
	IF SOURCE:母乳漏出
		CALL MESSAGE_BOX,@"「……乳汁漏出。若这是命令，我会继续。」"
		RETURN
	ENDIF
	CALL MESSAGE_BOX,@"「……取乳命令确认。我会配合。」"
	CALL MESSAGE_BOX,@"「……哪怕羞耻，也是忠诚的一部分。」"

CASE "抽出"
	CALL MESSAGE_BOX,@"「……身体发软。请求短暂恢复后继续执行命令。」"
	CALL MESSAGE_BOX,@"「……遵命。我会重新站稳。」"

CASE "日程"
	SELECTCASE ARGS:1
	CASE "调教"
		SELECTCASE ARGS:2
		CASE "开始调教"
			CALL MESSAGE_BOX,@"「命令待命。请下达今天的指示。」"
		CASE "调教结束"
			CALL MESSAGE_BOX,@"「命令结束确认。感谢您赐予指示。」"
		ENDSELECT
	CASEELSE
	ENDSELECT

CASE "阴茎称呼变更"
	CALL MESSAGE_BOX,@"「称呼变更确认。我会按您指定的称呼称呼。」"

CASE "膣称呼变更"
	CALL MESSAGE_BOX,@"「称呼变更确认。我会记住并执行。」"

CASE "肛门称呼变更"
	CALL MESSAGE_BOX,@"「称呼变更确认。后方也将按新称呼执行。」"

CASE "吸欧派"
	SELECTCASE ARGS:1
	CASE "开始"
		CALL MESSAGE_BOX,@"「……遵命。请尽情使用。」"
	CASE "结束"
		CALL MESSAGE_BOX,@"「……结束确认。我会等待下一道命令。」"
	ENDSELECT

CASE "访问"
	SELECTCASE ARGS:1
	CASE "入口"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「……来房确认。将优先处理您的指令。请下命令。」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……您进房间了。请下达命令。」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「……见您来。有任务请指定优先级。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……您来我这间了。要做什么。」"
		ELSE
			CALL MESSAGE_BOX,@"「……门开了。无命令则待命。」"
		ENDIF
	CASE "衣服修理"
		CALL MESSAGE_BOX,@"「……衣物修复指令确认。将以最小痕迹完成缝补与加固。」"
	CASE "摸头"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「……抚摸确认。情绪稳定度上升。将维持当前状态。」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……抚摸确认。若这是奖励，我会记下并继续执行职责。」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「……接触确认。无异常。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……接触确认。」"
			CALL MESSAGE_BOX,@"「……不理解。」"
		ELSE
			CALL MESSAGE_BOX,@"「……拒绝接触。」"
		ENDIF
	CASE "接吻"
		IF TALENT:无接吻经验
			RETURN
		ELSEIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「……接吻确认。将配合执行。」"
			CALL MESSAGE_BOX,@"「……请继续。执行到您满意为止。」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……接触确认。将配合执行。若您需要更久，请下达更明确的命令。」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「……接吻确认。配合。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……」"
			CALL MESSAGE_BOX,@"「……不想。」"
		ELSE
			CALL MESSAGE_BOX,@"「……拒绝。」"
		ENDIF
	CASE "停止泌乳"
		CALL MESSAGE_BOX,@"「……收到。停止泌乳。」"
	CASE "终止妊娠"
		CALL MESSAGE_BOX,@"「……收到。终止妊娠。」"
	CASE "侍奉口爆终了"
		SELECTCASE ARGS:2
		CASE "忍住"
			CALL MESSAGE_BOX,@"「……奴……遵命……于寸前收束。」"
			CALL MESSAGE_BOX,@"「……口を離します。……粗相はいたしません。」"
		CASE "咽下"
			CALL MESSAGE_BOX,@"「……戴き申し上げました。……粗末様に。」"
			CALL MESSAGE_BOX,@"「……奴の舌がお役に立てば……十分です。」"
		ENDSELECT
	CASE "揉胸轻抚"
		CALL MESSAGE_BOX,@"「……奴……领受。……非育子之触……亦不敢辞。」"
		CALL MESSAGE_BOX,@"「……分寸……惟主子裁断。」"
	CASE "拥抱嗅闻"
		CALL MESSAGE_BOX,@"「……主子若检气息……奴……屏息……伺候。」"
		CALL MESSAGE_BOX,@"「……此身贴近……皆……主恩。」"
	CASEELSE
	ENDSELECT

CASE "事件"
	CALL MESSAGE_BOX,@"「……事件确认。请告诉我该做什么。」"

CASE "肉体改造"
	CALL MESSAGE_BOX,@"「……身体将被改造。若这是命令，我会接受并适应。」"

CASE "战斗"
	SELECTCASE ARGS:1
	CASE "攻击"
		CALL MESSAGE_BOX,@"「……执行攻击。」"
	CASE "被击中"
		CALL MESSAGE_BOX,@"「……受击。仍可继续执行。」"
	CASEELSE
	ENDSELECT

CASEELSE
ENDSELECT
RETURN

@KOJO_GENERAL_愚忠1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
CALL KOJO_GENERAL_愚忠口上1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
RETURN

;--------------------------------------------
; 排泄羞耻／身体（本口上专用）
;--------------------------------------------
@KOJO_GENERAL_愚忠1_EXCRETION_BODY(ARGS:0, ARGS:1)
SELECTCASE ARGS:0
CASE "排泄事故"
	SELECTCASE ARGS:1
	CASE "肠"
		CALL MESSAGE_BOX,@"「……属下……失态了……」"
	CASE "尿"
		CALL MESSAGE_BOX,@"「……万分抱歉……弄脏了……」"
	CASEELSE
		CALL MESSAGE_BOX,@"「……」"
	ENDSELECT
CASE "放尿主动"
	CALL MESSAGE_BOX,@"「……遵命……排尿……执行……」"
CASE "灌肠妊娠求饶"
	CALL MESSAGE_BOX,@"「……请为少主着想……灌肠……恳请收回成命……」"
CASEELSE
ENDSELECT
RETURN 1


