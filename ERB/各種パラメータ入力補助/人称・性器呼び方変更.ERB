
;人称・性器の呼び方を変更する
;ARGS→呼び方変更をするCSTR
@CHANGE_PERSONAL_CALL(ARGS)

SELF_INPUT = 0
SELECTCASE ARGS
CASE "第一人称"
	;1800～,一人称
	STR_REF = 1800
	PRINTFORML 请选择第一人称。（当前：%CSTR:第一人称%）
	FOR LOCAL,STR_REF,STR_REF +50
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
	NEXT
	IF CALLNAME != ""
		PRINTFORMLC [800] %CALLNAME%
		PRINTFORMLC [801] %CALLNAME%酱
	ELSE
		PRINTFORMLC [800] (自己的名字)
		PRINTFORMLC [801] (自己的名字)酱
	ENDIF
	CALL INPUTBUTTON
	BINPUT
	SELECTCASE RESULT
	CASE 0 TO 99
		CSTR:第一人称 = %STR:(RESULT +STR_REF)%
		CFLAG:第一人称是名字 = 0
	CASE 800
		CSTR:第一人称 = %CALLNAME%
		CFLAG:第一人称是名字 = 1
	CASE 801
		CSTR:第一人称 = %CALLNAME%酱
		CFLAG:第一人称是名字 = 1
	
	;キャンセルで自動補正に行かないようにRETURN
	CASE 900
		RETURN
	CASE 901
		CALL INPUTS_NOT_EMPTY("第一人称")
		CSTR:第一人称 = %RESULTS%
		CFLAG:第一人称是名字 = 0
		SELF_INPUT = 1
	ENDSELECT
	CALL SWEET_PERSON_CALL_SELF
	
	;補正確認の共通→スキップ設定かOKでそのまま
	CALL CHANGE_PERSONAL_CALL_FIX_AFTER(SELF_INPUT,"第一人称")
	IF RESULT
		CALL INPUTS_NOT_EMPTY("絶頂回数が一定以上の場合の一人称")
		CSTR:第一人称／沉沦 = %RESULTS%
	ENDIF

CASE "陷落前的主人公的称呼"
	;1850～,陥落前二人称
	STR_REF = 1850
	PRINTFORML 请选取陷落前的主人公称呼。（现在：%CSTR:主人公的称呼／陷落前%）
	FOR LOCAL,STR_REF,STR_REF +50
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
	NEXT
	CALL INPUTBUTTON
	BINPUT
	SELECTCASE RESULT
	CASE 0 TO 99
		CSTR:主人公的称呼／陷落前 = %STR:(RESULT +STR_REF)%
	CASE 900
		RETURN
	CASE 901
		CALL INPUTS_NOT_EMPTY("陥落前あなた呼び方")
		CSTR:主人公的称呼／陷落前 = %RESULTS%
		SELF_INPUT = 1
	ENDSELECT
	CALL SWEET_PERSON_CALL_MASTER
	CALL CHANGE_PERSONAL_CALL_FIX_AFTER(SELF_INPUT,"主人公的称呼／陷落前")
	IF RESULT
		CALL INPUTS_NOT_EMPTY("絶頂回数が一定以上の場合の陥落前あなた呼び方")
		CSTR:主人公的称呼／陷落前／沉沦 = %RESULTS%
	ENDIF

CASE "陷落后的主人公的称呼"
	;子なら専用処理
	IF CSTR:状态／主人公的孩子 != ""
		CALL CHANGE_PERSONAL_C_CALL("主人公的称呼／陷落后")
		RETURN
	ENDIF
	
	;6300～,あなたの呼ばせ方
	STR_REF = 6300
	PRINTFORML 请选取陷落后的主人公称呼。（现在：%CSTR:主人公的称呼／陷落后%）
	FOR LOCAL,STR_REF,STR_REF +100
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
	NEXT
	CALL INPUTBUTTON
	BINPUT
	SELECTCASE RESULT
	CASE 0 TO 99
		CSTR:主人公的称呼／陷落后 = %STR:(RESULT +STR_REF)%
	CASE 900
		RETURN 99
	CASE 901
		CALL INPUTS_NOT_EMPTY("陷落后的主人公的称呼")
		CSTR:主人公的称呼／陷落后 = %RESULTS%
		SELF_INPUT = 1
	ENDSELECT
	CALL SWEET_PERSON_CALL_MASTER_LOVE
	CALL CHANGE_PERSONAL_CALL_FIX_AFTER(SELF_INPUT,"主人公的称呼／陷落后")
	IF RESULT
		CALL INPUTS_NOT_EMPTY("絶頂回数が一定以上の場合の陥落後あなた呼び方")
		CSTR:主人公的称呼／陷落后／沉沦 = %RESULTS%
		CALL INPUTS_NOT_EMPTY("甘えた声で呼ぶあなた呼び方")
		CSTR:主人公的称呼／依恋 = %RESULTS%
	ENDIF
	
CASE "阴茎称呼"
	;1500～,ペニス呼び方前半
	STR_REF = 1500
	PRINTFORML 请选择阴茎的称呼。（现在：%CSTR:性器称呼／阴茎%）
	STR_MAX = 50
	
	;恋慕／乳牛で選択範囲が増加
	SIF ＃陷落状态／恋慕以上＃ || CFLAG:乳牛
		STR_MAX = 100
	FOR LOCAL,STR_REF,STR_REF +STR_MAX
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
	NEXT
	CALL INPUTBUTTON
	BINPUT
	SELECTCASE RESULT
	CASE 0 TO 99
		CSTR:性器称呼／阴茎 = %STR:(RESULT +STR_REF)%
	
	;調教で来る場合に備えてRETURN 1にする
	CASE 900
		RETURN 1
	CASE 901
		CALL INPUTS_NOT_EMPTY("ペニスの呼び方")
		CSTR:性器称呼／阴茎 = %RESULTS%
		SELF_INPUT = 1
	ENDSELECT
	CALL SWEET_PENIS_CALL
	CALL CHANGE_PERSONAL_CALL_FIX_AFTER(SELF_INPUT,"性器称呼／阴茎")
	IF RESULT
		CALL INPUTS_NOT_EMPTY("絶頂回数が一定以上の場合のペニスの呼び方")
		CSTR:性器称呼／阴茎／沉沦 = %RESULTS%
	ENDIF

CASE "膣称呼"
	;1600～,膣呼び方前半
	STR_REF = 1600
	PRINTFORML 请选择%SAVESTR:标识／膣%的称呼。（现在：%CSTR:性器称呼／膣%）
	STR_MAX = 50
	SIF ＃陷落状态／恋慕以上＃ || CFLAG:乳牛
		STR_MAX = 100
	FOR LOCAL,STR_REF,STR_REF +STR_MAX
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
	NEXT
	CALL INPUTBUTTON
	BINPUT
	SELECTCASE RESULT
	CASE 0 TO 99
		CSTR:性器称呼／膣 = %STR:(RESULT +STR_REF)%
	CASE 900
		RETURN 1
	CASE 901
		CALL INPUTS_NOT_EMPTY,@"%SAVESTR:标识／膣%的称呼"
		CSTR:性器称呼／膣 = %RESULTS%
		SELF_INPUT = 1
	ENDSELECT
	CALL SWEET_VAGINA_CALL
	CALL CHANGE_PERSONAL_CALL_FIX_AFTER(SELF_INPUT,"性器称呼／膣")
	IF RESULT
		CALL INPUTS_NOT_EMPTY,@"达到一定的绝顶次数情况下的%SAVESTR:标识／膣%的称呼"
		CSTR:性器称呼／膣／沉沦 = %RESULTS%
	ENDIF

CASE "肛门称呼"
	;1700～,アナル呼び名前半
	STR_REF = 1700
	PRINTFORML 请选择%SAVESTR:标识／肛门%的称呼。（现在：%CSTR:性器称呼／肛门%）
	STR_MAX = 50
	SIF ＃陷落状态／恋慕以上＃ || CFLAG:乳牛
		STR_MAX = 100
	FOR LOCAL,STR_REF,STR_REF +STR_MAX
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
	NEXT
	CALL INPUTBUTTON
	BINPUT
	SELECTCASE RESULT
	CASE 0 TO 99
		CSTR:性器称呼／肛门 = %STR:(RESULT +STR_REF)%
	CASE 900
		RETURN 1
	CASE 901
		CALL INPUTS_NOT_EMPTY,@"%SAVESTR:标识／肛门%的称呼"
		CSTR:性器称呼／肛门 = %RESULTS%
		SELF_INPUT = 1
	ENDSELECT
	CALL SWEET_ANAL_CALL
	CALL CHANGE_PERSONAL_CALL_FIX_AFTER(SELF_INPUT,"性器称呼／肛门")
	IF RESULT
		CALL INPUTS_NOT_EMPTY,@"达到一定的绝顶次数情况下的%SAVESTR:标识／肛门%的称呼"
		CSTR:性器称呼／肛门／沉沦 = %RESULTS%
	ENDIF
ENDSELECT



;手動入力してないかつ、確認しないor手を出す前の娘ならそのままおわり
;ARG→SELF_INPUT
;ARGS→呼び方変更をするCSTR
@CHANGE_PERSONAL_CALL_FIX_AFTER(ARG,ARGS)
#DIMS SWEET_CALL

SIF (!FLAG:自动呼叫校正确认 || GROUPMATCH(CSTR:状态／主人公的孩子,"成长中","成长后")) && !ARG
	RETURN
SWEET_CALL = %ARGS%／沉沦
PRINTL
PRINTL 已添加自动校正
PRINTFORML 在绝顶次数达到一定以上时，将变为「%CSTR:SWEET_CALL%」

;陥落後あなた呼び方は甘えも表示
SIF SWEET_CALL == "主人公的称呼／陷落后／沉沦"
	PRINTFORML 依恋地呼唤时为「%CSTR:主人公的称呼／依恋%」。
PRINTLC [ 0] OK
PRINTLC [ 1] 手动输入
BINPUT
RETURN RESULT



