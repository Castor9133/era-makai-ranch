
;ペニス引き抜き
@COM890_MESSAGE

;調教外から来た場合引き抜き前に止める
;WAIT_SKIPがあれば止めない
SIF !TFLAG:调教中 && !WAIT_SKIP
	WAIT
IF GETBIT(＃Ｐ解除／Ｖ插入＃)
	PRINTFORML 从%CALLNAME%的%SLANG_V()%拔出了%SLANG_PENIS()%…
	CALL KOJO_PRINT("调教命令","Ｖ阴茎拔出")
	IF TFLAG:膣内精液
		CALL PRINT_WORD_COLOR,@"　%SLANG_V()%溢出了%CALLNAME:0%的%SLANG_SEMEN()%…","桃"
		CALL HEARTCB(0xD02830)
		PRINTL
	ENDIF

ELSEIF GETBIT(＃Ｐ解除／Ａ插入＃)
	PRINTFORML 从%CALLNAME%的%SLANG_A()%拔出了%SLANG_PENIS()%…
	CALL KOJO_PRINT("调教命令","Ａ阴茎拔出")
	IF TFLAG:尻穴精液
		CALL PRINT_WORD_COLOR,@"　%SLANG_A()%溢出了%CALLNAME:0%的%SLANG_SEMEN()%…","桃"
		CALL HEARTCB(0xD02830)
		PRINTL
	ENDIF

ELSEIF GETBIT(＃Ｐ解除／乳交＃)
	PRINTFORML 从%CALLNAME%的%SLANG_B()%拔出了%SLANG_PENIS()%…
	CALL KOJO_PRINT("调教命令","Ｂ阴茎拔出")
	IF TFLAG:乳内精液
		CALL PRINT_WORD_COLOR,@"　%SLANG_B()%的乳沟溢出了%CALLNAME:0%的%SLANG_SEMEN()%…","桃"
		CALL HEARTCB(0xD02830)
		PRINTL
	ENDIF

ELSEIF GETBIT(＃Ｐ解除／Ｍ插入＃)
	PRINTFORML 从%CALLNAME%口中拔出%SLANG_PENIS()%…
	CALL KOJO_PRINT("调教命令","Ｍ阴茎拔出")
	IF TFLAG:口内精液
		IF CFLAG:崩坏
			PRINTFORM %CALLNAME%的嘴里溢出了%CALLNAME:0%的%SLANG_SEMEN()%…
		ELSEIF ＃陷落状态／隶属＃ || (＃陷落状态／恋慕以上＃ && ABL:精液中毒 >= 10)
			CALL PRINT_WORD_COLOR,@"　%CALLNAME%吞下嘴里残留的%CALLNAME:0%%SLANG_SEMEN()%，然后张开嘴让%CALLNAME:0%检查…","桃"
			CALL HEARTCB(0xD02830)
		ELSEIF ABL:精液中毒 >= 10
			CALL PRINT_WORD_COLOR,@"　%CALLNAME%将嘴里残留的的%SLANG_SEMEN()%一饮而尽…","桃"
			CALL HEARTCB(0xD02830)
		ELSEIF MARK:恐怖刻印
			PRINTFORM %CALLNAME%泪眼婆娑地将残留在嘴里的%CALLNAME:0%%SLANG_SEMEN()%一饮而尽…
		ELSE
			PRINTFORM %CALLNAME%吐出嘴里残留的%CALLNAME:0%%SLANG_SEMEN()%…
		ENDIF
		PRINTL
	ENDIF

;素股、手コキ、授乳手コキ　とりあえず
ELSE
	PRINTFORML 让%CALLNAME%停止侍奉。
ENDIF



;搾乳器取り外し
;ARGS→LACTATION_TOOL
@COM891_MESSAGE(ARGS)

PRINTFORML 已从%CALLNAME%%SLANG_B()%上卸下%ARGS%…
CALL KOJO_PRINT("调教命令","搾乳器移除")
SIF BASE:母乳容量
	CALL MILK_WHITE_BUST_MESSAGE



;搾乳触手外し
;ARGS→LACTATION_TENTACLE
@COM892_MESSAGE(ARGS)

PRINTFORML 已从%CALLNAME%%SLANG_B()%上卸下%ARGS%…
CALL KOJO_PRINT("调教命令","取下榨乳触手")
SIF BASE:母乳容量
	CALL MILK_WHITE_BUST_MESSAGE



;白く染めていく
@MILK_WHITE_BUST_MESSAGE

CALL PRINT_WORD_COLOR,@"　溢出的%SLANG_MILK()%将%SLANG_B()%染成白色…","桃"
CALL HEARTCB(0xD02830)
PRINTL



;胸汚れ拭き取り
@COM893_MESSAGE

PRINTFORM %CALLNAME%的%SLANG_STAIN("Ｂ")%%SLANG_B()%被用湿毛巾擦拭干净了…
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
SIF EX:Ｂ绝顶 +EX:Ｎ绝顶 >= 10
	PRINTFORM 如此轻微的刺激%CALLNAME%似乎也有感觉…



;コンドーム外し
@COM895_MESSAGE
PRINTFORML 自己的%SAVESTR:标识／阴茎%上取下了避孕套…
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")


