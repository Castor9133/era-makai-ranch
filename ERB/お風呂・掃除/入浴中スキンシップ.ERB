
;スキンシップ前のフラグ処理
@PLAY_BATHLOOM_BEFORE

CALL RESET_TRAIN_PALAM
VARSET TFLAG,1,120,145
CALL AJUST_STRIP_FLAG
TFLAG:日程外Ｈ = 1
PLAYER = MASTER

;ちんぽチェック
CALL PLAYER_PENIS_CHECK

;浴槽内かどうか判定するのでまず入る
TFLAG:浴缸内 = 1
TFLAG:浴室 = 1
;お湯で潤滑増える
PALAM:Ｖ润滑 += 5000
PALAM:Ａ润滑 += 5000

;TARGETの保存が必要
SAVE_TARGET = TARGET
CALL PLAY_BATHLOOM

;リセット前にTARGET戻しが必要
TARGET = SAVE_TARGET
CALL RESET_TRAIN_PALAM
CALL RESET_TIME_FLAG

;行動済みにして大浴場をキャンセルさせる
CFLAG:SAVE_TARGET:行动完毕 = 1



;お風呂でスキンシップ
@PLAY_BATHLOOM

;行動でHP増減するので毎回個人の業務可能チェックを入れる
CALL TARGET_SCHEDULE_POSSIBLE

;毎回汚れをリセット
RESET_STAIN 0
RESET_STAIN TARGET
TFLAG:日程外Ｈ = 1

;スケジュール外でのリセット
VARSET TFLAG,0,30,100
VARSET TEQUIP

;全部WAITスキップでOK
TFLAG:Ｐ抽出后等待跳过 = 1
CALL MANYL(5)
CALL SHOW_SLAVE_STATE(2)
	;CALL KOJO_PRINT("訪問","入口")
PRINTL

;浴槽に入ってるかどうか判定
IF TFLAG:浴缸内
	PRINTL 　＜浴缸内＞
ELSE
	PRINTL 　＜浴室＞
ENDIF
CALL BATHLOOM_COMMAND_CHECK
CALL MANYL(3)
DRAWLINE
PRINTFORML [99] 洗完澡（经过时间：{TFLAG:亲密互动次数}）
BINPUT
IF CSTR:状态／主人公的孩子 == "成长后"
	SELECTCASE RESULT
	CASE 2,4,11
		CHILD_COM = RESULT
		CALL CHILD_REBELLION
		SIF RESULT
			RESTART
		RESULT = CHILD_COM
	ENDSELECT
ENDIF
SELECTCASE RESULT
CASE 0
	;[会いに行く]内と共通
	CALL VISIT_STROKING_HEAD
CASE 1
	CALL BATHLOOM_KISS
CASE 2
	CALL BATHLOOM_BUST_MASSAGE
CASE 3
	CALL BATHLOOM_SLAVE_WASHING
CASE 4
	CALL BATHLOOM_V_INSERT
CASE 10
	CALL BATHLOOM_PLAYER_WASHING
CASE 11
	CALL VISIT_BREAST_FEEDING
CASE 99
	CALL PLAY_BATHLOOM_AFTER
	RETURN
ENDSELECT

;回数制限撤廃ならここで回数を0
SIF GETBIT(＃限制解除／家庭浴池＃)
	TFLAG:亲密互动次数 = 0

;10回スキンシップを超えるとのぼせておわり　HP-100
IF TFLAG:亲密互动次数 > 9
	COST = 100
	PRINTFORML %CALLNAME:0%和%CALLNAME%都感到头晕目眩…　HP-{COST}
	CALL PLAYER_HP_COST(COST,1)
	CALL HP_COST(COST,1)
	WAIT_ON ++
	RETURN
ENDIF

;風呂は体力なくなったらおわり
IF !BASE:体力
	PRINTFORML %CALLNAME%看起来疲惫不堪…在晕眩之前让她出去吧。
	WAIT_ON ++
	RETURN
ENDIF
RESTART



