
;おっぱい関連まとめて表示
@PRINT_BUST_DETAIL(ARG)

;元々表示を広域変数制御
IF !ORIGINAL_STATUS
	PRINTFORM 胸围大小：%PRINT_BUSTSIZE(ABL:胸围大小)%
	CALL PRINT_BUST_C(1,1,1)
	CALL PRINT_NIPPLE_COLOR
ELSE
	CALL PRINT_ORIGINAL_BUST
ENDIF
SIF ARG
	PRINTL



;おっぱいサイズをランダム要素なしで表示
;FUNCTION型
@PRINT_BUST
#FUNCTIONS
#DIMS BUSTSIZE

BUSTSIZE =
SIF MARK:淫乳
	BUSTSIZE += "淫乱"
IF TALENT:超乳
	BUSTSIZE += "超乳"
ELSEIF TALENT:魔乳
	BUSTSIZE += "魔乳"
ELSEIF TALENT:神乳
	BUSTSIZE += "神乳"
ELSEIF TALENT:爆乳
	BUSTSIZE += "爆乳"
ELSEIF TALENT:丰乳
	BUSTSIZE += "丰乳"
ELSEIF TALENT:巨乳
	BUSTSIZE += "巨乳"
ELSEIF TALENT:普乳
	BUSTSIZE += "乳房"
ELSEIF TALENT:贫乳
	BUSTSIZE += "微乳"
ELSEIF TALENT:绝壁
	BUSTSIZE += "胸板"
ELSE
	BUSTSIZE += "柔乳"
ENDIF
RETURNF BUSTSIZE



