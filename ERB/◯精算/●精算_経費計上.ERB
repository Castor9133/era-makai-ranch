
;経費計上
@SETTLEMENT_BUDGET_COST
#DIM TOTAL_SALARY

SIF MONEY_TOTAL <= 0
	RETURN

;従業員の人数*20000が懐に入る最低保障
WORKER = SUMCARRAY(EQUIP:自室)
TOTAL_SALARY = WORKER *WORKER_SALARY

;最低保障までの場合それ+しておわり
IF MONEY_TOTAL <= TOTAL_SALARY
	MONEY_PLUS = MONEY_TOTAL
	MONEY_TOTAL = 0
	RETURN
ENDIF

;まず最低保障資金増加
MONEY_PLUS = TOTAL_SALARY
MONEY_TOTAL -= TOTAL_SALARY

;経費計上した分を精算・MONEY_TOTAL減少
CALL SETTLEMENT_ITEM_LOAN

;0になってたらおわり
SIF !MONEY_TOTAL
	RETURN

;ローン返済・MONEY_TOTAL減少
CALL SETTLEMENT_BUILDING_LOAN



;経費計上した分を精算
@SETTLEMENT_ITEM_LOAN

SIF !MONEY:经费计上
	RETURN
IF MONEY_TOTAL <= MONEY:经费计上
	MONEY:经费计上 -= MONEY_TOTAL
	CALL PRINTL_WORD_COLOR,@"经费结算：%VALUE_DIGIT(MONEY_TOTAL)%G 剩余%VALUE_DIGIT(MONEY:经费计上)%G ","浅蓝色"
	MONEY_TOTAL = 0
	RETURN
ENDIF
CALL PRINTL_WORD_COLOR,@"经费结算：%VALUE_DIGIT(MONEY:经费计上)%G ","浅蓝色"
MONEY_TOTAL -= MONEY:经费计上
MONEY:经费计上 = 0



;ローン返済
@SETTLEMENT_BUILDING_LOAN

SIF !MONEY:贷款
	RETURN

;支払いきれない場合は半分にする
IF MONEY_TOTAL <= MONEY:贷款
	MONEY_TOTAL /= 2
	MONEY:贷款 -= MONEY_TOTAL
	CALL PRINTL_WORD_COLOR,@"贷款偿还：%VALUE_DIGIT(MONEY_TOTAL)%G 剩余%VALUE_DIGIT(MONEY:贷款)%G ","浅蓝色"
	RETURN
ENDIF
CALL PRINTL_WORD_COLOR,@"贷款偿还：%VALUE_DIGIT(MONEY:贷款)%G ","浅蓝色"
MONEY_TOTAL -= MONEY:贷款
MONEY:贷款 = 0



