
;調教後スキルポイント獲得計算
@TRAIN_AFTER_SKILL_POINT_CALC
#DIM SKILL_POINT

;調教AP：蓄積値50→1AP
SKILL_POINT = MONEY:调教AP累积值 /50
IF SKILL_POINT
	MONEY:调教AP += SKILL_POINT
	MONEY:调教AP累计值 += SKILL_POINT
	MONEY:调教AP累积值 -= (SKILL_POINT *50)
	CALL PRINT_WORD_COLOR,@"【调教AP+{SKILL_POINT}】","浅蓝色"
ENDIF

;魔術AP：蓄積値100→1AP
SKILL_POINT = MONEY:魔法AP累积值 /100
IF SKILL_POINT
	MONEY:魔法AP += SKILL_POINT
	MONEY:魔法AP累计值 += SKILL_POINT
	MONEY:魔法AP累积值 -= (SKILL_POINT *100)
	CALL PRINT_WORD_COLOR,@"【魔法AP+{SKILL_POINT}】","浅蓝色"
ENDIF

;触手AP：蓄積値100→1AP
SKILL_POINT = MONEY:触手AP累积值 /100
IF SKILL_POINT
	MONEY:触手AP += SKILL_POINT
	MONEY:触手AP累计值 += SKILL_POINT
	MONEY:触手AP累积值 -= (SKILL_POINT *100)
	CALL PRINT_WORD_COLOR,@"【触手AP+{SKILL_POINT}】","浅蓝色"
ENDIF
SIF !LINEISEMPTY()
	PRINTL






