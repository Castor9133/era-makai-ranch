
;選択装備の状態含め表示
;ARG→選択アイテムID
;ARGS→表示箇所
@PRINT_SELECT_ITEM_DETAIL(ARG,ARGS)
#DIMS CLOTHE_CATEGORY
 
;ARGが0なら帰る
SIF !ARG
	RETURN

;種類取得
CALL CLOTHE_CATEGORY_CHECK(ITEMNAME:ARG)
CLOTHE_CATEGORY = %RESULTS%

;一応空欄なら帰る
SIF CLOTHE_CATEGORY == ""
	RETURN

;装備一覧でEXISTがあれば｜で区切る
SIF EXIST && ARGS == "装备一览"
	PRINT ｜
EXIST ++

;衣服の場合だけ状態とか複雑なので別関数
IF CLOTHE_CATEGORY == "衣服"
	CALL PRINT_SELECT_ITEM_DETAIL_CLOTHE(ARG,ARGS)
ELSE
	;色・柄・形→アイテム名
	;着替え候補だとPRINTLCする
	SELECTCASE ARGS
	CASE "穿着中"
		PRINTFORMLC 　穿着中：%CSTR:ARG%%ITEMNAME:ARG%
	CASE "所持中"
		PRINTFORMLC [ 0] 所持的%CSTR:ARG%%ITEMNAME:ARG%を穿着
	CASEELSE
		PRINTFORM %CSTR:ARG%%ITEMNAME:ARG%
	ENDSELECT
ENDIF



;衣服の状態表示
;ARG→選択アイテムID
;ARGS→表示箇所
@PRINT_SELECT_ITEM_DETAIL_CLOTHE(ARG,ARGS)
#DIMS CLOTHE

;色・柄・形→アイテム名
SELECTCASE ARGS
CASE "穿着中"
	CLOTHE = 　穿着中：
CASE "所持中"
	CLOTHE = [ 0] 持有中的
CASEELSE
	CLOTHE =
ENDSELECT

;色柄
CLOTHE += CSTR:ARG

;改造状態
IF !＃选择衣服／胸部撕裂＃
	IF ＃选择衣服／乳房露出＃
		CLOTHE += "乳房露出"
	ELSEIF ＃选择衣服／乳暖簾＃
		CLOTHE += "乳暖簾"
	ELSEIF !＃选择衣服／乳沟露出＃
		SIF ＃选择衣服／侧乳露出＃
			CLOTHE += "侧乳"
		SIF ＃选择衣服／乳沟穴＃
			CLOTHE += "乳沟穴"
		SIF ＃选择服装／授乳开口＃
			CLOTHE += "授乳开口"
	ENDIF
ENDIF
IF !＃选择衣服／私处撕裂＃
	IF ＃选择衣服／私处露出＃
		CLOTHE += "私处露出"
	ELSEIF ＃选择衣服／前掛け＃
		CLOTHE += "围裙"
	ENDIF
ENDIF

;アイテム名
CLOTHE += ITEMNAME:ARG

;露出状態
IF ＃选择衣服／胸部撕裂＃
	IF ＃选择衣服／私处撕裂＃
		CLOTHE += "[破损]"
	ELSE
		CLOTHE += "[胸部撕裂]"
	ENDIF
ELSE
	SIF ＃选择衣服／乳沟露出＃
		CLOTHE += "[乳沟露出]"
	SIF ＃选择衣服／私处撕裂＃
		CLOTHE += "[私处撕裂]"
ENDIF

;着替え候補だとPRINTLCする
SELECTCASE ARGS
CASE "穿着中"
	PRINTFORMLC %CLOTHE%
CASE "所持中"
	PRINTFORMLC %CLOTHE%穿着
CASEELSE
	PRINTFORM %CLOTHE%
ENDSELECT



;服とかの状態を表示
;ARG→追加改行
@SHOW_EQUIP(ARG)

;露出フラグを合わせる
CALL AJUST_STRIP_FLAG

;調教中かセクハラ中はTRAINのほうに飛ばす
IF TFLAG:调教中 || TFLAG:日程外Ｈ
	CALL SHOW_EQUIP_TRAIN
	RETURN
ENDIF

;改行判定を前のほうから
EXIST = 0
CALL PRINT_WORD_COLOR("[装备]","黄")

;全裸か判定

IF !EQUIP:装备中ID／铠 && !EQUIP:装备中ID／衣服 && !EQUIP:装备中ID／内衣上装 && !EQUIP:装备中ID／内衣下装
	CALL PRINTL_WORD_COLOR("＜全裸＞　","桃")

;鎧・衣服・下着
;衣服状態がだいぶ長いと1行に収まらないけどいい改行判定計算方法思いつかない
ELSE
	CALL PRINT_SELECT_ITEM_DETAIL(EQUIP:装备中ID／铠,"装备一览")
	CALL LINE_BREAKS
	CALL PRINT_SELECT_ITEM_DETAIL(EQUIP:装备中ID／衣服,"装备一览")
	CALL LINE_BREAKS
	CALL PRINT_SELECT_ITEM_DETAIL(EQUIP:装备中ID／内衣上装,"装备一览")
	CALL LINE_BREAKS
	
	;下着の上下IDが同じ場合は表示しない
	SIF EQUIP:装备中ID／内衣上装 != EQUIP:装备中ID／内衣下装
		CALL PRINT_SELECT_ITEM_DETAIL(EQUIP:装备中ID／内衣下装,"装备一览")
	CALL LINE_BREAKS
	CALL PRINT_STRIP_PART
	CALL LINE_BREAKS
	CALL LINE_BREAKS(1)
ENDIF

;アクセサリー
CALL PRINT_WORD_COLOR("[装饰]","黄")

;一旦リセット
EXIST = 0
FOR LOCAL,10,20
	SIF !EQUIP:LOCAL
		CONTINUE
	CALL PRINT_SELECT_ITEM_DETAIL(EQUIP:LOCAL,"装备一览")
	CALL LINE_BREAKS
NEXT

;家畜管理タグ
IF EQUIP:家畜管理标签／身分 || EQUIP:家畜管理标签／称呼
	SIF EXIST
		PRINT ｜
	EXIST ++
	PRINT 家畜管理标签
	CALL LINE_BREAKS
ENDIF
IF !EXIST
	CALL PRINTL_WORD_COLOR,@"＜没有＞","灰"
ELSE
	CALL LINE_BREAKS(1)
ENDIF
SIF ARG
	PRINTL



;調教中の装備状態表示
@SHOW_EQUIP_TRAIN

;今のところあなたは脱がせないので表示しない(プレイヤーのイメージにまかせる感じで)
SIF !TARGET
	RETURN

;一時的脱衣のフラグも使って判定する
;鎧脱がすからいらない　調教にいろいろ制限出るのでずっとそうだと思う
EXIST = 0
CALL PRINT_WORD_COLOR("[装备]","黄")
IF !TFLAG:临时脱衣／衣服 && EQUIP:装备中ID／衣服
	CALL PRINT_SELECT_ITEM_DETAIL(EQUIP:装备中ID／衣服,"装备一览")
	IF GETBIT(＃半脱／衣服上＃)
		IF GETBIT(＃半脱／衣服下＃)
			PRINT ＜半脱＞
		ELSE
			PRINT ＜上身半脱＞
		ENDIF
	ELSEIF GETBIT(＃半脱／衣服下＃)
		PRINT ＜下身半脱＞
	ENDIF
	CALL LINE_BREAKS
ENDIF
IF !TFLAG:临时脱衣／内衣上装 && EQUIP:装备中ID／内衣上装
	CALL PRINT_SELECT_ITEM_DETAIL(EQUIP:装备中ID／内衣上装,"装备一览")
	SIF GETBIT(＃半脱／内衣上装＃)
		PRINT ＜半脱＞
	CALL LINE_BREAKS
ENDIF

;上下一体の場合対応
IF EQUIP:装备中ID／内衣上装 == EQUIP:装备中ID／内衣下装

ELSEIF !TFLAG:临时脱衣／内衣下装 && EQUIP:装备中ID／内衣下装
	CALL PRINT_SELECT_ITEM_DETAIL(EQUIP:装备中ID／内衣下装,"装备一览")
	SIF GETBIT(＃半脱／内衣下装＃)
		PRINT ＜半脱＞
	CALL LINE_BREAKS
ENDIF

;露出状態を表示
;EXIST = 0なら全裸
IF EXIST
	CALL PRINT_STRIP_PART
	CALL LINE_BREAKS
	CALL LINE_BREAKS(1)
ELSE
	CALL PRINTL_WORD_COLOR("＜全裸＞　","桃")
ENDIF

;アクセサリー
CALL PRINT_WORD_COLOR("[装饰]","黄")
EXIST = 0
FLAG_REF = 120
FOR LOCAL,10,20
	SIF !EQUIP:LOCAL
		CONTINUE
	
	;一時的脱衣フラグがあれば表示しない　130～
	SIF TFLAG:(LOCAL +FLAG_REF)
		CONTINUE
	CALL PRINT_SELECT_ITEM_DETAIL(EQUIP:LOCAL,"装备一览")
	CALL LINE_BREAKS
NEXT
IF EQUIP:家畜管理标签／身分 || EQUIP:家畜管理标签／称呼
	SIF EXIST
		PRINT ｜
	EXIST ++
	PRINT 家畜管理标签
	CALL LINE_BREAKS
ENDIF
IF !EXIST
	CALL PRINTL_WORD_COLOR,@"＜没有＞","灰"
ELSE
	CALL LINE_BREAKS(1)
ENDIF



;露出部位表示
@PRINT_STRIP_PART
#DIMS STRIP_PART

;TFLAG:140～144が露出フラグ
STRIP_PART =

;上手いことループさせようとしても逆に複雑なので1つずつ
SIF TFLAG:Ａ露出
	STRIP_PART += "Ａ"
SIF TFLAG:Ｂ露出
	STRIP_PART += "Ｂ"
SIF TFLAG:Ｃ露出
	STRIP_PART += "Ｃ"
SIF TFLAG:Ｖ露出
	STRIP_PART += "Ｖ"
SIF TFLAG:Ｎ露出
	STRIP_PART += "Ｎ"

;なければ帰る
SIF STRIP_PART == ""
	RETURN
CALL PRINT_WORD_COLOR,@"【%STRIP_PART%露出】","桃"


;表示文字数が多すぎて絵に被りそうな場合に改行
;ARG→〆の時に1
@LINE_BREAKS(ARG)
#DIM LBCHECK

IF !ARG
	IF !LBCHECK
		VARSET CANDI_BOX
		VARSET CANDI_NO_BOX
	ENDIF
	HTML_POPPRINTINGSTR
	CANDI_BOX:LBCHECK = %RESULTS%
	LOCALS = %HTML_TOPLAINTEXT(CANDI_BOX:LBCHECK)%
	STRLENS LOCALS
	CANDI_NO_BOX:LBCHECK = RESULT
	LBCHECK ++
ELSEIF LBCHECK
	LOCAL = 0
	LOCALS = 
	REPEAT LBCHECK
		LOCALS += CANDI_BOX:COUNT
		LOCAL += CANDI_NO_BOX:COUNT
		IF LOCAL + CANDI_NO_BOX:(COUNT+1) > 80
			HTML_PRINT LOCALS
			LOCAL = 0
			LOCALS = 
		ENDIF
	REND
	SIF LOCALS != ""
		HTML_PRINT LOCALS
	LBCHECK = 0
ENDIF
