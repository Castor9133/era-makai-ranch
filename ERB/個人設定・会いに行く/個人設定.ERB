
;奴隷個人設定
@SLAVE_CONFIG

CLEARLINE LINECOUNT
CALL SHOW_SLAVE_STATE
IF MARK:母乳体质
	IF CSTR:风味牛奶 != ""
		CALL PRINTL_WORD_COLOR("　对于风味牛奶，无法更改商品名称","灰")
	ELSE
		PRINTL [ 1] 母乳商品更名
	ENDIF
ELSE
	CALL PRINTL_WORD_COLOR("　非【母乳体质】","灰")
ENDIF
PRINTL
PRINT [ 2] 更改使用口上/切换查看　
CALL PRINTL_WORD_COLOR,@"完整—口上视图\@ FLAG:口上表示 ? ON 　 # OFF　 \@","黄"
IF CFLAG:口上表示
	PRINTFORML 　　使用口上%CSTR:使用口上%
ELSE
	CALL PRINTL_WORD_COLOR("　　未设置口上","灰")
ENDIF
PRINTL
PRINTLC [ 4] 在主屏幕上隐藏
CALL PRINT_ONOFF(CFLAG:表示OFF／主要画面)
CALL PRINTL_WORD_COLOR,@"　完整：\@ FLAG:主要／奴隶隐藏 ? OFF则隐藏　 # 全部显示 　 \@","黄"
PRINTLC [ 5] 非屈服状态也允许入浴
CALL PRINT_ONOFF(CFLAG:入浴许可,1)
PRINTLC [ 6] 收藏夹设置
CALL PRINT_ONOFF(CFLAG:收藏夹,1)
PRINTL

;STR:アビリティ有効個人BIT→22020
STR_REF = 22020
PRINTL 《 能力有效个人设置 》
FOR LOCAL,0,10
	SIF STR:(STR_REF +LOCAL) == ""
		CONTINUE
	PRINTFORMLC [{LOCAL +10}] %STR:(STR_REF +LOCAL)%
	CALL PRINT_ONOFF(GETBIT(CFLAG:能力有效个人BIT,LOCAL),1)
NEXT
PRINTL
PRINTL [30] 像素画・角色图像
PRINTL [31] 料理・晚餐
PRINTL [32] 自动调教处理
CALL PRINTL_ALIGN
DRAWLINE
PRINTL [99] 完成
BINPUT
PRINTL
SELECTCASE RESULT
CASE 1
	CALL MILK_PRODUCT_NAME_CHANGE
CASE 2
	CALL KOJO_SETTING
CASE 4
	PRINTFORML 确保%CALLNAME%不出现在牧场主屏幕上？（仅显示为OFF，日程等仍可工作）
	PRINTL 适用于长时间自动调度相同任务等情况。
	CALL PRINTL_WORD_COLOR("由于HP不足而设置休息等也不会显示，因此在多人执行相同任务的情况下建议使用。","黄")
	PRINTL
	PRINTLC [ 0] 显示
	PRINTL [ 1] 隐藏
	INPUT
	SIF RESULT == 0 || RESULT == 1
		CFLAG:表示OFF／主要画面 = RESULT
CASE 5
	INVERTBIT CFLAG:入浴许可,0
CASE 6
	INVERTBIT CFLAG:收藏夹,0
CASE 10 TO 19
	INVERTBIT CFLAG:能力有效个人BIT,RESULT -10
CASE 30
	CALL SLAVE_CONFIG_PORTRAIT
CASE 31
	CALL SLAVE_CONFIG_COOKING
CASE 32
	CALL SLAVE_CONFIG_TRAIN_AUTO
CASE 99
	RETURN
ENDSELECT
RESTART



