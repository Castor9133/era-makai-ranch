
;1ページ
@SELF_CHARA_MAKE_STATUS_1

PRINTL 　《 状态 》
CALL HALFLINE
IF !CFLAG:非战斗职业
	PRINTLC [ 0] 等级
	PRINTFORML ：Lv{BASE:等级}
ELSE
	CALL PRINTL_WORD_COLOR,@"< 0> 等级：Lv{BASE:等级}固定","灰"
ENDIF
PRINTLC [ 1] 非战斗职业
CALL PRINT_ONOFF(CFLAG:非战斗职业,1)
PRINTLC 　级别（自动计算）
PRINTFORML ★{CFLAG:级别}
PRINTLC [ 2] 体力
PRINTFORML ：{MAXBASE:体力}HP
PRINTLC [ 3] 气力
PRINTFORML ：{MAXBASE:气力}SP
PRINTL

;各数値固定を追加
PRINTFORML 　灵力：%VALUE_DIGIT(MAXBASE:灵力)%EP
IF !CFLAG:非战斗职业
	PRINTL [ 4] 灵力重新计算
	
	;手動のみ変更可能
	IF !SELF_CHARA_MAKE_RANDOM
		PRINTLC [ 5] 灵力固定
		CALL PRINT_ONOFF(CFLAG:灵力固定,1)
	ELSE
		CALL PRINTL_WORD_COLOR,@"< 5> 灵力固定…手动输入仅可","灰"
	ENDIF
ELSE
	CALL PRINTL_WORD_COLOR,@"　灵力重新计算","灰"
	CALL PRINTL_WORD_COLOR,@"　灵力固定","灰"
ENDIF
PRINTL
PRINTFORML 　魔力：%VALUE_DIGIT(MAXBASE:魔力)%MP
PRINTLC [ 6] 魔力量
PRINTFORML ：{CFLAG:魔力量}/10
PRINTL [ 7] 魔力重新计算
IF !SELF_CHARA_MAKE_RANDOM
	PRINTLC [ 8] 魔力固定
	CALL PRINT_ONOFF(CFLAG:魔力固定,1)
	PRINTFORMLC [ 9] 魔力恢复率
	PRINTFORML ：{BASE:魔力恢复率}\%\/天
ELSE
	CALL PRINTL_WORD_COLOR,@"< 8> 　　魔力固定…手动输入仅可","灰"
	CALL PRINTL_WORD_COLOR,@"< 9> 魔力恢复率…手动输入仅可","灰"
ENDIF
PRINTL
PRINTFORML 　战斗力：%VALUE_DIGIT(MAXBASE:战斗力)%
IF !CFLAG:非战斗职业
	PRINTL [10] 战斗力重新计算
ELSE
	CALL PRINTL_WORD_COLOR,@"　战斗力重新计算","灰"
ENDIF



@SELF_CHARA_MAKE_STATUS_2

PRINTL 　《 战斗能力・同行同伴 》
CALL HALFLINE
IF !CFLAG:非战斗职业
	PRINTLC [ 0] 回复使用次数
	PRINTFORML ：{BASE:回复次数}
	PRINTLC [ 1] 大技使用次数
	PRINTFORML ：{BASE:大技次数}
ELSE
	CALL PRINTL_WORD_COLOR,@"　回复使用次数","灰"
	CALL PRINTL_WORD_COLOR,@"　大技使用次数","灰"
ENDIF
PRINTL
PRINTLC [ 2] 同行同伴
IF !CFLAG:同伴规模
	PRINTL ：无
	CALL PRINTL_WORD_COLOR,@"　同伴级别","灰"
	CALL PRINTL_WORD_COLOR,@"　同伴战斗力重新计算","灰"
ELSE
	PRINTFORML ：%GROUP_SCALE()%
	PRINTLC [ 3] 同伴级别
	PRINTFORML ：{CFLAG:同伴级别}
	PRINTFORML 　同伴战斗力：%VALUE_DIGIT(MAXBASE:同伴战斗力1)%
	PRINTL [ 4] 同伴战斗力重新计算
ENDIF
PRINTL



@SELF_CHARA_MAKE_STATUS_3

PRINTL 　《 工作能力 》
CALL HALFLINE
PRINTLC [ 0] 奶农
PRINTFORML ：Lv{ABL:奶农,2}
PRINTLC [ 1] 事务
PRINTFORML ：Lv{ABL:事务,2}
PRINTLC [ 2] 清洁
PRINTFORML ：Lv{ABL:清洁,2}
PRINTLC [ 3] 料理
PRINTFORML ：Lv{ABL:料理,2}
PRINTLC [ 4] 药学
PRINTFORML ：Lv{ABL:药学,2}
PRINTLC [ 5] 接客
PRINTFORML ：Lv{ABL:接客,2}
PRINTL
PRINTL 　《 工作相关素质 》
PRINTLC [10] 【不擅长清洁】
CALL PRINT_ONOFF(TALENT:不擅长清洁,1)
PRINTLC [11] 【不擅长料理】
CALL PRINT_ONOFF(TALENT:不擅长料理,1)
PRINTLC [12] 【不擅长接客】
CALL PRINT_ONOFF(TALENT:不擅长接客,1)
IF ABL:药学 >= 5
	PRINTLC [13] 【调合知识】
	CALL PRINT_ONOFF(TALENT:调合知识,1)
ELSE
	CALL PRINTL_WORD_COLOR,@"　【调合知识】为药学Lv5以上可设置","灰"
ENDIF



