
;新規追加
;ペニススラング設定
@SLANG_CONFIG_PENIS

CLEARLINE LINECOUNT
PRINTL 请选择以地文等形式显示的阴茎黑话候选词。
DRAWLINE
PRINTLC [ 0] 「Penis」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴茎,0),1)
PRINTLC [ 1] 「鸡巴」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴茎,1),1)
PRINTLC [ 2] 「男根」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴茎,2),1)
PRINTLC [ 3] 「阴茎」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴茎,3),1)
PRINTLC [ 4] 「男性器」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴茎,4),1)
PRINTLC [ 5] 「鸡鸡」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴茎,5),1)
PRINTLC [ 6] 「小鸡鸡」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴茎,6),1)
PRINTLC [ 7] 「大鸡鸡」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴茎,7),1)
PRINTLC [ 8] 「肉棒」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴茎,8),1)
PRINTL
PRINTL 　《 前缀设置 》
PRINTL 　（扩张的话以主人公／竿役的状态附加条件的预定）
PRINTLC [10] 「高高耸立的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／阴茎,0),1)
PRINTLC [11] 「发烫的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／阴茎,1),1)
PRINTLC [12] 「硬邦邦的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／阴茎,2),1)
PRINTLC [13] 「颤抖跳动的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／阴茎,3),1)
PRINTL
PRINTL 　《 特殊替换设置 》
PRINTLC [20] 首选特殊替换
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／阴茎,0),0)
PRINTL 　…如果满足特殊替换条件，则显示优先级
PRINTLC [29] 地文的设定
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／阴茎,9),0)
PRINTFORML 　（当前设置：%SAVESTR:标识／阴茎%）
CALL SLANG_CONFIG_FOOTER
INPUT
SELECTCASE RESULT
CASE 0 TO 8
	INVERTBIT FLAG:黑话标识／阴茎,RESULT
CASE 10 TO 13
	INVERTBIT FLAG:黑话前缀／阴茎,(RESULT -10)
CASE 20
	INVERTBIT FLAG:黑话替换／阴茎,(RESULT -20)
CASE 29
	INVERTBIT FLAG:黑话替换／阴茎,(RESULT -20)
CASE 80
	FLAG:黑话标识／阴茎 = 65535
CASE 81
	FLAG:黑话前缀／阴茎 = 65535
CASE 82
	FLAG:黑话替换／阴茎 = 65535
CASE 90
	FLAG:黑话标识／阴茎 = 0
CASE 91
	FLAG:黑话前缀／阴茎 = 0
CASE 92
	FLAG:黑话替换／阴茎 = 0
CASE 98
	PRINTL 回复默认阴茎黑话候选吗？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_SLANG_CONFIG_PENIS
CASE 99
	IF !FLAG:黑话标识／阴茎
		PRINTW 必须至少设置一个候选黑话。
	ELSE
		RETURN
	ENDIF
ENDSELECT
RESTART


