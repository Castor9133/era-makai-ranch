;CALL型
;ARG→ピンク色
;ARG:1→【】囲み
;ARG:2→弾力表示
@PRINT_BUST_C(ARG,ARG:1,ARG:2)
#DIMS BUSTSIZE

BUSTSIZE =
SIF ARG:1
	BUSTSIZE += "【"

;ランダムキャラメイク中に来た時隠蔽
IF GETBIT(＃状态隐藏／乳房细节＃) && !GETBIT(＃重新调整／胸部＃) && FLAG:角色化妆隐蔽有效
ELSE
	SIF ARG:2
		BUSTSIZE += CSTR:乳房弹性
ENDIF
SIF MARK:淫乳
	BUSTSIZE += "淫乱"

IF TALENT:超乳
	BUSTSIZE += "超乳"
ELSEIF TALENT:魔乳
	BUSTSIZE += "魔乳"
ELSEIF TALENT:神乳
	BUSTSIZE += "神乳"
ELSEIF TALENT:爆乳
	BUSTSIZE += "爆乳"
ELSEIF TALENT:丰乳
	BUSTSIZE += "丰乳"
ELSEIF TALENT:巨乳
	BUSTSIZE += "巨乳"
ELSEIF TALENT:普乳
	IF MARK:淫乳
		BUSTSIZE += "乳房"
	ELSE
		BUSTSIZE += "普乳"
	ENDIF
ELSEIF TALENT:贫乳
	BUSTSIZE += "贫乳"
ELSEIF TALENT:绝壁
	IF MARK:淫乳
		BUSTSIZE += "胸板"
	ELSE
		BUSTSIZE += "绝壁"
	ENDIF
ELSE
	BUSTSIZE += "柔乳"
ENDIF
SIF ARG:1
	BUSTSIZE +=  "】"
SIF ARG
	SETCOLOR 0xFF70FF
PRINTFORM %BUSTSIZE%
RESETCOLOR



;CALL型：バストサイズを指定
;ARG→0:通常色　1:ピンク色
;ARG:1→0:【】なし　1:【】あり
;ARG:2→指定バストサイズ
@PRINT_BUSTSIZE_SPECIFY(ARG,ARG:1,ARG:2)
#DIMS BUSTSIZE

BUSTSIZE =
SIF ARG:1
	BUSTSIZE += "【"

;元々表示のとき弾力も
SIF ORIGINAL_STATUS
	BUSTSIZE += CSTR:初始值／乳弾力
SELECTCASE ARG:2
CASE IS >= BUSTSIZE_超乳
	BUSTSIZE += "超乳"
CASE IS >= BUSTSIZE_魔乳
	BUSTSIZE += "魔乳"
CASE IS >= BUSTSIZE_神乳
	BUSTSIZE += "神乳"
CASE IS >= BUSTSIZE_爆乳
	BUSTSIZE += "爆乳"
CASE IS >= BUSTSIZE_丰乳
	BUSTSIZE += "丰乳"
CASE IS >= BUSTSIZE_巨乳
	BUSTSIZE += "巨乳"
CASE IS >= BUSTSIZE_普乳
	BUSTSIZE += "普乳"
CASE IS >= BUSTSIZE_贫乳
	BUSTSIZE += "贫乳"
CASE BUSTSIZE_绝壁
	BUSTSIZE += "绝壁"
ENDSELECT
SIF ARG:1
	BUSTSIZE +=  "】"
SIF ARG
	SETCOLOR 0xFF70FF
PRINTFORM %BUSTSIZE%
RESETCOLOR



;乳首の色
@PRINT_NIPPLE_COLOR

;ランダムキャラメイク中に来た時隠蔽
IF GETBIT(＃状态隐藏／乳房细节＃) && !GETBIT(＃重新调整／胸部＃) && FLAG:角色化妆隐蔽有效
	CALL PRINTL_WORD_COLOR("[乳头颜色仍不明] ","灰")
	RETURN
ENDIF
SETCOLOR CFLAG:颜色编码／乳头
PRINTFORML [乳头：%CSTR:乳头颜色%] 
RESETCOLOR



;乳弾力
@PRINT_BUST_FEELING

PRINTFORM %SAVESTR:标识／乳房%弹力：%CSTR:乳房弹性% 


