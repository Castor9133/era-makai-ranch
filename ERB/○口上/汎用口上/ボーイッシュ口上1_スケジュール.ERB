				ELSEIF ＃陷落状态／恋慕以上＃
					IF CSTR:0:日程 == "奶农"
						CALL MESSAGE_BOX,@"「%MASTER_CALL()%に搾ってもらえるんだし、一定乳汁が更加美味くなるよ♥♥」"
					ELSE
						CALL MESSAGE_BOX,@"「…真的は%MASTER_CALL()%に…… 不要、我儘言いっこなしだよな……」"
					ENDIF
				ELSEIF ＃陷落状态／屈服以上＃
					CALL MESSAGE_BOX,@"「はぅ… また搾乳されちまう…」"
				ELSE
					CALL MESSAGE_BOX,@"「っ……！ こんなマネ、許さねえからな……！」"
				ENDIF
			ENDIF
		ENDSELECT
	CASE "执行后"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			IF EX:喷乳 >= 10000
				CALL MESSAGE_BOX,@"「哈咿ぃ…♥ こんなに…だしちゃったぁ…♥♥♥ あぅ……♥♥」"
				SIF ABL:搾乳中毒 >= 10
					CALL MESSAGE_BOX,@"「か咿…♥♥ ちちしぼり…こんなに……しあわせぇ…っ♥♥♥」"
			ELSEIF !BASE:母乳生产力
				CALL MESSAGE_BOX,@"「は、はへっ…♥ 奶子からっぽ…♥♥ 已经らせない……♥♥♥」"
			ELSE
				CALL MESSAGE_BOX,@"「ふ啊啊…♥♥ 哈啊…哈啊…♥♥」"
