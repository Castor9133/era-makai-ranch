@COM605
;超乳薬
#DIM USING_HP

;超乳寸前の場合確認
CALL BUSTUP_HUGE_BUST_COMFIRM
SIF RESULT
	RETURN
SELECTCOM = 605
SOURCE:非性感带疼痛 = 1000

;膨乳段階により計算前に恥辱、屈辱、支配追加
SOURCE:已用时间 = 1
SOURCE:选择指令口上隐藏 = 1
EXP:肉体改造 ++
ITEM:超乳药 --
CFLAG:当日制限／肉体改造药 = 1
CALL BUST_TENTACLE_RESET
TRYCALLFORM COM{SELECTCOM}_MESSAGE
CALL BUSTUP
USING_HP = 100

;体力尽きるまで繰り返し
WHILE BASE:体力 > LOSEBASE:体力
	;追加増加制限と一致する場合ストップ
	SIF ABL:胸围大小 == FLAG:膨乳暂停胸围大小
		BREAK

	;超乳直前か超乳だとストップ
	SIF ABL:胸围大小 >= BUSTSIZE_超乳 -1
		BREAK
	PRINTFORML 在药品的作用下%CALLNAME%的%SLANG_B()%变得更大…！
	CALL BUSTUP
	
	;膨乳のたび体力・気力減少
	LOSEBASE:体力 += USING_HP
	LOSEBASE:气力 += 150
	USING_HP *= 15
	USING_HP /= 10
WEND
PRINTW
RETURN 1



@COM606
;受容器鋭敏化薬
#DIM SENSITIVE_BEFORES,6

;LOCAL→部位
FOR LOCAL,0,6
	;ABL:Ａ感度→10
	SENSITIVE_BEFORES:LOCAL = ABL:(LOCAL +10)

	IF ABL:(LOCAL +10) < 500
		FIX = 30
	ELSE
		FIX = 20
	ENDIF

	;Ｎ、Ｃに使う場合は増加幅倍増
	SIF LOCAL == 2 || LOCAL == 4
		FIX *= 2

	;990越えないように
	ABL:(LOCAL +10) += LIMIT(FIX,0,SENSITIVE_MAX -ABL:(LOCAL +10))
NEXT
SELECTCOM = 605
LOSEBASE:体力 += 1000
LOSEBASE:气力 += 2000
SOURCE:耻辱 = 50000
SOURCE:屈辱 = 34000
SOURCE:支配 = 30000
SOURCE:非性感带疼痛 = 1000
SOURCE:已用时间 = 1
SOURCE:选择指令口上隐藏 = 1
ITEM:感受器敏感化药 --
EXP:肉体改造 ++
CFLAG:当日制限／肉体改造药 = 1
TRYCALLFORM COM{SELECTCOM}_MESSAGE

;とりあえずここ
SETCOLOR 0xFF70FF
SIF ABL:Ａ敏感度 - SENSITIVE_BEFORES:0 > 0
	PRINTFORML 【Ａ敏感度+{ABL:Ａ敏感度 - SENSITIVE_BEFORES:0}→{ABL:Ａ敏感度}\%】
SIF ABL:Ｂ敏感度 - SENSITIVE_BEFORES:1 > 0
	PRINTFORML 【Ｂ敏感度+{ABL:Ｂ敏感度 - SENSITIVE_BEFORES:1}→{ABL:Ｂ敏感度}\%】
SIF ABL:Ｃ敏感度 - SENSITIVE_BEFORES:2 > 0
	PRINTFORML 【Ｃ敏感度+{ABL:Ｃ敏感度 - SENSITIVE_BEFORES:2}→{ABL:Ｃ敏感度}\%】
SIF ABL:Ｖ敏感度 - SENSITIVE_BEFORES:3 > 0
	PRINTFORML 【Ｖ敏感度+{ABL:Ｖ敏感度 - SENSITIVE_BEFORES:3}→{ABL:Ｖ敏感度}\%】
SIF ABL:Ｎ敏感度 - SENSITIVE_BEFORES:4 > 0
	PRINTFORML 【Ｎ敏感度+{ABL:Ｎ敏感度 - SENSITIVE_BEFORES:4}→{ABL:Ｎ敏感度}\%】
SIF ABL:Ｍ敏感度 - SENSITIVE_BEFORES:5 > 0
	PRINTFORML 【Ｍ敏感度+{ABL:Ｍ敏感度 - SENSITIVE_BEFORES:5}→{ABL:Ｍ敏感度}\%】
CALL NIPPLE_SENSITIVE_FIX
RESETCOLOR
PRINTW
RETURN 1



