
;奴隷の搾乳
@SLAVE_LACTATION

CATTLE_COUNT = CMATCH(CSTR:日程,"搾乳")
SIF !CATTLE_COUNT
	RETURN

;酪農が1人もいないと搾れない
SIF !CMATCH(CSTR:日程,"奶农")
	RETURN
PRINTL 　　　《 搾乳 》

;調教者人数と技巧補正値計算
CALL SLAVE_LACTATION_TECHNIQUE_SET
CALL RANDOM_CHARA_SCHEDULE_COMMON("搾乳")
CALL SECTION_MP_COST
CALL SCHEDULE_ABL_MARK_BULK(1,"搾乳")
PRINTW
DRAWLINE
CALL RESET_TRAIN_PALAM
PLAYER = -1



;抽選したキャラの搾乳風景表示
@SLAVE_LACTATION_ENTRANCE

SIF CSTR:状态／主人公的孩子 == "成长后"
	CALL CHILD_REBELLION(1)
IF !EXP:执行次数／搾乳
	KOJO_TYPE = 初次
ELSE
	KOJO_TYPE = 普通
ENDIF
CALL STANDBY_SLAVE_LACTATION_MESSAGE
CALL SLAVE_LACTATION_RUN(1,"搾乳")

;実行後の地の文は↑の中
FLAG:上次显示角色ID／搾乳 = CFLAG:ID

;TFLAGでABLUPしたか判定が必要　なかった
WAIT

;改行しないと見にくい
CALL MANYL(2)




