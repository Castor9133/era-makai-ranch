
;種族設定
@HEAVEN_TRIBE_CONFIG

;FLAG:候補割合／天界種族／天使→2630
FLAG_REF = 2630
STR_REF = 6540
FLAG:候选比例／天界种族／总计 = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +10)
TOTAL_RATIO = FLAG:候选比例／天界种族／总计
CLEARLINE LINECOUNT
PRINTL 请设定天界种族的比例。
CALL CONFIG_CHANGE_FLAG_CHECK
CALL PRINT_TENDENCY_BUTTON(1)
CALL PRINTL_ALIGN(-10)
CALL TENDENCY_CONFIG_FOOTER
CALL TENDENCY_INPUT
IF RESULT == 98
	PRINTL 天界种族比例回复默认？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_HEAVEN_TRIBE_CONFIG
ELSEIF RESULT == 99
	IF FLAG:候选比例／天界种族／总计 <= 0 || FLAG:候选比例／天界种族／总计 > 1000
		PRINTW 总出现比例应介于1到1000之间。
		RESTART
	ENDIF
	RETURN
ENDIF
RESTART



