
;調教する奴隷変更
;夜に来た場合とかの全奴隷参照はこっち
@TRAIN_SLAVE_SELECT_ALL
#DIM DYNAMIC PAGE
#DIM TRAIN_SLAVE_NUM

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML 选择%CALLNAME:0%调教的奴隶。
DRAWLINE
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	
	;調教可能　スケジュール-1だと調教可能も0だと思うけど念の為
	;調教可能でも牛舎にいるとダメ　調教可能フラグ変更は選択不可になる気がするのでPASSさ…
	;夜の場合は牛舎にいても引っ張り出せることにしよう
	;夜なら体内にいても引っ張ってこれる
	IF CFLAG:追踪对象
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：未捕获","灰"
		CONTINUE
	ELSEIF CFLAG:牛舍号码 && TIME < 3
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：%COWSHED_NAME:(CFLAG:牛舍号码)%","灰"
		CONTINUE
	
	;体内凌辱中で夜ならOKの例外処理のためこんなんに
	ELSEIF CSTR:日程 == "体内凌辱" && TIME >= 3
	ELSEIF CSTR:住处 == "体内" && TIME < 3
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：体内","灰"
		CONTINUE
	ELSEIF !CFLAG:可以调教 || CSTR:状态／主人公的孩子 == "成长中"
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：调教不可","灰"
		CONTINUE
	ENDIF

	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	
	;夜だけ牛舎内か体内か違うか表示する
	IF TIME == 3
		IF CFLAG:牛舍号码
			CALL PRINT_WORD_COLOR("[牛舍] ","黄")
		ELSEIF CSTR:日程 == "体内凌辱"
			CALL PRINT_WORD_COLOR("[体内] ","桃")
		ELSE
			PRINT 　　　 
		ENDIF
	ENDIF
	CALL TABLE_STATUS("调教对象")
	SIF CMATCH(CFLAG:调教对象ID,CFLAG:ID)
		CALL PRINT_WORD_COLOR(" 调教预定","黄")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  8] 更改显示项目
PRINTLC 　
PRINTL [ 99] 取消
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN

CASEELSE
	TRAIN_SLAVE_NUM = RESULT -100
	
	;既に調教が組まれてる場合はダメ
	IF CSTR:TRAIN_SLAVE_NUM:日程 == "调教对象"
		PRINTW 已经有调教的计划了。
		RETURN
	ENDIF
	SIF CSTR:TRAIN_SLAVE_NUM:日程 == "体内凌辱"
		FLAG:体内凌辱暂时解除 = 1
	CSTR:0:日程 = 调教
	CFLAG:0:调教对象ID = CFLAG:TRAIN_SLAVE_NUM:ID
	CSTR:TRAIN_SLAVE_NUM:日程 = 调教对象
	CALL SCHEDULE_ADJUST
	RETURN
ENDSELECT
RESTART



;調教可能な奴隷だけ表示
@TRAIN_SLAVE_SELECT
#DIM TRAIN_SLAVE_NUM

CLEARLINE LINECOUNT
IF CSTR:SAVE_TARGET:状态／主人公的孩子 == "成长中"
	PRINTFORML %CALLNAME:SAVE_TARGET%请选择授乳对象。
ELSE
	PRINTFORML 请选择要由%CALLNAME:SAVE_TARGET%调教的奴隶。
ENDIF
DRAWLINE
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	IF CFLAG:追踪对象
		CONTINUE
	ELSEIF CFLAG:牛舍号码
		CONTINUE
	ELSEIF CSTR:住处 == "体内"
		CONTINUE
	
	;一応この分岐も入れる
	ELSEIF !CFLAG:可以调教 || CSTR:状态／主人公的孩子 == "成长中"
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：调教不可","灰"
		CONTINUE
	ELSEIF SAVE_TARGET == TARGET
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%本人","灰"
		CONTINUE
	ENDIF
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("调教对象")
	SIF CMATCH(CFLAG:调教对象ID,CFLAG:ID)
		CALL PRINT_WORD_COLOR(" 调教预定","黄")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTFORMLC [  8] 更改显示项目
PRINTLC 　
PRINTL [ 99] 取消
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 99
	RETURN
CASEELSE
	TRAIN_SLAVE_NUM = RESULT -100
	IF CSTR:TRAIN_SLAVE_NUM:日程 == "调教对象"
		PRINTW 已经有调教的计划了。
		RETURN
	ENDIF
	CSTR:SAVE_TARGET:日程 = 调教
	CFLAG:SAVE_TARGET:调教对象ID = CFLAG:TRAIN_SLAVE_NUM:ID
	CSTR:TRAIN_SLAVE_NUM:日程 = 调教对象
	CALL SCHEDULE_ADJUST
	
	;自動で繰り返すようにセット
	IF CSTR:SAVE_TARGET:状态／主人公的孩子 == "成长中"
		CFLAG:SAVE_TARGET:520 = CFLAG:TRAIN_SLAVE_NUM:ID
		CSTR:SAVE_TARGET:360 = 调教／对象A
		CSTR:SAVE_TARGET:361 = 调教／对象A
		CSTR:SAVE_TARGET:362 = 调教／对象A
		VARSET CSTR:SAVE_TARGET,"自定义Ａ",350,357
	ENDIF
	RETURN
	
ENDSELECT
RESTART




