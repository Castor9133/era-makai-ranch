
;保管中のミルクを飲む
@DRINK_COLD_MILK_SELECT
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML 出货计划冷藏中%SAVESTR:标识／母乳%可以喝一点。
PRINTL
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	
	;奴隷がどこにいても関係なく出荷用に保管しているミルクを見る
	IF CFLAG:预计出货母乳量 < CUP_MILK
		SETCOLOR 0x606060
		PRINTFORM <{TARGET +100}> %CALLNAME_DIGIT()%
	ELSE
		PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	ENDIF
	CALL PRINT_POST_C
	IF CSTR:状态／主人公的孩子 == "成长中"
		PRINT 　【幼子】
		RESETCOLOR
	ELSE
		CALL TABLE_STATUS_BUST
		IF !CFLAG:预计出货母乳量
			CALL PRINT_WORD_COLOR,@"　%SAVESTR:标识／母乳%无出货计划","灰"
		ELSEIF CFLAG:预计出货母乳量 < CUP_MILK
			CALL PRINT_WORD_COLOR,@"　未达到%SAVESTR:标识／母乳%出货计划{CUP_MILK}%MILK_COUNTING()%","灰"
		ELSE
			PRINTFORM %VALUE_DIGIT(CFLAG:预计出货母乳量,"母乳")%
			CALL PRINT_MILK_NAME
		ENDIF
	ENDIF
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
CALL RIGHT_RETURN_BUTTON(0,"キャンセル")
BINPUT
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	TARGET = -1
	RETURN

CASEELSE
	TARGET = RESULT -100
	SIF CFLAG:预计出货母乳量 < CUP_MILK
		RESTART
	CALL DRINK_COLD_MILK
	RETURN
ENDSELECT
RESTART



;飲む
;TARGETはミルクの生産者
@DRINK_COLD_MILK

CALL MANYL(3)
PRINTFORM %CALLNAME:0%已保留
CALL PRINT_MILK_NAME(1)
PRINTL 喝了。

;ERHファイルのCUP_MILKで飲む量を変えられたりする
PRINTFORM 保管量-{CUP_MILK}%MILK_COUNTING()%　
CFLAG:预计出货母乳量 -= CUP_MILK

;飲んだ場合にWAITを入れる
WAIT_ON ++

;飲んだ分/10の体力回復（直飲みの半分）
FIX = 100 +ABL:母乳浓度 *50
HEAL = CUP_MILK *FIX /1000
HEAL -= (HEAL %10)
CALL PLAYER_HP_HEAL_CONST(HEAL)

;魔力母乳だと直飲みの半分MP回復
SIF !MARK:魔力母乳体质
	RETURN
HEAL = CUP_MILK *(ABL:母乳浓度 +1)
CALL PLAYER_MP_HEAL_CONST(HEAL)



