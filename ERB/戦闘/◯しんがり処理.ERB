
;戦闘中にターゲットだけを逃がす
@UNIT_ESCAPE_BATTLE

CALL UNIT_ESCAPE_BATTLE_MESSAGE
TFLAG:牺牲逃跑 = 1



;しんがりに魔物側勝利
@TARGET_ESCAPE_DEFEAT

CALL TARGET_ESCAPE_DEFEAT_MESSAGE
CALL PURPOSE_CHANGE("汇合撤退")
BASE:疲劳度 += 30
DAMAGE = 2 *TURN +RAND:5 +10
BASE:疲劳度 = LIMIT(BASE:疲劳度 +DAMAGE,0,MAXBASE:疲劳度)
PRINTFORML %CALLNAME% 疲劳度：{BASE:疲劳度}



;しんがりに魔物側敗北
@TARGET_ESCAPE_WIN

CALL TARGET_ESCAPE_WIN_MESSAGE
CALL PURPOSE_CHANGE("汇合撤退")
BASE:同伴战斗力1 = 0
BASE:疲劳度 += 30




