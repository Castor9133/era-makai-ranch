
;料理完成・食事
@DINNER_EAT

;母乳料理の場合母乳商品名をつける
PRINT 【
IF MILK_DINNER
	CALL PRINT_MILK_NAME(1)
	PRINT 用了大量的
ENDIF
PRINTFORML %DINNER_NAME%】完成了！

;回復量計算
CALL DINNER_HEAL_CALC
PRINTFORML %CALLNAME:0%们吃了晚饭…

;食事する設定のキャラはHEAL分回復
CALL DINNER_HEAL_CHARA(HEAL)
PRINTW



;回復量計算
@DINNER_HEAL_CALC

HEAL = 100 +ABL:料理 *10

;母乳料理なら+10%、濃度Lv1につきさらに+10%
SIF !MILK_DINNER
	RETURN
FIX = 10 +ABL:母乳浓度 *10
HEAL = HEAL *(100 +FIX)
HEAL /= 100



;食事回復
;ARG→計算したHEAL
@DINNER_HEAL_CHARA(ARG)

HEAL_PRINT_DONE = 0
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:住处 == "体内" || CFLAG:追踪对象 || (!EQUIP:自室 && !CFLAG:晚餐许可)
		CONTINUE
	CALL DINNER_HEAL(ARG)
	
	;食事の人数を+1、簡易食事を-1する
	FLAG:用餐人数 ++
	FLAG:简易餐食人数 --
NEXT


