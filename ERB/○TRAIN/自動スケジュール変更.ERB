
;搾乳を自動スケジュールするか
@AUTO_SCHEDULE_LACTATION

SIF TFLAG:调教前母乳体质 || !MARK:母乳体质
	RETURN
CALL MANYL(3)
PRINTFORML 【母乳体质】成为了%CALLNAME%的自动日程要修改吗？
PRINTL （所有星期都将一并修改）
PRINTL
PRINTLC [ 0] 保持
PRINTLC [ 1] 搾乳／整天
PRINTL [ 2] 搾乳／朝夕
IF !ITEM:灵力抽出装置
	CALL PRINTL_WORD_COLOR("　日程抽取未解放","灰")
ELSEIF !BASE:灵力 && !MAXBASE:魔力
	CALL PRINTL_WORD_COLOR("　无法抽出","灰")
ELSE
	PRINTL
	PRINTLC [ 3] 灵力抽出／整天
	PRINTLC [ 4] 灵力抽出／朝夕
	PRINTL [ 5] 搾乳→抽出
ENDIF
PRINTL
BINPUT
SELECTCASE RESULT
CASE 1
	CALL AUTO_SCHEDULE_LIST_SET(200,99)
CASE 2
	CALL AUTO_SCHEDULE_LIST_SET(201,99)
CASE 3
	CALL AUTO_SCHEDULE_LIST_SET(202,99)
CASE 4
	CALL AUTO_SCHEDULE_LIST_SET(203,99)
CASE 5
	CALL AUTO_SCHEDULE_LIST_SET(204,99)
ENDSELECT
CALL AUTO_SCHEDULE_REST_FIX



;超乳化した家畜のスケジュール変更
@AUTO_SCHEDULE_CATTLE_LACTATION
#DIMS CHANGE_SCHEDULE

;CSTR:自動スケジュール／月→350
CSTR_REF = 350
EXIST = 0
CHANGE_SCHEDULE =
FOR LOCAL,CSTR_REF,CSTR_REF +7
	;CSTRに業務にあたる文字が含まれているかチェック
	CALL AUTO_SCHEDULE_WORK_NAME_CHECK(LOCAL)
	EXIST += RESULT
NEXT

;EXISTがあれば再設定する
SIF !EXIST
	RETURN
CALL MANYL(5)
RESETCOLOR
PRINTFORML 因为成为了【超乳】，%CALLNAME%无法进行事务。

;母乳体質じゃない場合全部休日
IF !MARK:母乳体质
	PRINTW 将自动日程全部设定为【休息日】。
	CALL AUTO_SCHEDULE_LIST_SET(10,99)
	RETURN
ENDIF
PRINTL 请重新设置自动日程。（所有星期都将一并修改）
PRINTL
PRINTLC [ 0] 假日
PRINTLC [ 1] 搾乳／整天
PRINTL [ 2] 搾乳／朝夕
IF !ITEM:灵力抽出装置
	CALL PRINTL_WORD_COLOR("　日程抽取未解放","灰")
ELSEIF !BASE:灵力 && !MAXBASE:魔力
	CALL PRINTL_WORD_COLOR("　无法抽出","灰")
ELSE
	PRINTL
	PRINTLC [ 3] 灵力抽出／整天
	PRINTLC [ 4] 灵力抽出／朝夕
	PRINTL [ 5] 搾乳→抽出
ENDIF
PRINTL
BINPUT
SELECTCASE RESULT
CASE 0
	CALL AUTO_SCHEDULE_LIST_SET(10,99)
CASE 1
	CALL AUTO_SCHEDULE_LIST_SET(200,99)
CASE 2
	CALL AUTO_SCHEDULE_LIST_SET(201,99)
CASE 3
	CALL AUTO_SCHEDULE_LIST_SET(202,99)
CASE 4
	CALL AUTO_SCHEDULE_LIST_SET(203,99)
CASE 5
	CALL AUTO_SCHEDULE_LIST_SET(204,99)
ENDSELECT
CALL AUTO_SCHEDULE_REST_FIX

;カスタムの中身が業務なら自由に変更
;CSTR:自動スケジュール／カスタムＡ／朝→360
CSTR_REF = 360
FOR LOCAL,CSTR_REF,CSTR_REF +9
	SIF GROUPMATCH(CSTR:LOCAL,＃事务日程＃)
		CSTR:LOCAL = 自由
NEXT



;CSTRに業務にあたる文字が含まれているかチェック
;ARG→LOCAL
@AUTO_SCHEDULE_WORK_NAME_CHECK(ARG)

STRFIND CSTR:ARG,"奶农"
SIF RESULT >= 0
	RETURN 1
STRFIND CSTR:ARG,"事务"
SIF RESULT >= 0
	RETURN 1
STRFIND CSTR:ARG,"调合"
SIF RESULT >= 0
	RETURN 1
STRFIND CSTR:ARG,"清洁"
SIF RESULT >= 0
	RETURN 1

;めんどいのでカスタムの場合も含まれてる判定するよ
STRFIND CSTR:ARG,"自定义"
SIF RESULT >= 0
	RETURN 1



