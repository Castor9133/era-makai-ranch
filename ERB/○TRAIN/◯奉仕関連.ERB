
;奉仕可能状態判定
@TRAIN_SERVICE_JUDGE

TFLAG:奉仕可能 = 0

;体力0・崩壊→ダメ
SIF !BASE:体力 || CFLAG:崩坏
	RETURN

;屈服以上・乳牛堕ち・洗脳・淫紋→OK
IF ＃陷落状态／陷落以上＃ || CFLAG:乳牛 || CFLAG:洗脑 || MARK:淫纹
	TFLAG:奉仕可能 = 1

;反抗・拒絶のとき
;淫欲10000・奉仕精神10で抵抗心半分→OK
ELSEIF PALAM:淫欲 >= 10000 || (ABL:奉仕精神 >= 5 && BASE:抵抗心 < MAXBASE:抵抗心 /2)
	TFLAG:奉仕可能 = 1
ENDIF



;奉仕終了判定
@TRAIN_SERVICE_END

;体力あれば帰る・拘束中は無視
SIF BASE:体力 || TFLAG:拘束BIT
	RETURN

;触手フェラはOFF箇所違う
IF TEQUIP:触手口交
	TEQUIP:触手口交 = 0
	CALL TRAIN_SERVICE_END_FELLATIO_TENTACLE_MESSAGE
ENDIF

;奉仕継続中だけ
IF TEQUIP:口交
	CALL TRAIN_SERVICE_END_FELLATIO_MESSAGE

ELSEIF TEQUIP:乳交 || TEQUIP:纵乳交
	CALL TRAIN_SERVICE_END_PAIZURI_MESSAGE

ELSEIF TEQUIP:骑乘位
	CALL TRAIN_SERVICE_END_RIDE_SEX_V_MESSAGE
	CALL COM890

ELSEIF TEQUIP:背面骑乘位
	CALL TRAIN_SERVICE_END_RIDE_SEX_V_MESSAGE
	CALL COM890

ELSEIF TEQUIP:Ａ骑乘位
	CALL TRAIN_SERVICE_END_RIDE_SEX_A_MESSAGE
	CALL COM890

ELSEIF TEQUIP:Ａ背面骑乘位
	CALL TRAIN_SERVICE_END_RIDE_SEX_A_MESSAGE
	CALL COM890

ELSEIF TEQUIP:素股 && TFLAG:奉仕可能
	CALL TRAIN_SERVICE_END_CROTCH_MESSAGE

ELSEIF TEQUIP:手淫 || TEQUIP:授乳手交
	CALL TRAIN_SERVICE_END_HAND_MESSAGE

ELSE
	;下を呼ばないためにRETURN
	RETURN
ENDIF

;挿入解除→装備整理
VARSET TEQUIP,0,30,60
TEQUIP:Ｖ指插入中 = 0
TEQUIP:Ａ指插入中 = 0
TEQUIP:口内搅舌中 = 0
TEQUIP:压舌探喉中 = 0
CALL TEQUIP_ADJUST







