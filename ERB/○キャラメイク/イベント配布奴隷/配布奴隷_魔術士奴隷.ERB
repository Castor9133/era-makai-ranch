
;魔術士奴隷候補の追加処理
@CHARA_MAKE_FIXED_SLAVE_SORCEROUS

CALL MANYL(5)
PRINTL [弱气桃色遮单眼发苗条自卑的丰乳白魔法师]・[强势银发性感单纯的丰乳黑魔法师]
PRINTL 你更喜欢哪个？
PRINTL （如果全都想要的话，事件后也可以从CSV读取角色）
PRINTL （更改胸围大小阈值时，可能不会变成【丰乳】）
PRINTL
PRINTLC [ 0] 白魔法师
PRINTL [ 1] 黑魔法师
INPUT
IF !RESULT
	ADDCHARA 5
ELSE
	ADDCHARA 6
ENDIF
TARGET = CHARANUM -1
CALL CSV_CHARA_ADD_FIX
SIF !FLAG:候选比例／一般种族／人类
	CALL CHARA_MAKE_FIXED_SLAVE_TRIBE_QUESTION
CALL CHARA_MAKE_FIXED_SLAVE_SORCEROUS_SHUFFLE_INDEX



;シャッフル
@CHARA_MAKE_FIXED_SLAVE_SORCEROUS_SHUFFLE_INDEX
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL CHARA_MAKE_SLAVE_DATA(PAGE)
PRINTL 　《 调整 》
PRINTLC [ 0] 重命名屏幕
PRINTLC [ 1] 乳房弹性
PRINTLC [ 2] 乳头颜色
PRINTLC [ 3] 发型
PRINTLC [ 4] 瞳色
PRINTFORML [ 5] 口上设置　当前使用口上：%CSTR:使用口上%
CALL PRINTL_ALIGN
PRINTFORML [80] 更改显示项目 <PAGE{PAGE,2}／{PAGE_MAX}>
DRAWLINE

;別なほうも見たいなら
IF CSTR:职业 == "白魔法师"
	PRINTLC [90] 切换为黑魔法师
ELSE
	PRINTLC [90] 切换为白魔法师
ENDIF
PRINTLC [98] 提示
PRINTL [99] 完成
BINPUT
SELECTCASE RESULT
CASE 0
	CALL CHARA_MAKE_SLAVE_SHUFFLE_NAME
CASE 1
	CALL RANDOM_SLAVE_BUST_FEELING
CASE 2
	CALL RANDOM_SLAVE_NIPPLE_COLOR
CASE 3
	CALL RANDOM_SLAVE_HAIR_STYLE
CASE 4
	CALL RANDOM_SLAVE_EYE_COLOR
CASE 5
	CALL KOJO_SETTING
CASE 80
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 90
	IF CSTR:职业 == "白魔法师"
		DELCHARA TARGET
		ADDCHARA 6
	ELSE
		DELCHARA TARGET
		ADDCHARA 5
	ENDIF
	TARGET = CHARANUM -1
	CALL CSV_CHARA_ADD_FIX(1)
	SIF !FLAG:候选比例／一般种族／人类
		CALL CHARA_MAKE_FIXED_SLAVE_TRIBE_QUESTION
CASE 98
	CALL BROWSE_HINT("魔术师奴隶设定")
CASE 99
	IF !CFLAG:口上表示 && FLAG:口上表示
		CALL PRINTL_WORD_COLOR("没有设置口上，可以吗？","黄")
		CALL ASK_YN
		SIF RESULT
			RESTART
	ENDIF
	CALL CHARA_MAKE_END_CALC
	CALL CHARA_MAKE_END_FLAGSET
	RETURN
ENDSELECT
RESTART



