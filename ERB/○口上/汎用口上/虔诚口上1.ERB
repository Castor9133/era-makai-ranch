@KOJO_GENERAL_INDEX_虔诚1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

IF TFLAG:Ｍ装备
	CALL KOJO_GENERAL_MOUTH_SHACKLE_1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
	RETURN
ELSEIF CFLAG:崩坏 && !CFLAG:洗脑
	IF GROUPMATCH(ARGS:0,"例文")
	ELSEIF GROUPMATCH(ARGS:1,"洗脑触手","崩坏")
	ELSE
		IF NOWEX:总绝顶
			CALL MESSAGE_BOX,@"「……请宽恕……♥ ……我又……堕落了……♥」"
			CALL MESSAGE_BOX,@"「……惩罚……更重一点……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……我刚才……又软弱了吗……」"
		ENDIF
		RETURN
	ENDIF
ENDIF

SELECTCASE ARGS:0
CASE "身体"
	CALL KOJO_GENERAL_虔诚1_EXCRETION_BODY(ARGS:1, ARGS:2)
	RETURN
CASE "例文"
	CALL MESSAGE_BOX,@"「【虔诚1】已设置。\n罪与罚、祈祷与忏悔；越陷落越把快感神圣化。」"

CASE "调教命令"
	CALL KOJO_GENERAL_虔诚1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

CASE "绝顶"
	;深喉中的高潮（新增：深喉性癖相关口上）
	SIF TEQUIP:深喉
		CALL MESSAGE_BOX,@"「……呛……♥ 这窒息的羞辱……也要我承受吗……愿我不再逃避……♥」"
	SIF TEQUIP:深喉
		CALL MESSAGE_BOX,@"「……神啊……我明明在祈祷……身体却先屈膝……啊……♥」"
	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「啊……♥ 我愿献上……一切……♥」"
		CALL MESSAGE_BOX,@"「请引导我……让我更堕落……♥♥」"
	ELSEIF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「……请原谅……♥ 我、我快要……♥」"
	ELSEIF ＃陷落状态／屈服以上＃
		CALL MESSAGE_BOX,@"「……不行……这是试炼……♥」"
	ELSE
		CALL MESSAGE_BOX,@"「住手……这是不洁……！」"
	ENDIF
	IF NOWEX:Ａ绝顶
		IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
			CALL MESSAGE_BOX,@"「……！？　%ANAL_CALL()%……痛……！？　……可是……深处……像被神罚搔过……♥」"
			CALL MESSAGE_BOX,@"「……这也是……试炼吗……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……痛……！？　%ANAL_CALL()%……不洁……！」"
			CALL MESSAGE_BOX,@"「……只有痛楚……才是真实……」"
		ENDIF
	ENDIF
	IF NOWEX:5
		IF TEQUIP:尿道塞 || TFLAG:尿道装备
			SIF TALENT:尿道敏感 || EXP:尿道调教经验 >= 15
				CALL MESSAGE_BOX,@"「……尿道塞像钉子一样……把我钉在快感上……♥ 我、我不该渴求的……♥」"
			SIF !(TALENT:尿道敏感 || EXP:尿道调教经验 >= 15)
				CALL MESSAGE_BOX,@"「……不洁……那处被塞住……只剩尖锐的痛……请、请停下……！」"
		ELSE
			SIF TALENT:尿道敏感 || EXP:尿道调教经验 >= 15
				CALL MESSAGE_BOX,@"「……刺痛之下……竟有轻微的甜……这是诱惑……我会忏悔……♥」"
			SIF !(TALENT:尿道敏感 || EXP:尿道调教经验 >= 15)
				CALL MESSAGE_BOX,@"「……只有剧痛与尿意……神啊……救我……请停下……！」"
		ENDIF
	ENDIF

CASE "射精"
	IF SOURCE:膣内射精经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……在里面……♥ ……这是惩罚……也是恩赐……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「不、不要在里面……！」"
		ENDIF
	ELSEIF SOURCE:尻穴射精经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……后面……也被玷污了……♥ ……请、请继续惩罚我……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……不可以……那里……」"
		ENDIF
	ELSEIF SOURCE:精饮经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……咽下去了……♥ ……愿以此赎罪……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「咳……咳……我、我不该……」"
		ENDIF
	ELSEIF TEQUIP:手淫
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……手上……沾满了……♥ ……我会洗净……」"
		ELSE
			CALL MESSAGE_BOX,@"「……太下流了……」"
		ENDIF
	ENDIF

CASE "搾乳"
	IF SOURCE:母乳漏出
		CALL MESSAGE_BOX,@"「……不行……奶水……自己……♥」"
		RETURN
	ENDIF
	IF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「……这是试炼……♥ 我会承受……♥」"
		CALL MESSAGE_BOX,@"「……请别停……让我学会顺从……♥」"
	ELSE
		CALL MESSAGE_BOX,@"「住手……别把我拖向堕落……」"
	ENDIF

CASE "抽出"
	CALL MESSAGE_BOX,@"「……我有些……站不稳……请允许我稍作歇息……」"
	CALL MESSAGE_BOX,@"「……惩罚太重……我会……继续承受……」"

CASE "日程"
	SELECTCASE ARGS:1
	CASE "调教"
		SELECTCASE ARGS:2
		CASE "开始调教"
			CALL MESSAGE_BOX,@"「……若这是试炼……我愿接受。请引导我……」"
		CASE "调教结束"
			CALL MESSAGE_BOX,@"「……结束了吗……我会祈祷……让这份堕落……不再动摇我……」"
		ENDSELECT
	CASEELSE
	ENDSELECT

CASE "阴茎称呼变更"
	CALL MESSAGE_BOX,@"「……称呼也要变更……我明白了……」"

CASE "膣称呼变更"
	CALL MESSAGE_BOX,@"「……连那里也要……是……我会记住……」"

CASE "肛门称呼变更"
	CALL MESSAGE_BOX,@"「……后面也要……我会服从……」"

CASE "吸欧派"
	SELECTCASE ARGS:1
	CASE "开始"
		CALL MESSAGE_BOX,@"「……请。若这能减轻您的烦恼……」"
	CASE "结束"
		CALL MESSAGE_BOX,@"「……胸口仍在发烫……这是……罪吗……♥」"
	ENDSELECT

CASE "访问"
	SELECTCASE ARGS:1
	CASE "入口"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「……您进这房间了。若这也是苦修……请用我。%SELF_CALL()%不会躲……♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……见您来。若我能赎罪般地为您效劳……请吩咐。」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「……见您进我屋。要责罚、要支使，都请明说。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……门开了。别用“怜悯”当绳子。」"
		ELSE
			CALL MESSAGE_BOX,@"「……门开了。若只为看我难堪……您已经看见了。」"
		ENDIF
	CASE "衣服修理"
		CALL MESSAGE_BOX,@"「衣物破损……我会补好。针脚会一针一针收紧，免得下次受累的人还是您。」"
	CASE "摸头"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「……请继续。」"
			CALL MESSAGE_BOX,@"「若这能让我更顺从……那便是我该受的垂怜……♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……您的手很温暖。若这算垂怜……我会把它当作提醒：别再走偏。」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「……我明白了。」"
			CALL MESSAGE_BOX,@"「只是……别把这当成赦免。%SELF_CALL()%不配。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……请不要。」"
			CALL MESSAGE_BOX,@"「这种温柔，会让我更难受。」"
		ELSE
			CALL MESSAGE_BOX,@"「……别碰我。」"
		ENDIF
	CASE "接吻"
		IF TALENT:无接吻经验
			RETURN
		ELSEIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「……可以。」"
			CALL MESSAGE_BOX,@"「请把我亲到失去理智——这样我就不会再想“对不对”了……♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……可以。但请别把它当作轻佻的玩笑……我会认真地收下，也会认真地回报……♥」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「……明白了。」"
			CALL MESSAGE_BOX,@"「请快些。别让我把它当成奢望。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……不。」"
			CALL MESSAGE_BOX,@"「%SELF_CALL()%不想用嘴唇去换取你的好心情。」"
		ELSE
			CALL MESSAGE_BOX,@"「……请自重。」"
		ENDIF
	CASE "停止泌乳"
		IF CFLAG:魔界_妊娠S == 1 || CFLAG:魔界_妊娠S == 2
			CALL MESSAGE_BOX,@"「……在此时令我停下泌乳，我不愿。那像是……连赎罪都被夺走。」"
		ELSE
			CALL MESSAGE_BOX,@"「……停止泌乳。明白了。愿我能将这份渴求一并压下，不再以乳为罪。」"
		ENDIF
	CASE "终止妊娠"
		CALL MESSAGE_BOX,@"「……终止妊娠……？我明白了。若这是您的意志，我会承受并配合。」"
	CASE "侍奉口爆终了"
		SELECTCASE ARGS:2
		CASE "忍住"
			CALL MESSAGE_BOX,@"「……如您所诫……贫女……止于唇边……不敢逾矩。」"
			CALL MESSAGE_BOX,@"「……感谢……赐予分寸。」"
		CASE "咽下"
			CALL MESSAGE_BOX,@"「……承饮……恩泽。……喉中灼烫……亦作洗礼。」"
			CALL MESSAGE_BOX,@"「……愿此秽……不折您慈悲。」"
		ENDSELECT
	CASE "揉胸轻抚"
		CALL MESSAGE_BOX,@"「……贫女……领受。……非哺……亦……无违。」"
		CALL MESSAGE_BOX,@"「……只请……勿哫笑。」"
	CASE "拥抱嗅闻"
		CALL MESSAGE_BOX,@"「……主若查验气息……贫女……屏息……便是。」"
		CALL MESSAGE_BOX,@"「……此身……近之若斯……惟……主恩。」"
	CASEELSE
	ENDSELECT

CASE "事件"
	CALL MESSAGE_BOX,@"「……发生了什么……？请告诉我，我会祈求指引……」"

CASE "肉体改造"
	CALL MESSAGE_BOX,@"「……身子要变样……我会接受。愿这也是试炼的一环。」"

CASE "战斗"
	SELECTCASE ARGS:1
	CASE "攻击"
		CALL MESSAGE_BOX,@"「……请见谅。我上了。」"
	CASE "被击中"
		CALL MESSAGE_BOX,@"「……唔……我还能……继续……」"
	CASEELSE
	ENDSELECT

CASEELSE
ENDSELECT
RETURN

@KOJO_GENERAL_虔诚1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
CALL KOJO_GENERAL_虔诚口上1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
RETURN

;--------------------------------------------
; 排泄羞耻／身体（本口上专用）
;--------------------------------------------
@KOJO_GENERAL_虔诚1_EXCRETION_BODY(ARGS:0, ARGS:1)
SELECTCASE ARGS:0
CASE "排泄事故"
	SELECTCASE ARGS:1
	CASE "肠"
		CALL MESSAGE_BOX,@"「……神啊……宽恕这不堪的肉体……」"
	CASE "尿"
		CALL MESSAGE_BOX,@"「……失禁……是试炼……我……承受……」"
	CASEELSE
		CALL MESSAGE_BOX,@"「……」"
	ENDSELECT
CASE "放尿主动"
	CALL MESSAGE_BOX,@"「……在您面前……卸下羞耻……」"
CASE "灌肠妊娠求饶"
	CALL MESSAGE_BOX,@"「……请怜悯未出世的生命……灌肠……求您收回……」"
CASEELSE
ENDSELECT
RETURN 1


