
;PLAYERの表示
@PRINT_PLAYER_COMMAND_AFTER_MESSAGE

;あなた以外、スケジュールならおわり
SIF PLAYER < 0 || (!TFLAG:调教中 && !TFLAG:日程外Ｈ)
	RETURN
EXIST = 0
PRINTFORM %CALLNAME:PLAYER%：
CALL PRINT_PLAYER_HP_MESSAGE
CALL PRINT_PLAYER_VIGOR_MESSAGE
CALL PRINT_PLAYER_EXP_MESSAGE
CALL PRINT_MASTER_POWERUP_VOL
PRINTL

;何も表示ない場合1行消す
SIF !EXIST
	CLEARLINE 1



;PLAYERのHP
@PRINT_PLAYER_HP_MESSAGE

;回復表示かダメージ表示か
IF SOURCE:调教者体力消耗 > SOURCE:调教者体力回复
	PRINTFORM HP-{SOURCE:调教者体力消耗 -SOURCE:调教者体力回复} 
	EXIST ++
ELSEIF SOURCE:调教者体力消耗 < SOURCE:调教者体力回复
	PRINTFORM HP+{SOURCE:调教者体力回复 -SOURCE:调教者体力消耗} 
	EXIST ++
ENDIF



;PLAYERの精力消費表示
@PRINT_PLAYER_VIGOR_MESSAGE

SIF !SOURCE:调教者精力消费量
	RETURN
PRINTFORM 精力-{SOURCE:调教者精力消费量} 
SIF !BASE:0:精力
	CALL PRINT_WORD_COLOR,@"【精力0】","黄"
EXIST ++



;PLAYERの経験値表示
@PRINT_PLAYER_EXP_MESSAGE

SAVE_TARGET = TARGET
TARGET = PLAYER
FOR LOCAL,30,100
	SIF SOURCE:LOCAL <= 0
		CONTINUE
	SIF !GETBIT(＃上限到达后显示／性经验值＃) && EXP:LOCAL >= EXP_MAX
		CONTINUE
	EXIST ++
	PRINTFORM %SOURCENAME:LOCAL%+{SOURCE:LOCAL} 
	SIF LOCAL >= 40
		PRINTFORM <EXP+{PALAM:LOCAL}> 
	
	;あんまり多くないのでPRINTLしない
NEXT
TARGET = SAVE_TARGET



;最大値増加メッセージ　調教中以外は飛ばす
@PRINT_MASTER_POWERUP_VOL

SIF !SOURCE:玩家增加灵力量 && !SOURCE:玩家增加魔力量
	RETURN
IF SOURCE:玩家增加灵力量
	PRINTFORM 灵力最大值+{SOURCE:玩家增加灵力量} 
	EXIST ++
ENDIF
IF SOURCE:玩家增加魔力量
	PRINTFORM 魔力最大值+{SOURCE:玩家增加魔力量} 
	EXIST ++
ENDIF








