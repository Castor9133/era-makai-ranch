
;処女喪失時の地の文
@V_LOST_VARGIN_MIND_DAMAGE_MESSAGE

IF TALENT:性知识贫乏
	IF (＃陷落状态／恋慕以上＃ || CFLAG:乳牛) && V_PENIS == CALLNAME:0
		{
		CALL PRINTL_WORD_COLOR,@"%CALLNAME%对这一行为的意义并不十分明白，但
		%SAVESTR:标识／膣%处传来%CALLNAME:0%通过触感感受到非常幸福的感觉…","桃"
		}
	ELSEIF SOURCE:Ｖ疼痛 < 5000
		CALL PRINTL_WORD_COLOR,@"%CALLNAME%虽然不太理解这一行为的意义，但母性本能理解这是让人愉悦的事…","桃"
	ELSE
		CALL PRINTL_WORD_COLOR,@"%CALLNAME%虽然不太理解这一行为的意义，但似乎觉得很痛苦而讨厌…","桃"
		RETURN
	ENDIF
	
ELSEIF (＃陷落状态／恋慕以上＃ || CFLAG:乳牛) && V_PENIS == CALLNAME:0
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%因可以为%CALLNAME:0%献上处女而高兴…","桃"
	
ELSEIF (＃陷落状态／陷落以上＃ || TALENT:单纯) && !TALENT:贞操观念 && V_PENIS == CALLNAME:0
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%并不在意把她的处女之身献给%CALLNAME:0%…","桃"
ELSE
	IF TALENT:贞操观念
		CALL PRINTL_WORD_COLOR,@"%CALLNAME%一直守护的纯洁因被%V_PENIS%夺走，流下了绝望的眼泪…","红"
	ELSE
		CALL PRINTL_WORD_COLOR,@"%CALLNAME%一直守护的纯洁因被%V_PENIS%夺走而流下了眼泪…","红"
	ENDIF
	RETURN
ENDIF

;RETURNしなかったらここ
SIF TALENT:名器 || ABL:Ｖ敏感度 >= 200
	CALL PRINTL_WORD_COLOR,@"就在%V_PENIS%进入的瞬间，自己%CSTR:性器称呼／膣%本能地意识到这是其存在的意义…","桃"
SIF SOURCE:Ｖ疼痛 >= 5000
	CALL PRINTL_WORD_COLOR,@"不过，面部因痛苦而扭曲…","桃"



;初キス時
@FIRST_KISS_MIND_DAMAGE_MESSAGE

