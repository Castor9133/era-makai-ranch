
;リソースに上限を入れておく
;9223372036854775807を超えるとオーバーフローするかと
@RESOURCE_LIMIT

MAXBASE:0:灵力 = LIMIT(MAXBASE:0:灵力,0,RESOURCE_MAX)
MAXBASE:0:魔力 = LIMIT(MAXBASE:0:魔力,0,RESOURCE_MAX)

;資金マイナスってこともまれにある
MONEY = LIMIT(MONEY,-1 *RESOURCE_MAX,RESOURCE_MAX)
MONEY:储存灵力 = LIMIT(MONEY:储存灵力,0,RESOURCE_MAX)
MONEY:贡献PT = LIMIT(MONEY:贡献PT,0,RESOURCE_MAX)
FLAG:母乳出货总量 = LIMIT(FLAG:母乳出货总量,0,RESOURCE_MAX)
FLAG:母乳合计出货金额 = LIMIT(FLAG:母乳合计出货金额,0,RESOURCE_MAX)

;スキルポイントも上限つけとく　多分いかないけど
FOR LOCAL,20,25
	MONEY:LOCAL = LIMIT(MONEY:LOCAL,0,RESOURCE_MAX)
NEXT








