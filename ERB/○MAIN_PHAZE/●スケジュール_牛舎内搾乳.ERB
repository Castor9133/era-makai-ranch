
;牛舎にいる家畜の搾乳
@COWSHED_LACTATION

;人数　有無しかCMATCHは取れないっぽいので牛舎番号でなくスケジュール
CATTLE_COUNT = CMATCH(CSTR:日程,"牛舍")
SIF !CATTLE_COUNT
	RETURN

;家畜小屋の搾乳の直後に来るんだけど家畜小屋に誰もいない場合があるので改めて
SIF !CMATCH(CSTR:日程,"奶农")
	RETURN
CALL SLAVE_LACTATION_TECHNIQUE_SET
PRINTL 　　　《 牛舍 》

;FLAG:第1牛舎スケジュール→501
;FLAG:第1牛舎家畜頭数→502
;FLAG:第1牛舎スケジュール表示→503
FLAG_REF = 491
FLAG_REF:1 = 492
FLAG_REF:2 = 493
FOR COWSHED_NUM,1,11
	;建ってなければ終了
	SIF COWSHED_NUM > ITEM:牛舍
		BREAK
		
	;家畜がいなければ飛ばす
	SIF !FLAG:(FLAG_REF:1 +COWSHED_NUM *10)
		CONTINUE
	
	;昼でスケジュールが0なら休憩
	IF !FLAG:(FLAG_REF +COWSHED_NUM *10) && TIME == 1
		PRINTFORML 让%COWSHED_NAME:COWSHED_NUM%的乳牛们休息。
		CALL COWSHED_LACTATION_REST
	ELSE
		CALL COWSHED_LACTATION_RUN
	ENDIF
	PRINTL
NEXT
CALL SECTION_MP_COST
CALL COWSHED_LACTATION_ABL_MARK_BULK
PRINTW
DRAWLINE
CALL RESET_TRAIN_PALAM
PLAYER = -1



;休憩
@COWSHED_LACTATION_REST

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CFLAG:牛舍号码 != COWSHED_NUM
		CONTINUE
	CALL REST_HEAL(1)
NEXT



;搾乳本体
@COWSHED_LACTATION_RUN
#DIM TOTAL_MILK

;フラグにより表示するか判定
FLAG:牛栏搾乳显示跳过 = FLAG:(FLAG_REF:2 +COWSHED_NUM *10)
TOTAL_MILK = 0
CALL RANDOM_CHARA_SCHEDULE_COWSHED

;BOX_COUNTに何もないとたぶん壊れてる、RAND:0するのでエラー落ち
TARGET = RANDOM_NO_BOX:RAND(BOX_COUNT)
CALL COWSHED_LACTATION_START_MESSAGE

SIF !FLAG:牛栏搾乳显示跳过
	CALL SLAVE_LACTATION_RUN(1,"牛舍")

;合計値増加
TOTAL_MILK += EX:喷乳

;その後全員
;裸を見られた口上はここではいいや
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CFLAG:牛舍号码 != COWSHED_NUM || CFLAG:行动完毕
		CONTINUE
	;表示まるごとスキップ判定がここ
	SKIPDISP FLAG:牛栏搾乳显示跳过
	CALL SLAVE_LACTATION_RUN(0,"牛舍")
	TOTAL_MILK += EX:喷乳
NEXT

;SKIPDISPは刻印通る場所で0に戻ってる
PRINTFORML %COWSHED_NAME:COWSHED_NUM%：计%VALUE_DIGIT(TOTAL_MILK,"母乳")%搾乳 
FLAG:牛栏搾乳显示跳过 = 0



;牛舎内をまとめてABL,MARK
@COWSHED_LACTATION_ABL_MARK_BULK
#DIM SKIP

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF !CFLAG:牛舍号码
		CONTINUE
	SKIP = 0
	
	;FLAG:第1牛舎スケジュール表示→503
	SIF FLAG:(493 +CFLAG:牛舍号码 *10) == 2
		SKIP = 1
	SKIPDISP SKIP
	CALL ABL_UP
	SIF SKIP
		SKIPDISP 0
	CALL MARK_GET
NEXT




