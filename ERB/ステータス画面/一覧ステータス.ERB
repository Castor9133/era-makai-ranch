
;ARGS→飛んできた場所
@TABLE_STATUS(ARGS)

IF CSTR:状态／主人公的孩子 == "成长中"
	PRINT 　【幼子】
	SIF !GROUPMATCH(FLAG:列表状态切换,0,5,8)
		RETURN
ELSE
	CALL TABLE_STATUS_BUST
ENDIF
SELECTCASE FLAG:列表状态切换
CASE 0
	CALL TABLE_STATUS_BASE(ARGS)
CASE 1
	PRINTFORM HP：{BASE:体力,4} 
	CALL PRINT_COLORBAR(BASE:体力,MAXBASE:体力,8,BARCOLORSET("青绿"),RESULT:1)
	PRINT  
	CALL PRINT_MILKTANK(1,0,1)
	
CASE 2
	LOCALS = %VALUE_DIGIT(BASE:灵力)%
	LOCALS:1 = %VALUE_DIGIT(MAXBASE:灵力)%
	PRINTFORM EP：%LOCALS,10%／%LOCALS:1,10% 
	CALL PRINT_COLORBAR(BASE:灵力,MAXBASE:灵力,8,BARCOLORSET(""),RESULT:1)
	CALL PRINT_REMAINING_EP
	
CASE 3
	IF MARK:绝顶魔力回复淫纹
		CALL PRINT_MILKTANK(1,1,1,1)
		CALL PRINT_REMAINING_MP
	ELSEIF MAXBASE:魔力
		LOCALS = %VALUE_DIGIT(BASE:魔力)%
		LOCALS:1 = %VALUE_DIGIT(MAXBASE:魔力)%
		PRINTFORM MP：%LOCALS,10%／%LOCALS:1,10% 
		CALL PRINT_COLORBAR(BASE:魔力,MAXBASE:魔力,8,BARCOLORSET("深紫"),RESULT:1)
		CALL PRINT_REMAINING_MP
	ELSE
		CALL PRINT_WORD_COLOR("没有魔力","灰")
	ENDIF
	
CASE 4
	CALL PRINT_HEIGHT_SHORT
	CALL PRINT_TRIVE
	SIF !TALENT:男性
		CALL PRINT_HAIR_STYLE
	
CASE 5
	CALL PRINT_AFFILIATION_DATA
CASE 6
	CALL ABL_WORK_LIST(1)
CASE 7
	CALL PRINT_MILKTANK(1,0,1)
	CALL PRINT_CAPITULATION_LIST

CASE 8
	SELECTCASE ARGS
	CASE "主要"
		;メインの時だけスケジュール予定表示
		CALL TABLE_STATUS_AUTO_SCHEDULE
	CASEELSE
		PRINTFORM HP：{BASE:体力,4} 
		CALL PRINT_COLORBAR(BASE:体力,MAXBASE:体力,8,BARCOLORSET("青绿"),RESULT:1)
		PRINT  
		CALL PRINT_MILKTANK(1,0,1)
	ENDSELECT

ENDSELECT


;メイン0番
@TABLE_STATUS_BASE(ARGS)

PRINTFORM HP：{BASE:体力,4} 
CALL PRINT_COLORBAR(BASE:体力,MAXBASE:体力,8,BARCOLORSET("青绿"),RESULT:1)
PRINT  

;飛んできた場所で表示変更
SELECTCASE ARGS
CASE "主要"
	CALL SCHEDULE_PLAN_PRINT(CSTR:日程,1)
	
	;仕事の場合は出さない
	SIF !GROUPMATCH(CSTR:日程,"奶农","调教","事务","调剂","训练","大浴场清洁")
		CALL PRINT_MILKTANK(1,0,1)
	
CASE "牛舍","浴池","愿望"
	CALL PRINT_MILKTANK(1,0,1)
	
CASE "放入牛舍","推迟合作伙伴"
	;居場所も出す
	CALL PRINT_MILKTANK(1,0,1)
	CALL PRINT_NOW_PLACE(0,1)
	
CASE "调教对象"
	CALL PRINT_MILKTANK(1,0,1)
	IF SAVE_TARGET >= 0
		SIF !TALENT:SAVE_TARGET:男性
			CALL ABL_WORK_PRINT(0,"百合癖")
	ENDIF
	
CASE "料理值班"
	CALL PRINT_MILKTANK(1,0,1)
	PRINTFORM 料理：Lv{ABL:料理,2}
	
CASE "清洁值日"
	CALL PRINT_MILKTANK(1,0,1)
	PRINTFORM 清洁：Lv{ABL:清洁,2}
	
CASE "房间分配变更"
	CALL PRINT_ROOM_NUM
ENDSELECT



;自動スケジュール表示
@TABLE_STATUS_AUTO_SCHEDULE
#DIMS AUTO_SCHEDULE

;自動スケジュール無視の場合はその他
IF CFLAG:牛舍号码
	AUTO_SCHEDULE = ＜牛舍＞
ELSEIF CSTR:住处 == "体内"
	AUTO_SCHEDULE = ＜体内＞
ELSEIF CFLAG:追踪对象
	AUTO_SCHEDULE = ！未捕获
ELSE
	;CSTR:自動スケジュール／月→350
	FLAG_REF = 350
	AUTO_SCHEDULE = %CSTR:(DAY:曜日 +FLAG_REF)%
ENDIF

IF GROUPMATCH(AUTO_SCHEDULE,"＜牛舍＞","＜体内＞","！未捕获")
	CALL PRINT_WORD_COLOR,@"%AUTO_SCHEDULE,15,LEFT%","灰"
ELSE
	PRINTFORM %AUTO_SCHEDULE,15,LEFT%
ENDIF
CALL SCHEDULE_PLAN_PRINT(CSTR:日程,1)
SIF !GROUPMATCH(CSTR:日程,"奶农","调教","事务","调剂","训练","大浴场清洁")
	CALL PRINT_MILKTANK(1,0,1)



;おっぱい
@TABLE_STATUS_BUST

IF TALENT:男性
	PRINT 　　　　　
	SIF FLAG:淫乳奴隶存在
		PRINT 　　
ELSE
	PRINTFORM %PRINT_BUSTSIZE(ABL:胸围大小)%
	CALL PRINT_BUST_C(1,1)
	SIF FLAG:淫乳奴隶存在 && !MARK:淫乳
		PRINT 　　
ENDIF



;霊力残量
@PRINT_REMAINING_EP

SIF !TARGET
	RETURN
IF !BASE:可吸收的灵力
	IF !BASE:灵力
		CALL PRINT_WORD_COLOR(" 已经榨干了","灰")
	ELSE
		CALL PRINT_WORD_COLOR(" 不可吸收","灰")
	ENDIF
ELSE
	PRINTFORM  吸收可能：%VALUE_DIGIT(BASE:可吸收的灵力),10%EP
ENDIF



;魔力残量
@PRINT_REMAINING_MP

SIF !TARGET
	RETURN
IF !BASE:可吸收的魔力
	IF !BASE:魔力
		CALL PRINT_WORD_COLOR(" 已经榨干了","灰")
	ELSE
		CALL PRINT_WORD_COLOR(" 不可吸收","灰")
	ENDIF
ELSE
	PRINTFORM  吸收可能：%VALUE_DIGIT(BASE:可吸收的魔力),10%MP
ENDIF




