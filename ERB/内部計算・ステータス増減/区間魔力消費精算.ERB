
;区間魔力消費量精算
@SECTION_MP_COST

IF FLAG:区间魔力消费量
	SIF FLAG:电池消耗显示
		PRINTFORML 消费魔力：{FLAG:区间魔力消费量}MP　
	BASE:0:魔力 += FLAG:体内凌辱携带魔力
	BASE:0:魔力 -= FLAG:区间魔力消费量
	BASE:0:魔力 = LIMIT(BASE:0:魔力,0,MAXBASE:0:魔力)
ENDIF
IF FLAG:区间电池消耗量
	MONEY:电池追加消耗金额 += FLAG:区间电池消耗量
	SIF FLAG:电池消耗显示
		PRINTFORML 电池消费：{FLAG:区间电池消耗量}
ENDIF
FLAG:区间魔力消费量 = 0
FLAG:区间电池消耗量 = 0
FLAG:体内凌辱携带魔力 = 0

;MPが時間圧縮のコスト以下になったら解除
IF TFLAG:压缩时间中 && BASE:0:魔力 < MAGIC_USE_MP:GETNUM(ITEM,"时间压缩") *TFLAG:时间压缩有效回合数
	TFLAG:压缩时间中 = 0
	PRINTFORML 因为%CALLNAME:0%的魔力不能维持了，所以＜时间压缩＞被解除了。
ENDIF

;調教中ならMP0で触手など解除
SIF BASE:0:魔力
	RETURN
IF TFLAG:调教中 && TFLAG:触手装备
	FOR LOCAL,100,200
		TEQUIP:LOCAL = 0
	NEXT
	TFLAG:触手装备 = 0
	SIF GETBIT(＃束缚／触手＃)
		TFLAG:拘束BIT = 0
	PRINTFORML 因为%CALLNAME:0%的魔力耗尽了，所以触手消失了。
ENDIF

;体内凌辱しているなら全員解放される
SAVE_TARGET = TARGET
CATTLE_COUNT = CMATCH(CSTR:日程,"体内凌辱")
SIF !CATTLE_COUNT
	RETURN
FOR LOCAL,0,CHARANUM
	TARGET = LOCAL
	SIF CSTR:日程 != "体内凌辱"
		CONTINUE
		
	;一番目に当たったキャラの名前
	IF CSTR:日程 == "体内凌辱"
		PRINTFORM 由于%CALLNAME:0%的魔力耗尽，困在%CALLNAME:0%体内的%CALLNAME%
		SIF CATTLE_COUNT > 1
			PRINT 们
		BREAK
	ENDIF
NEXT
PRINTW 被解放了。
FOR LOCAL,0,CHARANUM
	TARGET = LOCAL
	SIF CSTR:日程 != "体内凌辱"
		CONTINUE
	SIF CSTR:日程 == "体内凌辱"
		CSTR:日程 = 行动完毕
NEXT
TARGET = SAVE_TARGET

