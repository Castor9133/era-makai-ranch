CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++
PRINTL
CALL EJACULATION_PISTON



;素股の要領で太腿・会陰を洗う（挿入なし・処女可）
@BATHLOOM_PLAYER_WASHING_SUMATA_THIGHS

SELECTCOM = 50
CALL SERVICE_JUDGE
IF !RESULT
	SELECTCOM = 0
	RETURN
ENDIF
IF !PLAYER_PENIS
	SELECTCOM = 0
	RETURN
ENDIF
CALL PENIS_STAIN_FIX
LOSEBASE:体力 += 38
LOSEBASE:气力 += 28
SOURCE:不洁 = 0
SOURCE:已用时间 = 1
CALL PRINT_IMAGE("奉仕")
CALL BATHLOOM_PLAYER_WASHING_SUMATA_THIGHS_MESSAGE
SOURCE:耻辱 += 2800
SOURCE:屈辱 += 1200
SOURCE:爱情 += 2200
SOURCE:学习 += 1600
SOURCE:支配 += 500
SOURCE:调教者习得 += 380
SOURCE:Ｃ快感 += 2600
SOURCE:Ｖ快感 += 1600
SOURCE:润滑 += 2800
SOURCE:Ｃ快感／主人公刺激 += 2400
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
; 调教と同じ素股射精分岐（EJACULATION_CROTCH／メッセージ_射精の股間素股）を通す
SOURCE:选择指令口上隐藏 = 1
TEQUIP:素股 = 1
SELECTCOM = 50
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
EXP:(SELECTCOM +1000) ++
CALL SOURCE_CHECK
LOCAL:91 = TFLAG:指令中射精次数
SIF LOCAL:91 > 0 && FLAG:口上显示 && CFLAG:口上显示
	CALL BATHLOOM_PLAYER_WASHING_SUMATA_EJAC_KOJO
TFLAG:指令中射精次数 = 0
TEQUIP:素股 = 0
SELECTCOM = 0
TFLAG:亲密互动次数 ++



;乳房で背中を推し洗う（正面の「乳洗い」とは別）
