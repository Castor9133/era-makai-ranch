
;調教外責めの結果表示
@SCHEDULE_LACTATION_TOTAL_RESULT

;揃える表示を別に使いたいかもしれない
;母乳体質ではない場合
RESETCOLOR
IF !MARK:母乳体质
	PRINTFORMC %CALLNAME_DIGIT()% <{EX:总绝顶,4}回绝顶> 
	CALL PRINT_STATUS_BEFORE_AFTER

;母乳体質の場合
ELSE
	PRINTFORMC 从%CALLNAME_DIGIT()%的%PRINT_BUST()%开始 
	CALL PRINT_TOTAL_MILK_FLAVOR
	PRINTFORM %VALUE_DIGIT(EX:喷乳)%%MILK_COUNTING()%搾乳 <{EX:总绝顶,4}回绝顶> 
	CALL PRINT_STATUS_BEFORE_AFTER
	
	;ここでフラグ立てる
	SIF !BASE:灵力
		EXP:灵力为零 = 1
ENDIF
IF CFLAG:崩坏
	CALL PRINTL_WORD_COLOR("[崩坏] ","红")
ELSE
	SIF !CFLAG:牛舍号码
		PRINTL
	CALL TRAIN_END_PALAM_CALC
ENDIF

;牛舎搾乳での表示スキップ判定を解除
SKIPDISP 0

;崩壊寸前や乳牛堕ち寸前なら常に表示
SIF BASE:精神力 < BASE_LIMITER_HEAL_MIND && !CFLAG:崩坏
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%　精神力：%PRINT_PALAM_PERCENT(BASE:精神力)% ","红"
SIF BASE:乳牛堕落 >= BASE_ENDURE_COW && !CFLAG:乳牛 && !CFLAG:崩坏
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%　乳牛堕落：%PRINT_PALAM_PERCENT(BASE:乳牛堕落)% ","桃"
CALL CAPITULATION_JUDGE

;あなたの体力増加・レベルアップ
CALL MASTER_POWERUP

;霊力・魔力の注入
CALL POWER_INJECTION

;あなたABL,MARK
CALL PLAYER_SOURCE_UP_AFTER_STATUS_UP(1)



@PRINT_TOTAL_MILK_FLAVOR
#DIMS MILK

MILK =
;濃度表示
SELECTCASE ABL:母乳浓度
CASE 1
	MILK = 浓厚
CASE 2
	MILK = 上质
CASE 3
	MILK = 丰润
CASE 4
	MILK = 特浓
CASE 5
	MILK = 极品
ENDSELECT
MILK += "母乳"
CALL PRINT_WORD_COLOR,@"%MILK,8,RIGHT%","桃"
;PRINTFORM %MILK,8,RIGHT%



;調教前後のステータス表示
@PRINT_STATUS_BEFORE_AFTER

;牛舎内なら表示しない
SIF CFLAG:牛舍号码
	RETURN
IF HP_BEFORE > BASE:体力
	PRINTFORM HP-{HP_BEFORE -BASE:体力,4,LEFT} 
	SIF !BASE:体力
		PRINT 【HP0】
ENDIF
IF SP_BEFORE > BASE:气力
	PRINTFORM SP-{SP_BEFORE -BASE:气力,4,LEFT} 
	SIF !BASE:气力
		PRINT 【SP0】
ENDIF

;ここからドレイン
IF MARK:绝顶魔力回复淫纹
	IF TFLAG:抽出中
		DAMAGE = EX:喷乳 *(ABL:母乳浓度 +1)
		PRINTFORM MP %VALUE_DIGIT(DAMAGE)%生成 
	ELSEIF GROUPMATCH(CSTR:日程,"抽出","体内凌辱")
		DAMAGE = EX:喷乳 *(ABL:母乳浓度 +1)
		PRINTFORM MP %VALUE_DIGIT(DAMAGE)%吸收 
	ENDIF
ENDIF
IF MP_BEFORE > BASE:魔力
	PRINTFORM MP-%VALUE_DIGIT(MP_BEFORE -BASE:魔力)% 
	SIF !BASE:魔力
		PRINT 【MP0】
ENDIF
IF EP_BEFORE > BASE:灵力
	PRINTFORM EP-%VALUE_DIGIT(EP_BEFORE -BASE:灵力)% 
	SIF !BASE:灵力
		PRINT 【EP0】
ENDIF



