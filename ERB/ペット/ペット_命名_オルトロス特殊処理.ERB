
;オルトロスの名前特殊処理
;ARG→FUNNY_NAME（ネタ名表示）
@NAMING_PET_ORTHROS_NAME_METHOD(ARG)

SIF ANIMAL != "双头犬"
	RETURN
PRINTL 请选择命名方法。
PRINTLC [ 0] 指定一个名称（从第一个名称开始重置）
PRINTLC [ 1] 给左右头分别起个名儿
PRINTL [99] 取消
INPUT
SELECTCASE RESULT
CASE 0
	PET_NAME:1 =
	PET_NAME:2 =
CASE 1
	PRINTL 请输入哥哥／姐姐的名字。
	CALL ORTHROS_NAME_INPUT(ARG)
	SIF RESULTS == ""
		RETURN
	PET_NAME = %RESULTS%
	CALL ORTHROS_NAME_JOINT_INPUT
	SIF RESULTS == ""
		RETURN
	PET_NAME:1 = %RESULTS%
	PRINTL
	PRINTL 请输入弟弟／妹妹的名字。
	CALL ORTHROS_NAME_INPUT(ARG)
	PET_NAME:2 = %RESULTS%
	
	;空欄になったら接続詞も消す
	SIF PET_NAME:2 == ""
		PET_NAME:1 =
ENDSELECT



;オルトロスの名前候補
@ORTHROS_NAME_INPUT(ARG)
#DIM LOOP_REF

STR_REF = 20200
LOOP_REF = 20210
SIF ARG
	LOOP_REF = 20300
BR = 0
FOR LOCAL,STR_REF,LOOP_REF
	SIF STR:LOCAL == ""
		CONTINUE
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
NEXT
CALL INPUTBUTTON
INPUT
SELECTCASE RESULT
CASE 0 TO 99
	RESULTS = %STR:(STR_REF +RESULT)%
CASE 901
	PRINTL 请输入名称。
	INPUTS
	RETURN
CASEELSE
	RESULTS =
ENDSELECT



;接続詞入力
@ORTHROS_NAME_JOINT_INPUT

STR_REF = 8120
PRINTL
PRINTL 请选择地文・标识上的连接词。
CALL PRINTL_WORD_COLOR("建议避免使用半角字符「&」，因为它似乎会导致错误。","黄")
BR = 0
FOR LOCAL,STR_REF,STR_REF +10
	SIF STR:LOCAL == ""
		CONTINUE
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
NEXT
CALL INPUTBUTTON
INPUT
SELECTCASE RESULT
CASE 0 TO 9
	RESULTS = %STR:(STR_REF +RESULT)%
CASE 901
	PRINTL 请输入连接词。
	INPUTS
	RETURN
CASEELSE
	RESULTS =
ENDSELECT




