
;母乳吸い
@TRAIN_MILK_SUCK_MESSAGE

IF MARK:母乳体质
	IF BASE:母乳容量 > 2000
		PRINTFORM 痛快地喝下从%SLANG_N()%溢出的%SLANG_MILK()%…
	ELSEIF BASE:母乳容量
		PRINTFORM 把嘴放在%SLANG_N()%上，不停地吸着%SLANG_MILK()%…
	ELSE
		PRINTFORM 为了获得%SLANG_MILK()%，不断吮吸%SLANG_N()%…
	ENDIF
ELSE
	PRINTFORM 像是渴求%SAVESTR:标识／母乳%般不断吮吸%SLANG_N()%…
ENDIF
PRINTL



;乳揉み
@TRAIN_BUST_LUB_MESSAGE

;揉むほどある？
IF ABL:胸围大小 >= BUSTSIZE_普乳
	SELECTCASE RAND:3
	CASE 0
		PRINT 噗尼噗尼的揉动着…
	CASE 1
		PRINT 揉来揉去玩弄着…
	CASE 2
		PRINT 用力的捏动着…
	ENDSELECT
ELSE
	PRINT 温柔地抚摸着…
ENDIF
PRINTL



;おっぱいを揉み／撫でながら
;ARG→「ながら」追加
@TRAIN_BUST_LUB_WHILE_MESSAGE(ARG)

PRINTFORM %SLANG_STAIN("Ｂ")%%SLANG_B()%和%BUST_LUB()%
IF ARG
	PRINT 同时，
ELSE
	PRINT 、
ENDIF



;触手おっぱい侵入
@TRAIN_BUST_TENTACLE_MESSAGE

CALL TRAIN_TENTACLE_APPEAR_MESSAGE

;横乳露出のとき服の下から侵入する
IF TFLAG:侧乳露出
	IF ＃穿着衣服／乳沟露出＃
		PRINT 从衣服的谷间侵入，
	ELSE
		PRINT 从衣服的侧面侵入，
	ENDIF
ELSE
	PRINTFORM 、%BUST_CLOTHES()%
ENDIF



;触手出現
;ARGS→触手種類
@TRAIN_TENTACLE_APPEAR_MESSAGE(ARGS)

PRINTFORM %CALLNAME:0%
SELECTCASE RAND:3
CASE 0
	PRINT 从身体中滑溜溜爬出
CASE 1
	PRINT 身体的一部分发生了变化
CASE 2
	PRINT 从中长出来
ENDSELECT

;触手種類
SELECTCASE ARGS
CASE "阴茎触手"
	PRINTFORM %SAVESTR:标识／阴茎触手%
CASE "刷子触手"
	PRINT 刷子型触手
CASEELSE
	PRINT 触手
ENDSELECT



;向きを返す
@DIRECTION(ARG)
#FUNCTIONS

SIF TFLAG:背后
	RETURNF "从背后"



;おっぱい着衣状態を返す
@BUST_CLOTHES(ARG)
#FUNCTIONS

IF TFLAG:Ｂ露出
	RETURNF "露出的"
ELSE
	RETURNF "依然穿着的"
ENDIF



;揉むほどあるか返す
@BUST_LUB(ARG)
#FUNCTIONS

IF ABL:胸围大小 >= BUSTSIZE_普乳
	RETURNF "揉捏"
ELSE
	RETURNF "抚摸"
ENDIF



;挿入したままか返す（CALL型）
@TRAIN_INSERT_MESSAGE

SIF GETBIT(＃Ｐ使用／Ｖ插入＃)
	PRINTFORM 将%SLANG_PENIS()%插入%SLANG_V()%，
SIF GETBIT(＃Ｐ使用／Ａ插入＃)
	PRINTFORM 将%SLANG_PENIS()%插入%SLANG_A()%，



;奉仕するか返す
@TRAIN_SERVICE(ARG)
#FUNCTIONS

IF CFLAG:洗脑
	RETURNF "空洞的表情"
ELSEIF ＃陷落状态／恋慕以上＃ || ABL:奉仕精神 >= 10
	RETURNF "带着亲切的神情"
ELSEIF PALAM:淫欲 >= 20000 || MARK:淫纹
	RETURNF "带着发情的表情"
ELSEIF CFLAG:无抵抗
	RETURNF "顺从地"
ELSE
	RETURNF "带着不悦的表情"
ENDIF



;射精先メッセージ
@TRAIN_EJACULATION_FINISH_MESSAGE

;膣内・尻穴・口内でメッセージ変更
PRINTFORM %SLANG_SEMEN()%，
IF SOURCE:膣内射精经验 || SOURCE:尻穴射精经验 || SOURCE:精饮经验
	PRINT 注入了…
ELSE
	PRINT 释放了…
ENDIF
PRINTL
; 臀部素股：射精收尾时补一句落点沿躯干向上（与尻部污渍、前文腰骶／后背叙述呼应）
IF TEQUIP:臀部素股 && SOURCE:股间射精
	PRINTFORML 尚有少许沿%CALLNAME%裸出的脊背缓缓淌下，在腰窝与肩胛一线留下断续的湿痕。
ENDIF





