
@COM10_MESSAGE
;乳揉み

CALL TRAIN_INSERT_MESSAGE

;横から手入れた場合の追加
;乳暖簾・乳出しはＢ露出→横乳露出はOFFになる
IF TFLAG:侧乳露出
	PRINTFORM 把手伸进衣服的一侧，用手指在%DIRECTION()%抚摸%CALLNAME%的%SLANG_B()%
ELSEIF TFLAG:露出乳沟
	PRINTFORM 从衣服的乳沟入手，将%CALLNAME%的%SLANG_B()%%DIRECTION()%
ELSE
	PRINTFORM %BUST_CLOTHES()%%CALLNAME%的%SLANG_STAIN("Ｂ")%%SLANG_B()%和%DIRECTION()%
ENDIF
CALL TRAIN_BUST_LUB_MESSAGE



@COM11_MESSAGE
;乳搾り

CALL TRAIN_INSERT_MESSAGE
PRINTFORM %BUST_CLOTHES()%%CALLNAME%的%SLANG_STAIN("Ｂ")%%SLANG_B()%和%DIRECTION()%握住，
IF MARK:母乳体质 && BASE:母乳容量
	PRINTFORM 朝顶端挤压出%SLANG_MILK()%…
ELSE
	PRINTFORM 以挤压%SAVESTR:标识／母乳%的方式，朝着顶端施加力道…
ENDIF
PRINTL



@COM12_MESSAGE
;乳首つまみ

CALL TRAIN_INSERT_MESSAGE
IF TFLAG:侧乳露出 && !TFLAG:Ｎ露出
	IF ＃穿着衣服／乳沟露出＃
		PRINT 从衣服的乳沟处
	ELSE
		PRINT 从衣服的侧面
	ENDIF
	PRINTFORM 中伸手找到%CALLNAME%的%SLANG_N()%，
ELSE
	PRINTFORM %CALLNAME%的%SLANG_N()%
ENDIF
PRINTFORML %DIRECTION()%扭来扭去地玩弄着…



