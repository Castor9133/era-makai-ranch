
;大浴場掃除開始の地の文
@WORK_LARGE_BATHLOOM_CLEANING_BEGIN_MESSAGE

SIF !EXP:执行次数／大浴场清洁 && TARGET
	PRINTFORML %CALLNAME%被%CALLNAME:0%命令，要打扫大浴场…
PRINTFORM %CALLNAME%%PRINT_WORK_GROUP()%将
SIF CSTR:0:日程 == "大浴场清洁" && TARGET
	PRINTFORM 和%CALLNAME:0%一起
PRINTL 打扫了大浴场。
CALL KOJO_PRINT("日程","大浴场清洁",KOJO_TYPE)



;掃除上手さ表示
@WORK_LARGE_BATHLOOM_CLEANING_ABL_MESSAGE

SIF !TARGET
	RETURN
IF !EXP:执行次数／大浴场清洁
	IF ABL:清洁 >= 8
		PRINTL 利用以前的经验，非常有效率的进行事务工作。
	ELSEIF ABL:清洁 >= 4
		PRINTL 看来很有条理。
	ELSE
		PRINTL …看起来进展不是很顺利。
	ENDIF
ELSE
	IF ABL:清洁 >= 8
		PRINTL 浴缸眼看着变干净了。
	ELSEIF ABL:清洁 >= 4
		PRINTL 进步得相当不错。
	ELSE
		PRINTL …看起来进展不是很顺利。
	ENDIF
ENDIF




