
;ステータス・仕事能力の変更シャッフル
;ARGS→CHANGE_STATE
@SELF_CHARA_MAKE_STATUS_INPUT_SHUFFLE(ARGS)

SELECTCASE ARGS
CASE "等级"
	;RAND幅自体をランダムに
	SELECTCASE RAND:100
	CASE IS < 50
		MAXBASE:等级 = 10 +RAND:40
	CASE IS < 80
		MAXBASE:等级 = 10 +RAND:90
	CASE IS < 90
		MAXBASE:等级 = 10 +RAND:140
	CASEELSE
		MAXBASE:等级 = 10 +RAND:250
	ENDSELECT
	BASE:等级 = MAXBASE:等级
	CFLAG:级别 = MAXBASE:等级 /10
	SIF !CFLAG:灵力固定
		CALL SLAVE_EP_CALC
	SIF !CFLAG:魔力固定
		CALL SLAVE_MP_CALC
	CALL SLAVE_BATTLE_POWER_CALC(1)
	
CASE "非战斗职业"
	;ONOFFなので同じ
	PRINTL 设定为[非战斗职业]的话等级固定为1，不能和敌人战斗。
	PRINTL （固定灵力·魔力的场合被重置）
	PRINTLC [ 0] 【非战斗职业】关闭
	PRINTLC [ 1] 【非战斗职业】开启
	INPUT
	IF RESULT
		CFLAG:非战斗职业 = 1
		MAXBASE:等级 = 1
		BASE:等级 = MAXBASE:等级
		CFLAG:级别 = 0
		BASE:回复次数 = 0
		BASE:大技次数 = 0
		CFLAG:灵力固定 = 0
		CFLAG:魔力固定 = 0
		CALL SLAVE_EP_CALC
		CALL SLAVE_MP_CALC
		CALL SLAVE_BATTLE_POWER_CALC(1)
	ELSE
		CFLAG:非战斗职业 = 0
	ENDIF
	
CASE "体力"
	MAXBASE:体力 = 800 +RAND:2000
	MAXBASE:体力 -= (MAXBASE:体力 %50)
	BASE:体力 = MAXBASE:体力
	
CASE "气力"
	MAXBASE:气力 = 800 +RAND:2000
	MAXBASE:气力 -= (MAXBASE:气力 %50)
	BASE:气力 = MAXBASE:气力

CASE "灵力重新计算"
	IF CFLAG:灵力固定
		PRINTL 关闭[灵力固定]标志并重新计算？
		CALL ASK_YN
		SIF RESULT
			RETURN
	ENDIF
	CFLAG:灵力固定 = 0
	CALL SLAVE_EP_CALC

CASE "灵力固定"
	;なし
	
CASE "魔力量"
	CFLAG:魔力量 = RAND:13
	SIF !RAND:4
		CFLAG:魔力量 = 0
	CALL SLAVE_MP_CALC
	CALL SLAVE_BATTLE_POWER_CALC(1)

CASE "魔力重新计算"
	IF CFLAG:魔力固定
		PRINTL 关闭[魔力固定]标志并重新计算？
		CALL ASK_YN
		SIF RESULT
			RETURN
	ENDIF
	CFLAG:魔力固定 = 0
	CALL SLAVE_MP_CALC

CASE "魔力固定"
CASE "战斗力重新计算"
	CALL SLAVE_BATTLE_POWER_CALC(1)


;2ページ目
CASE "回复次数"
	BASE:回复次数 = RAND:6
	
CASE "大技次数"
	BASE:大技次数 = RAND:6
	
CASE "同行同伴"
	CFLAG:同伴规模 = RAND:3
	CFLAG:同伴级别 = CFLAG:级别
	CALL GROUP_BATTLE_POWER_CALC
	
CASE "同伴级别"
	CFLAG:同伴级别 = RAND:13
	CALL GROUP_BATTLE_POWER_CALC

CASE "同伴战斗力重新计算"
	CALL GROUP_BATTLE_POWER_CALC


;3ページ目
CASE "奶农ABL"
	ABL:奶农 = RAND:12
		
CASE "事务ABL"
	ABL:事务 = RAND:12
		
CASE "清洁ABL"
	IF TALENT:不擅长清洁
		PRINTW 【不擅长清洁】的情况下，初始清洁Lv为0固定。
		RETURN
	ENDIF
	ABL:清洁 = RAND:12
	
CASE "料理ABL"
	IF TALENT:不擅长料理
		PRINTW 【不擅长料理】的情况下，初始料理Lv为0固定。
		RETURN
	ENDIF
	ABL:料理 = RAND:12
		
CASE "药学ABL"
	ABL:药学 = RAND:12
	SIF ABL:药学 < 5
		TALENT:调合知识 = 0
		
CASE "接客ABL"
	IF TALENT:不擅长接客
		PRINTW 【不擅长接客】的情况下，初始接客Lv为0固定。
		RETURN
	ENDIF
	ABL:接客 = RAND:12

CASE "不擅长清洁"
	INVERTBIT TALENT:不擅长清洁,0
	
	;ONにするにせよOFFにせよLv0
	ABL:清洁 = 0
	
CASE "不擅长料理"
	INVERTBIT TALENT:不擅长料理,0
	ABL:料理 = 0
	
CASE "不擅长接客"
	INVERTBIT TALENT:不擅长接客,0
	ABL:接客 = 0
	
CASE "调合知识"
	INVERTBIT TALENT:调合知识,0
ENDSELECT




