@NEWGAME_PLAYER_DATA_INDEX1
#DIM COLOR

;手動のみ変更可能
PRINTL 【仅手动输入】
IF !SELF_CHARA_MAKE_RANDOM
	PRINTL [ 0] 重命名
	PRINTL [ 1] 全名
	PRINTFORML [ 2] 　　第一人称：%CSTR:第一人称%
	PRINTFORML [ 3] 　　　语气：%SAVESTR:主人公语气%
	PRINT [ 4] 口上颜色：
ELSE
	CALL PRINTL_WORD_COLOR,@"< 0> 重命名","灰"
	CALL PRINTL_WORD_COLOR,@"< 1> 全名","灰"
	PRINTFORML < 2> 第一人称：%CSTR:第一人称%
	PRINTFORML < 3> 　语气：%SAVESTR:主人公语气%
	PRINT < 4> 口上颜色：
ENDIF

;口上の部分は共通
COLOR = CFLAG:颜色编码／口上
IF COLOR
	SETCOLOR COLOR
	PRINTFORML %UNICODE(0x2586)%(R:{GETRED(COLOR)} G:{GETGREEN(COLOR)} B:{GETBLUE(COLOR)})
	RESETCOLOR
ELSE
	PRINTL 未设置显示颜色。
ENDIF
IF !SELF_CHARA_MAKE_RANDOM
	IF FLAG:EX模式
		PRINTFORML [ 5] 　　　种族：%CSTR:种族%
	ELSE
		CALL PRINTL_WORD_COLOR,@"< 5> 　　　种族：仅限【EX模式】","灰"
	ENDIF
ELSE
	CALL PRINTL_WORD_COLOR,@"< 5> 种族","灰"
ENDIF
PRINTL
