PRINT [98] 排序方法　当前：
IF TEMP_FLAG
	PRINTL 升序
ELSE
	PRINTL 降序
ENDIF
PRINTL [99] 取消
BINPUT
SELECTCASE RESULT
CASE 0 TO 10
	CALL SLAVE_SORT_ALL_RUN(RESULT,TEMP_FLAG)
CASE 98
	TEMP_FLAG = ABS(TEMP_FLAG -1)
	RESTART
CASEELSE
	RETURN
ENDSELECT
TEMP_FLAG = 0



;ソート実行
;ARG→ソート項目　ARG:1→TEMP_FLAG
@SLAVE_SORT_ALL_RUN(ARG,ARG:1)

