
;外見・おっぱいの変更
;ARG→PAGE
;ARG:1→INPUT_NUM
@SELF_CHARA_MAKE_APPEARAINCE_INPUT(ARG,ARG:1)

;ページ+INPUT_NUMでINPUT_NUMを上書き
;INPUT_NUMで変更箇所を指定する
;イベント入手キャラの呼び出しにも使うのでこんな感じ
INPUT_NUM = (ARG -1) *100 +ARG:1
SELECTCASE INPUT_NUM
CASE 0
	CHANGE_STATE = 身高
CASE 1
	CHANGE_STATE = 体型
CASE 2
	CHANGE_STATE = 肤色
CASE 3
	CHANGE_STATE = 发色
CASE 4
	CHANGE_STATE = 头发特征
CASE 5
	CHANGE_STATE = 发型
CASE 6
	CHANGE_STATE = 发型一键调整
CASE 7
	CHANGE_STATE = 颜色编码／发
CASE 8
	CHANGE_STATE = 外表年龄
CASE 9
	CHANGE_STATE = 阴毛
CASE 10
	CHANGE_STATE = 右瞳色
CASE 11
	CHANGE_STATE = 颜色编码／右目
CASE 12
	CHANGE_STATE = 左瞳色
CASE 13
	CHANGE_STATE = 颜色编码／左目
CASE 14
	CHANGE_STATE = 瞳孔形状
CASE 15
	CHANGE_STATE = 眼睛特征

;2ページ目
CASE 100
	CHANGE_STATE = 胸围大小
CASE 101
	CHANGE_STATE = 乳房弹性
CASE 102
	CHANGE_STATE = 乳头颜色
CASE 103
	CHANGE_STATE = 颜色编码／乳头
CASE 104
	CHANGE_STATE = Ｂ敏感度
CASE 105
	CHANGE_STATE = Ｎ敏感度
CASE 106
	CHANGE_STATE = 陷没乳头
CASE 110
	CHANGE_STATE = 母乳体质
CASE 111
	CHANGE_STATE = 母乳容量修正值
CASE 112
	CHANGE_STATE = 母乳价格奖励
CASE 113
	CHANGE_STATE = 极上乳压
CASE 120
	CHANGE_STATE = 胸围大小+1
CASE 121
	CHANGE_STATE = 胸围大小-1
ENDSELECT

;SELF_CHARA_MAKE_RANDOMが有効かどうかで呼ぶ関数変更
IF SELF_CHARA_MAKE_RANDOM
	CALL SELF_CHARA_MAKE_APPEARAINCE_INPUT_SHUFFLE(CHANGE_STATE)
ELSE
	CALL SELF_CHARA_MAKE_APPEARAINCE_INPUT_MANUAL(CHANGE_STATE)
ENDIF






