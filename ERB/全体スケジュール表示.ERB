
;スケジュール
@ALL_SCHEDULE_PRINT

;自室にいれば表示　などの処理
CALL SCHEDULE_PRINT_YOU
CALL SCHEDULE_PRINT_FAVORITE
CALL SCHEDULE_PRINT_PLACE("自室")
CALL SCHEDULE_PRINT_PLACE("奴隶寮")
CALL SCHEDULE_PRINT_PLACE("家畜小屋")
CALL SCHEDULE_PRINT_COWSHED
CALL SCHEDULE_PRINT_VORE

;標的判定を変更した
CALL SCHEDULE_PRINT_CHASE_SLAVE
DRAWLINE



;スケジュール表示共通
@PRINT_MAIN_SCHEDULE

PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
CALL PRINT_POST_C

;表示切り替えフラグを追加
CALL TABLE_STATUS("主要")
PRINTL



;あなた
@SCHEDULE_PRINT_YOU
#DIMS PLACE

;あなたが外出済みかどうかで表記変更
IF FLAG:已外出
	PLACE = 《 外出中 》
ELSE
	PLACE = 《 事务所 》
ENDIF
PRINTFORML %PLACE,20%
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF !GROUPMATCH(CSTR:住处,"事务所","行动完毕")
		CONTINUE
	CALL PRINT_MAIN_SCHEDULE
NEXT
PRINTL



;お気に入りの優先表示
@SCHEDULE_PRINT_FAVORITE
#DIM CHARA_COUNT
#DIMS PLACE

;お気に入り探して0人だとおわり
CHARA_COUNT = SUMCARRAY(CFLAG:收藏夹)
SIF !CHARA_COUNT
	RETURN
PLACE = 《 收藏夹 》

;FLAG:メイン／折りたたみBITのBITを取得して番号出したり折りたたみONOFFする
BIT_REF = 0
PRINTFORM %PLACE,20%：{CHARA_COUNT,3}人 
PRINTFORML [{30 +BIT_REF,3}] \@ GETBIT(FLAG:主要／折叠BIT,BIT_REF) ? 隐藏 # 显示 \@
SIF GETBIT(FLAG:主要／折叠BIT,BIT_REF)
	RETURN
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF !CFLAG:收藏夹 || (FLAG:主要／奴隶隐藏 && CFLAG:表示OFF／主要画面)
		CONTINUE
	CALL PRINT_MAIN_SCHEDULE
NEXT
PRINTL



;場所表示共通
@SCHEDULE_PRINT_PLACE(ARGS)
#DIM CHARA_COUNT
#DIMS PLACE,2

CHARA_COUNT = CMATCH(CSTR:住处,ARGS)
SIF !CHARA_COUNT
	RETURN
PLACE:0 = 《 %ARGS% 》
PRINTFORM %PLACE:0,20%：{CHARA_COUNT,3}

;ヒト扱いするか
IF GROUPMATCH(ARGS,"自室","奴隶寮")
	PRINT 人 
ELSE
	PRINT 匹 
ENDIF

;場所でBIT_REF変更
SELECTCASE ARGS
CASE "自室"
	BIT_REF = 1
CASE "奴隶寮"
	BIT_REF = 2
CASE "家畜小屋"
	BIT_REF = 3
ENDSELECT
PRINTFORML [{30 +BIT_REF,3}] \@ GETBIT(FLAG:主要／折叠BIT,BIT_REF) ? 隐藏 # 显示 \@
SIF GETBIT(FLAG:主要／折叠BIT,BIT_REF)
	RETURN
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:住处 != ARGS || CFLAG:收藏夹 || (FLAG:主要／奴隶隐藏 && CFLAG:表示OFF／主要画面)
		CONTINUE
	CALL PRINT_MAIN_SCHEDULE
NEXT
PRINTL



;牛舎
@SCHEDULE_PRINT_COWSHED
#DIM CHARA_COUNT
#DIMS PLACE

;牛舎建ててなければ帰る
SIF !ITEM:牛舍
	RETURN
CHARA_COUNT = CMATCH(CSTR:住处,"牛舍")
PLACE = 《 牛舍 》
BIT_REF = 4
PRINTFORM %PLACE,20%：{CHARA_COUNT,3}匹 
PRINTFORML [{30 +BIT_REF,3}] \@ GETBIT(FLAG:主要／折叠BIT,BIT_REF) ? 隐藏 # 显示 \@
SIF GETBIT(FLAG:主要／折叠BIT,BIT_REF)
	RETURN
FOR COWSHED_NUM,1,11
	;FLAG:第1牛舎増築段階→500
	FLAG_REF = 490
	COWSHED_CAPACITY = FLAG:(FLAG_REF +COWSHED_NUM *10) *10
	SIF !COWSHED_CAPACITY
		BREAK
	
	;FLAG:第1牛舎家畜頭数→502
	FLAG_REF:1 = 492
	
		;一応ここでも揃える処理書いておく：エラー出る場合使おう
		;FLAG:(FLAG_REF:1 +COWSHED_NUM *10) = CMATCH(CFLAG:牛舎番号,COWSHED_NUM)
	COWSHED_SLAVE = FLAG:(FLAG_REF:1 +COWSHED_NUM *10)
	PRINTFORML [{19 +COWSHED_NUM,3}] %COWSHED_NAME:COWSHED_NUM,20%：{COWSHED_SLAVE,3}／{COWSHED_CAPACITY,3}匹 
NEXT
PRINTL



;体内凌辱中
@SCHEDULE_PRINT_VORE
#DIM CHARA_COUNT
#DIMS PLACE

;そもそも体内凌辱未習得なら帰る
SIF !ITEM:体内凌辱
	RETURN
CHARA_COUNT = CMATCH(CSTR:住处,"体内")
SIF !CHARA_COUNT
	RETURN
PLACE = 《 %CALLNAME:0%的体内 》
BIT_REF = 5

;上限人数の表示
PRINTFORM %PLACE,20%：{CHARA_COUNT,3}／{ITEM:体内凌辱 +ITEM:体内容量増加}匹 
PRINTFORML [{30 +BIT_REF,3}] \@ GETBIT(FLAG:主要／折叠BIT,BIT_REF) ? 隐藏 # 显示 \@
SIF GETBIT(FLAG:主要／折叠BIT,BIT_REF)
	RETURN
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:住处 != "体内" || CFLAG:收藏夹 || (FLAG:主要／奴隶隐藏 && CFLAG:表示OFF／主要画面)
		CONTINUE
	CALL PRINT_MAIN_SCHEDULE
NEXT
PRINTL



;追跡中
@SCHEDULE_PRINT_CHASE_SLAVE
#DIMS PLACE

CALL CHASE_SLAVE_CHECK

;いないなら帰る
SIF !FLAG:追踪中人数
	RETURN
PLACE = 《 追踪中 》
BIT_REF = 9
PRINTFORM %PLACE,20%：{FLAG:追踪中人数,3}匹 
PRINTFORML [{30 +BIT_REF,3}] \@ GETBIT(FLAG:主要／折叠BIT,BIT_REF) ? 隐藏 # 显示 \@
SIF GETBIT(FLAG:主要／折叠BIT,BIT_REF)
	RETURN
CALL PRINT_CHASE_SLAVE



