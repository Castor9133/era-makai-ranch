
;拘束選択肢
;ARGS→来た場所
@BIND_CHOICE(ARGS)
#DIM DYNAMIC SET
#DIM CHOISE_REF

DEFAULT_SET = SET
PRINTL

;選択肢に+する数値
CHOISE_REF = 0
SELECTCASE ARGS
CASE "个人设置"
	CHOISE_REF = 1
	PRINTL [ 0] 遵循整体配置（默认）。

;特に何もない
CASE "开始时选择","调教中","全局设置"
ENDSELECT

;拘束中なら解除
IF TFLAG:拘束BIT
	PRINTFORML [{0 +CHOISE_REF,2}] 解除拘束
ELSE
	PRINTFORM [{0 +CHOISE_REF,2}] 不拘束
	SIF ARGS == "全局设置"
		PRINT （默认）
	PRINTL
ENDIF

;STR:拘束中→3930
STR_REF = 3930
FOR LOCAL,0,20
	SIF STR:(STR_REF +LOCAL) == ""
		CONTINUE
	
	;拘束必要アイテム参照
	CALL BIND_NEED_ITEM(LOCAL)
	
	;必要アイテム所持か必要ないなら選択肢
	IF NEED_ITEM_ID && !ITEM:NEED_ITEM_ID
		;必要アイテム番号がNEED_ITEM_ID:0,1に入ってる
		CALL PRINT_WORD_COLOR,@"<{LOCAL +1 +CHOISE_REF,2}> %RESULTS,20,LEFT%","灰"
		IF !NEED_ITEM_ID:1
			PRINTFORML ：＜%ITEMNAME:NEED_ITEM_ID%＞必要
		ELSE
			PRINTFORML ：＜%ITEMNAME:NEED_ITEM_ID%＞・＜%ITEMNAME:(NEED_ITEM_ID:1)%＞必要
		ENDIF
	ELSEIF NEED_ITEM_ID:1 && !ITEM:(NEED_ITEM_ID:1)
		CALL PRINT_WORD_COLOR,@"<{LOCAL +1 +CHOISE_REF,2}> %RESULTS,20,LEFT%","灰"
		PRINTFORML ：＜%ITEMNAME:NEED_ITEM_ID%＞・＜%ITEMNAME:(NEED_ITEM_ID:1)%＞必要
	ELSE
		;三角木馬の場合はＣＶの判定
		IF RESULTS == "三角木马拘束"
			IF TFLAG:Ｃ装备 || TFLAG:Ｖ装备
				CALL PRINTL_WORD_COLOR,@"　装备在%SAVESTR:标识／阴蒂%或%SAVESTR:标识／膣%上时不可用","灰"
				CONTINUE
			ELSEIF ARGS != "全局设置" && TALENT:处女结界
				CALL PRINTL_WORD_COLOR,@"　【处女结界】不可","灰"
				CONTINUE
			ENDIF
		ENDIF
		PRINTFORML [{LOCAL +1 +CHOISE_REF,2}] %RESULTS%
	ENDIF
NEXT
PRINTL

;開始時はデフォルト設定も入れる
IF ARGS == "开始时选择"
	PRINT [90] 设置此角色的默认值
	CALL PRINT_CHECKBOX(SET,1)
	PRINTL [98] 提示
ELSE
	PRINTL [98] 提示
	PRINTL [99] 取消
ENDIF
BINPUT
SELECTCASE RESULT
CASE 90
	;デフォルト設定の場合RESTART
	INVERTBIT SET,0
	RESTART
CASE 98
	CALL BROWSE_HINT("拘束")
	RESTART
CASE 99
	RETURN -1
ENDSELECT
RETURN RESULT


