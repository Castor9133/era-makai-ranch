
;搾乳メッセージ
@TRAIN_LACTATION_MESSAGE

SIF !TFLAG:调教中 && !TFLAG:日程外Ｈ && !TFLAG:循环中消息显示
	RETURN
CALL TRAIN_LACTATION_ECSTASY_MESSAGE
CALL KOJO_PRINT("搾乳")



;おっぱい絶頂していれば追加地の文
@TRAIN_LACTATION_ECSTASY_MESSAGE
#DIM HEART_NUM

SIF !NOWEX:Ｂ绝顶 && !NOWEX:Ｎ绝顶
	RETURN

;関数呼ばんでもここでピンクにした
SETCOLOR 0xFF70FF

;Ｖ挿入中+Ｖ絶頂
IF GETBIT(＃Ｐ使用／Ｖ插入＃) && NOWEX:Ｖ绝顶
	SELECTCASE RAND:3
	CASE 0
		PRINTFORM %CALLNAME%的%SLANG_V()%每次被插入时，%SLANG_B()%的%SLANG_MILK()%就会流出……
	CASE 1
		PRINTFORM %CALLNAME%的%SLANG_V()%每次绝顶时%SLANG_MILK()%都会喷涌而出，迎来更大的绝顶
	CASE 2
		PRINTFORM %CALLNAME%的%SLANG_V()%每次被插入时，都会因为喷出%SLANG_MILK()%而全身继续绝顶…
	ENDSELECT

;アナル
ELSEIF GETBIT(＃Ｐ使用／Ａ插入＃) && NOWEX:Ａ绝顶
	SELECTCASE RAND:3
	CASE 0
		PRINTFORM %CALLNAME%的%SLANG_A()%每次被插入时，%SLANG_B()%的%SLANG_MILK()%就会流出…
	CASE 1
		PRINTFORM %CALLNAME%的%SLANG_A()%每次绝顶时%SLANG_MILK()%都会喷涌而出，迎来更大的绝顶…
	CASE 2
		PRINTFORM %CALLNAME%的%SLANG_A()%每次被插入时，都会因为喷出%SLANG_MILK()%而全身继续绝顶…
	ENDSELECT

;触手搾乳中
ELSEIF TFLAG:搾乳触手
	SELECTCASE RAND:3
	CASE 0
		PRINTFORM 每次%CALLNAME%被触手榨乳绝顶时，%SLANG_B()%的%SLANG_MILK()%就会被吸出…
	CASE 1
		PRINTFORM %CALLNAME%的%SLANG_B()%被触手榨取着，%SLANG_MILK()%不断的喷涌而出…
	CASE 2
		PRINTFORM 仿佛是在期待触手吸着%SLANG_B()%那样%CALLNAME%不断喷出%SLANG_MILK()%…
	ENDSELECT

;乳吸い中
ELSEIF TFLAG:吸奶
	SELECTCASE RAND:3
	CASE 0
		PRINTFORM 每当%MILK_SUCK_PLAYER%咬住%CALLNAME%的%SLANG_N()%%SLANG_MILK()%都会流入口中…
	CASE 1
		PRINTFORM 每当%MILK_SUCK_PLAYER%咬住%CALLNAME%的%SLANG_N()%，%SLANG_MILK()%都会不断流出…
	CASE 2
		PRINTFORM %CALLNAME%的%SLANG_B()%仿佛期待着%MILK_SUCK_PLAYER%的吸取%SLANG_MILK()%不断喷涌而出…
	ENDSELECT

;搾乳器使用中
ELSEIF TFLAG:搾乳器
	SELECTCASE RAND:3
	CASE 0
		PRINTFORM %CALLNAME%的%SLANG_B()%被榨乳器榨乳%SLANG_MILK()%不断的喷出…
	CASE 1
		PRINTFORM %CALLNAME%%SLANG_B()%被搾乳器压榨，不断喷出%SLANG_MILK()%绝顶…
	CASE 2
		PRINTFORM %CALLNAME%的%SLANG_B()%无法忍受榨乳器的刺激喷出%SLANG_MILK()%…
	ENDSELECT

;その他
ELSE
	PRINTFORM %SLANG_B()%绝顶后%CALLNAME%的%SLANG_MILK()%不断的被喷出…
ENDIF
RESETCOLOR

;噴乳量1000ccごとにハート1つ追加（MAX5コ）
HEART_NUM = LIMIT(NOWEX:喷乳 /1000,0,4)
CALL HEARTCB(0xD02830,(1 +HEART_NUM))
PRINTL



;搾乳量表示
@PRINT_LACTATION_VOL

SIF !TFLAG:调教中 && !TFLAG:日程外Ｈ && !TFLAG:循环中消息显示
	RETURN
IF TFLAG:搾乳器 || TFLAG:搾乳触手 || TFLAG:烹调搾乳
	PRINTFORM %PRINT_MILKWORD(1)%{NOWEX:喷乳}%MILK_COUNTING()%搾乳 
ELSEIF TFLAG:吸奶
	PRINTFORM %PRINT_MILKWORD(1)%{NOWEX:喷乳}%MILK_COUNTING()%吸吮 
ELSE
	PRINTFORM %PRINT_MILKWORD(1)%{NOWEX:喷乳}%MILK_COUNTING()%喷乳 
ENDIF
CALL PRINT_LACTATION_EP_DRAIN_VOL
CALL PRINT_LACTATION_MP_DRAIN_VOL



;霊力吸収時メッセージ
@PRINT_LACTATION_EP_DRAIN_VOL

SIF !SOURCE:灵力吸收量
	RETURN
IF TFLAG:搾乳触手 || TFLAG:吸奶
	CALL PRINT_WORD_COLOR("【吸收】","桃")
ELSE
	CALL PRINT_WORD_COLOR("【抽出】","桃")
ENDIF
PRINTFORM 灵力-{SOURCE:灵力吸收量} 



;魔力吸収時メッセージ
@PRINT_LACTATION_MP_DRAIN_VOL

SIF !SOURCE:魔力吸收量
	RETURN
IF TFLAG:搾乳触手 || TFLAG:吸奶
	CALL PRINT_WORD_COLOR("【吸收】","桃")
ELSEIF TEQUIP:小型灵力抽出装置
	CALL PRINT_WORD_COLOR("【抽出】","桃")
ENDIF
PRINTFORM 魔力-{SOURCE:魔力吸收量} 
IF (TFLAG:抽出中 || TEQUIP:小型灵力抽出装置) && FLAG:储存魔力上限值 && MONEY:储存魔力 < FLAG:储存魔力上限值
	PRINTFORM 魔力储存+%VALUE_DIGIT(SOURCE:魔力吸收量)% 
	SIF MONEY:储存魔力 == FLAG:储存魔力上限值
		PRINT [魔力储存量上限] 
ENDIF





