
;USERCOMから飛ばす用
;拘束入り口
@TRAIN_BIND_COMMON

;ペニス、搾乳器、搾乳触手、ほか触手使用中→おわり
SIF TFLAG:Ｐ使用BIT || TFLAG:搾乳器 || MATCH(TEQUIP,1,100,200)
	RETURN

;拘束状態の表示
;STR:拘束中→3930
STR_REF = 3930
EXIST = 0
PRINT 当前：

;LOCALのBIT番号がONになってるかを見る
FOR LOCAL,0,20
	SIF !GETBIT(TFLAG:拘束BIT,LOCAL)
		CONTINUE
	PRINTFORML 【%STR:(STR_REF +LOCAL)%拘束】
	EXIST ++
	BREAK
NEXT
SIF !EXIST
	PRINTL ＜没有拘束＞
CALL BIND_CHOICE("调教中")
CALL TRAIN_BIND_RUN(RESULT)

