
;ペットのごはん選択
@AGRI_COOP_PET_FOOD_SELECT

;ペットがいる部分を選択肢表示
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP
PRINTL 　《 宠物食品 》

;ITEM:堕天馬→100　選択肢を1から始めるので-1
ITEM_REF = 100 -1
PRINTFORML [ 0] 魔界乳牛：%PRINT_PET_FOOD("魔界乳牛")%
PRINTL
FOR LOCAL,1,21
	ANIMAL = %ITEMNAME:(ITEM_REF +LOCAL)%
	SIF ANIMAL == ""
		CONTINUE
	IF ITEM:ANIMAL
		PET_NAME = %PET_NAME_REF(ANIMAL)%
		PRINTFORMLC [{LOCAL,2}] %ANIMAL%／%PET_NAME%
		PRINTFORML ：%PRINT_PET_FOOD(ANIMAL)%
	ELSE
		CALL PRINTL_WORD_COLOR,@"　%ANIMAL%","灰"
	ENDIF
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL PET_FOOD_SELECT_INPUT("魔界乳牛")
CASE 1 TO 21
	ANIMAL = %ITEMNAME:(ITEM_REF +RESULT)%
	PET_NAME = %PET_NAME_REF(ANIMAL)%
	SIF ANIMAL != "" && ITEM:ANIMAL
		CALL PET_FOOD_SELECT_INPUT(ANIMAL,PET_NAME)
CASE 98
	CALL BROWSE_HINT("宠物食品")
CASE 99
	RETURN
ENDSELECT
RESTART



;ペットのごはん種類
;ARGS→動物名
@PRINT_PET_FOOD(ARGS)
#FUNCTIONS

FLAG_NAME = 食物种类／%ARGS%
SELECTCASE FLAG:FLAG_NAME
CASE 0
	RETURNF "一般综合食品"
CASE 1
	RETURNF "健康意识"
CASE 2
	RETURNF "营养丰富"
CASE 3
	RETURNF "高级平衡食品"
ENDSELECT



;ごはん選択
;ARGS→動物名
;ARGS:1→ペット名
@PET_FOOD_SELECT_INPUT(ARGS,ARGS:1)

FLAG_NAME = 食物种类／%ARGS%
IF ARGS:1 == ""
	PRINTFORML 请选择给予%ARGS%的食物类型。
ELSE
	PRINTFORML 请选择给予%ARGS:1%的食物类型。
ENDIF
PRINTL [ 0] 一般综合食品
PRINTL [ 1] 健康意识
PRINTL [ 2] 营养丰富
PRINTL [ 3] 高级平衡食品
INPUT
SIF RESULT >= 0 && RESULT <= 3
	FLAG:FLAG_NAME = RESULT






