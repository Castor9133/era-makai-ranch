
;名前による毛並みと性別補正
@NAMING_PET_NAME_FIX

SELECTCASE ANIMAL
CASE "堕落天马"
	CALL NAMING_PET_NAME_FIX_HORSE
CASE "双头犬"
	CALL NAMING_PET_NAME_FIX_DOG
CASE "魔界仓鼠"
	CALL NAMING_PET_NAME_FIX_HAMSTER
ENDSELECT



;ｳﾏﾁｬﾝ
;候補に上がってるやつ以外はキリがないのでやめ
@NAMING_PET_NAME_FIX_HORSE

SELECTCASE PET_NAME
CASE "施奈德","健太"
	PET_GENDER = 1
CASE "赤兔马"
	PET_COAT = 赤毛
CASE "松树"
	PET_COAT = 鹿毛
CASE "古尔法克西"
	PET_COAT = 金色
CASE "牧场王"
	PET_COAT = 白马
	PET_GENDER = 1
CASE "玛卡玛卡"
	PET_COAT = 黑鹿毛
	PET_GENDER = 0
CASE "奥达西"
	PET_COAT = 白马
	PET_GENDER = 0
CASE "黑王号","奶油"
	PET_COAT = 黑毛
	PET_GENDER = 1
CASE "糖果科城"
	PET_COAT = 鹿毛
	PET_GENDER = 0
CASE "叶波纳"
	PET_COAT = 尾花栗毛
	PET_GENDER = 0
ENDSELECT



