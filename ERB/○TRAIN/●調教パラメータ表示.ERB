SIF TARGET_PENIS
	PRINTFORM Ｐ：{ABL:阴茎尺寸,3}mm 



;Ｖサイズ表示
@PRINT_VSIZE
#DIM SIZE_DIFF

IF TALENT:男性
	PRINT 　　　　　　　　　　　
ELSE
	;ちんぽあるかチェック済み
	SIZE_DIFF = ABL:0:阴茎尺寸 - ABL:Ｖ尺寸 - ABL:Ｖ扩张
	{
	SIF TARGET && (TFLAG:调教中 || TFLAG:日程外Ｈ) && 
	(SIZE_DIFF > 20 || (ABL:0:阴茎尺寸 - ABL:初始值／Ｖ尺寸 * 3 > 0 && SIZE_DIFF > 0)) && PLAYER_PENIS
	}
		SETCOLOR BARCOLORSET("浅红色")
	IF ABL:Ｖ扩张
		PRINTFORM Ｖ：{ABL:Ｖ尺寸,3}～{ABL:Ｖ尺寸 + ABL:Ｖ扩张,3}mm　
	ELSE
		PRINTFORM Ｖ：{ABL:Ｖ尺寸,3}mm　　 　
	ENDIF
	RESETCOLOR
ENDIF



;Ａのサイズ表示
@PRINT_ASIZE
#DIM SIZE_DIFF

SIZE_DIFF = ABL:0:阴茎尺寸 - ABL:Ａ尺寸 - ABL:Ａ扩张
{
SIF TARGET && (TFLAG:调教中 || TFLAG:日程外Ｈ) && 
(SIZE_DIFF > 20 || (ABL:0:阴茎尺寸 - ABL:初始值／Ａ尺寸 * 6 > 0 && SIZE_DIFF > 0)) && PLAYER_PENIS
}
	SETCOLOR BARCOLORSET("浅红色")
IF ABL:Ａ扩张
	PRINTFORM Ａ：{ABL:Ａ尺寸,3}～{ABL:Ａ尺寸 + ABL:Ａ扩张,3}mm　
ELSE
	PRINTFORM Ａ：{ABL:Ａ尺寸,3}mm　
ENDIF
RESETCOLOR



