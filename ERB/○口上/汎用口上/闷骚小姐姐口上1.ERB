; ======================================
; 泛用口上（性格：闷骚小姐姐）
; 表面一本正经、措辞偏书面，带点「念过书」的较真；爱讲边界、赌气、羞恼参半，但不堆程序员/论文黑话；对性好奇、俏皮、闷骚。
; 陷落前抗拒拒绝；陷落后逐渐把各类调教当成「和你相处的一环」。
; 口上識別名：闷骚小姐姐1（Str.csv 6121）
; 许可证：CC BY-NC
; ======================================

@KOJO_GENERAL_INDEX_闷骚小姐姐1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

IF TFLAG:Ｍ装备
	CALL KOJO_GENERAL_MOUTH_SHACKLE_1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
	RETURN
ELSEIF CFLAG:崩坏 && !CFLAG:洗脑
	IF GROUPMATCH(ARGS:0,"例文")
	ELSEIF GROUPMATCH(ARGS:1,"洗脑触手","崩坏")
	ELSE
		IF NOWEX:总绝顶
			CALL MESSAGE_BOX,@"「……脑子……全白了……♥ ……什么理都……说不圆……♥」"
			CALL MESSAGE_BOX,@"「……别看……♥ ……别像看书一样盯着我……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……我……还……还撑得住吗……」"
		ENDIF
		RETURN
	ENDIF
ENDIF

SELECTCASE ARGS:0
CASE "身体"
	CALL KOJO_GENERAL_闷骚小姐姐1_EXCRETION_BODY(ARGS:1, ARGS:2)
	RETURN
CASE "例文"
	CALL MESSAGE_BOX,@"「【闷骚小姐姐1】已设置。\n地文／口上基调：书卷气、嘴硬、闷骚——爱用书面词讲人之常情：边界、赌气、害羞、求你先问一句；偶有较真，但不跳出生活语境玩术语梗。\n陷落前：拒绝时冷脸讲道理，像跟人谈判条款。\n陷落后：仍要面子，却肯软下来陪绑你，嘴上损你、身体诚实。」"

CASE "身体事件"
	SELECTCASE ARGS:1
	CASE "产後初调"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……产后复训？行，我把静养期记录带来了——你别装没看见。……过来，让我先量你脉搏，再谈别的。」"
		ELSE
			CALL MESSAGE_BOX,@"「……从医学伦理上讲，产后立刻高强度调教需要充分告知风险。……你现在的说明，不够。」"
		ENDIF
	CASE "妊娠性事初回"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……验出来了。……别瞪眼，我不是在念报告——我是在跟你说清楚：我们有份了。」"
		ELSE
			CALL MESSAGE_BOX,@"「……我怀孕了。……请你用成年人方式回答：你打算负哪一段责任？」"
		ENDIF
	CASE "妊娠性事"
		CALL MESSAGE_BOX,@"「……身子沉得厉害……我清楚……不敢跟%MASTER_CALL()%讨价还价……只求……若要继续……给我一点缓冲……」"
	CASE "妊娠调教谨慎开场"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……怀着还来……我嘴上会抱怨，可我不会骗自己——我会来，是因为信你不会把我当成『只来这一次』就算完的那种人。」"
		ELSE
			CALL MESSAGE_BOX,@"「……为什么非得今天……我心里打了一万次补丁……嘴上只敢说……好赖皮……可%MASTER_CALL()%开口了……我不敢拒……只敢……偷偷记一笔账……」"
		ENDIF
	ENDSELECT

CASE "调教命令"
	CALL KOJO_GENERAL_闷骚小姐姐1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

CASE "绝顶"
	SIF TEQUIP:深喉
		CALL MESSAGE_BOX,@"「……喉咙……透不过气……♥ ……这、这谁预习过啊……♥」"
	IF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「……脑子……清不掉了……♥ ……全是你……♥」"
		CALL MESSAGE_BOX,@"「……下次……换你丢脸……♥ ……说着玩的……别停……♥」"
		CALL MESSAGE_BOX,@"「……乱糟糟的……♥ ……可我看见你……就全都……对上了……♥」"
	ELSEIF ＃陷落状态／屈服以上＃
		CALL MESSAGE_BOX,@"「……我认输……♥ ……别再让我论证了……♥」"
	ELSE
		CALL MESSAGE_BOX,@"「……这、这不讲理……♥ ……身体……别先投降啊……！」"
	ENDIF

CASE "射精"
	IF SOURCE:膣内射精经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……内射……♥ ……行，我收下了……♥ ……记在你账上……以后慢慢还……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……里面不行——！……你、你这是单方做主……！」"
		ENDIF
	ELSEIF SOURCE:尻穴射精经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……后面也……♥ ……好，这笔账……我认了……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……后面……不许。……理由要我说满一整页吗。」"
		ENDIF
	ELSEIF SOURCE:精饮经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……咽下去了……♥ ……这种事……烂在肚子里就好……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……这不在……说好的范围里……！」"
		ENDIF
	ELSEIF TEQUIP:手淫
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……弄在手上了……♥ ……行，我帮你收拾……♥ ……别乱甩……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……手也要先问过我……！」"
		ENDIF
	ELSE
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……射了……♥ ……我接着……♥ ……比我想的……过分……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……你……自己收场……！」"
		ENDIF
	ENDIF

CASE "访问"
	SELECTCASE ARGS:1
	CASE "入口"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……进。茶在桌上——先喝，再说话。……我可不想照顾一个低血糖的笨蛋。」"
		ELSE
			CALL MESSAGE_BOX,@"「……有事？……三句话。多了请下次再说。」"
		ENDIF
	CASE "摸头"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……摸头算奖励还是惩罚？……算了，我允许你把我当一会儿猫。」"
		ELSE
			CALL MESSAGE_BOX,@"「……手。……我在忙，别闹。」"
		ENDIF
	CASE "接吻"
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……吻可以。……但我要声明：这是我点头的事，别想赖成我欠你。」"
		ELSE
			CALL MESSAGE_BOX,@"「……不行。……除非你先答我：为什么要吻。」"
		ENDIF
	CASE "排泄尿急"
		CALL MESSAGE_BOX,@"「……别乱想。……就是憋急了……不是冲你撒娇。」"
		CALL MESSAGE_BOX,@"「……洗手间。……现在。」"
	CASE "侍奉口爆终了"
		SELECTCASE ARGS:2
		CASE "忍住"
			CALL MESSAGE_BOX,@"「……行，忍住了。……你那头……还在跳……我看见了。」"
		CASE "咽下"
			CALL MESSAGE_BOX,@"「……全咽了……♥ ……别问好不好喝……我不答。」"
		CASEELSE
		ENDSELECT
	CASE "揉胸轻抚"
		CALL MESSAGE_BOX,@"「……轻点揉……我受得住，不代表你可以肆无忌惮。」"
		CALL MESSAGE_BOX,@"「……别看别的地方……我会害羞。」"
	CASE "拥抱嗅闻"
		CALL MESSAGE_BOX,@"「……抱就抱……别像闻标本。」"
		CALL MESSAGE_BOX,@"「……心跳……又要怪到你头上。」"
	CASEELSE
	ENDSELECT

CASE "搾乳"
	SELECTCASE ARGS:1
	CASE "牧场口便器"
		SIF !FLAG:牧场口便器玩法启用
			RETURN
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……把喉咙也写进规程里……行，我签你那份歪理……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……牧场把人用到这份上……正常吗。」"
		ENDIF
		RETURN
	ENDSELECT
	IF SOURCE:母乳漏出
		CALL MESSAGE_BOX,@"「……漏了点……别盯着说……我会想钻地缝……」"
		RETURN
	ENDIF
	IF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「……挤着挤着……身子发软……♥ ……你别把我当一次性的……♥」"
	ELSE
		CALL MESSAGE_BOX,@"「……胸口的难受……别说成『顺便』两个字……」"
	ENDIF

CASE "战斗"
	SELECTCASE ARGS:1
	CASE "攻击"
		CALL MESSAGE_BOX,@"「……让开。……我来。」"
		CALL MESSAGE_BOX,@"「……站稳了再打。」"
	CASE "被击中"
		CALL MESSAGE_BOX,@"「……还……还扛得住……」"
		CALL MESSAGE_BOX,@"「……别停……我还能站。」"
	CASEELSE
	ENDSELECT

CASE "事件"
	SELECTCASE ARGS:1
	CASE "牧场绝顶管理"
		SIF !FLAG:牧场口便器玩法启用 || !FLAG:牧场绝顶管理启用
			RETURN
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……整场不给痛快……腿都抖成那样了……♥ ……你是故意的……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……吊着人不放……我要记仇……」"
		ENDIF
	CASEELSE
	ENDSELECT

CASEELSE
ENDSELECT
RETURN


@KOJO_GENERAL_闷骚小姐姐1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
CALL KOJO_GENERAL_闷骚小姐姐口上1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
RETURN


;--------------------------------------------
; 排泄羞耻／身体（嘴硬破功、羞恼参半）
;--------------------------------------------
@KOJO_GENERAL_闷骚小姐姐1_EXCRETION_BODY(ARGS:0, ARGS:1)
SELECTCASE ARGS:0
CASE "排泄事故"
	SELECTCASE ARGS:1
	CASE "肠"
		CALL MESSAGE_BOX,@"「……别再看了……！……算我求你……今天这事别提……！」"
	CASE "尿"
		CALL MESSAGE_BOX,@"「……别看……！……我、我脸上都烧穿了……！」"
	CASEELSE
		CALL MESSAGE_BOX,@"「……」"
	ENDSELECT
CASE "放尿主动"
	IF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「……好……当着你的面……连羞耻也认了……♥」"
			CALL MESSAGE_BOX,@"「……你看了就算了……♥ ……别拿去当笑话说……♥」"
	ELSE
		CALL MESSAGE_BOX,@"「……排尿也要你在旁边盯着？……你申请的动机……交代清楚。」"
	ENDIF
CASE "灌肠妊娠求饶"
	CALL MESSAGE_BOX,@"「……从胎儿安全角度——我请求中止灌肠。……这不是撒娇，是正式异议。」"
CASE "高蓄尿"
	CALL MESSAGE_BOX,@"「……膀胱胀得发疼……你再盯着我……我读秒都要读不下来了……」"
CASE "羞耻调教链"
	CALL MESSAGE_BOX,@"「……这条链子还在……我每一步都像被人盯着打分……」"
CASEELSE
ENDSELECT
RETURN 1
