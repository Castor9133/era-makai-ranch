
; 魔界居民台词：套用口上色后显示
; ARGS：说话者名；ARGS:1：台词正文
@RESIDENT_KOJO(ARGS,ARGS:1)

; 按说话者改色
CALL RESIDENT_KOJO_COLOR_REF(ARGS)
SIF !LINEISEMPTY()
	PRINTL

; 与上次发言者不同且非主角时，先打印名字
SIF RESIDENT_KOJO_BEFORE != ARGS && ARGS != "主人公"
	PRINTFORM %ARGS%
PRINTFORML 「%ARGS:1%」
RESETCOLOR

; 记录上次发言者
RESIDENT_KOJO_BEFORE = %ARGS%



; 按说话者设置显示色（ARGS=居民名）
@RESIDENT_KOJO_COLOR_REF(ARGS)

SELECTCASE ARGS
CASE "主人公"
	; 主角用主角口上色
	SETCOLOR CFLAG:0:颜色编码／口上

; 部分 NPC 无法用 FORM 取色，此处硬编码
CASE "尤金"
	SETCOLOR RESIDENT_KOJO_尤金
CASE "玛诺"
	SETCOLOR RESIDENT_KOJO_玛诺
CASE "福多"
	SETCOLOR RESIDENT_KOJO_福多
CASE "肯奇"
	SETCOLOR RESIDENT_KOJO_肯奇
CASE "塔尔特"
	SETCOLOR RESIDENT_KOJO_塔尔特
CASE "亚拉希"
	SETCOLOR RESIDENT_KOJO_亚拉希
CASE "信美"
	SETCOLOR RESIDENT_KOJO_信美
CASE "诺诺美"
	SETCOLOR RESIDENT_KOJO_诺诺美
CASE "泰拉"
	SETCOLOR RESIDENT_KOJO_泰拉
CASE "辉夜"
	SETCOLOR RESIDENT_KOJO_辉夜
CASE "戈罗"
	SETCOLOR RESIDENT_KOJO_戈罗
CASE "肖"
	SETCOLOR RESIDENT_KOJO_肖
CASE "辛西娅"
	SETCOLOR RESIDENT_KOJO_辛西娅
CASE "普尼耶"
	SETCOLOR RESIDENT_KOJO_普尼耶
CASE "戈兹"
	SETCOLOR RESIDENT_KOJO_戈兹
CASE "右京"
	SETCOLOR RESIDENT_KOJO_右京
CASE "雏"
	SETCOLOR RESIDENT_KOJO_雏
CASE "库雷塔"
	SETCOLOR RESIDENT_KOJO_库雷塔
CASE "松平"
	SETCOLOR RESIDENT_KOJO_松平
ENDSELECT

; 0 则回到默认色
GETCOLOR
SIF !RESULT
	RESETCOLOR




