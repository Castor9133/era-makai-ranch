
;食事当番指定
@DINNER_DUTY_SELECT
#DIM COOK_JUDGE,2

;業務可能判定更新
CALL SCHEDULE_POSSIBLE

;曜日予定を見る
;FLAG:食事当番基準／月→300
;FLAG:食事当番ID・ABL／月→310
COOK_JUDGE = FLAG:(300 +DAY:曜日)
COOK_JUDGE:1 = FLAG:(310 +DAY:曜日)
SELECTCASE COOK_JUDGE
CASE 0
	;適当に済ます
	RETURN -1

CASE 1
	;選択
	CALL DINNER_DUTY_SELECT_TODAY
	RETURN RESULT

CASE 2
	;料理Lvが指定以上のキャラからランダム
	CALL DINNER_CHEF_RANDOM(COOK_JUDGE:1)
	RETURN RESULT
	
CASEELSE
	;指定IDのキャラ
	;見つからないなら-1、業務不可状態か牛舎にいるならダメ→その後に選ばせる
	FINDCHARA CFLAG:ID,COOK_JUDGE:1
	IF RESULT >= 0
		TARGET = RESULT
		IF CFLAG:牛舍号码
			CALL PRINT_WORD_COLOR,@"%CALLNAME%不能料理，因为在牛舍里。","黄"
		ELSEIF !CFLAG:可以工作
			CALL PRINT_WORD_COLOR,@"%CALLNAME%处于事务不能状态。","黄"
		
		;料理可能ならここ
		ELSE
			RETURN RESULT
		ENDIF
		FORCEWAIT
	ENDIF
	CALL DINNER_DUTY_SELECT_TODAY
	RETURN RESULT
ENDSELECT



;料理Lvが指定以上のキャラからランダム
;ARG→FLAG:食事当番ID・ABL／曜日
@DINNER_CHEF_RANDOM(ARG)
#DIM NEED_ABL
#DIM COOK_ABL

;要求値を入れる（書き換えたりするので）
NEED_ABL = ARG

;業務可能なキャラのMAX料理Lv取得
COOK_ABL = 0
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF !CFLAG:可以工作 || CFLAG:牛舍号码 || COOK_ABL >= ABL:料理
		CONTINUE
	COOK_ABL = ABL:料理
NEXT

;MAXが足りない場合は必要値を引き下げ
SIF NEED_ABL > COOK_ABL
	NEED_ABL = COOK_ABL

;必要値を満たす業務可能キャラをBOX入れ
VARSET RANDOM_NO_BOX
VARSET BOX_COUNT
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF !CFLAG:可以工作 || NEED_ABL > ABL:料理
		CONTINUE
	RANDOM_NO_BOX:BOX_COUNT = TARGET
	BOX_COUNT ++
NEXT

;一応バグ対策
IF !BOX_COUNT
	PRINTW ！获取料理ABL时出现错误
	RETURN -1
ENDIF
RETURN RANDOM_NO_BOX:RAND(BOX_COUNT)



;手動選択
@DINNER_DUTY_SELECT_TODAY
#DIM DYNAMIC PAGE

;スキップ状態ならFORCEWAIT
SIF MESSKIP()
	FORCEWAIT

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTL 请选择晚餐值班的角色。
PRINTFORML 制作量：{DISH_QUANTITY}人前　%SAVESTR:标识／母乳%制作料理所需量：%TOSTR(DISH_NEED_MILK,"#,0")%%MILK_COUNTING()% 
DRAWLINE
FOR TARGET_COUNT,0,20
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	
	;牛舎→NG　未捕獲→NG　体内→NG　業務不可→NG
	{
	IF CFLAG:追踪对象 || CSTR:住处 == "体内" || !CFLAG:可以工作 
	|| CFLAG:牛舍号码 || (!CFLAG:可以调教 && !TALENT:业主)
	}
		CALL DINNER_DUTY_SELECT_IMPOSSIBLE
		CONTINUE
	ENDIF
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("料理值班")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  8] 更改显示项目
PRINTLC [ 98] 提示
PRINTL [ 99] 随便安排。
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 98
	CALL BROWSE_HINT("料理")
CASE 99
	RETURN -1
CASEELSE
	TARGET = RESULT -100
	RETURN TARGET
ENDSELECT
RESTART



;ダメな理由
@DINNER_DUTY_SELECT_IMPOSSIBLE

SETCOLOR 0x606060
PRINTFORM %CALLNAME_DIGIT(4)%：
IF CFLAG:追踪对象
	PRINT 未捕获
ELSEIF CSTR:住处 == "体内"
	PRINT 体内
ELSEIF CFLAG:牛舍号码
	PRINT 牛舍
ELSEIF !BASE:体力
	PRINT HP0
ELSEIF !CFLAG:可以工作
	PRINT 无事务能力
ELSEIF !CFLAG:可以调教
	PRINT 无法调教
ENDIF
PRINTL
RESETCOLOR



