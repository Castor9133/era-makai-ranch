
;事業提携先入り口
@BUISINESS_PARTNER

;FLAG:事業提携先奴隷数／ニンゲン搾乳牧場→740
;STR:ニンゲン搾乳牧場→8200
FLAG_REF = 740
STR_REF = 8200
CLEARLINE LINECOUNT
PRINTL 　《 合作伙伴列表 》
DRAWLINE
FOR LOCAL,0,10
	SIF FLAGNAME:(FLAG_REF +LOCAL) == ""
		CONTINUE
	PRINTFORML [{LOCAL,2}] %STR:(STR_REF +LOCAL),20%：奴隶{FLAG:(FLAG_REF +LOCAL)}只 
NEXT
CALL PRINTL_ALIGN(-10)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(1,"戻る")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 9
	CALL BUISINESS_PARTNER_SLAVE(RESULT)
CASE 98
	CALL BROWSE_HINT("合作伙伴")
CASE 99
	RETURN
ENDSELECT
RESTART



;選択後
;ARG→提携先
@BUISINESS_PARTNER_SLAVE(ARG)
#DIM MAX_SLAVE

CLEARLINE LINECOUNT

;今とりあえず汎用牧場だけなのでそこ用
MAX_SLAVE = 20 +FLAG:魔界等级／奶农业 *5

;送った結果MAX以上にならないように
FLAG:(FLAG_REF +ARG) = LIMIT(FLAG:(FLAG_REF +ARG),0,MAX_SLAVE)
PRINTFORML %STR:(STR_REF +ARG)%：奴隶{FLAG:(FLAG_REF +ARG)}／{MAX_SLAVE}只（当前数量／最大数量）
CALL BUISINESS_PARTNER_REWORD(ARG)
DRAWLINE

;MAXでも送る＝奴隷削除はできる
PRINTL [ 0] 发送奴隶
CALL PRINTL_ALIGN(-10)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(0,"戻る")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL BUISINESS_PARTNER_SEND_SLAVE_SELECT(ARG)
CASE 99
	RETURN
ENDSELECT
RESTART



;提携事業の報酬
;ARG→提携先
@BUISINESS_PARTNER_REWORD(ARG)

PRINT 报酬：
SELECTCASE ARG
CASE 0
	PRINTFORML %VALUE_DIGIT(PARTNER_ALLSLAVE_REWORD)%G×奴隶数／日
ENDSELECT



;提携先に送る奴隷の選択
;ARG→提携先
@BUISINESS_PARTNER_SEND_SLAVE_SELECT(ARG)
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML %STR:(STR_REF +ARG)%要发送的奴隶请选择。
CALL PARTNER_SEND_SLAVE_TERM(ARG)
PRINTL
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	IF CFLAG:追踪对象
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：未捕获","灰"
		CONTINUE
	ELSEIF EQUIP:魔力枷锁
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：＜魔力枷锁＞适用中","灰"
		CONTINUE
	ELSEIF CSTR:住处 == "体内"
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：体内","灰"
		CONTINUE
	ELSEIF GROUPMATCH(CSTR:状态／主人公的孩子,"成长中","成长后")
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：爱女","灰"
		CONTINUE
	ENDIF
	
	;提携先による条件に合わない場合もダメ
	CALL PARTNER_SEND_SLAVE_TERM_CHECK(ARG)
	SIF RESULT
		CONTINUE
	
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("推迟合作伙伴")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  8] 更改显示项目
PRINTLC 　
PRINTL [ 99] 取消
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	TARGET = RESULT -100
	PRINTFORML %STR:(STR_REF +ARG)%为目的地，%CALLNAME%将被发送，确认吗？
	CALL ASK_YN
	SIF RESULT
		RETURN
	
	;ダブルチェック
	CALL PRINTL_WORD_COLOR("送出的奴隶将在数据上被删除，将无法再次遇见。是否确定？","黄")
	CALL ASK_YN
	SIF RESULT
		RETURN
	
	;口上もあるといいかもしれない　まだ
	PRINTFORMW %STR:(STR_REF +ARG)%为目的地，%CALLNAME%被送达了。
	FLAG:(FLAG_REF +ARG) ++
	CALL TARGET_CHARA_DELETE
	CALL SCHEDULE_ADJUST
ENDSELECT
RESTART



;送る条件
;ARG→提携先
@PARTNER_SEND_SLAVE_TERM(ARG)

PRINTL 能送出的奴隶：＜魔力枷锁＞取下完毕・＜体内凌辱＞没有进行（共通）
SELECTCASE ARG
CASE 0
	;他の条件なし
	PRINTL
ENDSELECT



;送る条件をTARGETごとにチェックしてダメならRETURN1
;ARG→提携先
@PARTNER_SEND_SLAVE_TERM_CHECK(ARG)

SELECTCASE ARG
CASE 0
	;他の条件なし
ENDSELECT





