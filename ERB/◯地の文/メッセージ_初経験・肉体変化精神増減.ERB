	CALL PRINTL_WORD_COLOR,@"%CALLNAME%因可以为%CALLNAME:0%献上初吻，而感到非常高兴…","桃"
	
ELSEIF (＃陷落状态／陷落以上＃ || TALENT:单纯) && !TALENT:贞操观念 && KISS_PLAYER == CALLNAME:0
	CALL PRINTL_WORD_COLOR,@"貌似%CALLNAME%对于为%CALLNAME:0%献上初吻没有反感…","桃"
ELSE
	IF TALENT:少女心
		CALL PRINTL_WORD_COLOR,@"%CALLNAME%的初吻被%KISS_PLAYER%夺走，流着绝望的眼泪…","桃"
	ELSE
		CALL PRINTL_WORD_COLOR,@"%CALLNAME%的初吻被%KISS_PLAYER%被夺走，流着悔恨的眼泪…","桃"
	ENDIF
ENDIF



