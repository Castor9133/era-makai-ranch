CASE "乳牛"
	CALL PRINT_WORD_COLOR,@"希望魔族的各位多多饮用%CSTR:第一人称%的%SAVESTR:标识／母乳%","桃"
	CALL HEARTCB(0xD02830)
		
CASE "奶牛奴隶"
	CALL PRINT_WORD_COLOR,@"请从%CSTR:第一人称%沉沦的%SAVESTR:标识／乳房%中，多多榨取%SAVESTR:标识／母乳%","桃"
	CALL HEARTCB(0xD02830)
		
CASE "奶牛家畜"
	CALL PRINT_WORD_COLOR,@"%CSTR:主人公的称呼／陷落后%成为了家畜，现在过着充满搾乳快感的日子，真的很幸福。","桃"
	CALL HEARTCB(0xD02830)
	
CASE "恋慕"
	PRINTFORM %CSTR:主人公的称呼／陷落后%为您服务是现在%CSTR:第一人称%的幸福…
	CALL HEARTCB(0xD02830)
	
CASE "乳牛恋慕"
	CALL PRINT_WORD_COLOR,@"%SAVESTR:牧场名%和%CSTR:主人公的称呼／陷落后%为了您，请多搾取%SAVESTR:标识／母乳%。","桃"
