
;クリスラング設定
@SLANG_CONFIG_CLITORIS

CLEARLINE LINECOUNT
PRINTL 请选择用地文等表示的阴蒂黑话的候选。
DRAWLINE
PRINTLC [ 0] 「阴蒂」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴蒂,0),1)
PRINTLC [ 1] 「阴蒂」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴蒂,1),1)
PRINTLC [ 2] 「肉豆」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴蒂,2),1)
PRINTLC [ 3] 「豆子」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴蒂,3),1)
PRINTLC [ 4] 「肉芽」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴蒂,4),1)
PRINTLC [ 5] 「栗子」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴蒂,5),1)
PRINTLC [ 6] 「栗子酱」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴蒂,6),1)
PRINTLC [ 7] 「女芽」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／阴蒂,7),1)
PRINTL
PRINTL 　《 前缀设置 》
PRINTLC [10] 「淫乱」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／阴蒂,0),0)
PRINTL 　（淫核时）
PRINTLC [11] 「年幼」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／阴蒂,1),0)
PRINTL 　（儿童标准身高时）
PRINTL
PRINTL 　《 特殊替换设置 》
PRINTLC [20] 首选特殊替换
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／阴蒂,0),0)
PRINTL 　…如果满足特殊替换条件，则显示优先级
PRINTLC [21] 「淫核」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／阴蒂,1),0)
PRINTL 　（淫核时）
PRINTLC [29] 地文的设定
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／阴蒂,9),0)
PRINTFORML 　（当前设置：%SAVESTR:标识／阴蒂%）
CALL SLANG_CONFIG_FOOTER
INPUT
SELECTCASE RESULT
CASE 0 TO 7
	INVERTBIT FLAG:黑话标识／阴蒂,RESULT
CASE 10 TO 11
	INVERTBIT FLAG:黑话前缀／阴蒂,(RESULT -10)
CASE 20 TO 21
	INVERTBIT FLAG:黑话替换／阴蒂,(RESULT -20)
CASE 29
	INVERTBIT FLAG:黑话替换／阴蒂,(RESULT -20)
CASE 80
	FLAG:黑话标识／阴蒂 = 65535
CASE 81
	FLAG:黑话前缀／阴蒂 = 65535
CASE 82
	FLAG:黑话替换／阴蒂 = 65535
CASE 90
	FLAG:黑话标识／阴蒂 = 0
CASE 91
	FLAG:黑话前缀／阴蒂 = 0
CASE 92
	FLAG:黑话替换／阴蒂 = 0
CASE 98
	PRINTL 重置阴蒂黑话候选项的默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_SLANG_CONFIG_CLITORIS
CASE 99
	IF !FLAG:黑话标识／阴蒂
		PRINTW 必须至少设置一个候选黑话。
	ELSE
		RETURN
	ENDIF
ENDSELECT
RESTART


