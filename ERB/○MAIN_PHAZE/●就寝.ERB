
;自室で就寝
@SLEEP_ROOM

;人数
EXIST = CMATCH(CSTR:日程,"自室就寝")
SIF !EXIST
	RETURN
TARGET = 0

;あなたが寝るコマンド選ぶ場合は別メッセージ
HEAL_PRINT_DONE = 0
IF CSTR:日程 == "自室就寝"
	PRINTFORML %CALLNAME%决定提前睡觉…
	CALL SLEEP_HEAL
	EXIST --
	IF !EXIST
		PRINTW
		DRAWLINE
		RETURN
	ENDIF
	PRINTL
	DRAWLINE
ENDIF

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "自室就寝"
		CONTINUE
	
	;一番目に当たったキャラの名前
	;「は」と「も」で変えようとしてたけど分岐増えてきたし廃止
	PRINTFORM %CALLNAME%
	SIF EXIST > 1
		PRINT 们
	BREAK
NEXT
PRINTL 睡着了…

;回復処理とメッセージ
HEAL_PRINT_DONE = 0
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "自室就寝"
		CONTINUE
	CALL SLEEP_HEAL
NEXT
PRINTW
DRAWLINE



;家畜小屋で就寝
@SLEEP_CAGE

EXIST = CMATCH(CSTR:日程,"小屋就寝")
SIF !EXIST
	RETURN
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "小屋就寝"
		CONTINUE
	PRINTFORM %CALLNAME%
	SIF EXIST > 1
		PRINT 们
	BREAK
NEXT
PRINTL 在牢里睡着了…
HEAL_PRINT_DONE = 0
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "小屋就寝"
		CONTINUE
	CALL SLEEP_HEAL
NEXT
PRINTW
DRAWLINE

;牛舎の家畜もここで回復する　非表示でOK
;全員詳細表示なら出す
SIF FLAG:休息回复显示格式 == 3 && CMATCH(CSTR:住处,"牛舍")
	PRINTL 牛舍里的乳牛们也睡着了…
HEAL_PRINT_DONE = 1
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "牛舍"
		CONTINUE
	CALL SLEEP_HEAL(1)
NEXT
IF FLAG:休息回复显示格式 == 3 && CMATCH(CSTR:住处,"牛舍")
	PRINTW
	DRAWLINE
ENDIF



;体内の奴隷も休ませる
@SLEEP_NIKUKABE

EXIST = CMATCH(CSTR:日程,"体内凌辱")
SIF !EXIST
	RETURN
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "体内凌辱"
		CONTINUE
	PRINTFORM %CALLNAME:0%睡着时，%CALLNAME%
	SIF EXIST > 1
		PRINT 们
	BREAK
NEXT
PRINTL 得到了短暂的安息…
HEAL_PRINT_DONE = 0
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "体内凌辱"
		CONTINUE
	CALL VORE_SLEEP_HEAL
NEXT
PRINTW
DRAWLINE






