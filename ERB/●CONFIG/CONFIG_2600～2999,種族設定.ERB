
;種族設定一覧
@LIST_CONFIG_TRIBE

PRINTL --- 《 种族设定 》 ---
ALIGNMENT LEFT
DRAWLINE
CALL PRINTL_WORD_COLOR("种族设定　・游戏开始前　・开发者模式　・<奴隶候补设定变更票>只能在使用中更改。","黄")
CALL CONFIG_CHANGE_FLAG_CHECK(1)

;もろもろ不要
PRINTL [70] 出现比例／一般种族
PRINTL [71] 出现比例／上位种族
PRINTL [72] 出现比例／天界种族
PRINTL [73] 种族特征



;ARG→INPUT
@CHANGE_CONFIG_TRIBE(ARG)

SELECTCASE ARG
CASE 70	;出現割合／一般種族
	CALL NORMAL_TRIBE_CONFIG
CASE 71	;出現割合／上位種族
	CALL SPECIAL_TRIBE_CONFIG
CASE 72	;出現割合／天界種族
	CALL HEAVEN_TRIBE_CONFIG
CASE 73	;種族特徴
	CALL TRIBE_FEATURE_CONFIG
ENDSELECT



