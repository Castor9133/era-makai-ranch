
;牧場の名前
@NEWGAME_RANCH_NAME_BEFORE

;STR:牧場名→5850
STR_REF = 5850
STR_MAX = 50
CALL NEWGAME_RANCH_NAME



@NEWGAME_RANCH_NAME

CLEARLINE LINECOUNT
PRINTL 可以组合单词来修改牧场名。
PRINTFORML 当前：＜%SAVESTR:牧场名%＞
PRINTL 由于是追加方式，若需更改请先重置。
DRAWLINE
BR = 0
FOR LOCAL,STR_REF,STR_REF +STR_MAX
	SIF STR:LOCAL == ""
		CONTINUE
	SIF LOCAL == STR_REF +10
		PRINTL
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTLC [80] （手动输入）
PRINTLC [81] （重置）
IF SAVESTR:牧场名 == ""
	CALL PRINTL_WORD_COLOR,@"请输入牧场名","灰"
ELSE
	PRINTL [99] 确定
ENDIF
BINPUT
SELECTCASE RESULT
CASE 80
	PRINTL 请输入。（将添加到当前候选文后）
	INPUTS
	SAVESTR:牧场名 += RESULTS
CASE 81
	SAVESTR:牧场名 =
CASE 99
	RETURN
CASEELSE
	SAVESTR:牧场名 += STR:(RESULT +STR_REF)
ENDSELECT
RESTART


