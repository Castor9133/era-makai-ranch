;感度表示
@SENSITIVE_LIST_CHARA_MAKE
#DIMS KANDO

IF GETBIT(＃状态隐藏／敏感度＃) && !GETBIT(＃重新调整／敏感度＃) && FLAG:角色化妆隐蔽有效
	CALL PRINTL_WORD_COLOR("敏感度还不明","灰")
	RETURN
ENDIF

;STR:Ｂ→3950
STR_REF = 3950
FOR LOCAL,STR_REF,STR_REF +10
	RESETCOLOR
	SIF STR:LOCAL == ""
		BREAK
	KANDO = %STR:LOCAL%敏感度
	
	;感度120%でピンク
	IF ABL:KANDO >= 120
		SETCOLOR 0xFF70FF
	
	;感度80%以下は水色
	ELSEIF ABL:KANDO <= 80
		SETCOLOR 0x50C0FF
	ENDIF
	
	;感度200%だとハート追加
	SIF ABL:KANDO >= 200
		CALL HEARTCB(0xD02830)
	PRINTFORM %KANDO%<{ABL:KANDO,3}\%> 
	RESETCOLOR
NEXT
PRINTL



;性体質表示
@TALENT_NASTY_CHARA_MAKE

IF GETBIT(＃状态隐藏／性体质＃) && !GETBIT(＃重新调整／性体质＃) && FLAG:角色化妆隐蔽有效
	CALL PRINTL_WORD_COLOR("性体质还不明","灰")
	RETURN
ENDIF
PRINT 　　性体质：
IF !MAXARRAY(TALENT,30,50)
	CALL PRINTL_WORD_COLOR("特别","灰")
	RETURN
ENDIF
SETCOLOR 0xFF70FF
FOR LOCAL,30,50
	SIF TALENT:LOCAL
		PRINTFORM ❤%TALENTNAME:LOCAL%❤ 
NEXT
RESETCOLOR
PRINTL

