@COM504
#DIM NOW_SIZE
;ペニス変化

SELECTCOM = 504
PRINTFORML %CALLNAME:PLAYER%的%SAVESTR:标识／阴茎%的尺寸将发生变化
PRINTFORML 您想将其更改为哪个尺寸？（当前尺寸视为取消处理）
CANDI_BOX:0 = 马根
CANDI_BOX:1 = 极粗
CANDI_BOX:2 = 巨根
CANDI_BOX:3 = 稍粗
CANDI_BOX:4 = 普通
CANDI_BOX:5 = 短小
CANDI_BOX:6 = 极小
FIX:0 = ABL:PLAYER:初始值／阴茎尺寸 * 5 / 2 - 2
FIX:1 = ABL:PLAYER:初始值／阴茎尺寸 * 2 - 2
FIX:2 = ABL:PLAYER:初始值／阴茎尺寸 * 3 / 2 - 2
FIX:3 = ABL:PLAYER:初始值／阴茎尺寸 * 5 / 4 - 2
FIX:4 = ABL:PLAYER:初始值／阴茎尺寸
FIX:5 = ABL:PLAYER:初始值／阴茎尺寸 * 3 / 4
FIX:6 = ABL:PLAYER:初始值／阴茎尺寸 / 2
NOW_SIZE = 4
SELECTCASE ABL:PLAYER:阴茎尺寸
	CASE IS >= FIX:0
		NOW_SIZE = 0
	CASE IS >= FIX:1
		NOW_SIZE = 1
	CASE IS >= FIX:2
		NOW_SIZE = 2
	CASE IS >= FIX:3
		NOW_SIZE = 3
	CASE IS < FIX:5
		NOW_SIZE = 6
	CASE IS < FIX:4
		NOW_SIZE = 5
ENDSELECT
REPEAT 7
	PRINTFORM [ {COUNT}] %CANDI_BOX:COUNT%
	SIF COUNT == NOW_SIZE
		CALL PRINT_WORD_COLOR( "<现在>","浅蓝色")
	PRINTL
REND
BINPUT
SELECTCASE RESULT
CASE IS == NOW_SIZE
	RETURN
CASE 4
	ABL:PLAYER:阴茎尺寸 = FIX:4
CASEELSE
	ABL:PLAYER:阴茎尺寸 = FIX:RESULT + RAND:3
ENDSELECT
PRINTFORML %CALLNAME:PLAYER%的%SAVESTR:标识／阴茎%的尺寸已变为%CANDI_BOX:RESULT%
BASE:0:魔力 -= MAGIC_USE_MP:GETNUM(ITEM,"阴茎变化")
RETURN 1



