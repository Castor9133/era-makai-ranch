
;アイテム作成
@ITEM_CREATION

CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_UPGRADE("物品制作")
PRINTFORML %CALLNAME:0%的魔力等消耗后，创建物品。
PRINTL
BR = 0
CALL ITEM_CREATION_LIST
PRINTL
DRAWLINE
CALL ITEM_DETAIL_ITEM_CREATION
CALL PRINTL_ALIGN
CALL ITEM_CREATION_JUDGE(SELECT_ITEM,1)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(1,"戻る")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	;購入処理
	CALL ITEM_CREATION_BUY(1)
CASE 1
	CALL ITEM_CREATION_BUY
CASE 98
	;CALL BROWSE_HINT("製薬")
CASE 99
	RETURN
CASE 1800
	SELECT_ITEM = RESULT
ENDSELECT
RESTART



;アイテム作成リスト
@ITEM_CREATION_LIST
PRINTL 　　　《 物品制作 》

;まだ触手服しかないので直接代入
;ITEM:触手服→1800
LOCAL = 1800

;アイテム名があれば表示
;SIF ITEMNAME:SELECT_ITEM == ""
;	CONTINUE
CALL BR_PLUS(3)
;リソース不足チェック
CALL ITEM_CREATION_JUDGE(LOCAL)
IF RESULT
	PRINTFORMLC [{LOCAL}] %ITEMNAME:LOCAL% 
ELSE
	CALL PRINTLC_WORD_COLOR,@"[{LOCAL}] %ITEMNAME:LOCAL%","灰"
ENDIF




;必要な魔力（現状ではCSV記載の価格そのまま）
;ARG→選択アイテムID
@ITEM_CREATION_PRICE_MP(ARG)
#FUNCTION

RETURNF ITEMPRICE:ARG


;アイテム説明
@ITEM_DETAIL_ITEM_CREATION

;対応IDでないなら汎用出して帰る
IF SELECT_ITEM != 1800 || ITEMNAME:SELECT_ITEM == ""
	PRINTL  《 显示选定物品的说明 》
	RETURN
ENDIF
;とりあえずアイテム名、価格、所持数を出す
PRINTFORML %ITEMNAME:SELECT_ITEM%：%TOSTR(ITEMPRICE:SELECT_ITEM,"#,0")%MP 持有数量{ITEM:SELECT_ITEM,3}支 

SELECTCASE ITEMNAME:SELECT_ITEM
CASE "触手服装"
	PRINTFORML 由活的触手构成的紧身衣状服装。
	PRINTL 看起来像普通的紧身衣，但穿上后显露本性，内侧潜伏着无数细小的触手不断刺激穿着者。
	PRINTL 当穿着者试图脱掉时，触手的动作会变得激烈，夺走抵抗力，因此自力脱掉非常困难。
	PRINTL 
	PRINTL 作成条件：魔力注入、刷子触手的学习
	PRINTFORML 消费素材：触手×1(所持数{FLAG:触手出产合计})
ENDSELECT



;アイテム作成実行　ARG=1だと一個指定
@ITEM_CREATION_BUY(ARG)
#DIM MP_COST

MP_COST = ITEM_CREATION_PRICE_MP(SELECT_ITEM)

IF !ARG
	CALL ITEM_CREATION_JUDGE(SELECT_ITEM)
	BUY_NUM = RESULT
	PRINTFORML 请输入要创建的数量：＜%ITEMNAME:SELECT_ITEM%＞。
	PRINTFORML 最大《 {BUY_NUM} 》个可以制作。
	PRINTL [ 0] 取消
	INPUT
	SIF RESULT <= 0 || RESULT > BUY_NUM
		RETURN
	BUY_NUM = RESULT
ELSE
	BUY_NUM = 1
ENDIF

IF MP_COST
	PRINTFORML %CALLNAME:0%的魔力还是储存的魔力优先使用？
	PRINTFORMLC [ 0] %CALLNAME:0%の魔力：%TOSTR(BASE:0:魔力,"#,0")%MP 
	PRINTFORMLC [ 1] 储存的魔力：%TOSTR(MONEY:储存魔力,"#,0")%MP 
	INPUT
	IF !RESULT
		BASE:0:魔力 -= (MP_COST * BUY_NUM)
		SIF BASE:0:魔力 < 0
			MONEY:储存魔力 += BASE:0:魔力
	ELSE
		MONEY:储存魔力 -= (MP_COST * BUY_NUM)
		SIF MONEY:储存魔力 < 0
			BASE:0:魔力 += MONEY:储存魔力
	ENDIF
ENDIF

ITEM:SELECT_ITEM += BUY_NUM
SELECTCASE ITEMNAME:SELECT_ITEM
CASE "触手服装"
	FLAG:触手出产合计 -= BUY_NUM
ENDSELECT
BASE:0:魔力 = LIMIT(BASE:0:魔力,0,MAXBASE:0:魔力)
MONEY:储存魔力 = LIMIT(MONEY:储存魔力,0,FLAG:储存魔力上限值)
PRINTFORMW 将＜%ITEMNAME:SELECT_ITEM%＞《 {BUY_NUM} 》个已制作。



;作成できるか判定　ARG=アイテム番号、ARG:1=1だと表示あり
@ITEM_CREATION_JUDGE(ARG,ARG:1)
#DIM MP_COST
#DIM CREATION_C,3

VARSET CREATION_C,99

;対応IDでないなら汎用出して帰る
IF ARG != 1800 || ITEMNAME:ARG == ""
	PRINTL 
	RETURN
ENDIF

;コストの判定
;魔力
MP_COST = ITEM_CREATION_PRICE_MP(ARG)
SIF MP_COST
	CREATION_C:1 = (MONEY:储存魔力 +BASE:0:魔力) / MP_COST
;素材と作成条件確認
SELECTCASE ITEMNAME:ARG
CASE "触手服装"
	CREATION_C:2 = FLAG:触手出产合计
ENDSELECT

IF ARG:1
	IF !CREATION_C:1 && !CREATION_C:2
		CALL PRINTL_WORD_COLOR("　魔力・素材不足","灰")
	ELSEIF !CREATION_C:1
		CALL PRINTL_WORD_COLOR("　魔力不足","灰")
	ELSEIF !CREATION_C:2
		CALL PRINTL_WORD_COLOR("　素材不足","灰")
	ELSE
		PRINTFORMLC [  0] 制作：%TOSTR(MP_COST,"#,0")%MP
		PRINTLC [  1] 指定数量制作
		PRINTL
	ENDIF
ENDIF
RETURN LIMIT(MIN(CREATION_C,CREATION_C:1,CREATION_C:2),0,99)

