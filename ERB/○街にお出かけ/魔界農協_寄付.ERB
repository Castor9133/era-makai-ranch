
;寄付
@AGRI_COOP_DONATION
#DIM UNIT_NUM
#DIM DONATE_MONEY

CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP
PRINTFORML 可以从牧场资金中向魔界的各种预算捐款。（自治体·冈地街在 Lv3 之前为每口%VALUE_DIGIT(DONATION_UNIT_OKACHI_EARLY)%G，其余为每口%VALUE_DIGIT(DONATION_UNIT)%G）
PRINTL
CALL GET_TAX_FLAG_REF
FOR LOCAL,0,10
	SIF FLAGNAME:(FLAG_REF:1 +LOCAL) == ""
		CONTINUE
	PRINTFORM [{LOCAL,2}] %STR:(STR_REF +LOCAL),12%
	PRINTFORM （每口%VALUE_DIGIT(GET_DONATION_UNIT_FOR(LOCAL))%G）
	
	;現在の納税額も表示
	{
	PRINTFORM 　%STR:(STR_REF +LOCAL),12%Lv：{FLAG:(FLAG_REF:2 +LOCAL),2}
	积累金额：%VALUE_DIGIT(FLAG:(FLAG_REF:1 +LOCAL)),8%G 
	}
	CALL MAKAI_LVUP_NEED_MONEY_CALC(FLAG:(FLAG_REF:2 +LOCAL))
	CALL PRINT_COLORBAR(FLAG:(FLAG_REF:1 +LOCAL),RESULT,8,BARCOLORSET("青绿"),RESULT:1)
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
CALL RIGHT_RETURN_BUTTON
BINPUT
PRINTL
INPUT_NUM = RESULT
SELECTCASE INPUT_NUM
CASE 0 TO 8
	;何口出せるか：1回の上限1000（カテゴリにより一口単価が異なる）
	UNIT_NUM = LIMIT(MONEY /GET_DONATION_UNIT_FOR(INPUT_NUM),1,1000)
	PRINTFORML %STR:(STR_REF +INPUT_NUM)%要捐赠多少口？（每口%VALUE_DIGIT(GET_DONATION_UNIT_FOR(INPUT_NUM))%G）
	PRINTLC [ 0] 取消
	PRINTLC [ 1] 1份
	SIF UNIT_NUM >= 10
		PRINTLC [10] 10份
	SIF UNIT_NUM > 10
		PRINTFORMLC [{UNIT_NUM}] {UNIT_NUM}份
	PRINTL
	PRINTFORML 或者输入份数，最多为{UNIT_NUM}。
	INPUT
	IF RESULT >= 1 && RESULT <= UNIT_NUM
		PRINTL
		DONATE_MONEY = GET_DONATION_UNIT_FOR(INPUT_NUM) *RESULT
		PRINTFORML 要进行{RESULT}口（%VALUE_DIGIT(DONATE_MONEY)%G）的捐赠吗？
		CALL ASK_YN
		IF !RESULT
			PRINTL
			MONEY -= DONATE_MONEY
			FLAG:(INPUT_NUM +FLAG_REF:1) += DONATE_MONEY
			PRINTFORML %STR:(STR_REF +INPUT_NUM)%的捐赠进行了
			CALL MAKAI_LVUP
			PRINTW
		ENDIF
	ENDIF
	
	;最低一口分を下回ったら帰る
	SIF MONEY < GET_DONATION_MENU_MIN_CASH()
		RETURN
CASE 99
	RETURN
ENDSELECT
RESTART


