
;浴槽挿入（前穴／后穴を選択）　※处女结界時は肛門のみ
@BATHLOOM_V_INSERT

CALL MANYL(5)
PRINTL 选择插入的部位。
IF !TALENT:处女结界
	PRINTL [0] 前穴（膣内）…对面坐位
ENDIF
PRINTL [1] 后穴（肛门）…Ａ对面坐位
SIF TALENT:处女结界
	PRINTL （【处女结界】中无法进行膣内插入，仅可选择肛门。）
PRINTL [99] 取消
BINPUT
PRINTL
SELECTCASE RESULT
CASE 99
	RETURN
CASE 1
	CALL BATHLOOM_INSERT_BATH_A
CASE 0
	SIF TALENT:处女结界
		RETURN
	CALL BATHLOOM_INSERT_BATH_V
CASEELSE
	RETURN
ENDSELECT
RETURN



;風呂場・膣内（对面坐位）
@BATHLOOM_INSERT_BATH_V

V_PENIS = %CALLNAME:0%
SELECTCOM = 32
CALL COM32
IF !RESULT
	PRINTW 决定不要插入了…
	RETURN
ENDIF
TFLAG:Ｖ装备 = 1
SETBIT ＃Ｐ使用／Ｖ插入＃
CALL BATHLOOM_INSERT_BATH_COMMON_AFTER_INSERT
RETURN



;風呂場・肛門（Ａ对面坐位）
@BATHLOOM_INSERT_BATH_A

V_PENIS = %CALLNAME:0%
SELECTCOM = 42
CALL COM42
IF !RESULT
	PRINTW 决定不要插入了…
	RETURN
ENDIF
TFLAG:Ａ装备 = 1
SETBIT ＃Ｐ使用／Ａ插入＃
CALL BATHLOOM_INSERT_BATH_COMMON_AFTER_INSERT
RETURN



;挿入成立後の共通処理（ピストン前）
@BATHLOOM_INSERT_BATH_COMMON_AFTER_INSERT

LOSEBASE:体力 += 20
LOSEBASE:气力 += 30
CALL PRINT_IMAGE("调教执行")
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("调教命令",TRAINNAME:SELECTCOM,"执行")
EXP:(SELECTCOM +1000) ++
CALL SOURCE_CHECK
TFLAG:亲密互动次数 ++
TFLAG:指令中射精次数 = 0
IF !BASE:0:精力
	RESULT = 3
ELSE
	;継続コマンド選択
	PRINTL
	PRINTFORML [ 0] 揉捏%SAVESTR:标识／乳房%
	PRINTFORML [ 1] 吸吮%SAVESTR:标识／母乳%
	PRINTFORML [ 2] %SAVESTR:标识／精液%注入
	PRINTFORML [ 3] 拔出%SAVESTR:标识／阴茎%
	INPUT
	PRINTL
ENDIF
SELECTCASE RESULT
CASE 0
	CALL BATHLOOM_BUST_MASSAGE(1)
CASE 1
	CALL BATHLOOM_BUST_SUCK(1)
;CASE 2
CASE 3
	WAIT_SKIP = 1
	CALL COM890
	WAIT_SKIP = 0
	PRINTW
	RETURN
ENDSELECT
CALL EJACULATION_PISTON
PRINTW
RETURN
