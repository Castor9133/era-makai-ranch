
;倍率カスタマイズ
@CUSTOM_MODE_CONFIG

CLEARLINE LINECOUNT
PRINTL 进行＜自定义模式＞的设定。
CALL HALFLINE
CALL PRINTL_WORD_COLOR("《 倍率自定义 》在游戏开始前或开发者模式下才可以更改。","黄")
PRINTL 如果任意一项设定为ON，并且不是[DEVELOP]的情况下　难度显示为[CUSTOM]。
PRINTL
CALL PRINTL_WORD_COLOR("如果设置的值过高，可能会由于计算结果的溢出而发生错误。","黄")
CALL PRINTL_WORD_COLOR("如果设置的值过低，游戏可能无法正常进行。","黄")
PRINTL 操作此页面的项目前请自行承担风险。
CALL PRINT_DIFFICULTY
DRAWLINE

;STR:母乳出荷価格→3840
STR_REF = 3840
FLAG_REF = 3500
FOR LOCAL,0,70
	SIF FLAGNAME:(LOCAL +FLAG_REF) == ""
		CONTINUE
	PRINTFORM [{LOCAL,2}] %STR:(STR_REF +LOCAL),16%：
	IF !FLAG:(FLAG_REF +LOCAL)
		CALL PRINTL_WORD_COLOR,@"默认","灰"
	ELSE
		PRINTFORML {FLAG:(FLAG_REF +LOCAL)}\% 
	ENDIF
NEXT
CALL PRINTL_ALIGN
CALL DEFAULT_VOID_RETURN_BUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 98
	;日付が1日目以降かつ開発者モード以外の場合RETURN
	SIF !FLAG:开发者模式 && DAY
		RETURN
	PRINTL 是否将倍率自定义设定全部恢复为OFF？
	CALL ASK_YN
	SIF !RESULT
		VARSET FLAG,0,3500,3600
CASE 99
	RETURN
CASEELSE
	CALL CHANGE_CUSTOM_MODE_CONFIG(RESULT)
ENDSELECT
RESTART




;ARG→INPUT
@CHANGE_CUSTOM_MODE_CONFIG(ARG)

SIF !FLAG:开发者模式 && DAY
	RETURN
FLAG_NUM = ARG +FLAG_REF
FLAG_NAME = %FLAGNAME:FLAG_NUM%
PRINTL 请选择项的倍率，并以%指定。
PRINTL
PRINTL [ 0] 回复默认值
PRINTL 或直接输入数字
INPUT
SIF RESULT >= 0
	FLAG:FLAG_NUM = RESULT



