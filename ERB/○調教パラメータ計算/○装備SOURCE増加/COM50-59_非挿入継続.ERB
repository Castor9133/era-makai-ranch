
;奉仕共通SOURCE
@SERVICE_CONTINUE_SOURCE_COMMON

LOSEBASE:体力 += 30
LOSEBASE:气力 += 50
SOURCE:学习 += 1500
SOURCE:耻辱 += 1000
SOURCE:爱情 += 2000
SOURCE:爱情 += (ABL:奉仕精神 *300)
SOURCE:屈辱 += 1000
SOURCE:不洁 += 500
SOURCE:支配 += 500



;強制系共通SOURCE
@FORCIBLY_CONTINUE_SOURCE_COMMON

SOURCE:调教者体力消耗 += 30
LOSEBASE:体力 += 50
LOSEBASE:气力 += 50
SOURCE:耻辱 += 1500
SOURCE:爱情 += 500
SOURCE:受虐狂 += 1000
SOURCE:屈辱 += 2500
SOURCE:不洁 += 1000
SOURCE:支配 += 1500





@EQUIP_50_CONTINUE
;素股継続

CALL SEX_MESSAGE("素股")
IF TFLAG:奉仕可能
	CALL SERVICE_CONTINUE_SOURCE_COMMON
ELSE
	CALL FORCIBLY_CONTINUE_SOURCE_COMMON
ENDIF
SOURCE:Ｖ快感／主人公刺激 += 1000



@EQUIP_51_CONTINUE
;フェラチオ継続

IF SELECTCOM == 132
	CALL SEX_MESSAGE("刺激龟头")
	;龟头责継続：奴隶は口腔性感を得ず（Ｍ快感SOURCEなし）、精神的奉仕・恭順・体力気力の軽回復。主人公の興奮は射精増加側。
	SOURCE:学习 += 1500
	SOURCE:耻辱 += 900
	SOURCE:爱情 += 1800
	SOURCE:爱情 += (ABL:奉仕精神 *300)
	SOURCE:屈辱 += 800
	SOURCE:不洁 += 450
	SOURCE:支配 += 500
	SOURCE:恭顺 += 1400
	LOSEBASE:体力 -= 22
	LOSEBASE:气力 -= 32
	CALL SOURCE_MIRROR_PLAY_APPLY("口交")
	SOURCE:Ｍ快感／主人公刺激 = 0
	IF TALENT:肛门嗜好 && TFLAG:Ａ露出
		SOURCE:Ａ快感／主人公刺激 += 400
	ENDIF
	RETURN
ELSEIF SELECTCOM == 133
	CALL SEX_MESSAGE("真空口交")
	CALL SERVICE_CONTINUE_SOURCE_COMMON
	SOURCE:Ｍ快感／主人公刺激 += 1520
	CALL SOURCE_MIRROR_PLAY_APPLY("口交")
	IF TALENT:肛门嗜好 && TFLAG:Ａ露出
		SOURCE:Ａ快感／主人公刺激 += 400
	ENDIF
	RETURN
ENDIF

CALL SEX_MESSAGE("口交")
CALL SERVICE_CONTINUE_SOURCE_COMMON
SOURCE:Ｍ快感／主人公刺激 += 720
CALL SOURCE_MIRROR_PLAY_APPLY("口交")

;口交継続中の後庭いじり（666）
