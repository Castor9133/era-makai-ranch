
;ニンゲンの勝利処理
@TARGET_WIN

CALL TARGET_WIN_MESSAGE

;20%以下にされたら退却目的に切り替え
SIF BASE:战斗力 < MAXBASE:战斗力 /5
	CALL PURPOSE_CHANGE("撤退")
PRINTW
CALL MERCENARY_RESET

;仮に犠牲逃走で勝っても合流は不可能
SIF TFLAG:牺牲逃跑
	CALL TARGET_ESCAPE_WIN

;疲労蓄積
DAMAGE = TURN *2 +RAND:5 +10
BASE:疲劳度 = LIMIT(BASE:疲劳度 +DAMAGE,0,MAXBASE:疲劳度)
PRINTFORML %CALLNAME%%PRINT_EXIST_GROUP()% 疲劳度：{BASE:疲劳度}

;回数残ってる+HP60%以下か仲間HP60%以下で回復
SIF !BASE:回复次数
	RETURN
IF BASE:战斗力 < MAXBASE:战斗力 *60 /100
	CALL TARGET_SPECIAL_HEAL_SELF
	
ELSEIF BASE:同伴战斗力1 < MAXBASE:同伴战斗力1 *60 /100 && BASE:同伴战斗力1
	CALL TARGET_SPECIAL_HEAL_GROUP
ENDIF



;ニンゲンの敗北時処理
@TARGET_DEFEAT

CALL TARGET_DEFEAT_MESSAGE
CALL ARMOR_STRIP
CSTR:陷落状态 = 反抗
IF CFLAG:追踪者 == 1
	CFLAG:追踪对象 = 2
	CALL PRINTL_WORD_COLOR,@"%PRINT_MONSTER()%露出猥琐的笑容，包围了%CALLNAME%…","黄"
	PRINTW
	CALL GOBLIN_CAPTURE_PLAYER_CHOICES
	SIF !CFLAG:哥布林捕获_无轮奸
		CALL RINKAN_SLAVE
ELSE
	CFLAG:追踪对象 = 3
ENDIF
CALL PURPOSE_CHANGE("逃跑")



;鎧がある場合の処理
@ARMOR_STRIP

;なければ終了
SIF !EQUIP:装备中ID／铠
	RETURN

;ひとまず解除だけ
EQUIP:(EQUIP:装备中ID／铠) = 0
EQUIP:装备中ID／铠 = 0
PRINTFORML %CALLNAME%的盔甲被夺走了。



;仲間捕獲可能な場合は提携先に送る
@GROUP_CAPTURE
#DIM MAX_SLAVE
#DIM SEND_SLAVE

SIF !FLAG:可捕获同伴
	RETURN

;FLAG:事業提携先奴隷数／ニンゲン搾乳牧場→740
;STR:ニンゲン搾乳牧場→8200
FLAG_REF = 740
STR_REF = 8200

;マイルストーンにより送付先みる　今1つだけ
MAX_SLAVE = 20 +FLAG:魔界等级／奶农业 *5
SEND_SLAVE = LIMIT(MAX_SLAVE -FLAG:(FLAG_REF),0,10)

;送るのに必要なのは*30固定
COST = MAGIC_USE_MP:GETNUM(ITEM,"个人用传送门") *30
PRINTFORML %STR:(STR_REF)%：奴隶{FLAG:(FLAG_REF)}／{MAX_SLAVE}匹（当前数量/最大数量）
IF !SEND_SLAVE
	PRINTW 因为奴隶数量到达最大值所以不能送过来。
ELSEIF BASE:0:魔力 >= COST
	{
	PRINTFORML 通过使用＜个人用传送门＞的%VALUE_DIGIT(COST)%MP，
	軍隊のメスを搾乳奴隷として{SEND_SLAVE}匹送ることができます。
	}
	PRINTFORML 是否作为奴隶送出？（当前MP：%VALUE_DIGIT(BASE:0:魔力)%）
	CALL ASK_YN
	IF !RESULT
		BASE:0:魔力 -= COST
		FLAG:(FLAG_REF) += SEND_SLAVE
		PRINTFORMW 使用 <个人传送门>，将 {SEND_SLAVE} 名人类女性发送到 %STR:(STR_REF)%。
	ENDIF
ELSE
	{
	PRINTFORMW 因为%CALLNAME:0%魔力不足所以无法发送。
	（%VALUE_DIGIT(BASE:0:魔力)%／%VALUE_DIGIT(COST)%：当前值／需求值）
	}
ENDIF





