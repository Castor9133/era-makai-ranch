
;膣スラング設定
@SLANG_CONFIG_VAGINA

CLEARLINE LINECOUNT
PRINTL 请选择用地的句子等被表示的阴道俚语的候选。
DRAWLINE
PRINTLC [ 0] 「阴道」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／膣,0),1)
PRINTLC [ 1] 「雌穴」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／膣,1),1)
PRINTLC [ 2] 「肉壶」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／膣,2),1)
PRINTLC [ 3] 「小穴」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／膣,3),1)
PRINTLC [ 4] 「Vagina」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／膣,4),1)
PRINTLC [ 5] 「女性器」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／膣,5),1)
PRINTLC [ 6] 「下面的口」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／膣,6),1)
PRINTL
PRINTL 　《 前缀设置 》
PRINTLC [10] 「淫乱」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／膣,0),0)
PRINTL 　（淫壶时）
PRINTLC [11] 「淫荡的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／膣,1),0)
PRINTL 　（淫壶时）
PRINTLC [12] 「未熟的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／膣,2),0)
PRINTL 　（儿童标准身高时）
PRINTL
PRINTL 　《 特殊替换设置 》
PRINTLC [20] 首选特殊替换
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／膣,0),0)
PRINTL 　…如果满足特殊替换条件，则显示优先级
PRINTLC [21] 「柔软私处」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／膣,1),0)
PRINTL 　（儿童标准身高时）
PRINTLC [22] 「萝莉私处」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／膣,2),0)
PRINTL 　（儿童标准身高时）
PRINTLC [23] 「名器」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／膣,3),0)
PRINTL 　（名器时）
PRINTLC [24] 「榨精淫穴」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／膣,4),0)
PRINTL 　（榨精淫穴时）
PRINTLC [25] 「鸡巴套」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／膣,5),0)
PRINTL 　（淫壶时）
PRINTLC [26] 「阴茎套」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／膣,6),0)
PRINTL 　（淫壶时）
PRINTLC [29] 地文的设定
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／膣,9),0)
PRINTFORML 　（当前设置：%SAVESTR:标识／膣%）
CALL SLANG_CONFIG_FOOTER
INPUT
SELECTCASE RESULT
CASE 0 TO 6
	INVERTBIT FLAG:黑话标识／膣,RESULT
CASE 10 TO 12
	INVERTBIT FLAG:黑话前缀／膣,(RESULT -10)
CASE 20 TO 26
	INVERTBIT FLAG:黑话替换／膣,(RESULT -20)
CASE 29
	INVERTBIT FLAG:黑话替换／膣,(RESULT -20)
CASE 80
	FLAG:黑话标识／膣 = 65535
CASE 81
	FLAG:黑话前缀／膣 = 65535
CASE 82
	FLAG:黑话替换／膣 = 65535
CASE 90
	FLAG:黑话标识／膣 = 0
CASE 91
	FLAG:黑话前缀／膣 = 0
CASE 92
	FLAG:黑话替换／膣 = 0
CASE 98
	PRINTL 回复默认阴道黑话候选？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_SLANG_CONFIG_VAGINA
CASE 99
	IF !FLAG:黑话标识／膣
		PRINTW 必须至少设置一个候选黑话。
	ELSE
		RETURN
	ENDIF
ENDSELECT
RESTART


