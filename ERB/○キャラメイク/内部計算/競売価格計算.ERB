
;競売価格計算
@SLAVE_AUCTION_PRICE_CALC

;競売じゃないならおわり
CFLAG:拍卖价格 = 0
SIF CFLAG:进入魔界的目的 != 7
	RETURN
CFLAG:拍卖价格 = 1000000

;ランクにより増加
CFLAG:拍卖价格 += (CFLAG:级别 *100000)

;魔力量により増加
CFLAG:拍卖价格 += (CFLAG:魔力量 *50000)

;巨乳以上なら増加
SIF ABL:胸围大小 >= BUSTSIZE_巨乳
	CFLAG:拍卖价格 += 200000

;豊乳以上なら追加
SIF ABL:胸围大小 >= BUSTSIZE_丰乳
	CFLAG:拍卖价格 += 100000

;非処女だと下がる　ユニコーン的な輩に判定させてるんじゃない？
SIF !TALENT:处女
	CFLAG:拍卖价格 -= 300000

;Ａ非処女だと少し下がる
SIF !TALENT:Ａ处女
	CFLAG:拍卖价格 -= 50000

;他の参加者は便器扱いする前提なので仕事ABLなどでは上がらないよ
;名器などでも不明な状態なので上がらないよ
;身分により増加
SELECTCASE CSTR:身份
CASE "教官"
	CFLAG:拍卖价格 += 300000
CASE "贵族"
	CFLAG:拍卖价格 += 1000000
CASE "王族"
	CFLAG:拍卖价格 += 5000000
ENDSELECT
CFLAG:拍卖价格 = LIMIT(CFLAG:拍卖价格,100000,1000000000)



