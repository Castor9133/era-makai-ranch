
;ステータス・仕事能力の変更
;ARG→PAGE
;ARG:1→INPUT_NUM
@SELF_CHARA_MAKE_STATUS_INPUT(ARG,ARG:1)

INPUT_NUM = (ARG -1) *100 +ARG:1
SELECTCASE INPUT_NUM
CASE 0
	CHANGE_STATE = 等级
CASE 1
	CHANGE_STATE = 非战斗职业
CASE 2
	CHANGE_STATE = 体力
CASE 3
	CHANGE_STATE = 气力
CASE 4
	CHANGE_STATE = 灵力重新计算
CASE 5
	CHANGE_STATE = 灵力固定
CASE 6
	CHANGE_STATE = 魔力量
CASE 7
	CHANGE_STATE = 魔力重新计算
CASE 8
	CHANGE_STATE = 魔力固定
CASE 9
	CHANGE_STATE = 魔力恢复率
CASE 10
	CHANGE_STATE = 战斗力重新计算


;2ページ目
CASE 100
	CHANGE_STATE = 回复次数
CASE 101
	CHANGE_STATE = 大技次数
CASE 102
	CHANGE_STATE = 同行同伴
CASE 103
	CHANGE_STATE = 同伴级别
CASE 104
	CHANGE_STATE = 同伴战斗力重新计算


;3ページ目
CASE 200
	CHANGE_STATE = 奶农ABL
CASE 201
	CHANGE_STATE = 事务ABL
CASE 202
	CHANGE_STATE = 清洁ABL
CASE 203
	CHANGE_STATE = 料理ABL
CASE 204
	CHANGE_STATE = 药学ABL
CASE 205
	CHANGE_STATE = 接客ABL
CASE 210
	CHANGE_STATE = 不擅长清洁
CASE 211
	CHANGE_STATE = 不擅长料理
CASE 212
	CHANGE_STATE = 不擅长接客
CASE 213
	CHANGE_STATE = 调合知识
ENDSELECT

;SELF_CHARA_MAKE_RANDOMが有効かどうかで呼ぶ関数変更
IF SELF_CHARA_MAKE_RANDOM
	CALL SELF_CHARA_MAKE_STATUS_INPUT_SHUFFLE(CHANGE_STATE)
ELSE
	CALL SELF_CHARA_MAKE_STATUS_INPUT_MANUAL(CHANGE_STATE)
ENDIF



