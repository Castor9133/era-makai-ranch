; ARGS:0 场景；ARGS:1/2 用于更细分
@KOJO_GENERAL_ボーイッシュ口上1_EVENT(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:0

CASE "进入魔界的"
	SELECTCASE ARGS:1
	CASE "魔界水晶1"
		CALL MESSAGE_BOX,@"「这里就是魔界吗……我还以为会是更荒凉的地方呢」"
	CASE "魔界水晶2"
		CALL MESSAGE_BOX,@"「附近的【魔界水晶】好像被采光了…」\n「不过也没那么容易吧……得小心点了」"
	CASE "魔界植物1"
		CALL MESSAGE_BOX,@"「这里就是魔界吗……比我想的草木要多啊…」"
	CASE "魔界植物2"
		CALL MESSAGE_BOX,@"「附近的【魔界植物】好像被采光了…」\n「不过也没那么容易吧……得小心点了」"
	CASE "夺回1"
		CALL MESSAGE_BOX,@"「这里就是魔界吗……对于有怪物出没的地方来说还挺和平的嘛…」"
	CASE "夺回2"
		CALL MESSAGE_BOX,@"（就算死也要救你出来…！）\n「求你了要平安无事啊……！」"
	CASE "声望1"
		CALL MESSAGE_BOX,@"「这里就是魔界吗……比我想的要安分啊…」"
	CASE "声望2"
		CALL MESSAGE_BOX,@"「话虽如此这儿毕竟是魔界，用来扬名也够格了…」\n（但城堡那边的『那个』我绝对不想靠近…）"
	CASE "大门事故1"
		CALL MESSAGE_BOX,@"「……！ ……这里是…？ %SELF_CALL()%、难道说到了魔界……！？」"
	CASE "大门事故2"
		CALL MESSAGE_BOX,@"「怎么办呢……反正也不可能有能依靠的地方……」"
	CASE "大门事故3"
		CALL MESSAGE_BOX,@"「不过那边好像有像城镇的地方…」\n「谈谈说不定能解决……不，太天真了吗…？ 不过嘛…」"
	CASE "讨伐1"
		CALL MESSAGE_BOX,@"「这里就是魔界吗……终于到魔族的地盘了啊…」"
	CASE "讨伐2"
		CALL MESSAGE_BOX,@"「他们的头目应该在那座城里吧……好，出发了…！」"
	CASE "特殊种族1"
		CALL MESSAGE_BOX,@"「这里就是魔界吗……说什么瘴气弥漫的土地，谣言不靠谱嘛」"
	CASE "特殊种族2"
		CALL MESSAGE_BOX,@"「好嘞，让%SELF_CALL()%给他们见识见识我的实力…！」"
	CASE "即将处置1"
		CALL MESSAGE_BOX,@"（切…是我小看他们了… 精锐跟杂兵完全不是一个级别啊…！）"
	CASE "即将处置2"
		CALL MESSAGE_BOX,@"（本来没抱期待的【处女结界】结果还是保护了我…）\n「不过，那他们为什么不杀%SELF_CALL()%呢…？」"
	CASE "拍卖1"
		CALL MESSAGE_BOX,@"（居然买卖人类……果然魔界的家伙不可原谅…）"
	CASE "异世界转移1"
		CALL MESSAGE_BOX,@"「……嗯？…这里是哪儿…？」"
	CASE "异世界转移2"
		CALL MESSAGE_BOX,@"「没见过的景色……感觉像电影布景啊…」"
	CASE "异世界转移3"
		CALL MESSAGE_BOX,@"「那边看到的是城镇…？ 希望能沟通啊…」"
	ENDSELECT

CASE "事件"
	IF TFLAG:Ｍ装备
		CALL KOJO_PRINT("Ｍ装备中事件",ARGS:1,ARGS:2,ARGS:3)
		
		;CALLの関係でＭ装備中イベント呼び出した場合ここでリセットが必要
		MESSAGE_COUNT = 0
		RETURN
	ENDIF
	
	SELECTCASE ARGS:1
	CASE "领取奴隶"
		IF CFLAG:轮奸次数
			CALL MESSAGE_BOX,@"「噫……让、让我经历了那种事…这次是奴隶…？」"
		ELSE
			CALL MESSAGE_BOX,@"「…这、这里是牧场…？」"
			CALL MESSAGE_BOX,@"「…把我带到这种地方想让我干什么啊…」"
			CALL MESSAGE_BOX,@"「…我说了快放了我……！」"
		ENDIF
		
	CASE "母乳体质化"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「嘿嘿…♥ 以后就能为%MASTER_CALL()%出奶了啊…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「啊、啊啊… 这种事怎么可能…」"
		ENDIF
		
	CASE "魔力母乳体质化"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「嗯啊…魔力流出来了…你这是打算彻底榨取吧…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「！？ 魔力被抽走了…！ %SELF_CALL()%的胸部你做了什么……！？」"
		ENDIF
		
	CASE "超乳化"
		IF CFLAG:乳牛
			CALL MESSAGE_BOX,@"「啊♥ 被改造成这么像乳牛的身体好感动…♥♥」\n「以后会作为『欧派家畜』养我一辈子的对吧♥♥」"
		ELSEIF ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「呼啊…♥ 被整成了这么无可救药的胸部了呀♥♥」\n「已经只能作为%MASTER_CALL()%的欧派奴隶活下去了…♥♥」"
		ELSE
			CALL MESSAGE_BOX,@"「什…啊啊……这样…骗、骗人的吧……！」\n「%SELF_CALL()%的身体、快给我变回去啊…！」"
		ENDIF
		
	CASE "崩坏"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"（啊…啊…被%MASTER_CALL()%……弄坏了……）"
			ELSE
				CALL MESSAGE_BOX,@"（已经……什么都……怎样都好了……嘻嘻……）"
			ENDIF
		CASEELSE
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"「啊…嘎……%MASTER_CALL()%……饶、饶了……我……」
			ELSE
				CALL MESSAGE_BOX,@"「啊啊……啊…啊……！…？」"
			ENDIF
		ENDSELECT
		
	CASE "反抗消除"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"（ここには誰も助けになんか来ない…っ 怖い…苦しい…っ）\n（反抗しないから…許してくれ…いや、許してください…っ！）"
		CASEELSE
			CALL MESSAGE_BOX,@"（怖い……こんなのが続くと、そのうち壊される…）\n「に、二度と逆らったりしないから…お願いです…許してください…」"
		ENDSELECT
	
	CASE "屈服"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"（どんな命令でも聞くからっ…ここから出してくれ…っ）"
		CASEELSE
			CALL MESSAGE_BOX,@"「はっ…ぐ…%SELF_CALL()%齿%MASTER_CALL()%のドレイです…」\n「……っ どんなことでも、言うこと聞きます…」"
		ENDSELECT
	
	CASE "陷落"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"（あぁ…地獄みたいな思いをしてようやく分かったよ…）\n（%SELF_CALL()%はコイツには逆らったり出来ないんだな…）"
		CASEELSE
			CALL MESSAGE_BOX,@"「なあ…%MASTER_CALL()%のこととか、いろいろ教えてくれよ…」\n「べ、別に少しは上手く立ち回ろうってだけだっての……」"
		ENDSELECT
	
	CASE "恋慕告白"
		SELECTCASE ARGS:2
		CASE "前"
			CALL MESSAGE_BOX,@"「那、那个…%MASTER_CALL()%有…喜欢过谁吗…？」\n「不，该怎么说呢……我有个有点在意的人……那个…」"
		CASE "后"
			CALL MESSAGE_BOX,@"「那、那个…我好像……迷、迷上%MASTER_CALL()%了…！♥」\n「我不会给你添麻烦的……只、只是想待在你身边…♥」"
		ENDSELECT
	
	CASE "隶属告白"
		SELECTCASE ARGS:2
		CASE "前"
			CALL MESSAGE_BOX,@"「%SWEET_MASTER_CALL()%…♥ %SELF_CALL()%啊、被你弄得这么幸福、真的很感激…♥♥」\n「然后我就在想该怎么报答%MASTER_CALL()%…♥♥」"
		CASE "后"
			CALL MESSAGE_BOX,@"「%SELF_CALL()%除了这身体也没什么了……那就把『全部』都给你好了♥♥」\n「我会尽量不坏掉的…♥♥ 要多用用我啊♥♥♥」"
		ENDSELECT
	
	CASE "乳牛堕落"
		SELECTCASE ARGS:2
		CASE "体内凌辱中"
			CALL MESSAGE_BOX,@"（啊♥ 好舒服…好幸福…♥ 至今的人生里从没有过这么幸福的事…♥）\n（已经不需要『人生』了…♥♥ 从今以后作为乳牛幸福地活着…♥♥）"
		CASEELSE
			CALL MESSAGE_BOX,@"「啊啊～…♥♥ 好舒服♥ 好舒服♥ 胸部好舒服…！♥」\n「被挤奶高潮的舒服、刻进了身体深处…♥」\n「一旦知道了被当成乳牛养着的幸福、就再也回不去当人了…♥♥」"
		ENDSELECT
	
	CASE "处女结界破坏"
		SIF TALENT:性知识贫乏
			RETURN
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「一直以来保护着%SELF_CALL()%的结界、已经不需要了呢…♥♥」\n\d"
		ELSE
			CALL MESSAGE_BOX,@"「…！ 结界在崩溃……怎么会…！？」"
		ENDIF
	
	CASE "处女丧失前"
		IF CFLAG:乳牛 || CFLAG:洗脑
			;乳牛状態で乙女心もないだろ、ということで素質：乙女心の判定はしない
			IF GETBIT(＃Ｐ使用／Ｖ插入＃)
				IF TFLAG:拘束BIT
					CALL MESSAGE_BOX,@"「啊呜…被绑着初体验什么的♥ 虽然有点害怕、但反而兴奋起来了…♥」"
				ELSEIF TFLAG:眼罩
					CALL MESSAGE_BOX,@"「啊呜…被蒙着眼初体验什么的♥ 虽然有点害怕、但反而兴奋起来了…♥」"
				ELSE
					CALL MESSAGE_BOX,@"「啊啊…♥ %SELF_CALL()%的处女、%MASTER_CALL()%要收下了啊…♥♥」"
				ENDIF
			ELSEIF TFLAG:眼罩
				CALL MESSAGE_BOX,@"「%MASTER_CALL()%…？ 蒙着眼看不太清楚…难、难道说…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「啊嘻…♥ %SELF_CALL()%的处女、要被这种东西夺走吗…♥♥」"
			ENDIF
		ELSEIF ＃陷落状态／恋慕以上＃
			;こちらは乙女心の判定あり
			IF GETBIT(＃Ｐ使用／Ｖ插入＃)
				IF TALENT:少女心
					CALL MESSAGE_BOX,@"「啊啊…♥ 初次的对象我早就决定一定要是%MASTER_CALL()%了…♥♥」"
				ELSEIF TFLAG:眼罩
					CALL MESSAGE_BOX,@"「啊啊…♥ 要蒙眼的话、至少抱着我做吧…♥♥\n　我想感受到%MASTER_CALL()%的存在啊…♥♥」"
				ELSE
					CALL MESSAGE_BOX,@"「啊♥ %MASTER_CALL()%…♥ 这一刻终于来了啊…♥♥」"
				ENDIF
			ELSEIF TALENT:少女心
				CALL MESSAGE_BOX,@"「怎么这样……不是说好第一次是%MASTER_CALL()%来收的吗…！」"
			ELSEIF TFLAG:眼罩
				CALL MESSAGE_BOX,@"「%MASTER_CALL()%…？ 蒙着眼看不太清楚…难、难道说…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「啊啊…我还以为第一次会是%MASTER_CALL()%来收的……\n　不、不过…%MASTER_CALL()%想的话那就…」"
			ENDIF
		ELSEIF TALENT:贞操观念 || TALENT:少女心
			CALL MESSAGE_BOX,@"「不、不要…！ 只有那个…求你了…！ 住手啊！」"
		ELSEIF ＃陷落状态／陷落以上＃ || TALENT:不在乎贞操
			CALL MESSAGE_BOX,@"「呜……虽然早就想到会有这么一天了……」"
		ELSEIF V_PENIS == "触手"
			CALL MESSAGE_BOX,@"「咿…！？ 第、第一次的对象是触手…！？ 这也…太过分了…！」"
		ELSEIF V_PENIS == "妖精"
			CALL MESSAGE_BOX,@"「呜啊啊！ 被哥布林给……啊啊啊啊啊！」"
		ELSE
			CALL MESSAGE_BOX,@"「放、放开我！ 你想往里面塞什么…！ 呜哇！」"
		ENDIF
	
	CASE "处女丧失后"
		IF CFLAG:乳牛 || CFLAG:洗脑
			IF GETBIT(＃Ｐ使用／Ｖ插入＃)
				IF TFLAG:拘束BIT || TFLAG:眼罩
					CALL MESSAGE_BOX,@"「哈呜♥ ……第一次就玩这个、要是变成变态了…♥♥\n　%MASTER_CALL()%可得负责啊…♥♥」"
				ELSE
					CALL MESSAGE_BOX,@"「嗯…被%MASTER_CALL()%抱着竟然这么幸福啊…♥♥」"
				ENDIF
			ELSE
				IF TFLAG:眼罩
					CALL MESSAGE_BOX,@"「唔咕♥…果、果然还是♥……真是个过分的家伙…♥♥」"
				ELSE
					CALL MESSAGE_BOX,@"「哈呜呜♥……啊、这是…眼泪？……一定是太疼了、嗯…♥♥」"
				ENDIF
			ENDIF
		ELSEIF ＃陷落状态／恋慕以上＃
			IF GETBIT(＃Ｐ使用／Ｖ插入＃)
				IF TALENT:少女心
					CALL MESSAGE_BOX,@"「和喜欢的人合为一体、开心得让人害怕…♥♥\n　%SELF_CALL()%、第一次能这么幸福真的可以吗…♥♥♥」"
				ELSEIF TFLAG:眼罩
					CALL MESSAGE_BOX,@"「%MASTER_CALL()%♥♥ %SWEET_MASTER_CALL()%…♥♥ 我爱你♥♥」"
				ELSE
					CALL MESSAGE_BOX,@"「和喜欢的人结合在一起竟然这么幸福…♥♥」"
				ENDIF
			ELSE
				IF TALENT:少女心
					CALL MESSAGE_BOX,@"「明知道%SELF_CALL()%的心意……%MASTER_CALL()%真是个过分的家伙……呜咽…」"
				ELSE
					CALL MESSAGE_BOX,@"「呜呜……竟然、以这种形式失去处女……」"
				ENDIF
			ENDIF
		ELSEIF TALENT:贞操观念 || TALENT:少女心
			CALL MESSAGE_BOX,@"「…这、这一定是梦……对、只是一场噩梦…」"
		ELSEIF ＃陷落状态／陷落以上＃ || TALENT:不在乎贞操
			IF V_PENIS == "妖精"
				CALL MESSAGE_BOX,@"「…虽然对初体验没什么幻想…但对象是哥布林的话…也太过分了……」"
			ELSEIF PALAM:Ｖ润滑 >= 10000
				CALL MESSAGE_BOX,@"「嗯……比想象中没那么难受啊…」"
			ELSE
				CALL MESSAGE_BOX,@"「咕…当、当然会疼啊…！\n　要、要是会关心人的话就快拔出来…！」"
			ENDIF
		ELSE
			CALL MESSAGE_BOX,@"「啊咕……咕…呜…」"
		ENDIF
	
	CASE "Ａ处女丧失前"
		IF TALENT:性知识贫乏
			CALL MESSAGE_BOX,@"「……？ 一体%ANAL_CALL()%に何をするつもりだ…？\n　…っ！？ %ANAL_CALL()%にっ…捻じ込まれてっ…！？」"
		ELSEIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			IF GETBIT(＃Ｐ使用／Ａ插入＃)
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「いてっ…！？　なのに…%ANAL_CALL()%の奥がジンジンして…変なの混ざってんじゃねえか…♥」"
					CALL MESSAGE_BOX,@"「%MASTER_CALL()%…尻まで好きにしていいって言ったのに…こんなの聞いてねえ…っ♥」"
				ELSE
					CALL MESSAGE_BOX,@"「%MASTER_CALL()%♥ 新品の%ANAL_CALL()%…自由に使っていいからな♥♥」"
				ENDIF
			ELSEIF A_PENIS == "触手"
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「痛っ…！？　でも…押し広げられながら…奥がムズムズ…気持ち悪…っ♥」"
				ELSE
					CALL MESSAGE_BOX,@"「触手が%ANAL_CALL()%に入ってくるのは…やっぱちょっと怖い……っ」"
				ENDIF
			ELSE
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「痛ぇ…！？　なのに…%ANAL_CALL()%が勝手に…吸い付いてんの感じる…マジかよ…♥」"
				ELSE
					CALL MESSAGE_BOX,@"「啊哈哈♥ %SELF_CALL()%的%ANAL_CALL()%でいっぱい遊んでくれよなぁ♥♥」"
				ENDIF
			ENDIF
		ELSEIF A_PENIS == "妖精"
			CALL MESSAGE_BOX,@"「……っ！？ %ANAL_CALL()%に触んじゃねえ…っ！？」"
		ELSE
			IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
				CALL MESSAGE_BOX,@"「そっちは違…っ！？　痛っ…！？　なのに…奥がぞわぞわ…っ、気持ち悪…！」"
			ELSE
				CALL MESSAGE_BOX,@"「そ、そっちは違っ…… っ～～～！」"
			ENDIF
		ENDIF
	
	CASE "Ａ处女丧失后"
		IF TALENT:性知识贫乏
			CALL MESSAGE_BOX,@"「かひっ…%ANAL_CALL()%は…なんかを入れたりするトコじゃ……んぐっ…」"
		ELSEIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
			IF GETBIT(＃Ｐ使用／Ａ插入＃)
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「…まだヒリヒリ…。でも…奥がうずいて…もっとって言ってんのかよ…嫌な予感だ…♥」"
					CALL MESSAGE_BOX,@"「%MASTER_CALL()%のせいだ…尻まで変な癖つく…♥」"
				ELSE
					CALL MESSAGE_BOX,@"「…んおぉっ！？ ひ、一突きで…♥ %ANAL_CALL()%が%PENIS_CALL()%に屈服させられたぁ…♥♥」"
				ENDIF
			ELSE
				IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
					CALL MESSAGE_BOX,@"「痛みの奥に…妙な火種みたいなの残ってんじゃん…マジで最悪…♥」"
				ELSE
					CALL MESSAGE_BOX,@"「お、おぉ…っ♥ 腹が押し広げられて……っ♥」"
				ENDIF
			ENDIF
		ELSEIF A_PENIS == "妖精"
			CALL MESSAGE_BOX,@"「ぎっ……うぐぅ……いてえっ！…やめ…っ！」"
		ELSE
			IF GETBIT(＃Ｐ使用／Ａ插入＃) && TALENT:处女结界
				CALL MESSAGE_BOX,@"「はぐぅっ……結界があるからって、%ANAL_CALL()%に入れるとか…っ」"
