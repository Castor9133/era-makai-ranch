; 口上内通用子程序：只 CALL MESSAGE_BOX 即可
; 将 [生真面目] 改为本性格对应名（本口上为 非敬語幼め）
@KOJO_GENERAL_非敬語幼め1_TRAIN_INSIDE(ARGS:1,ARGS:2)

SELECTCASE ARGS:1
CASE "Ｖ性交"
	;处女丧失时口上在【事件】侧，仅那边显示。
	SIF SOURCE:处女丧失
		RETURN
	
	SELECTCASE ARGS:2
	CASE "继续"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「%MASTER_CALL()%♥♥ %MASTER_CALL()%的%PENIS_CALL()%♥♥ 最喜欢%MASTER_CALL()%了♥♥♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「%MASTER_CALL()%的%PENIS_CALL()%…♥ 把%SELF_CALL()%的%VAGINA_CALL()%弄得乱七八糟吧…♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「啊♥  呃…♥ 才没有、感觉到…舒服…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「差不多了…  呃…♥ 来做吧…！」"
		ENDIF
	
	CASE "执行"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「啊啊啊♥ 快进到%SELF_CALL()%的%VAGINA_CALL()%来嘛♥♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「啊！？♥」"
		ELSE
			CALL MESSAGE_BOX,@"「不，不要啊！？」"
		ENDIF
	
	ENDSELECT
	
CASE "Ａ性交"
	SIF SOURCE:Ａ处女丧失
		RETURN
	
	SELECTCASE ARGS:2
	CASE "继续"
		IF ABL:Ａ感觉 >= 5
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
				CALL MESSAGE_BOX,@"「%MASTER_CALL()%♥♥ %MASTER_CALL()%的%PENIS_CALL()%真棒♥♥\n　%SELF_CALL()%、变成了被玩弄%ANAL_CALL()%就会感到舒服的变态了♥♥♥」"
			ELSEIF ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"「啊♥ 啊嗯♥♥ 哎♥ 竟然会在%ANAL_CALL()%里感到舒服♥♥」"
			ELSE
				CALL MESSAGE_BOX,@"「啊♥ 不、不可以呀♥ 会、会回不去的啦♥♥」"
			ENDIF
		ELSE
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
				CALL MESSAGE_BOX,@"「啊♥ 当然、%ANAL_CALL()%也可以按照%MASTER_CALL()%的喜欢来使用哦♥♥」"
			ELSEIF ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"「啊，呃… 竟然要用后面，%MASTER_CALL()%真是变态呢…♥♥」"
			ELSE
				CALL MESSAGE_BOX,@"「就算做这种事…也只会感到难受而已…！」"
			ENDIF
		ENDIF

	CASE "执行"
		IF ABL:Ａ感觉 >= 5
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"「啊呜♥♥ %PENIS_CALL()%进到%ANAL_CALL()%里了♥♥♥」"
			ELSE
				CALL MESSAGE_BOX,@"「呜咿♥ 在%ANAL_CALL()%里…♥」"
			ENDIF
		ELSE
			IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
				CALL MESSAGE_BOX,@"「诶、%ANAL_CALL()%…？没关系的…嗯嗯♥♥」"
			ELSE
				CALL MESSAGE_BOX,@"「好痛！？疼，好疼啊…！」"
			ENDIF
		ENDIF
	
	ENDSELECT

ENDSELECT


