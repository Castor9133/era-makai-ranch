
;割合設定フッター
@TENDENCY_CONFIG_FOOTER

DRAWLINE
IF !FLAG:可配置的候选奴隶
	IF ITEM:奴隶候补设定变更票
		PRINTLC [90] ＜奴隶候补设定变更票＞使用
	ELSE
		CALL PRINTLC_WORD_COLOR("　＜奴隶候补设定变更票据＞无","灰")
	ENDIF
ELSE
	PRINTLC [98] 回复默认值
ENDIF
IF TOTAL_RATIO > 0 && TOTAL_RATIO <= 1000
	PRINTLC 　
	PRINTL [99] 完成
ELSE
	CALL PRINTL_WORD_COLOR,@"！出现比率的总和必须介于1和1000之间：当前{TOTAL_RATIO}","黄"
ENDIF
BINPUT
PRINTL
INPUT_NUM = RESULT
IF INPUT_NUM == 90
	SIF FLAG:可配置的候选奴隶 || !ITEM:奴隶候补设定变更票
		RETURN
	PRINTL 使用＜奴隶候补设定变更票＞吗？
	CALL PRINTL_WORD_COLOR("在找到下一个奴隶候选之前，设置将保持可更改状态。","黄")
	CALL ASK_YN
	IF !RESULT
		FLAG:奴隶候补设定变更票使用中 = 1
		ITEM:奴隶候补设定变更票 --
		PRINTW 使用了＜奴隶候补设定变更票＞。
	ENDIF
ENDIF

;設定不可ならINPUT_NUMを強制的に99に置き換え
SIF !FLAG:可配置的候选奴隶
	INPUT_NUM = 99

;元関数にINPUT_NUMで判定させる

