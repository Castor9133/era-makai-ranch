
;魔力　霊力の何割あるかで計算しよう
@SLAVE_MP_CALC

;一旦OFF
CFLAG:庞大的魔力 = 0
STATUS = BASE:灵力 *CFLAG:魔力量 /10
CALL RANDOM_FIX(STATUS,5,"魔力量")
STATUS += FIX
STATUS -= (STATUS %50)

;魔力増加オプション判定
CALL SLAVE_MP_CALC_TRIBE_FIX

;低ランクで魔力量10以上の場合200万～増加させる処理
;非戦闘職の場合も
SIF (CFLAG:级别 < 3 && CFLAG:魔力量 >= 10) || (CFLAG:非战斗职业 && CFLAG:魔力量)
	CALL SLAVE_MP_CALC_OVER_SPEC_FIX
MAXBASE:魔力 = STATUS
BASE:魔力 = MAXBASE:魔力

;魔力回復量計算
CALL SLAVE_MP_CALC_HEALMP



;魔力増加オプション　とはいえ妖狐とヴァンパイアにしかない
@SLAVE_MP_CALC_TRIBE_FIX

SELECTCASE CSTR:种族
CASE "吸血鬼"
	SIF GETBIT(FLAG:种族设定／吸血鬼,2)
		STATUS *= 2
CASE "妖狐"
	SIF GETBIT(FLAG:种族设定／妖狐,4)
		STATUS *= 2
ENDSELECT



;低ランクだけど莫大な魔力の場合計算
@SLAVE_MP_CALC_OVER_SPEC_FIX

CFLAG:庞大的魔力 = 1

;10以上
IF CFLAG:魔力量 >= 10
	STATUS = 1000000 +100000 *(RAND:5 +CFLAG:魔力量)

;非戦闘職で9以下
ELSE
	STATUS = 100000 *(RAND:3 +CFLAG:魔力量)
ENDIF
CALL RANDOM_FIX(STATUS,5,"魔力量")
STATUS += FIX
STATUS -= (STATUS %50)



;魔力回復量計算
@SLAVE_MP_CALC_HEALMP

;魔力なしならおわり
SIF !MAXBASE:魔力
	RETURN

;(ランク +1)%の30%上限,膨大魔力の場合は1%
;魔界適応だと+10%
MAXBASE:魔力恢复率 = LIMIT(CFLAG:级别 +1,1,30)
SIF TALENT:魔界适应
	MAXBASE:魔力恢复率 += 10
SIF CFLAG:庞大的魔力
	MAXBASE:魔力恢复率 = 1
BASE:魔力恢复率 = MAXBASE:魔力恢复率




SIF TALENT:魔界种族
	MAXBASE:魔力恢复率 += 5
