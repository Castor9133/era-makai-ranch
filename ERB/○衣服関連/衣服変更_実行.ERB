
;衣服変更実行
;キャラが既に持っている衣服を着させる処理
@CHANGE_CHARA_CLOTHE_ENTER

;持っている衣服、プレゼントで装備適用の共通関数へ
;持っている場合は干渉装備を聞くようにするためARG=1を入れる
;チェック回し
CALL CHANGE_CLOTHE_RESIST_CHECK
CALL WEAR_CHARA_CLOTHE(1)

;RETURN 1してきたらキャンセル
SIF RESULT
	RETURN

;未所持ならアイテム消費→コマンド1に統合
CALL PRINT_SELECT_ITEM_DETAIL(SELECT_ITEM)
CALL CHANGE_CLOTHE_RESIST
SIF RESULT
	RETURN
IF TARGET
	PRINTW 穿上了。
ELSE
	PRINTW 穿上了。
ENDIF



;未所持衣服をプレゼントする場合の処理
@CHANGE_CHARA_NEW_CLOTHE
#DIM ITEM_DETAIL

;とりあえず色柄変更処理に飛ばす
CALL EQUIP_DETAIL_CHANGE

;RETURN 1してきた場合キャンセル
SIF RESULT
	RETURN
CALL CHANGE_CLOTHE_RESIST_CHECK

;キャラ所持数を追加、アイテムの所持数減らす
;途中にSETBITする処理あるのでここもSETBITしないとバグるな
SETBIT EQUIP:SELECT_ITEM,0
ITEM:SELECT_ITEM --
CALL WEAR_CHARA_CLOTHE

;衣服一式からRETURN 1してきた場合キャンセル
SIF RESULT
	RETURN
CALL PRINT_SELECT_ITEM_DETAIL(SELECT_ITEM)
CALL CHANGE_CLOTHE_RESIST(1)
SIF RESULT
	RETURN
IF TARGET
	PRINTW 赠送并穿上。
ELSE
	PRINTW 穿上了。
ENDIF



;デフォ状態の衣装の色柄を設定する場合の処理
@CHANGE_CHARA_CLOTHE_DETAIL_CHANGE
;#DIM ITEM_DETAIL

CALL EQUIP_DETAIL_CHANGE
SIF RESULT
	RETURN
IF CSTR:SELECT_ITEM == "" && EQUIP:SELECT_ITEM == 1
	PRINTW 没有设置。
ELSE
	CALL PRINT_SELECT_ITEM_DETAIL(SELECT_ITEM)
	PRINTW 的规格化距离的幂函数。
ENDIF



;衣服の変更
;ARG→干渉衣服の確認
;ARG:1→所持チェック回避
;SELECT_ITEM指定中
@WEAR_CHARA_CLOTHE(ARG,ARG:1)

;カテゴリ分類関数を作った
CALL CLOTHE_CATEGORY_CHECK(ITEMNAME:SELECT_ITEM)
SELECTCASE RESULTS
CASE "衣服一套"
	;一式のときは全部変更するので別個処理
	CALL EQUIP_CLOTHE_SET_WEAR
	
	;下でチェック回避する分ここ
	CALL EQUIP_CLOTHE_SET_CHECK
	
	;内部で「着せました」を出してRETURN先ではキャンセル
	RETURN 1

CASE "衣服"
	EQUIP:装备中ID／衣服 = SELECT_ITEM
	
	;下着制限フラグを一旦OFF
	EQUIP:内衣限制／极小 = 0
	EQUIP:内衣限制／贴纸 = 0
	
	;下着制限の服なら一回まとめて外す
	;シールのみ
	IF GROUPMATCH(ITEMNAME:SELECT_ITEM,"兔女郎装","比基尼盔甲","舞女的服装")
		EQUIP:装备中ID／内衣上装 = 0
		EQUIP:装备中ID／内衣下装 = 0
		EQUIP:内衣限制／贴纸 = 1
	ENDIF
	
	;極小のみ
	IF GROUPMATCH(ITEMNAME:SELECT_ITEM,"奴隶的破布","淫乱巫女服","淫乱修女服","淫乱女仆装","淫乱旗袍","淫乱礼服")
		EQUIP:装备中ID／内衣上装 = 0
		EQUIP:装备中ID／内衣下装 = 0
		EQUIP:内衣限制／极小 = 1
	ENDIF
	
	;逆バニーは特殊で脚不可
	SIF GROUPMATCH(ITEMNAME:SELECT_ITEM,"反向兔女郎装")
		EQUIP:装备中ID／腿 = 0

CASE "铠"
	EQUIP:装备中ID／铠 = SELECT_ITEM

CASE "内衣上下装","内衣上下装／极小"
	;下着制限の場合衣服のほうを脱がすか聞く：プレゼント時は無効にする
	IF RESULTS == "内衣上下装"
		CALL SMALL_LINGERIE_CHECK(ARG)
		SIF RESULT
			RETURN 1
	
	;上との差→極小タイプ可能ならそのまま通す
	ELSE
		CALL STICKER_LINGERIE_CHECK(ARG)
		SIF RESULT
			RETURN 1
	ENDIF
	EQUIP:装备中ID／内衣上装 = SELECT_ITEM
	EQUIP:装备中ID／内衣下装 = SELECT_ITEM

CASE "内衣上装","内衣上装／极小","内衣上装／贴纸"
	IF RESULTS == "内衣上装"
		CALL SMALL_LINGERIE_CHECK(ARG)
		SIF RESULT
			RETURN 1
	ELSEIF RESULTS == "内衣上装／极小"
		CALL STICKER_LINGERIE_CHECK(ARG)
		SIF RESULT
			RETURN 1
	
	;シールタイプは常に着用可能
	ENDIF
	
	;上下一体をつけている場合外す
	SIF EQUIP:装备中ID／内衣上装 == EQUIP:装备中ID／内衣下装
		EQUIP:装备中ID／内衣下装 = 0
	EQUIP:装备中ID／内衣上装 = SELECT_ITEM

CASE "内衣下装","内衣下装／极小","内衣下装／贴纸"
	IF RESULTS == "内衣下装"
		CALL SMALL_LINGERIE_CHECK(ARG)
		SIF RESULT
			RETURN 1
	ELSEIF RESULTS == "内衣下装／极小"
		CALL STICKER_LINGERIE_CHECK(ARG)
		SIF RESULT
			RETURN 1
	ENDIF
	SIF EQUIP:装备中ID／内衣上装 == EQUIP:装备中ID／内衣下装
		EQUIP:装备中ID／内衣上装 = 0
	EQUIP:装备中ID／内衣下装 = SELECT_ITEM

CASE "眼"
	EQUIP:装备中ID／眼 = SELECT_ITEM

CASE "头"
	EQUIP:装备中ID／头 = SELECT_ITEM

CASE "腕"
	EQUIP:装备中ID／腕 = SELECT_ITEM

CASE "腿"
	;逆バニーだと脚不可
	IF EQUIPNAME:(EQUIP:装备中ID／衣服) == "反向兔女郎装" && ARG
		PRINTFORML 穿着脚饰品不能戴的衣服。要脱掉<％＃穿着衣服／名称＃％＞并穿上<％ITEMNAME:SELECT_ITEM％>吗？
		CALL ASK_YN
		SIF RESULT
			RETURN 1
		EQUIP:装备中ID／衣服 = 0
	ENDIF
	EQUIP:装备中ID／腿 = SELECT_ITEM

CASE "颈"
	EQUIP:装备中ID／颈 = SELECT_ITEM

CASE "外衣"
	EQUIP:装备中ID／外衣 = SELECT_ITEM
ENDSELECT

;実行後に一式持ってる判定を回す→ARG:1ならやらない
SIF !ARG:1
	CALL EQUIP_CLOTHE_SET_CHECK



;下着制限か確認
;ARG：1の場合に確認を入れる
@SMALL_LINGERIE_CHECK(ARG)

SIF !EQUIP:内衣限制／极小 && !EQUIP:内衣限制／贴纸
	RETURN
IF !ARG
	CALL CLOTHE_STRIP_LINGERIE_OVERWRITE
	RETURN
ENDIF
IF EQUIP:内衣限制／极小
	PRINTL 现在的衣服只能穿＜尺寸极小＞和＜贴纸类型＞的内衣。
ELSEIF EQUIP:内衣限制／贴纸
	PRINTL 现在的衣服只有＜贴纸类型＞的内衣可以穿。
ELSE
	RETURN
ENDIF
PRINTFORML 要脱掉<％＃穿着衣服／名称＃％＞并穿上<％ITEMNAME:SELECT_ITEM％>吗？
CALL ASK_YN
SIF RESULT
	RETURN 1
CALL CLOTHE_STRIP_LINGERIE_OVERWRITE



;シールのみか確認
;ARG：1の場合に確認を入れる
@STICKER_LINGERIE_CHECK(ARG)

SIF !EQUIP:内衣限制／贴纸
	RETURN
IF !ARG
	CALL CLOTHE_STRIP_LINGERIE_OVERWRITE
	RETURN
ENDIF
PRINTL 现在的衣服只有＜贴纸类型＞的内衣可以穿。
PRINTFORML 要脱掉<％＃穿着衣服／名称＃％＞并穿上<％ITEMNAME:SELECT_ITEM％>吗？
CALL ASK_YN
SIF RESULT
	RETURN 1
CALL CLOTHE_STRIP_LINGERIE_OVERWRITE



;衣服解除
@CLOTHE_STRIP_LINGERIE_OVERWRITE

EQUIP:装备中ID／衣服 = 0
EQUIP:内衣限制／极小 = 0
EQUIP:内衣限制／贴纸 = 0



;抵抗した場合用の準備
@CHANGE_CLOTHE_RESIST_CHECK
;RETURN_PLAN　元の装備や元の露出度を保存する

SIF !TARGET
	RETURN
SIF (CFLAG:无抵抗 || !BASE:体力) && !GROUPMATCH(CSTR:状态／主人公的孩子,"成长中","成长后")
	RETURN

;各種装備中ID→EQUIP:0～19
;TFLAG:Ａ露出→140,-20して120
FLAG_REF = 120
FOR LOCAL,1,16
	RETURN_PLAN:LOCAL = EQUIP:LOCAL
NEXT
FOR LOCAL,20,25
	RETURN_PLAN:LOCAL = TFLAG:(LOCAL +FLAG_REF)
NEXT


;抵抗
;ARG　１はプレゼント、2は脱衣の場合
@CHANGE_CLOTHE_RESIST(ARG)

SIF !TARGET
	RETURN
SIF (CFLAG:无抵抗 || !BASE:体力) && !GROUPMATCH(CSTR:状态／主人公的孩子,"成长中","成长后")
	RETURN
CALL AJUST_STRIP_FLAG
RETURN_PLAN:0 = 0
FLAG_REF = 120
FOR LOCAL,20,25
	SIF RETURN_PLAN:LOCAL >= TFLAG:(LOCAL +FLAG_REF)
		RETURN_PLAN:0 ++
NEXT
IF RETURN_PLAN:0 < 5
	FOR LOCAL,1,16
		EQUIP:LOCAL = RETURN_PLAN:LOCAL
	NEXT
	IF ARG == 2
		PRINTFORMW 试图脱掉%CALLNAME%的衣服，但遭到抵抗……
	ELSEIF ARG == 1
		PRINTFORMW 赠送了，试图给%CALLNAME%穿上，但遭到抵抗……
		
		;渡そうとして拒否されたらアイテム戻す
		EQUIP:SELECT_ITEM = 0
		ITEM:SELECT_ITEM ++
	ELSE
		PRINTFORMW 试图给%CALLNAME%穿上，但遭到抵抗……
	ENDIF
	RETURN 1
ENDIF




