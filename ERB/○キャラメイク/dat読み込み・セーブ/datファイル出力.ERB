
;簡易版奴隷出力
@OUTPUT_CHARA_DATA_SELECT
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTL ・输出奴隶的数据，并保存为可在更改保存数据或新游戏时调用的格式。
PRINTL （将保存为dat文件）
PRINTL 由于版本升级，可能无法加载以前的数据。请谅解。
DRAWLINE
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("牛舍")
	PRINTL
NEXT
CALL PRINTL_ALIGN
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  8] 更改显示项目
PRINTLC 　
PRINTL [ 99] 取消
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN

CASEELSE
	TARGET = RESULT -100
	
	;出典[era魔界牧場]の奴隷は複製不可にしとくよ
	IF CSTR:原作名 == "era魔界牧场"
		PRINTW 原作名[era魔界牧场]的奴隶设定为不能输出。
		RESTART
	ENDIF
	CALL OUTPUT_CHARA_DATA_CLEATE
	RETURN
ENDSELECT
RESTART



;キャラメイク中に来るとき
@CHARA_MAKE_OUTPUT_DATA
#DIM NOW_CHARA_MAKE

IF CALLNAME == ""
	CALL PRINTW_WORD_COLOR,@"　请设置名称","黄"
	RETURN
ENDIF
PRINTW 正在将角色制作中的数据输出为dat文件。

;コピー
ADDCOPYCHARA TARGET
NOW_CHARA_MAKE = TARGET
TARGET = CHARANUM -1

;コピーの初期値を出す
CALL CHARA_MAKE_END_CALC

;下へ
CALL OUTPUT_CHARA_DATA_CLEATE

;コピーを消す
DELCHARA TARGET
TARGET = NOW_CHARA_MAKE



;キャラ選択後
@OUTPUT_CHARA_DATA_CLEATE

;キャラメイク中フラグON
FLAG:正在化妆角色 = 1

;キャラのコピーを作成
ADDCOPYCHARA TARGET
SAVE_TARGET = TARGET
TARGET = CHARANUM -1

;初期値が用意されているデータを初期値にリセット
FOR LOCAL,0,100
	CFLAG:LOCAL = CFLAG:(LOCAL +100)
	ABL:LOCAL = ABL:(LOCAL +100)
	MAXBASE:LOCAL = MAXBASE:(LOCAL +100)
	BASE:LOCAL = MAXBASE:LOCAL
	CSTR:LOCAL = %CSTR:(LOCAL +100)%
	EQUIP:LOCAL = EQUIP:(LOCAL +100)
NEXT

;初期値はどうせキャラ読み込み後に上書きされる　けど消しといたほうがバグ起こさなそう
VARSET CFLAG,0,100,200
VARSET EQUIP,0,100,200
VARSET CSTR,"",100,200

;一般使用部分はリセット
VARSET CFLAG,0,300,1000
VARSET EQUIP,0,300,2000
VARSET ABL,0,100,300
VARSET MAXBASE,0,100,300
VARSET BASE,0,100,300
VARSET CSTR,"",300,3000

;EXPの100～199は使う
VARSET EXP,0,0,100
VARSET EXP,0,200,2000
VARSET JUEL

;固定フラグON
CFLAG:灵力固定 = 1
CFLAG:魔力固定 = 1

;消去された素質あれば付ける
SIF MARK:消除乳房自卑感
	TALENT:乳房自卑 = 1
SIF MARK:消除乳房刺激厌恶感
	TALENT:乳房刺激厌恶感 = 1
SIF MARK:处女结界解除 || MARK:处女结界破坏
	TALENT:处女结界 = 1
SIF MARK:自尊心崩坏
	TALENT:自尊心高 = 1
SIF MARK:高傲消失
	TALENT:高傲 = 1
SIF MARK:坚强崩坏
	TALENT:坚强 = 1
SIF MARK:抗拒消失
	TALENT:抗拒 = 1
SIF MARK:傲慢消失
	TALENT:傲慢 = 1
SIF MARK:乐观消失
	TALENT:乐观 = 1
SIF MARK:领袖魅力崩坏
	TALENT:领袖魅力 = 1
SIF MARK:正义败北
	TALENT:正义感 = 1
SIF MARK:凌辱少女心
	TALENT:少女心 = 1
SIF MARK:自制力崩坏
	TALENT:自制力 = 1
VARSET MARK

;バストサイズ素質調整
CALL BUSTSIZE_TALENT_SET

;ランク再計算
CFLAG:级别 = MAXBASE:等级 /10

;一旦追跡対象に
CFLAG:追踪对象 = 1

;隠蔽は無効に→ランダムならどうせまたONになる
FLAG:角色化妆隐蔽有效 = 0

;バージョン突っ込む
CFLAG:dat创建版本 = GAMEBASE_VERSION

;CSV読み込みと同じ処理
;装備がある部分のIDを入れる
CALL CHARA_EQUIP_REGISTER

;このへん確実なのでいちいち書かなくてもいいように
SIF TALENT:处女结界
	CALL VARGIN_BARRIER
SIF TALENT:先天母乳体质
	MARK:母乳体质 = 1
SIF EXP:出产
	MARK:母乳体质 = 1

;確認とセーブ位置選択へ
CALL OUTPUT_CHARA_DATA_CONFIRM

;セーブしてもキャンセルしてもTARGETは消す
DELCHARA TARGET
TARGET = SAVE_TARGET



;確認
@OUTPUT_CHARA_DATA_CONFIRM

CLEARLINE LINECOUNT

;ステータス部分使う
;CALL SHOW_STATUS_DETAIL
CALL CHARA_MAKE_SLAVE_DATA(9)

CALL PRINTL_ALIGN
;DRAWLINE
PRINTL 将使用此数据进行保存。可以吗？
CALL ASK_YN
SIF RESULT
	RETURN
CFLAG:追踪对象 = 0
CALL OUTPUT_CHARA_DATA_LIST



;セーブするデータ位置選択
@OUTPUT_CHARA_DATA_LIST
#DIM DYNAMIC PAGE
#DIM SAVE_NUM
#DIMS SAVE_PROFILE,2

PAGE_MAX = 5
CLEARLINE LINECOUNT
SIF PAGE < 1
	PAGE = 1
PRINTL 请选择保存的编号
DRAWLINE
FOR LOCAL,20 *(PAGE -1) +100,20 *PAGE +100
	IF FIND_CHARADATA(TOSTR(LOCAL))
		CHKCHARADATA RESULTS
		PRINTFORML [{LOCAL}] %RESULTS%
	ELSE
		PRINTFORM [{LOCAL}]
		CALL PRINTL_WORD_COLOR,@" NO DATA","灰"
	ENDIF
NEXT
DRAWLINE
CALL PRINT_NOW_PAGE(PAGE)
CALL RIGHT_RETURN_BUTTON(0,"キャンセル")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	;データが既にある場合は確認
	SAVE_NUM = RESULT
	IF FIND_CHARADATA(TOSTR(SAVE_NUM))
		CALL PRINTL_WORD_COLOR,@"！<{SAVE_NUM}>号已存在角色数据。可以覆盖吗？","黄"
		CALL ASK_YN
		SIF RESULT
			RESTART
	ENDIF
	
	;表示するデータに名前・種族・おっぱい
	SAVE_PROFILE:1 = %PRINT_BUSTSIZE(ABL:胸围大小)%【%PRINT_BUSTSIZE_TALENT()%】
	SAVE_PROFILE = 【%CALLNAME%】【%CSTR:种族%】%SAVE_PROFILE:1%
	SAVECHARA TOSTR(SAVE_NUM),SAVE_PROFILE,TARGET
	PRINTFORMW %CALLNAME%的数据已输出至<{SAVE_NUM}>号。
	RETURN
ENDSELECT
RESTART




