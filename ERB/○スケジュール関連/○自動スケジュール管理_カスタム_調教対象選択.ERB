
;調教対象を決める
;ARG→ＡＢＣ
@AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_SELECT(ARG)
#DIM DYNAMIC PAGE
#DIM TRAIN_SLAVE_NUM
#DIMS PATTERN

SELECTCASE ARG
CASE 0
	PATTERN = Ａ
CASE 1
	PATTERN = Ｂ
CASE 2
	PATTERN = Ｃ
ENDSELECT

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML 请选择%CALLNAME:SAVE_TARGET%的调教对象%PATTERN%。
PRINTL ・如有冲突，将优先按顺序安排调教计划。
PRINTL
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	
	;本人枠は空欄作る
	IF SAVE_TARGET == TARGET
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%本人","灰"
		CONTINUE
	ELSEIF CFLAG:追踪对象 || CSTR:住处 == "体内" || CFLAG:牛舍号码 || !CFLAG:日程设定可能／调教
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：设定不可","灰"
		CONTINUE
	ENDIF
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL ABL_WORK_PRINT(0,"百合癖")
	PRINTFORM %PRINT_BUSTSIZE(ABL:胸围大小)%
	CALL PRINT_BUST_C(1,1)
	SIF FLAG:淫乳奴隶存在 && !MARK:淫乳
		PRINT 　　
	CALL PRINT_MILKTANK(1,0,1)
	PRINTL
NEXT
CALL PRINTL_ALIGN
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTLC [  8] 更改显示项目
PRINTLC 　
PRINTL [ 99] 取消
BINPUT
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 99
	RETURN

CASEELSE
	TRAIN_SLAVE_NUM = RESULT -100
	
	;CFLAG:自動スケジュール／調教対象ID／Ａ→520
	;IDを入れる
	CFLAG:SAVE_TARGET:(520 +ARG) = CFLAG:TRAIN_SLAVE_NUM:ID
	RETURN
ENDSELECT
RESTART




