
;天気表示
;ARG→明日の天気も表示
@SHOW_WEATHER(ARG)

;行になんかあれば空欄つける
SIF !LINEISEMPTY()
	PRINT 　　　
PRINTFORM 天气：%SAVESTR:天气／今天%
SIF !ARG
	RETURN
PRINTFORML 　　　明天的天气：%SAVESTR:天气／明天%



;朝昼夕夜の表示
@PRINT_TIME_NOW(ARG)
#FUNCTIONS

SELECTCASE ARG
CASE 0
	RETURNF "朝"
CASE 1
	RETURNF "昼" 
CASE 2
	RETURNF "夕"
CASE 3
	RETURNF "夜"
CASEELSE
	RETURNF "未知"
ENDSELECT

