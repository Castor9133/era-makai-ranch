
;ごほうび選択
;TARGET,ANIMAL,PET_NAME指定済み
@MASTER_REWORD_ANIMAL_SELECT

;撫でバリエーション　結果はどれも同じ
CALL PET_STROKE_SENTENCE

;ペット対応のおやつチェック
CALL SELECT_PET_SNACK
INPUT
PRINTL

;1かつおやつを持ってると使用
IF RESULT && ITEM:ITEM_NUM
	CALL PET_COMMU_SNACK(ITEM_NUM)
ELSE
	CALL PET_COMMU_STROKE
ENDIF
PRINTW



;バリエーションに意味はない撫で選択肢
@PET_STROKE_SENTENCE

STR_REF = 8100
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)
PRINTFORMLC [ 0] %RESULTS%
PRINTL



;ペット対応のおやつチェック
@SELECT_PET_SNACK

SELECTCASE ANIMAL
CASE "堕落天马"
	ITEM_NUM = GETNUM(ITEM,"精力萝卜")
CASE "双头犬"
	ITEM_NUM = GETNUM(ITEM,"谜肉肉干")
CASE "魔界仓鼠"
	ITEM_NUM = GETNUM(ITEM,"烤魔界葵花籽")
ENDSELECT

;持っているなら表示+個数+今の体型
IF ITEM:ITEM_NUM
	PRINTFORM [ 1] 给予<%ITEMNAME:ITEM_NUM%>：拥有数量{ITEM:ITEM_NUM}个。　
	CALL PRINT_PET_SHAPE(ANIMAL,0,1)
ELSE
	CALL PRINTL_WORD_COLOR,@"　　 %ITEMNAME:ITEM_NUM%：0","灰"
ENDIF



;ペットなでなで
;TARGET,ANIMAL,PET_NAME指定済み
@PET_COMMU_STROKE

;地の文呼び出し
CALL PET_COMMU_MESSAGE_STROKE

;なつき度増加倍率算出→増加
PRINT [
CALL PET_FRIENDRY_TIMES_CALC("撫で")
CALL PET_FRIENDRY_PLUS(RESULT,50)
PRINTL ]



;ペットにおやつ
;TARGET,ANIMAL,PET_NAME指定済み
;ARG→アイテムNO
@PET_COMMU_SNACK(ARG)

CALL PET_COMMU_MESSAGE_SNACK(ARG)
PRINT [
CALL PET_FRIENDRY_TIMES_CALC("零食")
CALL PET_FRIENDRY_PLUS(RESULT,300)

;体型増加
CALL PET_WEIGHT_PLUS(ARG)
PRINTL ]
ITEM:ARG --






