@COM26_MESSAGE
;乳舐め

CALL TRAIN_INSERT_MESSAGE

;横乳時かなり変えないと変かな
IF TFLAG:侧乳露出
	PRINTFORM 从衣服旁边露出的%CALLNAME%%SLANG_B()%被
ELSEIF TFLAG:露出乳沟
	PRINTFORM %CALLNAME%因为衣服容不下而裸露在外的%SLANG_B()%被
ELSE
	PRINTFORM %BUST_CLOTHES()%%CALLNAME%的%SLANG_STAIN("Ｂ")%%SLANG_B()%
	IF ABL:胸围大小 >= BUSTSIZE_丰乳
		PRINT 从侧面抬起，
	ELSEIF ABL:胸围大小 >= BUSTSIZE_普乳
		PRINT 捧起，
	ELSE
		PRINT 的尖端故意避开，
	ENDIF
ENDIF
PRINTL 用舌头来回舔着…



