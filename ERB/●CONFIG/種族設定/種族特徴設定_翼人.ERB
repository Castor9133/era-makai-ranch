
;翼人
@TRIBE_FEATURE_CONFIG_WINGHUMAN

CLEARLINE LINECOUNT
PRINTL 请选择【翼人】的种族设定。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTLC [ 0] 肤色变为【色白】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／翼人,0),1)
PRINTLC [ 1] 把体型向【苗条】靠拢
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／翼人,1),1)
PRINTLC [ 2] 发色变为【天蓝色】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／翼人,2),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(5)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL 肤色选择种抽到【标准】、【褐色】、【小麦色】时将变为【色白】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／翼人"),INPUT_NUM)
CASE 1
	PRINTL 体型从【苗条】和【瘦弱】中抽选。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／翼人"),INPUT_NUM)
CASE 2
	PRINTL 将发色变为【天蓝色】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／翼人"),INPUT_NUM)
CASE 98
	PRINTL 【翼人】的种族设定回复到默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_WINGHUMAN
CASE 99
	RETURN
ENDSELECT
RESTART


