
;日付を表示
;ARG→1なら合計日数も表示
@SHOW_DATE(ARG)

;季節・曜日もFUCTIONでまとめた
PRINTFORM %SAVESTR:牧场名% {DAY:年数}年目【%SHOW_DATE_SEASON()%{DAY:日期,2}日／%SHOW_DATE_WEEK()%】

;27,28日は月末表記
SIF DAY:日期 >= 27
	CALL PRINT_WORD_COLOR("<月末> ","黄")
PRINTFORM %PRINT_TIME_NOW(TIME)%

;合計日数
SIF ARG
	PRINTFORML （第{DAY}天）



;日付もろもろの計算
@DATE_CALC
#DIM DAY_CALC

;1週間＝7日、1季節＝4週間＝28日、1年＝4季節＝16週間＝112日
;経過日数-1/112+1で年数計算
DAY:年数 = (DAY -1)/112 +1

;経過日数から28ずつ引いた回数を記録、4で割った余りが季節
DAY:季节 = 0
DAY_CALC = DAY
WHILE 1
	SIF DAY_CALC <= 28
		BREAK
	DAY:季节 ++
	DAY_CALC -= 28
WEND
DAY:季节 = DAY:季节 %4

;経過日数/7の余りが曜日
;1日目→月曜日・フラグの最初→月曜日にするため-1で補正
DAY:曜日 = (DAY -1) %7

;経過日数/28の余りが季節内の日付
;0だと28
DAY:日期 = DAY %28
SIF !DAY:日期
	DAY:日期 = 28



;季節の表示関数
@SHOW_DATE_SEASON()
#FUNCTIONS

SELECTCASE DAY:季节
CASE 0
	RETURNF "春"
CASE 1
	RETURNF "夏"
CASE 2
	RETURNF "秋"
CASE 3
	RETURNF "冬"
ENDSELECT



;曜日表示
@SHOW_DATE_WEEK()
#FUNCTIONS

SELECTCASE DAY:曜日
CASE 0
	RETURNF "月"
CASE 1
	RETURNF "火"
CASE 2
	RETURNF "水"
CASE 3
	RETURNF "树"
CASE 4
	RETURNF "金"
CASE 5
	RETURNF "土"
CASE 6
	RETURNF "天"
ENDSELECT







