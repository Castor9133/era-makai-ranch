CASE 1
	PRINT [植物]　　
CASE 2
	PRINT [声望]　　
CASE 3
	PRINT [夺回]　　
CASE 4
	PRINT [事故]　　
CASE 5
	PRINT [入侵]　　
CASE 6
	PRINT [有处女结界]
CASE 7
	PRINT [拍卖行]　
CASE 8
	PRINT [上等种族]
CASE 9
	PRINT [天界种族]
	
;CSV読み込み専用
CASE 10
	PRINT [异世界转移]
ENDSELECT



;種族とか表示
;ARG→LOCAL
@PRINT_LIST_TRIBE(ARG)
#DIMS TRIBE_DATA
#DIMS TRIBE_DISP

;種族は確実にある→上位・天界だとジョブなし身分欄ありの可能性　神格も考える
TRIBE_DATA = 【%LIST_TRIBE:ARG%】

;1つずつ足していくと上手いこと表示されないかな
SIF LIST_JOB:ARG != ""
	TRIBE_DATA += @"【%LIST_JOB:ARG%】"
SIF LIST_POSITION:ARG != ""
	TRIBE_DATA += @"[%LIST_POSITION:ARG%]"
SIF LIST_DIVINITY:ARG
	TRIBE_DATA += "[神格]"

;短縮表示に対応しなきゃならんかった
SELECTCASE LIST_TRIBE:ARG
CASE "Ｈ身人"
	TRIBE_DISP = 半身人
CASE "Ｈ精灵"
	TRIBE_DISP = 半精灵
CASE "Ｄ精灵"
	TRIBE_DISP = 暗精灵
CASEELSE
	TRIBE_DISP = %LIST_TRIBE:ARG%
ENDSELECT

;未所持強調表示フラグで色つける
CALL POSSESSION_COLOR_CHECK(ARG,TRIBE_DISP)
SIF RESULT
	SETCOLOR 0xFFFF00
PRINTFORMLC %TRIBE_DATA%
RESETCOLOR



;未所持強調表示フラグで色つける
;RETURN 1したら色付け
;ARG→LOCAL
;ARGS→TRIBE_DISP
@POSSESSION_COLOR_CHECK(ARG,ARGS)

SELECTCASE FLAG:奴隶候选未拥有的强调显示形式
CASE 1
	;種族未所持
	SIF !CMATCH(CSTR:种族,ARGS)
		RETURN 1
CASE 2
	;ジョブ未所持
	SIF !CMATCH(CSTR:职业,LIST_JOB:ARG)
		RETURN 1
CASE 3
	;種族未所持or種族一致でもジョブ未所持
	FOR TARGET_COUNT,1,CHARANUM
		TARGET = TARGET_COUNT
		SIF CSTR:种族 != ARGS
			RETURN 1
		SIF CSTR:职业 != LIST_JOB:ARG
			RETURN 1
	NEXT
CASE 4
	;種族未所持or種族一致でも身分未所持
	FOR TARGET_COUNT,1,CHARANUM
		TARGET = TARGET_COUNT
		SIF CSTR:种族 != ARGS
			RETURN 1
		SIF CSTR:初始值／身分 != LIST_POSITION:ARG
			RETURN 1
	NEXT
ENDSELECT



;魔力表示
@SLAVE_LIST_MAGIC_POWER(ARG)

SELECTCASE LIST_MAGIC_POWER:ARG
CASE 0
	CALL PRINT_WORD_COLOR("魔力：☓　","灰")
CASE 1 TO 3
	CALL PRINT_WORD_COLOR("魔力：△　","")
CASE 4 TO 7
	CALL PRINT_WORD_COLOR("魔力：○　","")
CASEELSE
	CALL PRINT_WORD_COLOR("魔力：◎　","青绿")
ENDSELECT


