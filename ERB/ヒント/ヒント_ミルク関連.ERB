
;おっぱい関連目次
@HINT_MILK
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTL 请选择要查看其说明的项目。
DRAWLINE
BR = 0
STR_REF = 9060

;ページで出す項目変更
SELECTCASE PAGE
CASE 1
	CALL HINT_BUTTON_LIST(0,15)
CASE 2
	CALL HINT_BUTTON_LIST(15)
ENDSELECT
DRAWLINE
CALL HINT_DETAIL_MILK
CALL PRINTL_ALIGN(5)
DRAWLINE
PRINTLC [90] 页面切换
PRINTFORMLC PAGE：{PAGE}／{PAGE_MAX}
PRINTL [99] 返回
INPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 29
	SELECT_TIPS = RESULT
CASE 90
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_TIPS = -1
CASE 99
	RETURN
ENDSELECT
RESTART



;おっぱい関連解説
@HINT_DETAIL_MILK

STR_NUM = STR_REF +SELECT_TIPS

;対応IDでないなら汎用出して帰る
IF SELECT_TIPS < 0 || SELECT_TIPS >= 30 || STR:STR_NUM == ""
	CALL NOT_SELECT_HINT_COMMON
	RETURN
ENDIF

;項目名
PRINTFORML 　《 %STR:STR_NUM% 》
SELECTCASE STR:STR_NUM
