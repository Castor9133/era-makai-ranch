
;おっぱいスラング設定
@SLANG_CONFIG_BUST

CLEARLINE LINECOUNT
PRINTL 请选择用地文等表示的乳房黑话的候选。
DRAWLINE
PRINTLC [ 0] 「欧派」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／乳房,0),1)
PRINTLC [ 1] 「乳房」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／乳房,1),1)
PRINTLC [ 2] 「乳肉」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／乳房,2),1)
PRINTLC [ 3] 「Bust」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／乳房,3),1)
PRINTLC [ 4] 「胸部」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／乳房,4),1)
PRINTLC [ 5] 「膨胀」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／乳房,5),0)
PRINTL 　（贫乳→「微微隆起」，绝壁→「胸部」）
PRINTLC [ 6] 《胸围大小》
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／乳房,6),0)
PRINTL 　（贫乳、绝壁→「乳房」）
PRINTL
PRINTL 　《 前缀设置 》
PRINTLC [10] [乳房弹性]
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／乳房,0),1)
PRINTLC [11] 「丰满的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／乳房,1),0)
PRINTL 　（巨乳以上时）
PRINTLC [12] 「快要爆开的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／乳房,2),0)
PRINTL 　（超乳以上时）
PRINTLC [13] 「淫乱」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／乳房,3),0)
PRINTL 　（淫乳时）
PRINTLC [14] 「淫荡的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／乳房,4),0)
PRINTL 　（淫乳时）
PRINTL
PRINTL 　《 特殊替换设置 》
PRINTLC [20] 首选特殊替换
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／乳房,0),0)
PRINTL 　…如果满足特殊替换条件，则显示优先级
PRINTLC [21] 「小乳房」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／乳房,1),0)
PRINTL 　（贫乳以下时）
PRINTLC [22] 「大奶子」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／乳房,2),0)
PRINTL 　（巨乳以上时）
PRINTLC [23] 「巨大乳块」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／乳房,3),0)
PRINTL 　（超乳時）
PRINTLC [24] 「极大乳房」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／乳房,4),0)
PRINTL 　（超乳時）
PRINTLC [25] 「乳罐」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／乳房,5),0)
PRINTL 　（乳罐刻印时）
PRINTLC [26] 「淫乳」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／乳房,6),0)
PRINTL 　（淫乳时）
PRINTLC [27] 「色情欧派」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／乳房,7),0)
PRINTL 　（淫乳时）
PRINTLC [28] 「萝莉《胸围大小》」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／乳房,8),0)
PRINTL 　（儿童标准身高，浓密巨乳以上时）
PRINTLC [29] 地文的设定
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／乳房,9),0)
PRINTFORML 　（当前设置：%SAVESTR:标识／乳房%）
CALL SLANG_CONFIG_FOOTER
INPUT
SELECTCASE RESULT
CASE 0 TO 6
	INVERTBIT FLAG:黑话标识／乳房,RESULT
CASE 10 TO 14
	INVERTBIT FLAG:黑话前缀／乳房,(RESULT -10)
CASE 20 TO 29
	INVERTBIT FLAG:黑话替换／乳房,(RESULT -20)
CASE 80
	FLAG:黑话标识／乳房 = 65535
CASE 81
	FLAG:黑话前缀／乳房 = 65535
CASE 82
	FLAG:黑话替换／乳房 = 65535
CASE 90
	FLAG:黑话标识／乳房 = 0
CASE 91
	FLAG:黑话前缀／乳房 = 0
CASE 92
	FLAG:黑话替换／乳房 = 0
CASE 98
	PRINTL 回复默认乳房黑话候选？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_SLANG_CONFIG_BUST
CASE 99
	IF !FLAG:黑话标识／乳房
		PRINTW 必须至少设置一个候选黑话。
	ELSE
		RETURN
	ENDIF
ENDSELECT
RESTART


