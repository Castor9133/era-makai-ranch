
;処女結界奴隷の初期設定
@CHARA_MAKE_FIXED_SLAVE_VIRGIN_BARRIER
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL CHARA_MAKE_SLAVE_DATA(PAGE,"初期设定")
CALL FIXED_SLAVE_CHANGE_LIST
CALL PRINTL_ALIGN(2)
PRINTFORMLC [80] 更改显示项目 <PAGE{PAGE,2}／{PAGE_MAX}>
PRINTFORML [89] 选择方式切换：\@ SELF_CHARA_MAKE_RANDOM ? 调整 # 手动输入 \@
DRAWLINE

;別なほうも見たいなら
IF CSTR:职业 == "退魔巫女"
	PRINTLC [90] 切换到【修女】
ELSE
	PRINTLC [90] 切换到【巫女】
ENDIF
PRINTLC [98] 提示
PRINTL [99] 完成
BINPUT
SELECTCASE RESULT
CASE 80
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 89
	INVERTBIT SELF_CHARA_MAKE_RANDOM,0
CASE 90
	;逆側のキャラリセット関数を呼ぶ
	IF CSTR:职业 == "退魔巫女"
		CALL NEWGAME_CHARA_RESET(4)
	ELSE
		CALL NEWGAME_CHARA_RESET(3)
	ENDIF
	SIF !FLAG:候选比例／一般种族／人类
		CALL CHARA_MAKE_FIXED_SLAVE_TRIBE_QUESTION
CASE 98
	CALL BROWSE_HINT("处女结界奴隶设定")
CASE 99
	IF !CFLAG:口上表示 && FLAG:口上表示
		CALL PRINTL_WORD_COLOR("没有设置口上，可以吗？","黄")
		CALL ASK_YN
		SIF RESULT
			RESTART
	ENDIF
	RETURN
CASEELSE
	CALL FIXED_SLAVE_CHANGE_INPUT(RESULT)
ENDSELECT
RESTART



