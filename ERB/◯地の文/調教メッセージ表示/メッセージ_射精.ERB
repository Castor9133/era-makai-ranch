
;射精メッセージ
@PRINT_EJACULATION_MESSAGE

SIF !TFLAG:调教中 && !TFLAG:日程外Ｈ && !TFLAG:循环中消息显示
	RETURN
SIF !SOURCE:射精次数
	RETURN
MESSAGE_EXIST ++
SIF !LINEISEMPTY()
	PRINTL

;スケジュール外なら射精メッセージ前に止める
IF TFLAG:日程外Ｈ
	PRINTW
ELSE
	PRINTL
ENDIF

;注ぎ込みは別パターン呼ぶ
IF SOURCE:注入灵力量 || SOURCE:注入魔力量
