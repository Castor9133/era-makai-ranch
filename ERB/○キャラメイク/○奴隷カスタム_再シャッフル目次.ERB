
;再シャッフルの目次
;飛ばした先でリストにして決めさせようかなと思ったけど厳選したいなら頑張って感出したくてやめた
@CHARA_MAKE_SLAVE_SHUFFLE_INDEX
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1

;使用貢献ptを計算
;FLAG:再シャッフルBITのBITがONなら対応する疑似定数を加算
FLAG:使用贡献PT = 0
FOR LOCAL,0,20
	SIF GETBIT(FLAG:重新调整BIT,LOCAL)
		FLAG:使用贡献PT += SHUFFLE_AGAIN_PT:LOCAL
NEXT
CLEARLINE LINECOUNT
CALL CHARA_MAKE_SLAVE_DATA(PAGE)
PRINTL 选择要调整的项目
PRINTFORML ＜贡献pt：%VALUE_DIGIT(FLAG:使用贡献PT)%／%VALUE_DIGIT(MONEY:贡献PT)%（决定时使用的pt／所持中的pt）＞
PRINTL

;シャッフル可能項目を絞った
PRINTLC [ 0] 名称
PRINTFORMLC [ 1] %SAVESTR:标识／乳房%
PRINTLC [ 2] 外表
PRINTLC [ 3] 性格・素质
PRINTLC [ 4] 性经验・体质
PRINTL [ 5] 服装
CALL PRINTL_ALIGN(2)
PRINTFORML [80] 更改显示项目 <PAGE{PAGE,2}／{PAGE_MAX}>
DRAWLINE
PRINTLC [90] 回复到初始状态
PRINTLC 　
PRINTL [99] 转到确认屏幕
BINPUT
SELECTCASE RESULT
CASE 0
	CALL CHARA_MAKE_SLAVE_SHUFFLE_NAME
CASE 1
	CALL CHARA_MAKE_SLAVE_SHUFFLE_BUST
CASE 2
	CALL CHARA_MAKE_SLAVE_SHUFFLE_APPEARAINCE
CASE 3
	CALL CHARA_MAKE_SLAVE_SHUFFLE_PERSONALITY
CASE 4
	CALL CHARA_MAKE_SLAVE_SHUFFLE_SENSITIVE
CASE 5
	CALL CHARA_MAKE_SLAVE_SHUFFLE_CLOTHE
CASE 80
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 90
	PRINTL 将更改还原到原？
	CALL ASK_YN
	IF !RESULT
		;-1されてるのでTARGETはバックアップになってる
		DELCHARA TARGET
		ADDCOPYCHARA TARGET
		FLAG:重新调整BIT = 0
	ENDIF
CASE 99
	RETURN
ENDSELECT
RESTART

