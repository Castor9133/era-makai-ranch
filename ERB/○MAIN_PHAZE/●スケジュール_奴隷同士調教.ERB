
;奴隷の調教
@TRAIN_LESBIAN_CHECK
#DIM EXIST_TRAIN

;調教スケジュール組んだ従業員がいるか
;あなたが調教スケジュールの場合は他スケジュール全部完了してから
EXIST_TRAIN = 0
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "调教"
		CONTINUE
	
	;PLAYER,ASSI,TARGETをセット
	PLAYER = TARGET
	FINDCHARA CFLAG:ID,CFLAG:调教对象ID
	
	;調教対象が見つからない場合CONTINUE
	SIF RESULT <= 0
		CONTINUE
	TARGET = RESULT
	
	;最初の1回だけスケジュール名表示
	SIF !EXIST_TRAIN
		PRINTL 　　　《 奴隶之间的调教 》
	CALL TRAIN_LESBIAN
	PLAYER = -1
	ASSI = -1
	EXIST_TRAIN ++
NEXT



;奴隷による奴隷の調教　ASSIなし
@TRAIN_LESBIAN
#DIM PLAY_C
#DIM PLAY_V
#DIM PLAY_A
#DIM PLAYER_HP_BEFORE
#DIM PLAYER_MAXHP_BEFORE
#DIM PLAYER_MP_BEFORE
#DIM PLAYER_MAXMP_BEFORE
#DIM PLAYER_EP_BEFORE
#DIM PLAYER_MAXEP_BEFORE
#DIM PLAYER_SP_BEFORE
#DIM PLAYER_LV_BEFORE
#DIM MATERNAL_BEFORE
#DIM TECHNIQUE_BEFORE
#DIM LESBIAN_BEFORE,2

SIF CSTR:状态／主人公的孩子 == "成长后"
	CALL CHILD_REBELLION(1)
CALL TRAIN_LESBIAN_MILK_SUCK_MESSAGE

;条件により下責めの判定してRESULTを保存
CALL TRAIN_LESBIAN_LOWER_CHECK_C
PLAY_C = RESULT
CALL TRAIN_LESBIAN_LOWER_CHECK_V
PLAY_V = RESULT
CALL TRAIN_LESBIAN_LOWER_CHECK_A
PLAY_A = RESULT

;下責めある場合WAIT
SIF PLAY_C || PLAY_V || PLAY_A
	PRINTW
CALL RESET_TRAIN_PALAM
TFLAG:训练前体力 = BASE:体力
TFLAG:吸奶 = 1
TFLAG:搾乳刺激 = 1
SIF ITEM:搾乳能量吸收 && GETBIT(＃个人有效／搾乳能量吸收＃) && GETBIT(＃有效／搾乳能量吸取＃) && CSTR:PLAYER:状态／主人公的孩子 != ""
	TFLAG:能量吸收 = 1

CALL STATUS_BEFORE_RECORD

;PLAYERの現在HP,MP,SP
PLAYER_HP_BEFORE = BASE:PLAYER:体力
PLAYER_MAXHP_BEFORE = MAXBASE:PLAYER:体力
PLAYER_MP_BEFORE = BASE:PLAYER:魔力
PLAYER_MAXMP_BEFORE = MAXBASE:PLAYER:魔力
PLAYER_EP_BEFORE = BASE:PLAYER:灵力
PLAYER_MAXEP_BEFORE = MAXBASE:PLAYER:灵力
PLAYER_SP_BEFORE = BASE:PLAYER:气力
PLAYER_LV_BEFORE = BASE:PLAYER:等级

;元の母性・レズ
MATERNAL_BEFORE = EXP:授乳爱情经验
LESBIAN_BEFORE:0 = EXP:百合调教经验
LESBIAN_BEFORE:1 = EXP:PLAYER:百合调教经验
TECHNIQUE_BEFORE = EXP:PLAYER:学习

;初経験枠入れ
V_PENIS = 震动棒
A_PENIS = 肛用震动棒
MILK_SUCK_PLAYER = %CALLNAME:PLAYER%
FOR LOCAL,0,15
	CALL TRAIN_LESBIAN_SOURCE(PLAY_C,PLAY_V,PLAY_A)
	SIF !LOCAL
		CALL PRINT_IMAGE("调教执行")
	CALL SOURCE_CHECK
NEXT
CALL SCHEDULE_ECSTASY_FIX
CALL SCHEDULE_LACTATION_TOTAL_RESULT
CALL TRAIN_LESBIAN_MILK_MESSAGE

;調教者
SAVE_TARGET = TARGET
TARGET = PLAYER
PRINTFORML ＜%CALLNAME%＞技巧EXP+{EXP:学习 -TECHNIQUE_BEFORE} 百合调教经验EXP+{EXP:百合调教经验 -LESBIAN_BEFORE:1} 
;CALL ABL_UP
;CALL MARK_GET
EXP:执行次数／百合调教执行 ++
EXP:区间执行次数／百合调教执行 ++

IF PLAYER_EP_BEFORE < BASE:灵力
	CALL EP_LEVEL_CALC
	BASE:等级 = RESULT
	IF MAXBASE:体力 < HP_MAX
		CFLAG:灵力蓄积量 += BASE:灵力 - PLAYER_EP_BEFORE

		IF CFLAG:灵力蓄积量 >= MAXBASE:体力 * 50
			CFLAG:灵力蓄积量 -= MAXBASE:体力 * 50
			;溢れた分は次の増加値-10まで下がる
			SIF CFLAG:灵力蓄积量 >= MAXBASE:体力 * 50
				CFLAG:灵力蓄积量 = MAXBASE:体力 * 50 -10
			MAXBASE:体力 += 50
			BASE:体力 += 50
		ENDIF
	ENDIF
ENDIF

;HP,MPが回復した場合に表示
FIX:0 = MAXBASE:体力 - PLAYER_MAXHP_BEFORE
FIX:1 = BASE:体力 - PLAYER_HP_BEFORE
FIX:2 = MAXBASE:灵力 - PLAYER_MAXEP_BEFORE
FIX:3 = BASE:灵力 - PLAYER_EP_BEFORE
FIX:4 = BASE:等级 - PLAYER_LV_BEFORE
FIX:5 = MAXBASE:魔力 - PLAYER_MAXMP_BEFORE
FIX:6 = BASE:魔力 - PLAYER_MP_BEFORE

SIF LOCAL == LINECOUNT && SUMARRAY(FIX,0,7)
	PRINTFORM %CALLNAME%：

SIF FIX:4 > 0
	CALL PRINTL_WORD_COLOR,@"LvUP！　Lv{PLAYER_LV_BEFORE} → Lv{BASE:等级}","浅蓝色"
SIF FIX:0
	PRINTFORM 最大体力＋%TOSTR(FIX:0,"#,0")%　
SIF FIX:1 > 0 && FIX:0 - FIX:1 > 0
	PRINTFORM 体力＋%TOSTR(FIX:1,"#,0")%　

SIF FIX:2
	PRINTFORM 最大灵力＋%TOSTR(FIX:2,"#,0")%　
SIF FIX:3 > 0 && FIX:2 - FIX:3 > 0
	PRINTFORM 灵力＋%TOSTR(FIX:3,"#,0")%　

SIF FIX:5 > 0
	PRINTFORM 最大魔力＋%TOSTR(FIX:5,"#,0")%　
SIF FIX:6 > 0 && FIX:5 - FIX:6 > 0
	PRINTFORM 魔力＋%TOSTR(FIX:6,"#,0")% 
SIF !LINEISEMPTY()
	PRINTL
PRINTL
TARGET = SAVE_TARGET

;被調教者

;授乳経験・レズ経験の表示
PRINTFORML ＜%CALLNAME%＞授乳经验EXP+{EXP:授乳爱情经验 -MATERNAL_BEFORE} 百合调教经验EXP+{EXP:百合调教经验 -LESBIAN_BEFORE} 
CALL ABL_UP
CALL MARK_GET
IF EP_BEFORE > BASE:灵力
	CALL EP_LEVEL_CALC
	LOCAL = RESULT

	IF LOCAL < BASE:等级
		SETCOLOR 0xEE10EE
		PRINTFORML 　等级下降　Lv{BASE:等级} → Lv{LOCAL} 
		RESETCOLOR
		BASE:等级 = LOCAL
		EXP:等级下降 ++
	ENDIF
ENDIF

;レズ調教の回数は女あなたでも増加しない
EXP:执行次数／被百合调教 ++
EXP:区间执行次数／被百合调教 ++

CALL SECTION_MP_COST
PRINTW
DRAWLINE



;Ｃ責め判定
@TRAIN_LESBIAN_LOWER_CHECK_C

;PLAYERのＣ絶頂10回以上+ローター
SIF !ITEM:备用阴蒂跳蛋 || EXP:PLAYER:Ｃ绝顶次数 < 10
	RETURN
CALL TRAIN_LESBIAN_C_MESSAGE
RETURN 1



;Ｖ
@TRAIN_LESBIAN_LOWER_CHECK_V

;非処女+PLAYERのＶ絶頂10回以上+バイブ
SIF TALENT:处女 || !ITEM:备用震动棒 || EXP:PLAYER:Ｖ绝顶次数 < 10
	RETURN
CALL TRAIN_LESBIAN_V_MESSAGE
RETURN 1



;Ａ
@TRAIN_LESBIAN_LOWER_CHECK_A

;Ａ非処女+アナルバイブ必須
SIF TALENT:Ａ处女 || !ITEM:备用肛用震动棒
	RETURN

;PLAYERがＡ絶頂10回以上+【サド】orPLAYERがＡ絶頂50回以上
SIF (EXP:PLAYER:Ａ绝顶次数 < 10 || !TALENT:PLAYER:抖Ｓ) && EXP:PLAYER:Ａ绝顶次数 < 50
	RETURN
CALL TRAIN_LESBIAN_A_MESSAGE
RETURN 1



;SOURCE入れ
@TRAIN_LESBIAN_SOURCE(PLAY_C,PLAY_V,PLAY_A)
#DIM PLAY_C
#DIM PLAY_V
#DIM PLAY_A

;母性大きく上がる
LOSEBASE:体力 = 10
LOSEBASE:气力 = 10
SOURCE:授乳 = 1000
SOURCE:Ｂ快感／百合调教 = 300
SOURCE:Ｎ快感／百合调教 = 700
SOURCE:耻辱 = 200
SOURCE:屈辱 = 200
SOURCE:支配 = 500
SOURCE:调教者习得 = 200

;下責めが入っている場合に追加
IF PLAY_C
	SOURCE:Ｃ快感／百合调教 = 300
	SOURCE:电池消费量 += 5
ENDIF
IF PLAY_V
	SOURCE:Ｖ快感／百合调教 = 500
	SOURCE:电池消费量 += 5
	SOURCE:屈辱 += 100
	SOURCE:耻辱 += 100
ENDIF
IF PLAY_A
	SOURCE:Ａ快感／百合调教 = 500
	SOURCE:电池消费量 += 5
	SOURCE:不洁 += 500
	SOURCE:屈辱 += 500
	SOURCE:耻辱 += 500
ENDIF



