
;魔王軍研究所に霊力を渡す
@TOWN_INSTITUTE
#DIM DYNAMIC SELECT_NUM

CALL ITEM_SHOP_BUDGET_MONEY_JUDGE
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_INSTITUTE
PRINTL 抽出的灵力交给研究所，兑换贡献pt和便利物品。
PRINTL 还有，＜灵力抽出装置＞等的调教用大型魔道具的开发委托可能。
PRINTL
CALL INSTITUTE_LIST
DRAWLINE
CALL ITEM_DETAIL_INSTITUTE(SELECT_NUM)
CALL PRINTL_ALIGN
CALL EP_DEVELOP_JUDGE(SELECT_NUM)
DRAWLINE
CALL RIGHT_RETURN_BUTTON
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	;購入処理→SELECT_NUMで変化
	CALL TOWN_INSTITUTE_BUY(SELECT_NUM)
CASE 99
	RETURN
CASE 10 TO 10 +INSTITUTE_LIST_NUM
	SELECT_NUM = RESULT
ENDSELECT
RESTART



;購入処理
;ARG→選択項目
@TOWN_INSTITUTE_BUY(ARG)
#DIM MAX_TRADE

SELECTCASE ARG
CASE 10
	;桁合わせしない
	MAX_TRADE = LIMIT(MONEY:储存灵力 /EP_CONTRIBUTION_PT,1,CHARA_MAKE_COST)
	PRINTFORML 贡献pt要换多少？MAX：%TOSTR(MAX_TRADE,"#,0")%pt）
	PRINTLC [ 0] 取消
	PRINTFORMLC [{MAX_TRADE}] 最大交换
	PRINTL
	PRINTL 或者输入数值。
	INPUT
	IF RESULT > 0 && RESULT <= MAX_TRADE
		MONEY:贡献PT += RESULT
		MONEY:储存灵力 -= (RESULT *EP_CONTRIBUTION_PT)
		PRINTFORMW 贡献pt为%TOSTR(RESULT,"#,0")%pt　被交换了。
	ENDIF
	
CASE 11
	PRINTL 要兑换＜奴隶候补设定变更票＞吗？
	PRINTL ※因为超高额，为了保险起见再确认进入。
	CALL ASK_YN
	SIF RESULT
		RETURN
	MONEY:储存灵力 -= ITEMPRICE:奴隶候补设定变更票
	ITEM:奴隶候补设定变更票 ++
	PRINTW ＜奴隶候补设定变更票＞交换了。
	
CASE 12
	CALL INSTITUTE_BUY_ITEM_COMMON("灵力抽出装置")
	MONEY:储存灵力 -= (ITEMPRICE:灵力抽出装置 /2)
	
CASE 13
	CALL INSTITUTE_BUY_ITEM_COMMON("魔力枷锁")
	MONEY:储存魔力 -= (ITEMPRICE:魔力枷锁 /2)
	
CASE 14
	CALL INSTITUTE_BUY_ITEM_COMMON("魔力补给装置")
	MONEY:储存灵力 -= (ITEMPRICE:魔力补给装置 /2)
	
CASE 15
	ITEM:魔改造魔力储存器 ++
	MONEY:储存魔力 = 0
	PRINTL 改造了＜魔改造魔力储存器＞。
	CALL MAGIC_STORAGE
	
CASE 16
	CALL INSTITUTE_BUY_ITEM_COMMON("小型灵力抽出装置")
ENDSELECT




;代金+アイテム増加処理
;ARGS→アイテム名
@INSTITUTE_BUY_ITEM_COMMON(ARGS)

IF FLAG:购物／开销记账
	MONEY:经费计上 += ITEMPRICE:ARGS
ELSE
	MONEY -= ITEMPRICE:ARGS
ENDIF
ITEM:ARGS ++
CALL PRINTW_WORD_COLOR,@"＜%ARGS%＞制造了。","浅蓝色"




