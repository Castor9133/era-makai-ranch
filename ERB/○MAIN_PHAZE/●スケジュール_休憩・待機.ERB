
;自由時間
@MAIN_REST_ROOM

;自由時間の誰か1人を見る→他を休憩にする　予定だけど今とりあえずみんなそのまま休憩
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "自由"
		CONTINUE
	IF CSTR:状态／主人公的孩子 == "成长中"
		CSTR:日程 = 成长
		CONTINUE
	ENDIF
	CSTR:日程 = 休息
NEXT
CALL MAIN_REST_ROOM_1
CALL MAIN_REST_ROOM_2



;休憩
@MAIN_REST_ROOM_1

;人数
WORKER = CMATCH(CSTR:日程,"休息")
SIF !WORKER
	RETURN
PRINTL 　　　《 休息 》
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "休息"
		CONTINUE
	;一番目に当たったキャラの名前
	PRINTFORM %CALLNAME%
	SIF WORKER > 1
		PRINT 们
	BREAK
NEXT
PRINTL 在自己的房间里悠闲地度过了…

;回復処理とメッセージ
HEAL_PRINT_DONE = 0
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "休息"
		CONTINUE
	CALL REST_HEAL
NEXT
PRINTW
DRAWLINE



;成長
@MAIN_REST_ROOM_2

WORKER = CMATCH(CSTR:日程,"成长")
SIF !WORKER
	RETURN

TARGET = -1
LOCAL = 0
HEAL_PRINT_DONE = 0

WHILE 1
	FINDCHARA CSTR:日程, "成长", TARGET + 1
	TARGET = RESULT
	SIF TARGET < 0
		BREAK
	IF !LOCAL
		PRINTL 　　　《 成长 》
		PRINTFORM %CALLNAME%
		SIF WORKER > 1
			PRINT 们
		PRINTL 正在健康成长…
		LOCAL = 1
	ENDIF
	PRINTFORM %CALLNAME%：
	;回復処理
	;CALL REST_HEAL
	;ランダムで経験値増加
	;接客はまだないのでRAND:5
	FIX = 20 + RAND:5
	ABL_NAME = %ABLNAME:FIX%
	SIF ABL_NAME != ""
		CALL EXP_UP(ABL_NAME)
	CALL ABL_UP_WORK
	RESETCOLOR
	PRINTL 
	SIF TARGET == CHARANUM - 1
		BREAK
WEND
PRINTW
DRAWLINE



;待機
@MAIN_REST_CAGE

CATTLE_COUNT = CMATCH(CSTR:日程,"等待")
SIF !CATTLE_COUNT
	RETURN
PRINTL 　　　《 等待 》
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "等待"
		CONTINUE
	PRINTFORM %CALLNAME%
	SIF CATTLE_COUNT > 1
		PRINT 们
	BREAK
NEXT
PRINTL 被关进牢房里度过…
HEAL_PRINT_DONE = 0
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != "等待"
		CONTINUE
	CALL REST_HEAL
NEXT
PRINTW
DRAWLINE




