
;装備の責めSOURCEを追加、メッセージ表示
@TRAIN_EQUIP_SOURCE_COMMON

;拘束TFLAGでの追加処理
FOR LOCAL,0,20
	SIF !GETBIT(TFLAG:拘束BIT,LOCAL)
		CONTINUE
	TRYCCALLFORM BIND_{LOCAL}_CONTINUE
		SIF TFLAG:调教中 || TFLAG:日程外Ｈ || SOURCE:体内凌辱中继续显示信息
			TRYCALLFORM BIND_{LOCAL}_CONTINUE_MESSAGE
	CATCH
	ENDCATCH
	BREAK
NEXT

;TEQUIPに応じてSOURCE追加処理
FOR LOCAL,0,300
	;FORM使えば済んだ
	SIF !TEQUIP:LOCAL
		CONTINUE
	TRYCCALLFORM EQUIP_{LOCAL}_CONTINUE
		;あったらメッセージ呼び→口上呼び
		;1行で済むやつはSOURCEのついでに入ってたりするのでTRY
		IF TFLAG:调教中 || TFLAG:日程外Ｈ || SOURCE:体内凌辱中继续显示信息
			TRYCALLFORM EQUIP_{LOCAL}_CONTINUE_MESSAGE
			CALL KOJO_PRINT("调教命令",TEQUIPNAME:LOCAL,"继续")
		ENDIF
	CATCH
	ENDCATCH
NEXT

;触手服でのSOURCE追加処理
CALL TRAIN_T_CLOTHE


