
;母乳の商品名表示
;ARG→0：名前を右揃え+商品名左揃え　1：揃えない
@PRINT_MILK_NAME(ARG)
#DIMS MILKWORD

SIF !MARK:母乳体质
	RETURN
MILKWORD =

;フレーバーミルク判定追加
IF CSTR:风味牛奶 != ""
	CALL PRINT_MILK_NAME_PREFIX(ARG)
	MILKWORD += RESULTS
	MILKWORD += CSTR:风味牛奶
	CALL PRINT_MILK_NAME_RESULT(ARG,MILKWORD)

ELSEIF CSTR:母乳商品名自由记述 != ""
	SETCOLOR 0xFF70FF
	IF ARG
		PRINTFORM %CSTR:母乳商品名自由记述%
	ELSE
		PRINTFORM %CSTR:母乳商品名自由记述,(FLAG:角色名称栏宽度 +28)%
	ENDIF

ELSEIF CSTR:母乳商品名浓度自动 != ""
	CALL PRINT_MILK_NAME_PREFIX(ARG)
	MILKWORD += RESULTS
	MILKWORD += CSTR:母乳商品名浓度自动
	CALL PRINT_MILK_NAME_RESULT(ARG,MILKWORD)
	
ELSE
	CALL PRINT_MILK_NAME_PREFIX(ARG)
	MILKWORD += RESULTS
	SIF !EXP:肉体改造
		MILKWORD += "天然"
	SIF TALENT:处女
		MILKWORD += "处女"
	SIF GROUPMATCH(CSTR:身高,"矮小","儿童体型") && TALENT:巨乳
		MILKWORD += "萝莉巨乳"
	SIF GROUPMATCH(CSTR:身高,"幼儿体型","儿童体型") && ABL:胸围大小 < BUSTSIZE_普乳
		MILKWORD += "ょぅι゛ょ"
	SIF CFLAG:上位种族 || TALENT:天界种族
		MILKWORD += CSTR:种族
	SIF CSTR:初始值／身分 == "王族"
		MILKWORD += "皇家"
	SIF CSTR:初始值／身分 == "贵族"
		MILKWORD += "贵族"
		
	;CSV取り込みキャラ用の素質
	SIF TALENT:ＪＳ
		MILKWORD += "ＪＳ"
	SIF TALENT:ＪＣ
		MILKWORD += "ＪＣ"
	SIF TALENT:ＪＫ
		MILKWORD += "ＪＫ"
		
	IF MARK:魔力母乳体质
		MILKWORD += SAVESTR:标识／魔力母乳
	ELSE
		MILKWORD += SAVESTR:标识／母乳
	ENDIF
	CALL PRINT_MILK_NAME_RESULT(ARG,MILKWORD)
ENDIF
RESETCOLOR



;接頭語共通
;ARG→0：名前を右揃え+商品名左揃え　1：揃えない
@PRINT_MILK_NAME_PREFIX(ARG)

IF ARG
	PRINTFORM %CALLNAME%特制
ELSE
	PRINTFORM %CALLNAME_DIGIT()%特制
ENDIF
SELECTCASE ABL:母乳浓度
CASE 0
	RESULTS =
CASE 1
	RESULTS = 浓厚
CASE 2
	RESULTS = 上质
CASE 3
	RESULTS = 丰润
CASE 4
	RESULTS = 特浓
CASE 5
	RESULTS = 极品
ENDSELECT



;結果表示共通
;ARG→0：名前を右揃え+商品名左揃え　1：揃えない
;ARGS→MILKWORD
@PRINT_MILK_NAME_RESULT(ARG,ARGS)

SETCOLOR 0xFF70FF
IF ARG
	PRINTFORM %ARGS%
ELSE
	PRINTFORM %ARGS,24,LEFT%
ENDIF



