
;妖狐
@TRIBE_FEATURE_CONFIG_SPECTERFOX

CLEARLINE LINECOUNT
PRINTL 请选择【妖狐】的种族设定。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL 固定：始终拥有魔力・素质【魔界适应】【动物耳】【尾巴】
PRINTLC [ 0] 把身高向【高挑】靠拢
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,0),1)
PRINTLC [ 1] 肤色变为【色白】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,1),1)
PRINTLC [ 2] 发色变为【金色】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,2),1)
PRINTLC [ 3] 发色变为【银色】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,3),1)
PRINTLC [ 4] 使所持魔力加倍
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,4),1)
PRINTLC [ 5] 素质【回复快】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,5),1)
PRINTLC [ 6] 素质【药毒耐性】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,6),1)
PRINTLC [ 7] 素质【被动物讨厌】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,7),1)
PRINTLC [ 8] 素质【怕太阳】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,8),1)
PRINTL
PRINTLC [10] 素质【煽动】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,10),1)
PRINTLC [11] 素质【傲慢】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,11),1)
PRINTLC [12] 素质【自尊心高】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,12),1)
PRINTLC [13] 素质【高傲】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,13),1)
PRINTLC [14] 素质【献身的】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,14),1)
PRINTLC [15] 素质【抖Ｓ】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,15),1)
PRINTLC [16] 素质【讨厌泡澡】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,16),1)
PRINTLC [17] 素质【爱慕虚荣】
CALL PRINT_ONOFF(GETBIT(FLAG:种族设定／妖狐,17),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(15)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL 当身高抽选到【标准】【矮小】【娇小】时，将转换为【高挑】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
CASE 1
	PRINTL 肤色选择种抽到【标准】、【褐色】、【小麦色】时将变为【色白】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
CASE 2
	PRINTL 头发颜色【金色】。
	PRINTL ※和【银色】二选一
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
	SIF GETBIT(FLAG:种族设定／妖狐,2) && GETBIT(FLAG:种族设定／妖狐,3)
		CLEARBIT FLAG:种族设定／妖狐,3
CASE 3
	PRINTL 使发色变成【银发】。
	PRINTL ※和【金色】二选一
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
	SIF GETBIT(FLAG:种族设定／妖狐,2) && GETBIT(FLAG:种族设定／妖狐,3)
		CLEARBIT FLAG:种族设定／妖狐,2
CASE 4
	PRINTL 在普通状态计算后魔力倍增。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
CASE 5
	PRINTL 被赋予素质【回复快】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
CASE 6
	PRINTL 被赋予素质【药毒耐性】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
CASE 7
	PRINTL 被赋予素质【被动物讨厌】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
CASE 8
	PRINTL 被赋予素质【怕太阳】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
CASE 10
	PRINTL 被赋予素质【煽动】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
CASE 11
	PRINTL 被赋予素质【傲慢】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
CASE 12
	PRINTL 被赋予素质【自尊心高】。
	PRINTL ※和【高傲】二选一
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
	SIF GETBIT(FLAG:种族设定／妖狐,12) && GETBIT(FLAG:种族设定／妖狐,13)
		CLEARBIT FLAG:种族设定／妖狐,13
CASE 13
	PRINTL 被赋予素质【高傲】。
	PRINTL ※和【自尊心高】二选一
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
	SIF GETBIT(FLAG:种族设定／妖狐,12) && GETBIT(FLAG:种族设定／妖狐,13)
		CLEARBIT FLAG:种族设定／妖狐,12
CASE 14
	PRINTL 被授予素质【献身的】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
CASE 15
	PRINTL 被赋予素质【抖Ｓ】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
CASE 16
	PRINTL 被赋予素质【讨厌泡澡】。
	SIF FLAG:玩笑表示
		PRINTL 我想是因为干湿尾巴要花点时间。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
CASE 17
	PRINTL 被赋予素质【爱慕虚荣】。
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"种族设定／妖狐"),INPUT_NUM)
CASE 98
	PRINTL 【妖狐】的种族设定回复到默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_SPECTREFOX
CASE 99
	RETURN
ENDSELECT
RESTART


