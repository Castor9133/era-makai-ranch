
;スラング表示設定目次
@SLANG_CONFIG

CLEARLINE LINECOUNT
PRINTL 《 黑话标识设置 》
DRAWLINE
PRINTL [ 0] 乳房
PRINTL [ 1] 乳头
PRINTL [ 2] 母乳
PRINTL [ 3] 膣
PRINTL [ 4] 肛门
PRINTL [ 5] 尻
PRINTL [ 6] 阴蒂
PRINTL [ 7] 精液
PRINTL [ 8] 阴茎
PRINT [ 9] 污垢添加
CALL PRINT_ONOFF(FLAG:黑话标识／污垢添加,1)
PRINTL
PRINTFORML [10] 儿童标准的身高的黑话适用：{FLAG:黑话／儿童标准上限身高数值}mm未满
CALL PRINTL_ALIGN(-5)
CALL DEFAULT_VOID_RETURN_BUTTON(1)
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL SLANG_CONFIG_BUST
CASE 1
	CALL SLANG_CONFIG_NIPPLE
CASE 2
	CALL SLANG_CONFIG_MILK
CASE 3
	CALL SLANG_CONFIG_VAGINA
CASE 4
	CALL SLANG_CONFIG_ANAL
CASE 5
	CALL SLANG_CONFIG_HIP
CASE 6
	CALL SLANG_CONFIG_CLITORIS
CASE 7
	CALL SLANG_CONFIG_SEMEN
CASE 8
	CALL SLANG_CONFIG_PENIS
CASE 9
	INVERTBIT FLAG:黑话标识／污垢添加,0
CASE 10
	PRINTL 请选择适用儿童标准的身高的黑话。
	PRINTLC [ 0] 【娇小】以下
	PRINTLC [ 1] 【矮小】以下
	PRINTL [ 2] 【儿童体型】以下
	PRINTL
	PRINTLC [90] （直接输入）
	PRINTL [99] （取消）
	INPUT
	SELECTCASE RESULT
	CASE 0
		FLAG:黑话／儿童标准上限身高数值 = HEIGHT_MAX_娇小
	CASE 1
		FLAG:黑话／儿童标准上限身高数值 = HEIGHT_MAX_矮小
	CASE 2
		FLAG:黑话／儿童标准上限身高数值 = HEIGHT_MAX_儿童体型
	CASE 90
		PRINTL 请输入适用儿童标准的身高的黑话上限值（适用低于设定值）以mm为单位。
		PRINTFORML （设定上限：【高身高】的值　={HEIGHT_MAX_标准}～0）
		INPUT
		SIF RESULT >= 0 && RESULT <= HEIGHT_MAX_标准
			FLAG:黑话／儿童标准上限身高数值 = RESULT
	ENDSELECT
CASE 98
	PRINTL 将所有候选黑话回复为默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_SLANG_CONFIG
CASE 99
	RETURN
ENDSELECT
RESTART

