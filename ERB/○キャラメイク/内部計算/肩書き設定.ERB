
;肩書き設定
@CHARA_SECOND_NAME_SETTING
#DIMS AFFILIATION

AFFILIATION += "【"
EXIST = 0
IF CSTR:所属 != ""
	AFFILIATION += CSTR:所属
	EXIST ++
ENDIF
IF CSTR:身份 != ""
	AFFILIATION += CSTR:身份
	EXIST ++
ENDIF
IF CSTR:职业 != ""
	SIF EXIST
		AFFILIATION += "・"
	AFFILIATION += CSTR:职业
	EXIST ++
ENDIF
AFFILIATION += "】"
IF EXIST
	CSTR:头衔 = %AFFILIATION%
ELSEIF TALENT:天界种族 || CFLAG:上位种族
	CSTR:头衔 = %CSTR:种族%
ELSE
	CSTR:头衔 = 普通的%CSTR:种族%
ENDIF


