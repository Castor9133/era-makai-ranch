
;建築判定
;ARG→選択項目
@ESTATE_JUDGE(ARG)

;非対応IDならそのまま帰る
IF ARG < 10 || ARG > 10 +ESTATE_LIST_NUM
	PRINTL
	RETURN
ENDIF
SELECTCASE ARG
CASE 10
	COST = ITEMPRICE:牛舍
	IF ITEM:牛舍 >= ESTATE_COWSHED_LIMIT
		CALL PRINTL_WORD_COLOR("　建造到最大","浅蓝色")
	ELSE
		CALL ESTATE_JUDGE_MONEY_CHECK("建築")
	ENDIF

CASE 11
	COST = ESTATE_COWSHED_EXTENSION
	IF !ITEM:牛舍
		CALL PRINTL_WORD_COLOR("　＜牛舍＞尚未建成","灰")
	ELSE
		CALL ESTATE_JUDGE_MONEY_CHECK("増築する牛舎を選択")
	ENDIF

CASE 12
	COST = ITEMPRICE:事务所扩建
	IF ITEM:事务所扩建 >= ESTATE_OFFICE_LIMIT
		CALL PRINTL_WORD_COLOR("　已达到当前版本的扩建上限","浅蓝色")
	ELSE
		CALL ESTATE_JUDGE_MONEY_CHECK("増築")
	ENDIF
	
CASE 13
	COST = ITEMPRICE:家庭浴池
	IF ITEM:家庭浴池
		CALL PRINTL_WORD_COLOR("　改建完成","浅蓝色")
	ELSEIF !ITEM:事务所扩建
		CALL PRINTL_WORD_COLOR("　需要至少扩建＜事务所＞1次。","灰")
	ELSE
		CALL ESTATE_JUDGE_MONEY_CHECK("改装")
	ENDIF

CASE 14
	COST = ITEMPRICE:大浴场
	IF ITEM:大浴场
		CALL PRINTL_WORD_COLOR("　建造完成","浅蓝色")
	ELSEIF !ITEM:家庭浴池
		CALL PRINTL_WORD_COLOR("　需要＜家庭浴池＞","灰")
	ELSE
		CALL ESTATE_JUDGE_MONEY_CHECK("建築")
	ENDIF

CASE 15
	COST = ITEMPRICE:宠物小屋
	IF ITEM:宠物小屋 >= ESTATE_PETHOUSE_LIMIT
		CALL PRINTL_WORD_COLOR("　已达到当前版本的扩建上限","浅蓝色")
	ELSEIF !ITEM:事务所扩建
		CALL PRINTL_WORD_COLOR("　需要至少扩建＜事务所＞1次。","灰")
	ELSE
		CALL ESTATE_JUDGE_MONEY_CHECK("増築")
	ENDIF

CASE 16
	COST = ITEMPRICE:奴隶寮
	IF ITEM:奴隶寮
		CALL PRINTL_WORD_COLOR("　建造完成","浅蓝色")
	ELSEIF !ITEM:事务所扩建
		CALL PRINTL_WORD_COLOR("　需要至少扩建＜事务所＞1次。","灰")
	ELSE
		CALL ESTATE_JUDGE_MONEY_CHECK("建築")
	ENDIF

CASE 17
	COST = ITEMPRICE:奴隶寮扩建
	IF !ITEM:奴隶寮
		CALL PRINTL_WORD_COLOR("　我首先需要建造＜奴隶寮＞","灰")
	ELSEIF ITEM:奴隶寮扩建 >= ESTATE_DORMITORY_LIMIT
		CALL PRINTL_WORD_COLOR("　最大扩建完成","浅蓝色")
	ELSE
		CALL ESTATE_JUDGE_MONEY_CHECK("増築")
	ENDIF
	
CASE 18
	COST = ITEMPRICE:系统化厨房
	IF ITEM:系统化厨房
		CALL PRINTL_WORD_COLOR("　改建完成","浅蓝色")
	ELSEIF !ITEM:事务所扩建
		CALL PRINTL_WORD_COLOR("　需要至少扩建＜事务所＞1次。","灰")
	ELSE
		CALL ESTATE_JUDGE_MONEY_CHECK("改装")
	ENDIF
ENDSELECT



;資金判定になったときの建築可能チェック
;ARGS→OKの場合の文面
@ESTATE_JUDGE_MONEY_CHECK(ARGS)

IF CAN_LOAN_MONEY +MONEY < COST
	PRINTFORMLC 　贷款上限加持有金不足：%VALUE_DIGIT(COST)%G　
ELSE
	PRINTFORMLC [  0] %ARGS%（贷款自动优先）：%VALUE_DIGIT(COST)%G
ENDIF
PRINTFORML （%VALUE_DIGIT(MONEY)%G持有／%VALUE_DIGIT(CAN_LOAN_MONEY)%G可贷款） 




