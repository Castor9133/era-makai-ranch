	CASEELSE
		PRINTFORM 在%CALLNAME%口内深处、
	ENDSELECT
ELSE
	SELECTCASE RAND:5
	CASE 0
		PRINTFORM 在%CALLNAME%被顶到发呕的喉底、
	CASE 1
		PRINTFORM 肉棒堵死喉口脉动射精，%CALLNAME%鼻腔里溢出窒息般的呜咽，
	CASE 2
