
;动作确认用口上：显示全部候选
@KOJO_OPERATION_CHECK(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

TRYCALLFORM KOJO_GENERAL_INDEX_操作确认口上(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

; 若 MESSAGE 箱里有内容则全部打印
SIF MESSAGE_COUNT
	CALL MESSAGE_PRINT_OPERATION_CHECK

; ======================================
; 泛用口上：选句与显示（调试全显版）
@MESSAGE_PRINT_OPERATION_CHECK
#DIM  LCOUNT,2		; 循环用
#DIM  FIND_ARRAY_COUNT,VARSIZE("MESSAGE_BOX")		; 各 stock 命中数
#DIM  CANDIDATE_COUNT		; 随机抽选用箱个数
#DIMS CANDIDATE_BOX,500	; 随机抽选用箱
#DIM  TEMP

; 对 MESSAGE_COUNT 循环，逐条显示
FOR LCOUNT,0,MESSAGE_COUNT
	CALL MESSAGE_PRINT_ESCAPE(MESSAGE_BOX:LCOUNT)
	RESETCOLOR
	PRINTL
NEXT

