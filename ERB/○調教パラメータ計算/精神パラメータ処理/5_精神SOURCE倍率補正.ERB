
;⑤TALENTなどで倍率計算して乗算
@MIND_EXP_MULTIPLY

CALL MIND_EXP_MULTIPLY_CATTLE
CALL MIND_EXP_MULTIPLY_NASTY
CALL MIND_EXP_MULTIPLY_OBEDIENCE
CALL MIND_EXP_MULTIPLY_SURRENDER
CALL MIND_EXP_MULTIPLY_PAIN
CALL MIND_EXP_MULTIPLY_FEAR
CALL MIND_EXP_MULTIPLY_UNPLEASANT
CALL MIND_EXP_MULTIPLY_HATE
CALL MIND_EXP_MULTIPLY_DESPAIR

;崩壊なら失意以外の感情全て0
SIF !CFLAG:崩坏
	RETURN
FOR LOCAL,30,40
	SIF SOURCENAME:LOCAL != "失意"
		CONTINUE
	SOURCE:LOCAL = 0
NEXT
SOURCE:被虐快感经验 = 0
SOURCE:百合调教经验 = 0
SOURCE:学习 = 0
SOURCE:授乳爱情经验 = 0



;乳牛
@MIND_EXP_MULTIPLY_CATTLE

SIF CFLAG:乳牛
	TIMES SOURCE:乳牛,1.30
SIF MARK:淫乳
	TIMES SOURCE:乳牛,1.30

;搾乳器なら*1.5
SIF TFLAG:搾乳器
	TIMES SOURCE:乳牛,1.50



;淫欲
@MIND_EXP_MULTIPLY_NASTY

;0にしてから共通通し
FIX = 0
CALL MIND_CALC_MULTIPLY_COMMONFIX

;+-入れ替え
FIX *= -1

;+の場合は半減
SIF FIX > 0
	FIX /= 2

;なんか少ないので+感情は+50
FIX += 150
SIF TALENT:幼稚
	FIX += 20
SIF TALENT:解放
	FIX += 10
SIF TALENT:接受快感
	FIX += 20
SIF MARK:快感刻印
	FIX += 30
SIF MARK:淫纹
	FIX += 50
	
SIF TALENT:否定快感
	FIX -= 20
IF !BASE:好感度
	SIF TALENT:坚强
		FIX -= 20
	SIF TALENT:自制力
		FIX -= 10
	SIF TALENT:冷漠
		FIX -= 10
	SIF TALENT:清纯
		FIX -= 10
	SIF TALENT:高雅
		FIX -= 10
ENDIF
SIF MARK:淫核 && SOURCE:Ｃ快感
	FIX += 30
FIX = LIMIT(FIX,10,300)
SOURCE:淫欲 = SOURCE:淫欲 *FIX /100



;恭順
@MIND_EXP_MULTIPLY_OBEDIENCE

FIX = 0
CALL MIND_CALC_MULTIPLY_COMMONFIX
FIX *= -1
SIF FIX > 0
	FIX /= 2
FIX += 150

;気力0%→-30
SIF !BASE:气力
	FIX -= 30
SIF TALENT:清纯
	FIX += 10
SIF TALENT:单纯 && !PLAYER
	FIX += 100
SIF MARK:快感刻印
	FIX += 10
SIF MARK:淫纹
	FIX += 20

IF !BASE:好感度
	SIF BASE:理性
		FIX -= 30
	SIF TALENT:否定快感
		FIX -= 20
	SIF TALENT:坚强
		FIX -= 20
	SIF TALENT:自尊心高
		FIX -= 10
	SIF TALENT:高傲
		FIX -= 20
	SIF TALENT:抗拒
		FIX -= 20
ENDIF
SIF TALENT:自制力
	FIX -= 10
SIF TALENT:冷漠
	FIX -= 10
SIF TALENT:傲慢
	FIX -= 10
SIF BASE:抵抗心
	FIX -= 20
SIF BASE:厌恶感
	FIX -= 20
FIX = LIMIT(FIX,10,300)
SOURCE:恭顺 = SOURCE:恭顺 *FIX /100

;苦痛・恐怖刻印があると恭順1/5
SIF MARK:痛苦刻印
	SOURCE:恭顺 /= 5
SIF MARK:恐怖刻印
	SOURCE:恭顺 /= 5

;あなた調教以外なら恭順0
SIF PLAYER
	SOURCE:恭顺 = 0



;屈服
@MIND_EXP_MULTIPLY_SURRENDER

FIX = 0
CALL MIND_CALC_MULTIPLY_COMMONFIX
FIX *= -1
SIF FIX > 0
	FIX /= 2
FIX += 150

;TALENT:処女結界破壊→150
FOR LOCAL,150,200
	SIF TALENT:LOCAL
		FIX += 20
NEXT

;体力0→+50
SIF !BASE:体力
	FIX += 50

;気力0→+50
SIF !BASE:气力
	FIX += 50

SIF MARK:屈服刻印
	FIX += 30
SIF MARK:痛苦刻印
	FIX += 20
SIF MARK:恐怖刻印
	FIX += 20
SIF MARK:绝望刻印
	FIX += 10
SIF MARK:淫纹
	FIX += 20

IF !BASE:好感度
	SIF TALENT:否定快感
		FIX -= 20
	SIF TALENT:坚强
		FIX -= 20
ENDIF
SIF TALENT:自制力
	FIX -= 10
SIF TALENT:冷漠
	FIX -= 10
FIX = LIMIT(FIX,10,300)
SOURCE:屈服 = SOURCE:屈服 *FIX /100



;苦痛
@MIND_EXP_MULTIPLY_PAIN

FIX = 100
CALL MIND_CALC_MULTIPLY_COMMONFIX

;気力0%→+30
SIF !BASE:气力
	FIX += 30
SIF TALENT:幼稚
	FIX += 50
SIF TALENT:怕痛
	FIX += 30
SIF TALENT:胆怯
	FIX += 20
	
SIF TALENT:不怕痛
	FIX -= 30
SIF TALENT:感情缺乏
	FIX -= 20
SIF TALENT:坚强
	FIX -= 20
SIF CFLAG:上位种族
	FIX -= 20
FIX = LIMIT(FIX,10,300)
SOURCE:痛苦 = SOURCE:痛苦 *FIX /100



;恐怖
@MIND_EXP_MULTIPLY_FEAR

FIX = 100
CALL MIND_CALC_MULTIPLY_COMMONFIX
SIF TALENT:幼稚
	FIX += 20
SIF TALENT:胆怯
	FIX += 50
SIF TALENT:弱势
	FIX += 20
SIF TALENT:悲观
	FIX += 30
	
SIF TALENT:感情缺乏
	FIX -= 30
SIF TALENT:乐观
	FIX -= 30
SIF TALENT:坚强
	FIX -= 20
SIF TALENT:粗野
	FIX -= 20
SIF TALENT:高雅
	FIX -= 10
SIF TALENT:正义感
	FIX -= 30
FIX = LIMIT(FIX,10,300)
SOURCE:恐怖 = SOURCE:恐怖 *FIX /100

;乳牛→恐怖1/5
SIF CFLAG:乳牛
	SOURCE:恐怖 /= 5



;不快
@MIND_EXP_MULTIPLY_UNPLEASANT

FIX = 100
CALL MIND_CALC_MULTIPLY_COMMONFIX

SIF TALENT:感情缺乏
	FIX -= 30
FIX = LIMIT(FIX,10,300)
SOURCE:不快 = SOURCE:不快 *FIX /100



;反感
@MIND_EXP_MULTIPLY_HATE

SIF TFLAG:春药使用中
	TIMES SOURCE:反感,2.00
FIX = 100
CALL MIND_CALC_MULTIPLY_COMMONFIX

;恋慕でHP0でない→-50
SIF ＃陷落状态／恋慕以上＃ && BASE:体力
	FIX -= 50
FIX -= EX:总绝顶
SIF TALENT:傲慢
	FIX += 20
SIF TALENT:抗拒
	FIX += 30
SIF TALENT:坚强
	FIX += 30
SIF TALENT:自尊心高
	FIX += 30
SIF TALENT:高傲
	FIX += 50
	
SIF TALENT:胆怯
	FIX -= 10
SIF TALENT:老实
	FIX -= 10
SIF TALENT:坦率
	FIX -= 20
SIF TALENT:幼稚
	FIX -= 10
SIF MARK:奉仕中毒
	FIX -= 30
FIX = LIMIT(FIX,10,300)
SOURCE:反感 = SOURCE:反感 *FIX /100

;隷属or乳牛→反感・失意を0
SIF ＃陷落状态／隶属＃ || CFLAG:乳牛
	SOURCE:反感 = 0



;失意
@MIND_EXP_MULTIPLY_DESPAIR

FIX = 100
CALL MIND_CALC_MULTIPLY_COMMONFIX

;尊厳50%以上→-30
SIF BASE:尊严 >= 5000
	FIX -= 30
	
;霊力0で戦闘職→+50
SIF !BASE:灵力 && !CFLAG:非战斗职业
	FIX += 50
	
;体力0なら+50
SIF !BASE:体力
	FIX += 50
SIF TFLAG:搾乳刺激
	FIX -= (ABL:搾乳中毒 *2)
SIF TALENT:弱势
	FIX += 10
SIF TALENT:胆怯
	FIX += 30
SIF TALENT:悲观
	FIX += 20
SIF TALENT:卑屈
	FIX += 50
SIF TALENT:贞操观念 && !TALENT:处女
	FIX += 100
SIF MARK:处女结界破坏 && !CFLAG:上位种族
	FIX += 100
	
SIF TALENT:幼稚
	FIX -= 30
SIF TALENT:高雅
	FIX -= 20
SIF TALENT:乐观
	FIX -= 20
SIF TALENT:坚强
	FIX -= 30
	
;魔力枷かつ霊力があれば半減
SIF EQUIP:魔力枷锁 && BASE:灵力
	FIX /= 2
FIX = LIMIT(FIX,10,300)
SOURCE:失意 = SOURCE:失意 *FIX /100

;恋慕で半減
SIF ＃陷落状态／恋慕以上＃ && BASE:体力
	SOURCE:失意 /= 2

;隷属・乳牛・気力ありなら0
SIF ＃陷落状态／隶属＃ || CFLAG:乳牛 || BASE:气力
	SOURCE:失意 = 0




