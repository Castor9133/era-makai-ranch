
;③振り分け前のSOURCEに倍率かける
@MIND_SOURCE_MULTIPLY

;主にTALENTで補正
;授乳愛情経験
CALL MATERNAL_EXP

;不潔
SIF TALENT:污臭钝感
	TIMES SOURCE:不洁,0.50
SIF TALENT:污臭敏感
	TIMES SOURCE:不洁,1.50
SIF TALENT:清纯
	TIMES SOURCE:不洁,1.20
SIF TALENT:高雅
	TIMES SOURCE:不洁,1.20
SIF TALENT:少女心
	TIMES SOURCE:不洁,1.20

;恥辱
IF TALENT:害羞
	TIMES SOURCE:耻辱,1.50
ELSEIF TALENT:不知羞恥
	TIMES SOURCE:耻辱,0.50
ENDIF
SIF TALENT:乳房刺激厌恶感 && (SOURCE:Ｂ快感 || SOURCE:Ｎ快感)
	TIMES SOURCE:耻辱,1.50

;屈辱
IF TALENT:自尊心高
	TIMES SOURCE:屈辱,1.30
ELSEIF TALENT:高傲
	TIMES SOURCE:屈辱,1.60
ELSEIF TALENT:自尊心低
	TIMES SOURCE:屈辱,0.80
ELSEIF TALENT:卑屈
	TIMES SOURCE:屈辱,0.50
ENDIF

;支配
IF TALENT:自尊心高
	TIMES SOURCE:支配,1.30
ELSEIF TALENT:高傲
	TIMES SOURCE:支配,1.60
ELSEIF TALENT:自尊心低
	TIMES SOURCE:支配,0.90
ELSEIF TALENT:卑屈
	TIMES SOURCE:支配,0.80
ENDIF



;授乳愛情経験倍率
@MATERNAL_EXP

;噴乳なしならおわり
SIF !NOWEX:喷乳
	RETURN

;バストサイズ補正*相手の体型補正*ABL補正*刻印補正
FIX = 100 +(ABL:胸围大小 *2)

;ABLによる増加
FIX += (ABL:母乳生产力 *2)
FIX += (ABL:母乳浓度 *5)
FIX += (ABL:奉仕精神 *2)

;噴乳量によりさらに増加
SIF NOWEX:喷乳 >= 2000
	FIX += 10
SIF NOWEX:喷乳 >= 1000
	FIX += 10

;刻印による増加
SIF MARK:乳罐
	FIX += 10
SIF MARK:荷斯坦奶牛
	FIX += 10
SIF MARK:牛奶机
	FIX += 10
SIF MARK:搾乳奴隶
	FIX += 10
SIF MARK:搾乳家畜
	FIX += 10
	;SIF MARK:ご奉仕雌奴隷
		;FIX += 100
	
;精神的なところが大きいので感情処理みたいに素質も見る
SIF TALENT:献身的
	FIX += 30
SIF TALENT:母性本能
	FIX += 50
SIF TALENT:幼稚
	FIX -= 30
IF !＃陷落状态／陷落以上＃
	SIF TALENT:自制力
		FIX -= 10
	SIF TALENT:难以越过的底线
		FIX -= 10
	SIF TALENT:贞操观念
		FIX -= 20
ENDIF

;出産していれば増加
SIF EXP:出产
	FIX += 50

;幼稚母性補正フラグで見る
;-のとき飛ばさないと変になる
IF TFLAG:幼稚母性补正 > 0
	IF GETBIT(TFLAG:幼稚母性补正,0) && GETBIT(TFLAG:幼稚母性补正,1)
		TIMES FIX,3.00
	ELSEIF GETBIT(TFLAG:幼稚母性补正,0) || GETBIT(TFLAG:幼稚母性补正,1)
		TIMES FIX,2.00
	ENDIF
ENDIF

;実の娘なら最大値も合わせて補正
IF TFLAG:幼稚母性补正 > 0 && GETBIT(TFLAG:幼稚母性补正,2)
	TIMES FIX,4.00
	FIX = LIMIT(FIX,1,1000)
ELSE
	FIX = LIMIT(FIX,1,500)
ENDIF
SOURCE:授乳爱情经验 *= FIX
SOURCE:授乳爱情经验 /= 100


