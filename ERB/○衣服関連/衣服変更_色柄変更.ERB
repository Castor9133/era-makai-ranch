;おっぱい露出改造
@BUST_STRIP_MODIFICATION

SIF !ITEM:魔法剪刀 && !FLAG:正在化妆角色
	RETURN
PRINTFORML %ITEMNAME:SELECT_ITEM%的%SAVESTR:标识／乳房%露出改造吗？
PRINTL [ 0] 侧乳露出改造
PRINTL [ 1] 乳沟穴改造
PRINTL [ 2] 露出乳沟
PRINTL [ 3] 侧乳＋乳沟穴
PRINTL [ 4] 授乳开口
PRINTL [ 5] 普通的衣服
PRINTL
PRINTL [99] 取消
INPUT

;元の衣服状態を上書きしてキャンセルしないように一旦1にするのは内部で
;計算めんどい+間違ってたら修正めんどい
SELECTCASE RESULT
CASE 0
	EQUIP:SELECT_ITEM = 1
	SETBIT EQUIP:SELECT_ITEM,3
CASE 1
	EQUIP:SELECT_ITEM = 1
	SETBIT EQUIP:SELECT_ITEM,4
CASE 2
	EQUIP:SELECT_ITEM = 1
	SETBIT EQUIP:SELECT_ITEM,5
CASE 3
	EQUIP:SELECT_ITEM = 1
	SETBIT EQUIP:SELECT_ITEM,3
	SETBIT EQUIP:SELECT_ITEM,4
CASE 4
	SETBIT EQUIP:SELECT_ITEM,10
CASE 5
	EQUIP:SELECT_ITEM = 1
CASEELSE
	RETURN 1
ENDSELECT



;淫乱改造
@NASTY_MODIFICATION
#DIM BUST_STRIP

SIF !ITEM:魔法剪刀 && !FLAG:正在化妆角色
	RETURN
PRINTFORML %ITEMNAME:SELECT_ITEM%改造得更加淫荡吗？
PRINTFORML 《 %SAVESTR:标识／乳房% 》
PRINTL
PRINTL [ 0] 乳暖簾
PRINTFORML [ 1] %SAVESTR:标识／乳房%完全露出
PRINTL [ 2] Ｂ露出就够了
PRINTL
PRINTL [99] 取消
INPUT
SIF RESULT > 2 || RESULT < 0
	RETURN 1
BUST_STRIP = RESULT

PRINTFORML 《 %SAVESTR:标识／膣% 》
PRINTL
PRINTL [ 0] 私处上的贴纸
PRINTFORML [ 1] %SAVESTR:标识／膣%完全露出
PRINTL [ 2] 普通的高腿裁
PRINTL
PRINTL [99] 取消
INPUT
SELECTCASE RESULT
CASE 0
	EQUIP:SELECT_ITEM = 1
	SETBIT EQUIP:SELECT_ITEM,7
CASE 1
	EQUIP:SELECT_ITEM = 1
	SETBIT EQUIP:SELECT_ITEM,9
CASE 2
	EQUIP:SELECT_ITEM = 1
CASEELSE
	RETURN 1
ENDSELECT
CALL NASTY_MODIFICATION_BUST(BUST_STRIP)



;おっぱい露出形状の適応
;ARG→BUST_STRIP
@NASTY_MODIFICATION_BUST(ARG)

SELECTCASE ARG
CASE 0
	SETBIT EQUIP:SELECT_ITEM,6
CASE 1
	SETBIT EQUIP:SELECT_ITEM,8
ENDSELECT


