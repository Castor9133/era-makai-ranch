
;衣服の修理
@VISIT_REPAIR_CLOTHE

PRINTFORML 你想帮%CALLNAME%修理破损的%＃穿着衣服／名称＃%吗？（将使用1块衣服修复布）
CALL ASK_YN
SIF RESULT
	RETURN
ITEM:衣服修理布 --
CLEARBIT EQUIP:(EQUIP:装备中ID／衣服),1
CLEARBIT EQUIP:(EQUIP:装备中ID／衣服),2
PRINTFORML 已经帮%CALLNAME%修复了破损的%＃穿着衣服／名称＃%。
CALL KOJO_PRINT("访问","衣服修理")
PRINTW



;栄養ドリンク
@VISIT_TAKE_ENERGY_DRINK

;最大体力の20%か400の多いほうが回復量になる
HEAL = MAX(400,MAXBASE:体力 *20 /100)
PRINTFORML 让%CALLNAME%喝了营养饮料。
PRINTFORML %CALLNAME%体力有所回复！

;アイテム使用時回復関数
CALL ITEM_USE_HEAL(HEAL)
CFLAG:当日制限／营养饮料 ++
ITEM:营养饮料 --
TRYCALL EXCRETION_BLADDER_ON_NUTRITION_DRINK
PRINTW



;ハーブティー
@VISIT_DRINK_HERBAL_TEA

;精神力、理性を10%回復＆乳牛堕ちを20%減少
;1日1回は通常、それ以降は1/5にする
PRINTFORML 让%CALLNAME%喝了花草茶。
PRINTFORML %CALLNAME%似乎平静了一些。

;理性・精神力回復
;MAXなら回復処理しないようになる処理が共通関数内にある
;【崩壊】【洗脳】だと回復しなくなった
HEAL = 1000
SIF CFLAG:当天限用／花草茶
	HEAL /= 5
SIF BASE:理性
	CALL MIND_BASE_DIRECT_PLUS("理性",HEAL)
CALL MIND_BASE_DIRECT_PLUS("精神力",HEAL)

;乳牛堕ち減少
HEAL = 2000
SIF CFLAG:当天限用／花草茶
	HEAL /= 5
SIF !CFLAG:乳牛
	CALL MIND_BASE_DIRECT_MINUS("乳牛堕落",HEAL)
CFLAG:时刻限制／花草茶 ++
CFLAG:当天限用／花草茶 ++
ITEM:花草茶 --
PRINTW >
SOURCE:精神参数增减已完成 = 0


;----------------------------------------------------------------
; 停止泌乳（平日・会いに行く）
;----------------------------------------------------------------
@VISIT_MANUAL_DRY

PRINTFORML 你要令%CALLNAME%停止泌乳（停止产奶）吗？
CALL ASK_YN
SIF RESULT
	RETURN
CALL PREGNANCY_MANUAL_DRY
CALL KOJO_PRINT("访问","停止泌乳","停止泌乳")
PRINTW


;----------------------------------------------------------------
; 终止妊娠（平日・会いに行く）
;----------------------------------------------------------------
@VISIT_ABORT_PREGNANCY

SIF CFLAG:魔界_妊娠S != 1
	RETURN
PRINTFORML 你要终止%CALLNAME%的妊娠吗？
CALL ASK_YN
SIF RESULT
	RETURN
CALL PREGNANCY_ABORT_MAKAI
CALL KOJO_PRINT("访问","终止妊娠","终止妊娠")
PRINTW









