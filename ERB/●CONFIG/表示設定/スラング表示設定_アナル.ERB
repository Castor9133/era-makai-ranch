
;アナルスラング設定
@SLANG_CONFIG_ANAL

CLEARLINE LINECOUNT
PRINTL 请选择用地文等表示的肛门黑话的候选。
DRAWLINE
PRINTLC [ 0] 「尻穴」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／肛门,0),1)
PRINTLC [ 1] 「菊门」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／肛门,1),1)
PRINTLC [ 2] 「Anal」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／肛门,2),1)
PRINTLC [ 3] 「肛门」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／肛门,3),1)
PRINTLC [ 4] 「屁股小穴」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／肛门,4),1)
PRINTLC [ 5] 「后面的穴」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／肛门,5),1)
PRINTLC [ 6] 「不洁之穴」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话标识／肛门,6),1)
PRINTL

PRINTL 　《 前缀设置 》
PRINTLC [10] 「淫乱」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／肛门,0),0)
PRINTL 　（淫尻时）
PRINTLC [11] 「淫荡的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／肛门,1),0)
PRINTL 　（淫尻时）
PRINTLC [12] 「未熟的」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话前缀／肛门,2),0)
PRINTL 　（儿童标准身高时）
PRINTL
PRINTL 　《 特殊替换设置 》
PRINTLC [20] 首选特殊替换
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／肛门,0),0)
PRINTL 　…如果满足特殊替换条件，则显示优先级
PRINTLC [21] 「疑似性器」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／肛门,1),0)
PRINTL 　（Ａ名器时）
PRINTLC [22] 「搾精器官」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／肛门,2),0)
PRINTL 　（Ａ名器时）
PRINTLC [23] 「淫穴」
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／肛门,3),0)
PRINTL 　（淫尻时）
PRINTLC [29] 地文的设定
CALL PRINT_ONOFF(GETBIT(FLAG:黑话替换／肛门,9),0)
PRINTFORML 　（当前设置：%SAVESTR:标识／肛门%）
CALL SLANG_CONFIG_FOOTER
INPUT
SELECTCASE RESULT
CASE 0 TO 5
	INVERTBIT FLAG:黑话标识／肛门,RESULT
CASE 10 TO 12
	INVERTBIT FLAG:黑话前缀／肛门,(RESULT -10)
CASE 20 TO 23
	INVERTBIT FLAG:黑话替换／肛门,(RESULT -20)
CASE 29
	INVERTBIT FLAG:黑话替换／肛门,(RESULT -20)
CASE 80
	FLAG:黑话标识／肛门 = 65535
CASE 81
	FLAG:黑话前缀／肛门 = 65535
CASE 82
	FLAG:黑话替换／肛门 = 65535
CASE 90
	FLAG:黑话标识／肛门 = 0
CASE 91
	FLAG:黑话前缀／肛门 = 0
CASE 92
	FLAG:黑话替换／肛门 = 0
CASE 98
	PRINTL 回复默认肛门黑话候选吗？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_SLANG_CONFIG_ANAL
CASE 99
	IF !FLAG:黑话标识／肛门
		PRINTW 必须至少设置一个候选黑话。
	ELSE
		RETURN
	ENDIF
ENDSELECT
RESTART


