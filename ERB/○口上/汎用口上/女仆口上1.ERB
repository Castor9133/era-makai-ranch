@KOJO_GENERAL_INDEX_女仆1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

IF TFLAG:Ｍ装备
	CALL KOJO_GENERAL_MOUTH_SHACKLE_1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
	RETURN
ELSEIF CFLAG:崩坏 && !CFLAG:洗脑
	IF GROUPMATCH(ARGS:0,"例文")
	ELSEIF GROUPMATCH(ARGS:1,"洗脑触手","崩坏")
	ELSE
		IF NOWEX:总绝顶
			CALL MESSAGE_BOX,@"「遵、遵命……♥ ……我、我……要……♥」"
			CALL MESSAGE_BOX,@"「……礼仪……做不到了……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……遵命……」"
		ENDIF
		RETURN
	ENDIF
ENDIF

SELECTCASE ARGS:0
CASE "例文"
	CALL MESSAGE_BOX,@"「【女仆1】已设置。\n规矩、侍奉、流程化羞耻；陷落后会主动以“服务”引导你更舒服。」"

CASE "调教命令"
	CALL KOJO_GENERAL_女仆1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

CASE "绝顶"
	IF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「啊……♥ 失礼了……女仆要失态了……♥」"
		CALL MESSAGE_BOX,@"「请、请继续命令……我会更舒服地服侍您……♥」"
	ELSE
		CALL MESSAGE_BOX,@"「……不行……这样会……♥」"
	ENDIF
	SIF NOWEX:Ａ绝顶
		IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
			CALL MESSAGE_BOX,@"「……失礼……！？　%ANAL_CALL()%……痛……可是……深处……像被命令牵着走……♥」"
			CALL MESSAGE_BOX,@"「……这也是……侍奉的一环吗……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……痛……！？　%ANAL_CALL()%……失礼了……请、请轻一点……」"
			CALL MESSAGE_BOX,@"「……只有那里……太勉强了……」"
		ENDIF
	SIF NOWEX:Ｕ绝顶
		IF TALENT:尿道敏感 || EX:尿道调教经验 >= 15
			CALL MESSAGE_BOX,@"「……失礼……那处竟……有侍奉般的麻意……♥」"
			CALL MESSAGE_BOX,@"「……这也是……身体被训练后的……失礼反应……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……好痛……失礼了……请、请轻些……」"
			CALL MESSAGE_BOX,@"「……只有刺与急……太失礼了……」"
		ENDIF

CASE "射精"
	IF SOURCE:膣内射精经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……已接收。会妥善处理……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「不、不要在里面……」"
		ENDIF
	ELSEIF SOURCE:尻穴射精经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……后方已接收。将按流程处理……♥」"
			CALL MESSAGE_BOX,@"「……失礼了……请给我一点时间整理……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……不行……后面不可以……」"
		ENDIF
	ELSEIF SOURCE:精饮经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……已咽下。谢谢款待……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「咳……咳……请、请别这样……」"
		ENDIF
	ELSEIF TEQUIP:手淫
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……手部已弄脏。将立刻进行清理……」"
		ELSE
			CALL MESSAGE_BOX,@"「……我会擦干净……」"
		ENDIF
	ELSEIF SOURCE:股间射精
		CALL MESSAGE_BOX,@"「股间射精已确认。将执行擦拭与清理流程。」"
		CALL MESSAGE_BOX,@"「……失礼。请稍等片刻。」"
	ELSEIF SOURCE:乳房射精
		CALL MESSAGE_BOX,@"「乳房射精已确认。将执行清理流程，并更换衣物。」"
	ELSEIF SOURCE:颜面射精
		CALL MESSAGE_BOX,@"「颜面射精已确认。将执行擦拭流程。」"
	ENDIF

CASE "搾乳"
	IF SOURCE:母乳漏出
		CALL MESSAGE_BOX,@"「……乳汁已自行渗出……我会处理干净……」"
		RETURN
	ENDIF
	IF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「遵命。将配合取乳服务……♥」"
		CALL MESSAGE_BOX,@"「若您想要更多……我会调整节奏与力度……♥」"
	ELSE
		CALL MESSAGE_BOX,@"「……我会配合……但请温柔些……」"
	ENDIF

CASE "抽出"
	CALL MESSAGE_BOX,@"「……身体发软。将进入恢复流程……请允许我稍作休息。」"
	CALL MESSAGE_BOX,@"「……遵命。我会重新整理姿势……」"

CASE "日程"
	SELECTCASE ARGS:1
	CASE "调教"
		SELECTCASE ARGS:2
		CASE "开始调教"
			CALL MESSAGE_BOX,@"「欢迎回来，%MASTER_CALL()%。今天也将由我为您服务。」"
		CASE "调教结束"
			CALL MESSAGE_BOX,@"「辛苦了。请先慢慢呼吸……我会照顾到您舒服为止。」"
		ENDSELECT
	CASEELSE
	ENDSELECT

CASE "阴茎称呼变更"
	CALL MESSAGE_BOX,@"「遵命。今后将按您指定的称呼称呼。」"

CASE "膣称呼变更"
	CALL MESSAGE_BOX,@"「遵命。将统一使用新称呼……」"

CASE "肛门称呼变更"
	CALL MESSAGE_BOX,@"「遵命。后方称呼也将一并变更……」"

CASE "吸欧派"
	SELECTCASE ARGS:1
	CASE "开始"
		CALL MESSAGE_BOX,@"「遵命。请您慢慢来，我会配合呼吸与姿势。」"
	CASE "结束"
		CALL MESSAGE_BOX,@"「已结束。若您还想继续……请直接命令我。」"
	ENDSELECT

CASE "访问"
	SELECTCASE ARGS:1
	CASE "入口"
		CALL MESSAGE_BOX,@"「%MASTER_CALL()%在吗？女仆前来报到。需要我做什么？」"
	CASEELSE
	ENDSELECT

CASE "事件"
	CALL MESSAGE_BOX,@"「已收到事件。请下达指示，我会立刻处理。」"

CASE "肉体改造"
	CALL MESSAGE_BOX,@"「……身体规格将被调整。遵命，我会尽快适应并继续服务。」"

CASE "战斗"
	SELECTCASE ARGS:1
	CASE "攻击"
		CALL MESSAGE_BOX,@"「遵命。将执行攻击。」"
	CASE "被击中"
		CALL MESSAGE_BOX,@"「……受击确认。仍可继续行动。」"
	CASEELSE
	ENDSELECT

CASEELSE
ENDSELECT
RETURN

@KOJO_GENERAL_女仆1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
CALL KOJO_GENERAL_女仆口上1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
RETURN

