
;種族特徴設定
@TRIBE_FEATURE_CONFIG
#DIMS TRIBE_PROSPERITY

CLEARLINE LINECOUNT
PRINTL 启用或设置人类的种族特性。
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE

;FLAG:種族設定／人間→2650
;STR:種族→6600
FLAG_REF = 2650
STR_REF = 6600
FOR LOCAL,0,30
	SIF LOCAL == 13 || LOCAL == 18
		PRINTL
	SIF FLAGNAME:(LOCAL +FLAG_REF) == ""
		BREAK
	PRINTFORML [{LOCAL,2}] %STR:(LOCAL +STR_REF)%
NEXT
CALL PRINTL_ALIGN
DRAWLINE
PRINTLC [98] 回复默认值
PRINTLC 　
PRINTLC [99] 完成
PRINTL
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL TRIBE_FEATURE_CONFIG_HUMAN
CASE 1
	CALL TRIBE_FEATURE_CONFIG_ELF
CASE 2
	CALL TRIBE_FEATURE_CONFIG_DARKELF
CASE 3
	CALL TRIBE_FEATURE_CONFIG_HALFELF
CASE 4
	CALL TRIBE_FEATURE_CONFIG_HALFLING
CASE 5
	CALL TRIBE_FEATURE_CONFIG_WINGHUMAN
CASE 6
	CALL TRIBE_FEATURE_CONFIG_DOGEAR
CASE 7
	CALL TRIBE_FEATURE_CONFIG_CATEAR
CASE 8
	CALL TRIBE_FEATURE_CONFIG_RABBITEAR
CASE 9
	CALL TRIBE_FEATURE_CONFIG_FOXEAR
CASE 10
	CALL TRIBE_FEATURE_CONFIG_RACCOONEAR
CASE 11
	CALL TRIBE_FEATURE_CONFIG_COWHORN
CASE 12
	CALL TRIBE_FEATURE_CONFIG_SHEEPHORN
CASE 13
	CALL TRIBE_FEATURE_CONFIG_HERMIT
CASE 14
	CALL TRIBE_FEATURE_CONFIG_DRAGON
CASE 15
	CALL TRIBE_FEATURE_CONFIG_SPECTERFOX
CASE 16
	CALL TRIBE_FEATURE_CONFIG_VAMPIRE
CASE 17
	CALL TRIBE_FEATURE_CONFIG_DHAMPIR
CASE 18
	CALL TRIBE_FEATURE_CONFIG_ANGEL
CASE 19
	CALL TRIBE_FEATURE_CONFIG_CELESTIAL
CASE 20
	CALL TRIBE_FEATURE_CONFIG_GODDESS
CASE 98
	IF !FLAG:可配置的候选奴隶
		CALL PRINTL_WORD_COLOR("必须使用＜奴隶候补设定变更票＞。","黄")
		WAIT
		RESTART
	ENDIF
	PRINTL 您想要将所有种族特征回复为默认值吗？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG
CASE 99
	RETURN
ENDSELECT
RESTART



