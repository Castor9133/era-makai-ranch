
;ちんぽ汚れでの不潔補正
@PENIS_STAIN_FIX

;ペニスに汚れがあると不潔など増加したり
;射精後
IF GETBIT(STAIN:0:阴茎,6)
	SOURCE:屈辱 += 2000
	SOURCE:不洁 += 5000
	SOURCE:爱情 += 1000
ENDIF

;尻挿入後
IF GETBIT(STAIN:0:阴茎,2)
	SOURCE:屈辱 += 5000
	SOURCE:不洁 += 10000
ENDIF



;恋慕以上で胸に母乳汚れないなら母乳パイズリ
@MILK_PAIZURI_SELF

SIF !BASE:母乳容量 || !＃陷落状态／恋慕以上＃ || GETBIT(STAIN:乳房,0) || TFLAG:Ｎ装备
	RETURN
SOURCE:Ｂ快感／主人公刺激 += 500
SOURCE:Ｎ快感／主人公刺激 += 500
SOURCE:爱情 += 1000
CALL SET_STAIN_TARGET("乳房","母乳")

;後で呼ぶのも今呼ぶのも変わりない
CALL MILK_PAIZURI_SELF_MESSAGE



;あなた主導母乳パイズリ
@MILK_PAIZURI_FORCE

SIF !BASE:母乳容量 || GETBIT(STAIN:乳房,0) || TFLAG:Ｎ装备
	RETURN
PRINTFORML 用%CALLNAME%的%SAVESTR:标识／母乳%代替润滑液吗？
CALL ASK_YN
SIF RESULT
	RETURN
SOURCE:Ｂ快感／主人公刺激 += 1000
SOURCE:Ｎ快感／主人公刺激 += 500
SOURCE:爱情 += 1000
CALL SET_STAIN_TARGET("乳房","母乳")
CALL MILK_PAIZURI_FORCE_MESSAGE




