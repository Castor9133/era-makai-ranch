
;フレーバーミルク化
@SELECT_WISH_MILK_FLAVOR

;STR:コーヒーミルク→5800
STR_REF = 5800
STR_MAX = 50
PRINTFORML 请选择您想要从%CALLNAME%身上出来的%SAVESTR:标识／母乳%的味道。
FOR LOCAL,STR_REF,STR_REF +STR_MAX
	SIF STR:LOCAL == ""
		CONTINUE
	PRINTFORMLC [{LOCAL -STR_REF,2}] %STR:LOCAL%
NEXT
CALL INPUTBUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 50
	RESULTS = %STR:(STR_REF +RESULT)%
CASE 900
	RESULTS =
CASE 901
	PRINTFORML 请输入%SAVESTR:标识／母乳%的味道。
	INPUTS
CASE 999
	RETURN
ENDSELECT

;RESULTSが現在と異なる場合に処理
SIF CSTR:风味牛奶 == RESULTS
	RETURN
IF RESULTS == ""
	PRINTFORML %CALLNAME%的%SAVESTR:标识／母乳%已经恢复为正常状态了吗？
ELSE
	PRINTFORML 您要将%CALLNAME%产出的%SAVESTR:标识／母乳%变成【%RESULTS%】吗？
ENDIF
CALL ASK_YN
SIF RESULT
	RETURN
CSTR:风味牛奶 = %RESULTS%
CSTR:母乳商品名浓度自动 =
CSTR:母乳商品名自由记述 =
IF RESULTS == ""
	CALL PRINTW_WORD_COLOR,@"%CALLNAME%的%SAVESTR:标识／母乳%已经恢复为正常状态了！","桃"
ELSE
	CALL PRINTW_WORD_COLOR,@"%CALLNAME%的%SAVESTR:标识／母乳%变成了%CSTR:风味牛奶%！","桃"
ENDIF
ITEM:龙之珠 = 0




