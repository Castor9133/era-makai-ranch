
;セーブデータ表示項目の編集
@PRINT_SAVEDATA_ITEM_CONFIG

;STR:セーブデータメモ→6650
STR_REF = 6650
CLEARLINE LINECOUNT
PRINTL 编辑要显示在存档数据中的项目。
DRAWLINE
PRINTL 存储时间：显示
FOR LOCAL,0,10
	SIF STR:(STR_REF +LOCAL) == ""
		BREAK
	PRINTFORM [{LOCAL,2}] %STR:(STR_REF +LOCAL),20%
	CALL PRINT_ONOFF(GETBIT(FLAG:保存数据显示信息BIT,LOCAL),1)
NEXT
PRINTL
PRINTFORML [20] 编辑保存数据注释：%SAVESTR:保存数据注释%
CALL PRINTL_ALIGN(-10)
CALL SAVEDATA_DISPLAY_CALC
PRINTFORML 显示项目：%RESULTS%
DRAWLINE
PRINTLC [98] 回复默认值
PRINTLC 　
PRINTL [99] 完成
BINPUT
SELECTCASE RESULT
CASE 0 TO 19
	INVERTBIT FLAG:保存数据显示信息BIT,RESULT
CASE 20
	PRINTL 请输入备注的内容。
	INPUTS
	SAVESTR:保存数据注释 = %RESULTS%
CASE 98
	FLAG:保存数据显示信息BIT = 0b111010111
CASE 99
	RETURN
ENDSELECT
RESTART



;セーブデータ表示項目を返す
@SAVEDATA_DISPLAY_CALC
#DIMS DISPLAY

;プレイ時間用計算
TIME:1 += GETMILLISECOND() /1000 -TIME:2
TIME:2 = GETMILLISECOND() /1000

;セーブ時刻は必ず表示
GETTIME
DISPLAY = %RESULTS%

IF GETBIT(＃保存数据／备注＃) && SAVESTR:保存数据注释 != ""
	LOCALS = %SAVESTR:保存数据注释%
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃保存数据／牧场名＃)
	LOCALS = 【%SAVESTR:牧场名%】
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃保存数据／难易度＃)
	LOCALS = %SAVESTR:难度%
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃保存数据／等级＃)
	LOCALS = 【Lv{MAXBASE:0:等级}】
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃存档数据／奴隶人数＃)
	;追跡対象だと捕まえてない＋あなたは入らない
	LOCAL = CMATCH(CFLAG:追踪对象,0) -1
	LOCALS = ＜奴隶{LOCAL,3}人>
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃存档数据／经过天数＃)
	LOCALS = 【第{DAY}天／%PRINT_TIME_NOW(TIME)%】
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃保存数据／日期＃)
	LOCALS = 【{DAY:年数}年度：%SHOW_DATE_SEASON()%{DAY:日期,2}日／%SHOW_DATE_WEEK()% %PRINT_TIME_NOW(TIME)%】
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃存档数据／游戏时间＃)
	LOCALS = 游戏时间 %PRINT_TIME(TIME:1)%
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃存档数据／版本＃)
	LOCALS = [ver{FLAG:保存数据的版本 /1000}.%TOSTR(FLAG:保存数据的版本 %1000,"000")%]
	DISPLAY += LOCALS
ENDIF
RESULTS = %DISPLAY%

