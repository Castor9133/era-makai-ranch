
;擬音表示設定
@ONOMATOPEIA_CONFIG

CLEARLINE LINECOUNT
PRINTL 设置拟音显示的开／关设置。
DRAWLINE
PRINTLC [ 0] 吸奶
CALL PRINT_ONOFF(GETBIT(FLAG:拟音表示,0),1)
PRINTLC [ 1] 揉胸
CALL PRINT_ONOFF(GETBIT(FLAG:拟音表示,1),1)
PRINTLC [ 2] 搾乳器
CALL PRINT_ONOFF(GETBIT(FLAG:拟音表示,2),1)
PRINTLC [ 3] 通用舔
CALL PRINT_ONOFF(GETBIT(FLAG:拟音表示,3),1)
PRINTLC [ 4] 活塞运动
CALL PRINT_ONOFF(GETBIT(FLAG:拟音表示,4),1)
PRINTLC [ 5] 射精
CALL PRINT_ONOFF(GETBIT(FLAG:拟音表示,5),1)
PRINTL
PRINTLC [ 6] 吸阴蒂
CALL PRINT_ONOFF(GETBIT(FLAG:拟音表示,6),1)
PRINTLC [ 7] 包乳花瓣搾乳触手
CALL PRINT_ONOFF(GETBIT(FLAG:拟音表示,7),1)
PRINTLC [ 8] 透明杯状搾乳触手
CALL PRINT_ONOFF(GETBIT(FLAG:拟音表示,8),1)
PRINTLC [ 9] 榨乳蠕虫触手
CALL PRINT_ONOFF(GETBIT(FLAG:拟音表示,9),1)
PRINTLC [10] 触手活塞
CALL PRINT_ONOFF(GETBIT(FLAG:拟音表示,10),1)
PRINTLC [11] 乳房露出
CALL PRINT_ONOFF(GETBIT(FLAG:拟音表示,11),1)
PRINTLC [12] 乳头露出
CALL PRINT_ONOFF(GETBIT(FLAG:拟音表示,12),1)
PRINTL
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTLC [20] 拟音批量ON
PRINTLC [21] 拟声批量OFF
IF FLAG:拟音表示
	SETCOLOR FLAG:拟音显示颜色编码
	PRINTFORML [30] 拟音显示颜色　：%UNICODE(0x2586)%(R:{GETRED(FLAG:拟音显示颜色编码)} G:{GETGREEN(FLAG:拟音显示颜色编码)} B:{GETBLUE(FLAG:拟音显示颜色编码)})
	RESETCOLOR
ELSE
	CALL PRINTL_WORD_COLOR("　　 拟音显示颜色","灰")
ENDIF
CALL DEFAULT_VOID_RETURN_BUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 19
	INVERTBIT FLAG:拟音表示,RESULT
CASE 20
	FLAG:拟音表示 = 65535
CASE 21
	FLAG:拟音表示 = 0
CASE 30
	CALL EDIT_COLOR_CODE(FLAG:拟音显示颜色编码)
	SIF RESULT
		FLAG:拟音显示颜色编码 = RESULT
CASE 98
	PRINTL 回复默认的拟音显示设置吗？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_ONOMATOPEIA_CONFIG
CASE 99
	RETURN
ENDSELECT
RESTART

