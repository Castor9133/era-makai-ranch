
;あなた調教で来る場所
@EVENTTRAIN

PLAYER = MASTER
FINDCHARA CFLAG:ID,CFLAG:0:调教对象ID
SIF RESULT <= 0
	RETURN
TARGET = RESULT

;母乳体質にしたとき自動スケジュールを割り振るために使う
TFLAG:调教前母乳体质 = MARK:母乳体质
TFLAG:调教中 = 1
TFLAG:尿道塞调教经过回合 = 0
;调教回合数：可配置，默认 20（仅当未设置时）
SIF FLAG:调教回合数 <= 0
	FLAG:调教回合数 = 20
TFLAG:剩余时间 = FLAG:调教回合数 +ITEM:调教时间増加
TFLAG:训练前体力 = BASE:体力
BASE:0:射精 = 0
SELECTCOM = 0
PREVCOM = 0

;専用イベントチェック
FLAG:特殊事件发生 = 0
SIF CFLAG:专用设置／事件
	TRYCALLFORM EX_TRAIN_BEFORE_%CSTR:识别名%_%CSTR:原作名%

;子供を始めて調教する場合の処理
SIF CSTR:状态／主人公的孩子 == "成长后"
	CALL CHILD_REBELLION(1)

;専用イベントがなかった場合は基本処理＝口上呼び出し
IF !FLAG:特殊事件发生
	;体内凌辱からの場合変化
	IF FLAG:体内凌辱暂时解除
		CALL VORE_SEX_DIRECT_TRAIN
	ELSE
		CALL KOJO_PRINT("日程","调教","开始调教")
		CALL TRAIN_BEGIN_MESSAGE
	ENDIF
ENDIF

;処女結界によって保護されているかのフラグ
;最初に来るのはONにするため↓と違う
CALL VARGIN_BARRIER_BREAK_FLAG

;触手服を着ている場合
CALL BEFORE_TRAIN_T_CLOTHE
CALL BEFORE_TRAIN_T_CLOTHE_M

;Ｖ潤滑を増加
CALL BEFORE_TRAIN_LUBRICATION

;調教前に自動で脱衣・拘束の設定
CALL BEFORE_TRAIN_COMMAND_BEFORE

;詰み防止しとく
IF !CMATCH(MARK:母乳体质,1) && !ITEM:魔力母乳分泌促进药
	CALL PRINTL_WORD_COLOR("尤金带来了＜魔力母乳分泌促进药＞的备用品。","浅蓝色")
	ITEM:魔力母乳分泌促进药 ++
ENDIF

PRINTFORML 开始%CALLNAME%的调教…
FORCEWAIT
CLEARLINE LINECOUNT



@SHOW_STATUS

;PLAYERにちんぽあるか
CALL PLAYER_PENIS_CHECK

;奉仕可能か見る
CALL TRAIN_SERVICE_JUDGE

;拘束フラグの処理はまとめた
;パイズリ中、イラマ中などは体勢的にかなり制約があるよ処理→挿入部位でいい
CALL SHOW_STATUS_TRAIN

;多少の自動ヒント
CALL TUTORIAL_TIPS_TRAIN

;拘束中の体位制限
CALL TRAIN_BIND_FLAG_FIX

;回数制限撤廃チェック
CALL CHECK_LIMIT_BREAK_CONFIG

;この後にCOMABLEを自動で呼び出す



@SHOW_USERCOM

;コマンドを種類で分割→BIT処理にした
;表示調教コマンドBIT用STR→8050
STR_REF = 8050
DRAWLINE
FOR LOCAL,0,20
	SIF STR:(LOCAL +STR_REF) == ""
		BREAK
	IF GETBIT(FLAG:显示调教指令BIT,LOCAL)
		CALL PRINT_WORD_COLOR,@"[{LOCAL +400,3}] %STR:(LOCAL +STR_REF)%　","黄色"
	ELSE
		PRINTFORM [{LOCAL +400,3}] %STR:(LOCAL +STR_REF)%　
	ENDIF
	SIF STR:(LOCAL +STR_REF) == "其他"
		PRINTL
NEXT
PRINTL

;拘束変更不可いくつか
IF TFLAG:Ｐ使用BIT
	CALL PRINTLC_WORD_COLOR("　Ｐ正在使用","灰")
ELSEIF TFLAG:搾乳器 || TFLAG:搾乳触手
	CALL PRINTLC_WORD_COLOR("　正在搾乳","灰")
ELSEIF MATCH(TEQUIP,1,100,200)
	CALL PRINTLC_WORD_COLOR("　正在使用触手","灰")
ELSE
	PRINTLC [450] 拘束状态更改
ENDIF
PRINTLC [451] 服装状态变更
IF MATCH(TEQUIP,1)
	PRINTLC [452] 解除刑具
ELSE
	CALL PRINTLC_WORD_COLOR("　无刑具","灰")
ENDIF
PRINTL
DRAWLINE
PRINTLC [700] 配置
PRINTLC [800] 状态显示
IF TFLAG:压缩时间中
	PRINTFORMLC [900] 调教结束（时间压缩中：{TFLAG:时间压缩有效回合数}回合使用）
ELSE
	PRINTFORMLC [900] 调教结束（剩余时间：{TFLAG:剩余时间}）
ENDIF
PRINTLC [801] 提示



@USERCOM

PRINTL
SELECTCASE RESULT
CASE 400 TO 419
	INVERTBIT FLAG:显示调教指令BIT,RESULT -400
CASE 450
	CALL TRAIN_BIND_COMMON
	RETURN 1
CASE 451
	CALL TRAIN_CLOTHES_COMMON
	RETURN 1
CASE 452
	CALL TRAIN_RELEASE_COMMON
	RETURN 1
CASE 700
	CALL GAME_CONFIG
	CLEARLINE LINECOUNT
	RETURN 1
CASE 800
	CALL SHOW_STATUS_DETAIL_TRAIN
	CLEARLINE LINECOUNT
	RETURN 1
CASE 801
	CALL BROWSE_HINT("调教")
CASE 900
	PRINTL 还有时间，要结束调教吗？
	CALL ASK_YN
	SIF !RESULT
		BEGIN AFTERTRAIN
	RETURN 1
ENDSELECT
RETURN 0



@EVENTCOM

;PRINTL EVENTCOMだよ
;ここでPENISをとりあえずあなたにする
V_PENIS = %CALLNAME:0%
A_PENIS = %CALLNAME:0%
M_PENIS = %CALLNAME:0%
PAIZURI_PENIS = %CALLNAME:0%
KISS_PLAYER = %CALLNAME:0%
MILK_SUCK_PLAYER = %CALLNAME:0%

;責めフラグ、刻印フラグを一度OFF
VARSET TFLAG,0,30,40

;あなた調教中は脱衣メッセージ表示常に1
SOURCE:脱衣消息显示 = 1
CALL MANYL(5)



@EVENTCOMEND
;PRINTW EVENTCOMENDだよ

CALL SECTION_MP_COST
CALL TEQUIP_ADJUST

;毎回反抗削除とかの判定を入れる
CALL CAPITULATION_JUDGE

;あなたのHPが0で調教終了
IF !BASE:0:体力
	PRINTFORMW 《 %CALLNAME:0%的体力不足。调教结束 》
	BEGIN AFTERTRAIN
ENDIF

;時間切れで調教終了
IF TFLAG:剩余时间 <= 0
	PRINTW 《 时间到了。调教结束 》
	BEGIN AFTERTRAIN
ENDIF

;奉仕終了判定
CALL TRAIN_SERVICE_END
PREVCOM = SELECTCOM



@EVENTEND

;NOWEXだけはリセットかけないと口上が変になりがち
VARSET NOWEX
PRINTL

;全部取り外し
CALL ALL_TEQUIP_REMOVE
CALL TRAIN_BIND_RUN(0,1)
VARSET TFLAG,0,30,100
TFLAG:刻印入手 = 0
PRINTW 调教结束了…
CALL MANYL(3)

EXP:执行次数／主人公调教 ++
EXP:区间执行次数／主人公调教 ++
EXP:0:执行次数／主人公调教 ++
EXP:0:区间执行次数／主人公调教 ++

CALL TRAIN_END_RESULT
CALL TRAIN_AFTER_SKILL_POINT_CALC
CALL TRAIN_END_PALAM_CALC
CALL KOJO_PRINT("日程","调教","调教结束")
PRINTW
TFLAG:刻印入手 = 0
CALL CAPITULATION_JUDGE

;好感度系も追加した陥落判定
CALL TRAIN_END_CAPITULATION

;スケジュール変更
CALL AUTO_SCHEDULE_LACTATION

;もしかしてここからBEGIN SHOPでいいかも？　はい
;BEGIN ABLUP

;一時的脱衣のフラグがある場合に没収したままにするかの処理
CALL CLOTHE_SEIZURE

;リセットここでもかけないと装備とか残ってますがな
CALL RESET_TRAIN_PALAM
CALL MANYL(5)
DRAWLINE

;BEGIN TRAINするとMAIN_PHASEのターンエンド処理が飛ばされるのでここで改めてやる必要ある
CALL MAIN_TURNEND





;ここから下ないと止まるかと思ったけどそうでもなかったやつ
@EVENTTURNEND
;ないと止まる
PRINTL EVENTTURNENDだよ
BEGIN SHOP

@SHOW_JUEL
;ないと止まる
PRINTL 用珠表示也许不用吧

@SHOW_ABLUP_SELECT
;ないと止まる
PRINTL 我觉得这里也是空白就好了
PRINTL [100] 下面

@USERABLUP
;ないと止まる
PRINTL USERABLUPにいるよ
IF RESULT == 100
	BEGIN TURNEND
	RETURN 1
ENDIF
RETURN 0




