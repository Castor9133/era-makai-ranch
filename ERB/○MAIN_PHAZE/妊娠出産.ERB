
;妊娠日数経過
@CHILDBIRTH_COUNT
#DIM LINES

LINES = LINECOUNT
FOR TARGET,1,CHARANUM
	;妊娠日数がない場合は無視
	SIF !CFLAG:妊娠日数
		CONTINUE
	CFLAG:妊娠日数 ++
	
	;CFLAG:妊娠日数が10(丸８日経過)で妊娠発覚、16で出産
	;触手はCFLAG:妊娠日数が93(丸一日経過)で妊娠発覚、95で出産
	SELECTCASE CFLAG:妊娠日数
		CASE 10
			;あなたに初めて孕ませられた場合あなたの孕ませ人数(EXP:出産でカウント)を加算
			IF !EXP:经验次数／主人公／出产
				SIF !EXP:0:出产
					CSTR:0:初经验／出产 = %CALLNAME%
				EXP:0:出产 ++
			ENDIF
			PRINTFORMW %CALLNAME%的肚子似乎有点鼓起来了，似乎怀了%CALLNAME:0%的孩子…
			PRINTL 
			PRINTW  注意：如果想要亲自抚养新生儿，请在分娩时确保有空房间。
		CASE 13
			PRINTFORMW %CALLNAME%的肚子已经变得很大了…
		CASE 15
			PRINTFORMW %CALLNAME%的肚子里的孩子，明天就可能出生了…
		;前Verまで31までだったのでその対処用
		;CASE 16
		CASE 16 TO 31
			CALL CHILDBIRTH
		CASE 93
			PRINTFORMW %CALLNAME%的肚子似乎有点鼓起来了，似乎怀了触手的孩子…
			;TARGETのリアクションも書こうかと思ったけどあなたとの経験もある場合、
			;本人はどっちの子かまだ判断できなさそうな気がするので見送り
		CASE 94
			PRINTFORMW %CALLNAME%的肚子已经变得很大了，明天就可能出生了…
		CASE 95
			CALL TENTACLE_BIRTH
	ENDSELECT
NEXT
SIF LINES != LINECOUNT
	CALL HALFLINE



;出産
;今のところ一人ずつだけど一応双子以上にも対応可
@CHILDBIRTH
#DIM CHILDBIRTH_COUNT = 1
#DIM SOURCE_FIX

PRINTFORML %CALLNAME%似乎开始生产了…
PRINTL 
IF CSTR:日程 == "体内凌辱"
	PRINTFORML %CALLNAME:0%把意识放在了约束在体内空间的%CALLNAME%身上…
	PRINTFORMW 进一步让触手进入%SLANG_V()%，同时刺激子宫以促进分娩…
	PRINTFORML 经过一段时间的刺激后，从%SLANG_V()%抽出触手，立即开始分娩
ELSE
	PRINTFORML %CALLNAME:0%朝%CALLNAME%走去、
	PRINTFORMW 为了防止%CALLNAME%暴动，以张开腿的姿势将其束缚在床上…
	PRINTFORML 守护着%CALLNAME%时，过了一会儿，分娩开始了
ENDIF
PRINTFORM %CALLNAME%感到痛苦
IF BASE:好感度 >= BASE_FIRST_MAX || CFLAG:崩坏 || CFLAG:洗脑
	PRINT 忍耐着
ELSE
	PRINT 同时感到绝望地哭喊着
ENDIF
SIF BASE:好感度 >= BASE_FIRST_MAX
	PRINT 爱
PRINTFORM 与%CALLNAME:0%的孩子
SIF CHILDBIRTH_COUNT > 1
	PRINTFORM {CHILDBIRTH_COUNT}人
PRINTL 成功分娩了…
IF !MARK:母乳体质
	MARK:母乳体质 = 1
	CALL PRINTL_WORD_COLOR("出产したことで浓密%CALLNAME%的%SLANG_N()%から%SAVESTR:标识／母乳%が出るようになった…","桃")
	CALL MILKTANK_CALC
ENDIF
WAIT

PLAYER = 0
CALL STATUS_BEFORE_RECORD
CALL RESET_TRAIN_PALAM
TFLAG:调教中 = 0
IF CSTR:日程 == "体内凌辱"
	TFLAG:Ｖ装备 = 1
	TEQUIP:触手Ｖ插入 = 1
	SETBIT ＃束缚／触手＃
	IF FLAG:主人公的触手也是主人公
		V_PENIS = %CALLNAME:0%
	ELSE
		V_PENIS = 触手
	ENDIF
ELSE
	SETBIT ＃拘束／打桩机＃
ENDIF

;BASE:好感度次第で100～0%まで減少補正
;ニンゲンからしたらあなたも異種族だし基礎値は触手と同じでいいかな？
SOURCE_FIX = LIMIT(1000000 - (BASE:好感度 * BASE:好感度),0,1000000)
LOSEBASE:体力 = 200 * CHILDBIRTH_COUNT

;気力は基本0になる
LOSEBASE:气力 = 5000
SOURCE:爱情 = CHILDBIRTH_COUNT * LIMIT(BASE:好感度 * BASE:好感度 / 100 - 2500,0,10000)
SOURCE:Ｖ疼痛 = 20000 * CHILDBIRTH_COUNT
SOURCE:耻辱 = 100000 * CHILDBIRTH_COUNT * SOURCE_FIX / 1000000
SOURCE:屈辱 = 200000 * CHILDBIRTH_COUNT * SOURCE_FIX / 1000000
SOURCE:失意 = 100000 * CHILDBIRTH_COUNT * SOURCE_FIX / 1000000
SOURCE:反感 = 50000 * CHILDBIRTH_COUNT * SOURCE_FIX / 1000000
SOURCE:支配 = 50000 * CHILDBIRTH_COUNT * SOURCE_FIX / 1000000
CALL SOURCE_CHECK
CALL TRAIN_END_PALAM_CALC
CALL PRINT_STATUS_BEFORE_AFTER
CALL ABL_UP
CALL MARK_GET
CALL CHILDBIRTH_AVOID_MIND_BREAK
CALL CAPITULATION_JUDGE
CALL SECTION_MP_COST

SIF CSTR:初经验／出产 == "" && !EXP:出产
	CSTR:初经验／出产 = %CALLNAME:MASTER%
EXP:出产 += CHILDBIRTH_COUNT
EXP:经验次数／主人公／出产 += CHILDBIRTH_COUNT
CFLAG:妊娠日数 = 0
PRINTL 
IF FLAG:单间数／空房
	PRINTFORML 是否要在身边抚养出生的孩子？
	CALL ASK_YN
ELSE
	RESULT = 1
ENDIF
IF !RESULT
	FLAG:单间数／空房 --
	CALL CHARA_MAKE_CHILD
ELSE
	PRINTFORMW  决定把出生的孩子送到熟人的孤儿院。
ENDIF
CALL MANYL(3)






;触手出産
@TENTACLE_BIRTH
#DIM TENTACLE_BIRTH_COUNT
#DIM SOURCE_FIX

PLAYER = 0
;とりあえず5～8匹で
TENTACLE_BIRTH_COUNT = 5 + RAND:4

PRINTFORML %CALLNAME%似乎开始生产了…
PRINTL 
IF CSTR:日程 == "体内凌辱"
	PRINTFORML %CALLNAME:0%把意识放在了约束在体内空间的%CALLNAME%身上…
ELSE
	PRINTFORML %CALLNAME:0%朝%CALLNAME%走去、
	PRINTFORML 从体内伸出的触手束缚住了%CALLNAME%，并打开了其双腿…
ENDIF
PRINTFORMW 进一步让触手进入%SLANG_V()%，同时刺激子宫以促进分娩…
PRINTL 
PRINTFORML 经过一段时间的刺激后，从%SLANG_V()%抽出触手，立即开始分娩
PRINTFORM %CALLNAME%感受到痛苦和快感
IF ABL:触手中毒 > 9 || CFLAG:崩坏 || CFLAG:洗脑
	PRINT 喘息着
ELSE
	PRINT 、同时因绝望而哭喊着
ENDIF
PRINTFORML ながら触手を{TENTACLE_BIRTH_COUNT}匹出产した…
IF !MARK:母乳体质
	MARK:母乳体质 = 1
	PRINTFORML 经历了分娩，从%CALLNAME%的%SLANG_N()%开始流出了%SAVESTR:标识／母乳%...
	CALL MILKTANK_CALC
ENDIF
PRINTFORMC 当前的触手总数 <{FLAG:触手出产合计 + TENTACLE_BIRTH_COUNT}匹> 
IF FLAG:触手出产合计 < 10 && FLAG:触手出产合计 + TENTACLE_BIRTH_COUNT >= 10
	CALL MANYL(3)
	PRINTL 日程で＜触手刺激搾乳＞が可供选择了。
	PRINTL 每个人需要10只触手。
ENDIF
WAIT

CALL STATUS_BEFORE_RECORD
CALL RESET_TRAIN_PALAM
TFLAG:调教中 = 0
TFLAG:Ｖ装备 = 1
SETBIT ＃束缚／触手＃
TEQUIP:触手Ｖ插入 = 1
IF FLAG:主人公的触手也是主人公
	V_PENIS = %CALLNAME:0%
ELSE
	V_PENIS = 触手
ENDIF

;ABL:触手中毒があると100～20%まで減少補正
SOURCE_FIX = LIMIT(500 - (ABL:触手中毒 * ABL:触手中毒),100,500)
LOSEBASE:体力 = 200 * TENTACLE_BIRTH_COUNT
LOSEBASE:气力 = 5000
SOURCE:Ｖ快感／触手 = 10000 * TENTACLE_BIRTH_COUNT
SOURCE:Ｖ疼痛 = 20000 * TENTACLE_BIRTH_COUNT
SOURCE:痛苦 = 20000 * TENTACLE_BIRTH_COUNT
SOURCE:耻辱 = 100000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:屈辱 = 200000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:淫欲 = 100 * TENTACLE_BIRTH_COUNT * LIMIT(ABL:触手中毒 - 4,0,99)
SOURCE:失意 = 100000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:反感 = 50000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:分娩恐惧 = 100000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:不洁 = 30000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:支配 = 50000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:异形恐惧 = 30000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:Ｖ润滑追加 = 10000
CALL SOURCE_CHECK
CALL TRAIN_END_PALAM_CALC
SIF EX:总绝顶
	PRINTFORMC %CALLNAME_DIGIT()% <{EX:总绝顶,4}回绝顶> 
CALL PRINT_STATUS_BEFORE_AFTER
CALL ABL_UP
CALL MARK_GET
CALL CHILDBIRTH_AVOID_MIND_BREAK
CALL CAPITULATION_JUDGE
CALL SECTION_MP_COST

FLAG:触手出产合计 += TENTACLE_BIRTH_COUNT
;あなたの触手もあなた扱いフラグONでも触手の子の認識
SIF CSTR:初经验／出产 == "" && !EXP:出产
	CSTR:初经验／出产 = 触手
EXP:出产 += TENTACLE_BIRTH_COUNT
EXP:经验次数／异形／出产 += TENTACLE_BIRTH_COUNT
CFLAG:妊娠日数 = 0
CALL MANYL(3)



;崩壊回避手段がなさそうなので洗脳して崩壊回避するかを選択(一時的なヤツなので消費半分)
@CHILDBIRTH_AVOID_MIND_BREAK

USE_MP = MAGIC_USE_MP:GETNUM(ITEM,"洗脑") /2
IF !BASE:精神力 && !CFLAG:崩坏 && !CFLAG:洗脑 && ITEM:洗脑 && BASE:0:魔力 >= USE_MP
	PRINTFORML 如果这样下去，%CALLNAME%的精神似乎即将达到极限…
	PRINTFORML 消耗{USE_MP}魔力使用洗脑触手，来防止精神崩溃吗？
	PRINTFORML %CALLNAME:0%的魔力：%VALUE_DIGIT(BASE:0:魔力)%MP 
	CALL ASK_YN
	IF !RESULT
		PRINTFORML %CALLNAME:MASTER%使用洗脑触手暂时控制了%CALLNAME%，
		PRINTFORMW 设法使%CALLNAME%的精神稳定了
		BASE:精神力 = 10
		BASE:0:魔力 -= USE_MP
	ENDIF
ELSE
	WAIT
ENDIF



