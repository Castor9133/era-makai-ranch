
;アイテム購入処理
;ARG→RESULT
@BUY_ITEM_COMMON(ARG)

;衣服セット対応のためここでCOST計算
CALL BUY_ITEM_PRICE_CALC
SELECTCASE ARG
CASE 0
	;購入処理　所持金
	ITEM:SELECT_ITEM ++
	SIF ITEMNAME:SELECT_ITEM == "避孕套"
		ITEM:SELECT_ITEM += 4
	
	;経費計上か財布かで変更
	IF FLAG:购物／开销记账
		MONEY:经费计上 += COST
	ELSE
		MONEY -= COST
	ENDIF
	CALL PRINTW_WORD_COLOR,@"购买了＜%ITEMNAME:SELECT_ITEM%＞。","浅蓝色"

CASE 1
	;複数購入
	ITEM:SELECT_ITEM += BUY_NUM
	SIF ITEMNAME:SELECT_ITEM == "避孕套"
		ITEM:SELECT_ITEM += BUY_NUM * 4
	IF FLAG:购物／开销记账
		MONEY:经费计上 += (COST *BUY_NUM)
	ELSE
		MONEY -= (COST *BUY_NUM)
	ENDIF
	
	;ついでに衣服だと「着」
	IF SELECT_ITEM >= 1000
		CALL PRINTW_WORD_COLOR,@"购买了＜%ITEMNAME:SELECT_ITEM%＞{BUY_NUM}套。","浅蓝色"
	ELSE
		CALL PRINTW_WORD_COLOR,@"购买了{BUY_NUM}个＜%ITEMNAME:SELECT_ITEM%＞。","浅蓝色"
	ENDIF
ENDSELECT



;ローン購入処理
;ARG→価格
@ITEM_LOAN_BUY(ARG)
#DIM LOAN_OVER

;ARG分ローン増加→足りないとき所持金減少
IF CAN_LOAN_MONEY < ARG
	LOAN_OVER = ARG -CAN_LOAN_MONEY
	MONEY:贷款 += CAN_LOAN_MONEY
	MONEY -= LOAN_OVER
	PRINTFORML 贷款+%VALUE_DIGIT(CAN_LOAN_MONEY)%G／资金-%VALUE_DIGIT(LOAN_OVER)%G 
ELSE
	MONEY:贷款 += ARG
	PRINTFORML 贷款+%VALUE_DIGIT(ARG)%G 
ENDIF




