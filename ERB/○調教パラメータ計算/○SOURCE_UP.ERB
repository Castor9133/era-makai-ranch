
;ソース処理
@SOURCE_UP

;Ｖ潤滑の増加
CALL WET_PLUS

;だいたいに5%のランダム補正
;@SENSITIVE_SUM_CALC内で既に補正かけてるので快楽(0～9)は除外
FOR LOCAL,10,100
	CALL RANDOM_FIX(SOURCE:LOCAL,5,SOURCENAME:LOCAL)
	SOURCE:LOCAL += FIX
NEXT
;排泄羞耻：羞耻调教余回合链——耻辱／屈服倍率随余回合上升；镜子PLAY／公开排泄系 COM 再叠一层
SIF TARGET > 0 && CFLAG:排泄_羞耻调教余回合 > 0
	LOCAL = MIN(CFLAG:排泄_羞耻调教余回合, 18)
	FIX = 1060 + LOCAL * 8
	SIF TFLAG:镜子PLAY
		FIX += 42
	SIF EXCRETION_SHAME_CHAIN_EXTRA_COM(SELECTCOM)
		FIX += 35
	TIMES SOURCE:耻辱, FIX / 1000
	FIX = 1035 + LOCAL * 5
	SIF TFLAG:镜子PLAY
		FIX += 20
	TIMES SOURCE:屈服, FIX / 1000
ENDIF
;榨乳口便器牧场：恭顺／屈服微量倍率（FLAG:5011）
IF TFLAG:调教中 && TARGET > 0 && FLAG:牧场口便器玩法启用
	LOCAL = GET_RANCHORAL_TRAIN_SOURCE_MUL()
	SIF LOCAL != 1000
		TIMES SOURCE:恭顺, LOCAL / 1000
		TIMES SOURCE:屈服, LOCAL / 1000
ENDIF
SOURCE:指令前气力 = BASE:气力

;体力・気力計算前に精神パラメータ計算へ
CALL MIND_SOURCE_UP

;LOSEは計算してやる必要ある
;霊力注ぎ込みの回復量を入れる・気力回復量あればそれも
BASE:体力 += SOURCE:调教对象体力回复
BASE:气力 += SOURCE:调教对象气力回复

;元々0ならLOSEBASEを0にして表示省略
SIF !BASE:体力
	LOSEBASE:体力 = 0
SIF !BASE:气力
	LOSEBASE:气力 = 0

;片方が0のときもう片方の減少量50%増加
SIF !BASE:体力
	TIMES LOSEBASE:气力,1.50
SIF !BASE:气力
	TIMES LOSEBASE:体力,1.50

;榨乳体力/气力消耗减轻（为当前的 60%）
;以本回合是否发生喷乳（含母乳不足结算）作为判定，避免误伤其他指令
IF NOWEX:喷乳 + NOWEX:母乳不足 > 0
	TIMES LOSEBASE:体力,0.60
	TIMES LOSEBASE:气力,0.60
ENDIF
;排泄羞耻：灌肠无肛塞忍耐→体力消耗加重（叠在喷乳减轻之后）
SIF TARGET > 0 && CFLAG:排泄_灌肠无肛塞忍耐中
	TIMES LOSEBASE:体力, 1.10
;排泄羞耻：孕早期（妊娠超 30 日后排泄加重段）排泄类调教（放尿／灌肠）体力下降为平常叠乘后的 2 倍
SIF TARGET > 0 && EXCRETION_IS_EARLY_PREG_EXCRETION() && GROUPMATCH(SELECTCOM, 220, 221, 223)
	TIMES LOSEBASE:体力, 2.00
BASE:体力 = LIMIT(BASE:体力 -LOSEBASE:体力,0,MAXBASE:体力)
BASE:气力 = LIMIT(BASE:气力 -LOSEBASE:气力,0,MAXBASE:气力)

;そのままPALAMに加算
FOR LOCAL,0,30
	SIF SOURCE:LOCAL >= 0
		PALAM:LOCAL += SOURCE:LOCAL
NEXT

;現在ABLでの補正後にPALAM、EXPに加算
;表示が「+SOURCE（+PALAM）」になる
;ABLが10未満なら(10-現在ABL)割　10以上なら(1/現在ABL)する
FOR LOCAL,40,100
	;一旦0に
	PALAM:LOCAL = 0
	SIF SOURCE:LOCAL <= 0
		CONTINUE
	
	;体内凌辱だとあんまり多すぎるので半減しとく
	SIF TFLAG:体内凌辱中
		SOURCE:LOCAL /= 2
	PALAM:LOCAL = SOURCE:LOCAL
	
	;濃度は別個計算
	IF PALAMNAME:LOCAL == "母乳浓度增加"
		;Lv1増加ごとに半減
		FIX = POWER(2,ABL:LOCAL)
		PALAM:LOCAL /= FIX
		
		;もう最大なら0
		SIF ABL:LOCAL >= 5
			PALAM:LOCAL = 0
		
	ELSEIF PALAMNAME:LOCAL == "丰饶增加"
		;そのまま入れる、豊穣上限なら0にしてる
	
	ELSE
		;LV5までは(100 -20*現在ABL)%のEXP・5以降は(1/現在ABL)のEXP・10以降はさらに1/2
		IF ABL:LOCAL < 5
			PALAM:LOCAL *= (100 -20 *ABL:LOCAL)
			PALAM:LOCAL /= 100
		ELSE
			PALAM:LOCAL /= ABL:LOCAL
			SIF ABL:LOCAL >= 10
				PALAM:LOCAL /= 2
		ENDIF
	ENDIF
	
	;EXP増減コンフィグあればここで計算
	CALL DIFFICULTY_CONFIG_APPLY("性EXP获得量_PALAM",LOCAL)
	
	;EXPもここで入れてしまう
	EXP:LOCAL = LIMIT(EXP:LOCAL +PALAM:LOCAL,0,EXP_MAX)
NEXT
PALAM:Ｖ润滑 += SOURCE:爱液

;絶頂回数
;SOURCE:Ａ快楽／触手→130
FOR LOCAL,0,6
	SIF !NOWEX:LOCAL
		CONTINUE
	
	;絶頂回数により快楽を持ち越し、上限9999
	PALAM:LOCAL = PALAM:LOCAL %10000
	PALAM:LOCAL = LIMIT(PALAM:LOCAL +NOWEX:LOCAL *100,0,9999)
	EX:LOCAL += NOWEX:LOCAL
	EXP:LOCAL = LIMIT(EXP:LOCAL +NOWEX:LOCAL,0,PALAM_MAX)
	
	;触手責めしていれば触手絶頂回数増加
	SIF SOURCE:(LOCAL +130)
		EXP:触手绝顶次数 += NOWEX:LOCAL
NEXT
SIF NOWEX:Ｕ绝顶
	EX:Ｕ绝顶次数 = LIMIT(EX:Ｕ绝顶次数 + NOWEX:Ｕ绝顶, 0, ECSTASY_MAX)
	EXP:Ｕ绝顶次数 = LIMIT(EXP:Ｕ绝顶次数 + NOWEX:Ｕ绝顶, 0, PALAM_MAX)
IF NOWEX:总绝顶
	EX:总绝顶 += NOWEX:总绝顶
	EXP:总绝顶次数 = LIMIT(EXP:总绝顶次数 +NOWEX:总绝顶,0,ECSTASY_MAX)
ENDIF
; ＜绝顶育成＞契约中：本回合有部位绝顶则按部位数提高最大体力/气力
TRYCALL MAGIC_绝顶育成_APPLY
CFLAG:总搾乳量 += NOWEX:喷乳
EX:喷乳 += NOWEX:喷乳
;奶牛堕（精神相关）：使用「搾乳绝顶次数」作为累积值
;- 榨乳回合：累积速度降为现有的 60%
;- 非榨乳回合：提供缓慢下降，并在“气力/体力回复”发生时额外下降（作为安抚/休息/恢复类手段）
IF NOWEX:喷乳 + NOWEX:母乳不足 > 0
	EXP:搾乳绝顶次数 += ((NOWEX:Ｎ绝顶 + NOWEX:Ｂ绝顶) * 60 / 100)
ELSE
	FIX = 1
	;有恢复量时，视作“精神/身体回稳”，加速降低堕落累积
	SIF SOURCE:调教对象气力回复 > 0
		FIX += SOURCE:调教对象气力回复 / 50
	SIF SOURCE:调教对象体力回复 > 0
		FIX += SOURCE:调教对象体力回复 / 80
	EXP:搾乳绝顶次数 = LIMIT(EXP:搾乳绝顶次数 - FIX, 0, ECSTASY_MAX)
ENDIF

;潤滑上限は99999
PALAM:Ｖ润滑 = LIMIT(PALAM:Ｖ润滑,0,99999)
PALAM:Ａ润滑 = LIMIT(PALAM:Ａ润滑,0,99999)

;継続時費用計算
SOURCE:魔力消耗量 += SOURCE:触手魔力消耗量
IF SOURCE:魔力消耗量
	;消費量増加コンフィグがあれば増加
	CALL DIFFICULTY_CONFIG_APPLY("魔力消耗量")
	FLAG:区间魔力消费量 += SOURCE:魔力消耗量
ENDIF
IF SOURCE:电池消费量
	CALL DIFFICULTY_CONFIG_APPLY("电池消费量")
	FLAG:区间电池消耗量 += SOURCE:电池消费量
ENDIF

;一応上限
EXP:触手绝顶次数 = LIMIT(EXP:触手绝顶次数,0,ECSTASY_MAX)
EXP:搾乳绝顶次数 = LIMIT(EXP:搾乳绝顶次数,0,ECSTASY_MAX)
CFLAG:总搾乳量 = LIMIT(CFLAG:总搾乳量,0,ECSTASY_MAX)

;PLAYERのSOURCE処理
CALL SOURCE_UP_PLAYER



;PLAYERのSOURCE処理
@SOURCE_UP_PLAYER

	;IF ((SOURCE:経過時間 && TFLAG:調教中) || TFLAG:スケジュール外Ｈ) && PLAYER >= 0
SIF PLAYER < 0
	RETURN

;調教者の体力消費/回復
HEAL = SOURCE:调教者体力回复
DAMAGE = SOURCE:调教者体力消耗

;スキルポイント蓄積値増加
SIF !PLAYER
	MONEY:魔法AP累积值 += SOURCE:玩家增加魔力量／衰减前

;調教者習得から変換
CALL PLAYER_TECHNIQUE_EXP_UP_CALC(PLAYER)
SAVE_TARGET = TARGET
TARGET = PLAYER

;PLAYERも5%ランダム補正
FOR LOCAL,0,100
	CALL RANDOM_FIX(SOURCE:LOCAL,5,SOURCENAME:LOCAL)
	SOURCE:LOCAL += FIX
NEXT

;精力消費
;絶倫ならスキップ
SIF ITEM:绝伦 && GETBIT(＃有效／绝伦＃)
	SOURCE:SAVE_TARGET:调教者精力消费量 = 0
;ペニスサイズ差補正がプラスなら軽減
SIF TFLAG:阴茎尺寸差修正 > 0
	SOURCE:SAVE_TARGET:调教者精力消费量 = SOURCE:SAVE_TARGET:调教者精力消费量 * 1000 / (1000 + TFLAG:阴茎尺寸差修正)
BASE:精力 = LIMIT(BASE:精力 -SOURCE:SAVE_TARGET:调教者精力消费量,0,BASE:精力)

;ここでリセット後に上書きがあるので調教者のリセットはしなくても大丈夫
SOURCE:学习 = EXPUP
BASE:体力 = LIMIT(BASE:体力 -DAMAGE +HEAL,0,MAXBASE:体力)
FOR LOCAL,41,100
	PALAM:LOCAL = 0
	SIF SOURCE:LOCAL <= 0
		CONTINUE
	PALAM:LOCAL = SOURCE:LOCAL
	
	;濃度は来ないはず
	IF ABL:LOCAL < 5
		PALAM:LOCAL *= (100 -20 *ABL:LOCAL)
		PALAM:LOCAL /= 100
	ELSE
		PALAM:LOCAL /= ABL:LOCAL
		SIF ABL:LOCAL >= 10
			PALAM:LOCAL /= 2
	ENDIF
	CALL DIFFICULTY_CONFIG_APPLY("性EXP获得量_PALAM",LOCAL)
	EXP:LOCAL = LIMIT(EXP:LOCAL +PALAM:LOCAL,0,EXP_MAX)
NEXT
TARGET = SAVE_TARGET





