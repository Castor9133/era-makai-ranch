@RANCH_STATUS_FACILITY

CALL SHOW_COW_HEALTH(1)
CALL SHOW_FINANCE_VALUE(1)
CALL SHOW_BATHLOOM_CLEAN(1)
IF FLAG:调合中药品ID
	PRINTFORML 调合中的药品：%ITEMNAME:(FLAG:调合中药品ID)%　　进展：{MONEY:调合进行度}／{ITEMPRICE:(FLAG:调合中药品ID) *2} 
ELSE
	CALL PRINTL_WORD_COLOR,@"未指定调合","灰"
ENDIF
PRINTL
LOCALS = 灵力抽出装置
PRINTFORML %LOCALS,20%：{ITEM:LOCALS}台 

;どの魔力貯蔵器があるか
;ITEM:魔改造魔力貯蔵器→53
;逆順FORを珍しく使う
ITEM_REF = 53
ITEM_MAX = -4
LOCALS = 魔力储存器等级
FOR LOCAL,ITEM_REF,ITEM_REF +ITEM_MAX,-1
	SIF ITEMNAME:LOCAL == ""
		CONTINUE
	IF ITEM:LOCAL
		PRINTFORML %LOCALS,20%：%ITEMNAME:LOCAL%
		BREAK
	ENDIF
	
	;どれもない時ないと表示
	SIF LOCAL == 50
		CALL PRINTL_WORD_COLOR,@"　无魔力储存器","灰"
NEXT

;ITEM:牛床マット→40
ITEM_REF = 40
ITEM_MAX = 10
FOR LOCAL,ITEM_REF,ITEM_REF +ITEM_MAX
	SIF ITEMNAME:LOCAL == ""
		CONTINUE
	PRINTFORM %ITEMNAME:LOCAL,20%：
	IF !ITEM:LOCAL
		CALL PRINTL_WORD_COLOR("残余 0天","灰")
	ELSE
		PRINTFORML 剩余{ITEM:LOCAL,2}天
	ENDIF
NEXT

;龍のタマ→補正・揃ってるとき案内
LOCALS = 龙之珠
IF ITEM:LOCALS >= 7
	CALL PRINTL_WORD_COLOR,@"%LOCALS,20%：{ITEM:LOCALS}个：[%CALLNAME:0%]选择 → 可使用[物品]","浅蓝色"
ELSE
	SIF !ITEM:LOCALS
		SETCOLOR 0x606060
	PRINTFORM %LOCALS,20%：{ITEM:LOCALS}个 
	IF FLAG:龙之珠发现率修正 < 0
		PRINTFORML ＜发现率修正：{FLAG:龙之珠发现率修正}\%＞
	ELSE
		PRINTFORML ＜发现率修正：+{FLAG:龙之珠发现率修正}\%＞
	ENDIF
ENDIF
RESETCOLOR
PRINTL



