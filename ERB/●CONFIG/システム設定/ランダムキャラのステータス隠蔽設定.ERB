
;ランダムキャラのステータス隠蔽設定
@HIDE_RANDOM_STATUS_CONFIG

CLEARLINE LINECOUNT
PRINTL 可以设定随机角色的部分状态在重新洗牌或决定之前是否为【未知】。
DRAWLINE
PRINTLC [ 0] 事务ABL
CALL PRINT_ONOFF(GETBIT(＃状态隐藏／事务ABL＃),1)
PRINTLC [ 1] 性ABL
CALL PRINT_ONOFF(GETBIT(＃状态隐藏／性ABL＃),1)
PRINTLC [ 2] 素质
CALL PRINT_ONOFF(GETBIT(＃状态隐藏／素质＃),1)
PRINTLC [ 3] 敏感度
CALL PRINT_ONOFF(GETBIT(＃状态隐藏／敏感度＃),1)
PRINTLC [ 4] 性体质
CALL PRINT_ONOFF(GETBIT(＃状态隐藏／性体质＃),1)
PRINTLC [ 5] 胸部详细
CALL PRINT_ONOFF(GETBIT(＃状态隐藏／乳房细节＃),1)
PRINTLC [ 6] 阴毛
CALL PRINT_ONOFF(GETBIT(＃状态隐藏／阴毛＃),1)

CALL PRINTL_ALIGN(-5)
CALL DEFAULT_VOID_RETURN_BUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 98
	PRINTL 是否将随机角色的状态隐藏设定恢复为默认值？
	CALL ASK_YN
	SIF !RESULT
		FLAG:随机角色状态隐藏BIT = 0
CASE 99
	RETURN
CASEELSE
	CALL CHANGE_HIDE_RANDOM_STATUS_CONFIG(RESULT)
ENDSELECT
RESTART



;設定変更
;ARG→INPUT
@CHANGE_HIDE_RANDOM_STATUS_CONFIG(ARG)

;ひっくり返すだけ
INVERTBIT FLAG:随机角色状态隐藏BIT,ARG


