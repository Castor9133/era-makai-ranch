
;風呂に呼ぶ奴隷選択
@SELECT_TOGETHER_BATHING_SLAVE
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML 选择奴隶和%CALLNAME:0%洗澡。
PRINTL
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	
	;牛舎→OK　未捕獲→NG　体内→NG
	IF CFLAG:追踪对象
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：未捕获","灰"
		CONTINUE
	ELSEIF CSTR:住处 == "体内"
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：体内","灰"
		CONTINUE
	ELSEIF !CFLAG:可以调教
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：调教不可","灰"
		CONTINUE
	ELSEIF EQUIP:魔力枷锁
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：魔力枷锁使用中","灰"
		CONTINUE
	ENDIF
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	IF CFLAG:牛舍号码
		CALL PRINT_WORD_COLOR("[牛舍] ","黄")
	ELSE
		PRINT 　　　 
	ENDIF
	CALL TABLE_STATUS("浴池")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  8] 更改显示项目
PRINTLC 　
PRINTL [ 99] 一个人进去
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	TARGET = -1
	RETURN

CASEELSE
	TARGET = RESULT -100
	SIF !CFLAG:可以调教
		RESTART
	RETURN
ENDSELECT
RESTART


