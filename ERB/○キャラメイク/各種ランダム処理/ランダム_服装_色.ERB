
;服の色ランダム
@RANDOM_SLAVE_CLOTHE_COLOR

;奴隷候補の今の服で変更
;種族が色になるバグがここで起きていたので対策に衣服欄が空なら帰れ
;直ったはずなので来ないと思うけどあって困るものでもないので置いとく
SIF ＃穿着衣服／名称＃ == ""
	RETURN
SELECTCASE ＃穿着衣服／名称＃
CASE "礼服","战斗礼服","淫乱礼服","哥特萝莉装","军服"
	STR_REF = 6720
CASEELSE
	STR_REF = 6700
ENDSELECT
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)

;一部配色に優先がある服
SELECTCASE ＃穿着衣服／名称＃
CASE "女巫服","战斗用女巫服"
	;元々紅白やろと想像つくので空欄多め
	SIF RAND:100 < 50
		RESULTS =

CASE "法衣","忍装束","女仆装","战斗女仆装","修道服","战斗修女服"
	;なんとなく想像つくので空欄少し
	SIF RAND:100 < 20
		RESULTS =

CASE "长袍"
	;白魔術士は白、黒は黒
	IF CSTR:职业 == "白魔法师" && RAND:100 < 80
		RESULTS = 白色
	ELSEIF CSTR:职业 == "黑魔法师" && RAND:100 < 80
		RESULTS = 黑色
	ENDIF
ENDSELECT

;金と銀はやめとこうかな…　ベージュもなんかダサいな…
;このとき+10%で空欄にするくらいでちょうどいいかも
SIF GROUPMATCH(RESULTS,"金色","银色","米色的") || RAND:100 < 10
	RESULTS =
CSTR:(EQUIP:装备中ID／衣服) = %RESULTS%



;下着色ランダム
@RANDOM_SLAVE_LINGERIE_COLOR
#DIMS LINGERIE_COLOR

STR_REF = 6820
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)

;ここはループ防止に再シャッフルしない
LINGERIE_COLOR = %RESULTS%
FOR LOCAL,3,5
	SIF EQUIPNAME:LOCAL == "" || !EQUIP:LOCAL
		CONTINUE
	
	;一旦さっき指定した色を入れる
	CSTR:(EQUIP:LOCAL) = %LINGERIE_COLOR%
	
	;物によって特殊配色
	SELECTCASE EQUIPNAME:(EQUIP:LOCAL)
	CASE "裹胸布","私处贴纸"
		;空欄
		CSTR:(EQUIP:LOCAL) =
	ENDSELECT
NEXT



;アクセサリー色ランダム
@RANDOM_SLAVE_ACCESSORY_COLOR
#DIMS ACCESSORY_COLOR

STR_REF = 6700
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)

;ここはループ防止に再シャッフルしない　10%で空欄
SIF GROUPMATCH(RESULTS,"金色","银色","米色的") || RAND:100 < 10
	RESULTS =
ACCESSORY_COLOR = %RESULTS%
FOR LOCAL,10,20
	SIF EQUIPNAME:LOCAL == "" || !EQUIP:LOCAL
		CONTINUE
	
	;一旦さっき指定した色を入れる
	CSTR:(EQUIP:LOCAL) = %ACCESSORY_COLOR%
	
	;物によって特殊配色
	SELECTCASE EQUIPNAME:(EQUIP:LOCAL)
	CASE "斗篷"
		CALL RANDOM_SLAVE_ACCESSORY_COLOR_EX(EQUIP:LOCAL)
	CASE "皇冠","项圈","吊袜带"
		;空欄
		CSTR:(EQUIP:LOCAL) =
	CASE "修女面纱"
		;服装＝修道服と同じ色
		IF EQUIP:修道服
			CSTR:(EQUIP:LOCAL) = %CSTR:GETNUM(ITEM,"修道服")%
		ELSEIF EQUIP:战斗修女服
			CSTR:(EQUIP:LOCAL) = %CSTR:GETNUM(ITEM,"战斗修女服")%
		ENDIF
	CASE "眼镜"
		;形の変更
		CALL RANDOM_SLAVE_ACCESSORY_GLASSES(EQUIP:LOCAL)
	ENDSELECT
NEXT



;特殊配色
;ARG→装備ID
@RANDOM_SLAVE_ACCESSORY_COLOR_EX(ARG)

STR_REF = 6720
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)
CSTR:ARG = %RESULTS%



;メガネの形変更
@RANDOM_SLAVE_ACCESSORY_GLASSES(ARG)

;他アクセサリーと別個色判定
STR_REF = 6700
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)
SIF GROUPMATCH(RESULTS,"金色","银色","米色的") || RAND:100 < 10
	RESULTS =
CSTR:ARG = %RESULTS%

;形状を追加
STR_REF = 6800
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)
SIF RAND:100 < 20
	RESULTS =
CSTR:ARG += RESULTS






