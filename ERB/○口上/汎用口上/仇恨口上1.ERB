@KOJO_GENERAL_INDEX_仇恨1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

IF TFLAG:Ｍ装备
	CALL KOJO_GENERAL_MOUTH_SHACKLE_1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
	RETURN
ELSEIF CFLAG:崩坏 && !CFLAG:洗脑
	IF GROUPMATCH(ARGS:0,"例文")
	ELSEIF GROUPMATCH(ARGS:1,"洗脑触手","崩坏")
	ELSE
		IF NOWEX:总绝顶
			CALL MESSAGE_BOX,@"「哈……哈……♥ 去死……♥ ……还要……♥」"
			CALL MESSAGE_BOX,@"「……恨死你了……♥ ……别停……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……滚……」"
		ENDIF
		RETURN
	ENDIF
ENDIF

SELECTCASE ARGS:0
CASE "身体"
	CALL KOJO_GENERAL_仇恨1_EXCRETION_BODY(ARGS:1, ARGS:2)
	RETURN
CASE "例文"
	CALL MESSAGE_BOX,@"「【仇恨1】已设置。\n怨毒、咬牙切齿；恋慕走扭曲路线：越爽越恨，越恨越想要。」"

CASE "调教命令"
	CALL KOJO_GENERAL_仇恨1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

CASE "绝顶"
	;深喉中的高潮（新增：深喉性癖相关口上）
	SIF TEQUIP:深喉
		CALL MESSAGE_BOX,@"「呕……咳……♥ 喉咙被你当成玩具……哈……去死……！」"
	SIF TEQUIP:深喉
		CALL MESSAGE_BOX,@"「……别看……我现在这种样子……明明想掐死你……身体却先抖……♥」"
	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
		CALL MESSAGE_BOX,@"「啊……♥ ……我会照做……因为我恨你……♥」"
		CALL MESSAGE_BOX,@"「……别以为你赢了……我只是……身体坏了……♥」"
	ELSEIF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「不许停……！……不对，停下……不许停！♥」"
		CALL MESSAGE_BOX,@"「我明明恨你……为什么身体会……啊……♥」"
	ELSEIF ＃陷落状态／屈服以上＃
		CALL MESSAGE_BOX,@"「住手……！……呜……♥」"
	ELSE
		CALL MESSAGE_BOX,@"「别碰我……去死……！」"
	ENDIF
	SIF NOWEX:Ａ绝顶
		IF TALENT:Ａ名器 || TALENT:肛门嗜好 || ABL:Ａ感觉 >= 3
			CALL MESSAGE_BOX,@"「……！？　%ANAL_CALL()%……痛……！？　……可恶……深处……居然……发酥……♥」"
			CALL MESSAGE_BOX,@"「……我恨你……身体却……去死……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……痛……！？　%ANAL_CALL()%……滚……！」"
			CALL MESSAGE_BOX,@"「……只有痛……去死……！」"
		ENDIF
	SIF NOWEX:Ｕ绝顶
		IF TEQUIP:尿道塞 || TFLAG:尿道装备
			SIF TALENT:尿道敏感 || EX:尿道调教经验 >= 15
				CALL MESSAGE_BOX,@"「……尿道塞在里面搅……哈……我恨你……可这股酸麻……去死……♥」"
			SIF !(TALENT:尿道敏感 || EX:尿道调教经验 >= 15)
				CALL MESSAGE_BOX,@"「……尿道里塞着还敢动？疼得我发黑……滚开……！」"
		ELSE
			SIF TALENT:尿道敏感 || EX:尿道调教经验 >= 15
				CALL MESSAGE_BOX,@"「……别碰那条缝……哈……可恶……一碰就电得我腿软……♥」"
			SIF !(TALENT:尿道敏感 || EX:尿道调教经验 >= 15)
				CALL MESSAGE_BOX,@"「……像把针往里送……别戳尿道……我会把你剁了……！」"
		ENDIF

CASE "射精"
	IF SOURCE:膣内射精经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……射进来了吗……♥ ……恶心……但……别拔……♥」"
			CALL MESSAGE_BOX,@"「……别看我……这种样子……我会杀了你……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「不许在里面……！」"
		ENDIF
	ELSEIF SOURCE:尻穴射精经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……后面也……射进来……♥ ……卑鄙……但……别停……♥」"
			CALL MESSAGE_BOX,@"「……这种屈辱……我会记一辈子……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「住手……！」"
		ENDIF
	ELSEIF SOURCE:精饮经验
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……咽下去了……♥ ……恶心……但……身体却……♥」"
			CALL MESSAGE_BOX,@"「……别用那种眼神看我……我恨你……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「呕……咳……」"
		ENDIF
	ELSEIF TEQUIP:手淫
		IF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……弄在我手上了……♥ ……恶心……但……再来……♥」"
			CALL MESSAGE_BOX,@"「……别以为这是温柔……我只是……恨你……♥」"
		ELSE
			CALL MESSAGE_BOX,@"「……别让我碰……」"
		ENDIF
	ENDIF

CASE "搾乳"
	IF SOURCE:母乳漏出
		CALL MESSAGE_BOX,@"「……自己漏出来了……恶心……」"
		RETURN
	ENDIF
	IF ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「……挤吧……我会记住这份屈辱……♥」"
		CALL MESSAGE_BOX,@"「……别停……不对……停下……别停……♥」"
	ELSE
		CALL MESSAGE_BOX,@"「别碰那里！」"
	ENDIF

CASE "抽出"
	CALL MESSAGE_BOX,@"「……腿软了……别碰我……」"
	CALL MESSAGE_BOX,@"「……滚……让我缓一会儿……」"

CASE "日程"
	SELECTCASE ARGS:1
	CASE "调教"
		SELECTCASE ARGS:2
		CASE "开始调教"
			CALL MESSAGE_BOX,@"「……又来？去死……」"
			CALL MESSAGE_BOX,@"「……别以为我会求你……」"
		CASE "调教结束"
			CALL MESSAGE_BOX,@"「……结束了？……哼……」"
			CALL MESSAGE_BOX,@"「……别看我……」"
		ENDSELECT
	CASEELSE
	ENDSELECT

CASE "阴茎称呼变更"
	CALL MESSAGE_BOX,@"「……要我叫那种恶心的称呼？做梦。」"

CASE "膣称呼变更"
	CALL MESSAGE_BOX,@"「……别让我说出口……」"

CASE "肛门称呼变更"
	CALL MESSAGE_BOX,@"「……闭嘴……」"

CASE "吸欧派"
	SELECTCASE ARGS:1
	CASE "开始"
		CALL MESSAGE_BOX,@"「……别咬……你这混账……」"
	CASE "结束"
		CALL MESSAGE_BOX,@"「……满意了？……去死。」"
	ENDSELECT

CASE "访问"
	SELECTCASE ARGS:1
	CASE "入口"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「……你进我房了。行啊。」"
			CALL MESSAGE_BOX,@"「反正我现在也会听你——你最好别让我后悔没咬死你……♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……你进我屋想干什么。」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「……有事快说。别用见面当施舍。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……你进来看完了？满意了。」"
		ELSE
			CALL MESSAGE_BOX,@"「……滚。别装得好像你在乎我。」"
		ENDIF
	CASE "衣服修理"
		CALL MESSAGE_BOX,@"「衣服破了？……哈。连这种事也要我替你收拾？给我，别站太近。」"
	CASE "摸头"
		IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「……别停。」"
			CALL MESSAGE_BOX,@"「你既然把我弄成这样，就给我把这点感觉也做到底……♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……别碰。」"
			CALL MESSAGE_BOX,@"「你碰一下，我就觉得恶心。」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「……拿开。」"
			CALL MESSAGE_BOX,@"「别装温柔。你那只手沾过什么，你自己清楚。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……别碰！」"
		ELSE
			CALL MESSAGE_BOX,@"「滚开。」"
		ENDIF
	CASE "接吻"
		IF TALENT:无接吻经验
			RETURN
		ELSEIF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／隶属＃
			CALL MESSAGE_BOX,@"「……来。」"
			CALL MESSAGE_BOX,@"「咬也行。把我弄疼也行。反正我已经脏了——你就别假惺惺……♥」"
		ELSEIF ＃陷落状态／恋慕以上＃
			CALL MESSAGE_BOX,@"「……想亲？做梦。你凑过来，我就咬破你的嘴。」"
		ELSEIF ＃陷落状态／陷落以上＃
			CALL MESSAGE_BOX,@"「……别碰我嘴。」"
			CALL MESSAGE_BOX,@"「敢亲上来，我就让你见血。」"
		ELSEIF ＃陷落状态／屈服以上＃
			CALL MESSAGE_BOX,@"「……滚。」"
		ELSE
			CALL MESSAGE_BOX,@"「去死。」"
		ENDIF
	CASE "停止泌乳"
		IF CFLAG:魔界_妊娠S == 1 || CFLAG:魔界_妊娠S == 2
			CALL MESSAGE_BOX,@"「……这种时候还要我停？你就这么喜欢看别人痛苦，是吗。」"
		ELSE
			CALL MESSAGE_BOX,@"「……停止泌乳？呵。你倒是挺会挑别人最恶心的地方下手。」"
		ENDIF
	CASE "终止妊娠"
		CALL MESSAGE_BOX,@"「……终妊。你真敢说得出口。……做吧，反正你也只会这样。」"
	CASE "侍奉口爆终了"
		SELECTCASE ARGS:2
		CASE "忍住"
			CALL MESSAGE_BOX,@"「……哈……居然忍住了？……玩弄人很爽吗。」"
			CALL MESSAGE_BOX,@"「……滚开……别贴那么近。」"
		CASE "咽下"
			CALL MESSAGE_BOX,@"「……咽了。……恶心。……满意了？」"
			CALL MESSAGE_BOX,@"「……下次我宁愿咬断。」"
		ENDSELECT
	CASE "揉胸轻抚"
		CALL MESSAGE_BOX,@"「……就这？……拿我泄气呢。」"
		CALL MESSAGE_BOX,@"「……手拿走。」"
	CASE "拥抱嗅闻"
		CALL MESSAGE_BOX,@"「……装什么缠绵。」"
		CALL MESSAGE_BOX,@"「……闻够了？」"
	CASEELSE
	ENDSELECT

CASE "事件"
	CALL MESSAGE_BOX,@"「……发生了什么？……关我什么事。」"

CASE "肉体改造"
	CALL MESSAGE_BOX,@"「……连身体也要改？……你最好别后悔。」"

CASE "战斗"
	SELECTCASE ARGS:1
	CASE "攻击"
		CALL MESSAGE_BOX,@"「……去死。」"
	CASE "被击中"
		CALL MESSAGE_BOX,@"「……啧……」"
	CASEELSE
	ENDSELECT

CASEELSE
ENDSELECT
RETURN

@KOJO_GENERAL_仇恨1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
CALL KOJO_GENERAL_仇恨口上1_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
RETURN

;--------------------------------------------
; 排泄羞耻／身体（本口上专用）
;--------------------------------------------
@KOJO_GENERAL_仇恨1_EXCRETION_BODY(ARGS:0, ARGS:1)
SELECTCASE ARGS:0
CASE "排泄事故"
	SELECTCASE ARGS:1
	CASE "肠"
		CALL MESSAGE_BOX,@"「……混账……这种屈辱……我记住了……」"
	CASE "尿"
		CALL MESSAGE_BOX,@"「……杀了我……也别想我求你原谅……」"
	CASEELSE
		CALL MESSAGE_BOX,@"「……」"
	ENDSELECT
CASE "放尿主动"
	CALL MESSAGE_BOX,@"「……排尿……命令……执行……仅此而已。」"
CASE "灌肠妊娠求饶"
	CALL MESSAGE_BOX,@"「……孩子是无辜的。……你要折磨的是我——灌肠，住手。」"
CASEELSE
ENDSELECT
RETURN 1


