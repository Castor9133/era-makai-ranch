
;個人詳細
@SETTLEMENT_DETAIL_MILK_SLAVE

CLEARLINE LINECOUNT
CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT
CALL PRINT_ALL_STATE
PRINTFORM %CALLNAME%
CALL PRINT_AFFILIATION_DATA
SIF !CFLAG:非战斗职业 || BASE:等级 > 1
	PRINTFORM Lv{BASE:等级} 
PRINTL
PRINTFORM 【%CSTR:身高%】胸围大小：%PRINT_BUSTSIZE(ABL:胸围大小)%
CALL PRINT_BUST_C(1,1,1)
CALL PRINT_VIRGIN_SIMPLE
PRINTL
SELECTCASE FLAG:选择画面显示形式／素质
CASE 0
	CALL SHOW_TALENT_LIST_SIMPLE
CASE 1
	CALL SHOW_TALENT_LIST
	CALL SHOW_TALENT_NASTY
ENDSELECT
SIF FLAG:选择画面显示形式／刻印 != 2
	CALL SHOW_MILK_MARK_LIST
CALL PRINTL_ALIGN(-15)
CALL PRINT_NOW_PLACE
PRINTL
CALL PRINT_MILK_NAME
PRINTFORM  %VALUE_DIGIT(CFLAG:预计出货母乳量,"母乳")% ／ %VALUE_DIGIT(CFLAG:母乳出荷金额／当日)%G 
CALL SELL_MILK_PRICE_NEW_RECORD
CALL MANYL(2)

CALL PRINT_SELL_MILK_PRICE_FIX
SIF CFLAG:母乳价格奖励
	PRINTFORML %SAVESTR:标识／母乳%价格奖励：{CFLAG:母乳价格奖励}\%
PRINTFORML %SAVESTR:标识／母乳%需求：%VALUE_DIGIT(CFLAG:母乳需求值,"母乳")%
SIF CFLAG:预计出货母乳量 > CFLAG:母乳需求值
	PRINTFORML （需求超过：%VALUE_DIGIT(CFLAG:预计出货母乳量 -CFLAG:母乳需求值,"母乳")%）
CALL PRINTL_ALIGN(-3)
PRINTFORML 　出货量合计：%VALUE_DIGIT(CFLAG:出货母乳／合计量,"母乳")% 
PRINTFORML 出货合计金额：%VALUE_DIGIT(CFLAG:出货母乳／合计金额)%G 
PRINTFORML 　　总搾乳量：%VALUE_DIGIT(CFLAG:总搾乳量,"母乳")% 
DRAWLINE
PRINTLC [300] 上一个角色
PRINTLC [301] 下一个角色
PRINTL [ 99] 完成
BINPUT
PRINTL
SELECTCASE RESULT
CASE 300
	CALL CHANGE_TARGET_CHARA(0,"结算详情")
CASE 301
	CALL CHANGE_TARGET_CHARA(1,"结算详情")
CASE 99
	RETURN
ENDSELECT
RESTART



@PRINT_SELL_MILK_PRICE_FIX

PRINTL ＜价格修正＞
EXIST = 0
IF ABL:母乳浓度
	CALL PRINT_MILKWORD_C(1,1)
	PRINTFORML ：+{ABL:母乳浓度 *30}\%
	EXIST ++
ENDIF
IF !EXP:肉体改造 && (DAY -CFLAG:捕获日 < 20)
	PRINTFORML 天然%SAVESTR:标识／母乳%：+20\%（至第20天）
	EXIST ++
ENDIF
SIF !EXIST
	CALL PRINTL_WORD_COLOR,@"没有价格修正","灰"




