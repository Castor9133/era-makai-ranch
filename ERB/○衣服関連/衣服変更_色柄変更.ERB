
;色柄変更処理
;SELECT_ITEM指定で来ている
@EQUIP_DETAIL_CHANGE
#DIMS EQUIP_DETAIL
#DIM ITEM_DETAIL

EQUIP_DETAIL =
CALL CHECK_EQUIP_DETAIL_CHANGE(ITEMNAME:SELECT_ITEM)
ITEM_DETAIL = RESULT
SELECTCASE ITEM_DETAIL
CASE 0
	;なんもないやつ
	RETURN
CASE 1
	PRINTL 颜色可更变的装备。
CASE 2
	PRINTL 颜色・花纹／形状可更变的装备。
CASE 3
	PRINTL 颜色的变更・乳露改造可能的装备。
	SIF !ITEM:魔法剪刀 && !FLAG:正在化妆角色
		CALL PRINTL_WORD_COLOR("※因为没有＜魔法剪刀＞，不能改造。","黄")
CASE 4
	PRINTL 是可以改变颜色、淫乱改造的装备。
	SIF !ITEM:魔法剪刀 && !FLAG:正在化妆角色
		CALL PRINTL_WORD_COLOR("※因为没有＜魔法剪刀＞，不能改造。","黄")
ENDSELECT

CALL ITEM_COLOR_SELECT

;1が帰ってきたらキャンセル
SIF RESULT
	RETURN 1
EQUIP_DETAIL += RESULTS
SELECTCASE ITEM_DETAIL
CASE 2
	CALL ITEM_PATTERN_SELECT
	EQUIP_DETAIL += RESULTS
CASE 3
	CALL BUST_STRIP_MODIFICATION
CASE 4
	CALL NASTY_MODIFICATION
ENDSELECT
SIF RESULT
	RETURN 1

;最後までいったらCSTRに保存
CSTR:SELECT_ITEM = %EQUIP_DETAIL%

;逆バニーは上下丸出しにセットする
IF GROUPMATCH(ITEMNAME:SELECT_ITEM,"反兔女郎")
	SETBIT EQUIP:SELECT_ITEM,8
	SETBIT EQUIP:SELECT_ITEM,9
ENDIF



;色変更
@ITEM_COLOR_SELECT

PRINTFORML %ITEMNAME:SELECT_ITEM%的颜色更改吗？

;一部選択肢をちょっと変えたいね
SELECTCASE ITEMNAME:SELECT_ITEM
CASE "礼服","战斗礼服","淫乱礼服","哥特萝莉装","军服","斗篷"
	STR_REF = 6720
CASEELSE
	STR_REF = 6700
ENDSELECT

FOR LOCAL,STR_REF,STR_REF +20
	SIF STR:LOCAL == ""
		CONTINUE
	PRINTFORMLC [{LOCAL -STR_REF,2}] %STR:LOCAL%
NEXT
CALL INPUTBUTTON(1)
INPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 20
	RESULTS = %STR:(STR_REF +RESULT)%
CASE 900
	RESULTS =
CASE 901
	PRINTL 请输入颜色。
	INPUTS
CASE 999
	RETURN 1
ENDSELECT



