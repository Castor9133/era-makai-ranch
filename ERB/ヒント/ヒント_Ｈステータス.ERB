@HINT_SENSITIVE_STATUS
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTL 请选择要查看其说明的项目。
DRAWLINE
BR = 0
STR_REF = 9160
SELECTCASE PAGE
CASE 1
	CALL HINT_BUTTON_LIST(0,15)
CASE 2
	CALL HINT_BUTTON_LIST(15)
ENDSELECT
DRAWLINE
CALL HINT_DETAIL_SENSITIVE_STATUS
CALL PRINTL_ALIGN(5)
DRAWLINE
PRINTLC [90] 页面切换
PRINTFORMLC PAGE：{PAGE}／{PAGE_MAX}
PRINTL [99] 返回
INPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 29
	SELECT_TIPS = RESULT
CASE 90
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_TIPS = -1
CASE 99
	RETURN
ENDSELECT
RESTART



