	ENDIF
	; [%PENIS_CALL()%] / [%VAGINA_CALL()%] / [%ANAL_CALL()%]：阴茎、阴道、肛门称呼
	; 与直接读 CSTR 不同：绝顶次数超阈值会进入「融化」称呼
	
	SIF ABL:Ｖ敏感度 >= 200 || ABL:Ｖ感觉 >= 10
		CALL MESSAGE_BOX,@"「呜——♥♥ %SELF_CALL()%的%VAGINA_CALL()%♥ 被手指搅得…要去了♥♥♥」"
		
	IF CFLAG:乳牛 || CFLAG:洗脑 || ＃陷落状态／恋慕以上＃
		CALL MESSAGE_BOX,@"「手指的话…♥ 想要%MASTER_CALL()%的%PENIS_CALL()%哦♥♥♥」"
	ELSEIF ＃陷落状态／屈服以上＃
		CALL MESSAGE_BOX,@"「啊啊啊♥ 不要搅动里面啦啦♥」"
	ELSE
		CALL MESSAGE_BOX,@"「真过分，太过分了…呜♥」"
	ENDIF

CASE "Ａ指插入"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:洗脑
			CALL MESSAGE_BOX,@"「嗯咿♥ 指头进来了啦啦♥ %MASTER_CALL()%的手指啦啦♥♥」"
		ELSEIF ＃陷落状态／屈服以上＃
