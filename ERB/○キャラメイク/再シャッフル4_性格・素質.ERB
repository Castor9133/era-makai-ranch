
;性格・素質・性ABL・1／2人称再シャッフル
@CHARA_MAKE_SLAVE_SHUFFLE_PERSONALITY

CLEARLINE LINECOUNT
CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT
PRINTL 重新调整奴隶候选人的性格・素质。
PRINTL
PRINTFORML 　性格：【%CSTR:性格%】　第一人称：%CSTR:第一人称%　主人公的称呼：%CSTR:主人公的称呼／陷落前%
CALL ABL_WORK_LIST_CHARA_MAKE
CALL SHOW_TALENT_LIST
PRINTL
CALL ABL_NASTY_LIST_CHARA_MAKE
CALL TALENT_NASTY_CHARA_MAKE
CALL PRINTL_ALIGN(-15)
CALL HALFLINE
SIF GETBIT(＃重新调整／性格素质＃)
	SETCOLOR 0x80FFFF
PRINTFORML 【%VALUE_DIGIT(SHUFFLE_AGAIN_PT:5)%pt】
PRINTL 　[ 0] 性格打乱
PRINTL 　（性格调整时，素质也会产生变化）
PRINTL 　[ 1] 性格保持不变地打乱素质
RESETCOLOR
SIF GETBIT(＃重新调整／性ABL＃)
	SETCOLOR 0x80FFFF
PRINTFORML 【%VALUE_DIGIT(SHUFFLE_AGAIN_PT:6)%pt】
PRINTL 　[ 2] 性ABL打乱
RESETCOLOR
CALL PRINTL_ALIGN
DRAWLINE
PRINTL [99] 完成
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL RANDOM_SLAVE_PERSONALITY
	CALL RANDOM_SLAVE_TALENT
	CALL RANDOM_SLAVE_CALLPERSON
	SETBIT ＃重新调整／性格素质＃
CASE 1
	CALL RANDOM_SLAVE_TALENT
	CALL RANDOM_SLAVE_CALLPERSON
	SETBIT ＃重新调整／性格素质＃
CASE 2
	CALL RANDOM_SLAVE_NASTY_ABL
	SETBIT ＃重新调整／性ABL＃
CASE 99
	RETURN
ENDSELECT
RESTART

