
;処女喪失などでの増減　あなた調教以外からも来たいので関数化
@LOST_VARGIN_MIND_DAMAGE

SIF CFLAG:崩坏 || CFLAG:洗脑
	RETURN
SIF SOURCE:处女丧失 && !TALENT:不在乎贞操
	CALL V_LOST_VARGIN_MIND_DAMAGE
SIF SOURCE:初吻 && !TALENT:不在乎贞操
	CALL FIRST_KISS_MIND_DAMAGE
SIF SOURCE:母乳体质化
	CALL LACTATION_MIND_DAMAGE
SIF SOURCE:膨乳阶段
	CALL BUSTUP_MIND_DAMAGE
SIF SOURCE:处女结界破坏 && !CFLAG:上位种族
	CALL BREAK_VIRGIN_BARRIER_MIND_DAMAGE

;SOURCE:処女喪失→300
VARSET SOURCE,0,300,310



;処女喪失時のパラメータ増減
@V_LOST_VARGIN_MIND_DAMAGE

;地の文から
CALL V_LOST_VARGIN_MIND_DAMAGE_MESSAGE
IF V_PENIS == CALLNAME:0
	IF TALENT:性知识贫乏
		;痛みが強いかで変更
		IF SOURCE:Ｖ疼痛 >= 5000
			CALL MIND_BASE_DIRECT_MINUS("好感度",1000)
		ELSE
			CALL MIND_BASE_DIRECT_PLUS("好感度",1000)
		ENDIF
	ELSEIF ＃陷落状态／恋慕以上＃ || CFLAG:乳牛
		LOVE = 1000
		SIF TALENT:少女心
			TIMES LOVE,2.00
		CALL MIND_BASE_DIRECT_PLUS("好感度",LOVE)
	ELSEIF (＃陷落状态／陷落以上＃ || TALENT:单纯) && !TALENT:贞操观念
		LOVE = 1000
		SIF TALENT:少女心
			TIMES LOVE,2.00
		CALL MIND_BASE_DIRECT_PLUS("好感度",LOVE)
	ELSE
		GOTO MIND_DAMAGE_COMMON
	ENDIF
ELSE
	$MIND_DAMAGE_COMMON
	IF TALENT:贞操观念
		DAMAGE = 2000
	ELSE
		DAMAGE = 1000
	ENDIF
	SIF TALENT:少女心
		TIMES DAMAGE,1.50
	SIF ＃陷落状态／陷落以上＃
		TIMES DAMAGE,0.50
	CALL MIND_BASE_DIRECT_MINUS("尊严",DAMAGE)
	CALL MIND_BASE_DIRECT_MINUS("精神力",DAMAGE)
	
	;あなた以外だとここは通らない
	IF !PLAYER
		;表示する分があれば
		SIF BASE:厌恶感 < MAXBASE:厌恶感 || BASE:好感度
			PRINTL
		CALL MIND_BASE_DIRECT_PLUS("厌恶感",DAMAGE)
		CALL MIND_BASE_DIRECT_MINUS("好感度",DAMAGE)
	ENDIF
ENDIF
CALL MIND_PALAM_AFTER_PRINT(1)



;初キス時
@FIRST_KISS_MIND_DAMAGE

CALL FIRST_KISS_MIND_DAMAGE_MESSAGE
IF KISS_PLAYER == CALLNAME:0
	IF ＃陷落状态／恋慕以上＃ || CFLAG:乳牛
		LOVE = 1000
		SIF TALENT:少女心
			TIMES LOVE,2.00
		CALL MIND_BASE_DIRECT_PLUS("好感度",LOVE)
	ELSEIF (＃陷落状态／陷落以上＃ || TALENT:单纯) && !TALENT:贞操观念
		LOVE = 300
		SIF TALENT:少女心
			TIMES LOVE,2.00
		CALL MIND_BASE_DIRECT_PLUS("好感度",LOVE)
	ELSE
		GOTO MIND_DAMAGE_COMMON
	ENDIF
ELSE
	$MIND_DAMAGE_COMMON
	IF TALENT:少女心
		DAMAGE = 2000
	ELSE
		DAMAGE = 1000
	ENDIF
	SIF TALENT:贞操观念
		TIMES DAMAGE,1.50
	SIF ＃陷落状态／陷落以上＃
		TIMES DAMAGE,0.50
	CALL MIND_BASE_DIRECT_MINUS("尊严",DAMAGE)
	CALL MIND_BASE_DIRECT_MINUS("精神力",DAMAGE)
	SIF !PLAYER
		CALL MIND_BASE_DIRECT_PLUS("厌恶感",DAMAGE)
ENDIF
CALL MIND_PALAM_AFTER_PRINT(1)



;母乳体質化
@LACTATION_MIND_DAMAGE

CALL LACTATION_MIND_DAMAGE_MESSAGE
SIF !TALENT:性知识贫乏 && !＃陷落状态／恋慕以上＃
	CALL MIND_BASE_DIRECT_MINUS("尊严",1000)
CALL MIND_PALAM_AFTER_PRINT(1)



;膨乳
@BUSTUP_MIND_DAMAGE

CALL BUSTUP_MIND_DAMAGE_MESSAGE
IF CFLAG:乳牛
	LOVE = SOURCE:膨乳阶段 *800
	CALL MIND_BASE_DIRECT_PLUS("乳牛堕落",LOVE)
ELSEIF ＃陷落状态／隶属＃
	LOVE = SOURCE:膨乳阶段 *500
	CALL MIND_BASE_DIRECT_PLUS("乳牛堕落",LOVE)
ELSEIF MARK:搾乳中毒
	LOVE = SOURCE:膨乳阶段 *300
	CALL MIND_BASE_DIRECT_PLUS("乳牛堕落",LOVE)
ELSEIF ＃陷落状态／恋慕以上＃
	IF ABL:胸围大小 > 26
		DAMAGE = 500
		CALL MIND_BASE_DIRECT_MINUS("精神力",DAMAGE)
		CALL MIND_BASE_DIRECT_MINUS("好感度",DAMAGE)
	ENDIF
ELSE
	IF ABL:胸围大小 > 26
		DAMAGE = 3000
		CALL MIND_BASE_DIRECT_MINUS("抵抗心",DAMAGE)
		CALL MIND_BASE_DIRECT_MINUS("尊严",DAMAGE)
		DAMAGE = 1000
		CALL MIND_BASE_DIRECT_MINUS("精神力",DAMAGE)
		
	ELSEIF ABL:胸围大小 < BUSTSIZE_爆乳 && TALENT:乳房自卑
		DAMAGE = SOURCE:膨乳阶段 *300
		CALL MIND_BASE_DIRECT_MINUS("抵抗心",DAMAGE)
		CALL MIND_BASE_DIRECT_MINUS("尊严",DAMAGE)
		SIF !PLAYER
			CALL MIND_BASE_DIRECT_MINUS("厌恶感",DAMAGE)
	ELSE
		DAMAGE = SOURCE:膨乳阶段 *500
		CALL MIND_BASE_DIRECT_MINUS("抵抗心",DAMAGE)
		CALL MIND_BASE_DIRECT_MINUS("尊严",DAMAGE)
	ENDIF
ENDIF
CALL MIND_PALAM_AFTER_PRINT(1)



;処女結界破壊
@BREAK_VIRGIN_BARRIER_MIND_DAMAGE

CALL BREAK_VIRGIN_BARRIER_MIND_DAMAGE_MESSAGE
IF CFLAG:乳牛 || ＃陷落状态／恋慕以上＃ || CFLAG:无抵抗
ELSE
	DAMAGE = 5000
	CALL MIND_BASE_DIRECT_MINUS("抵抗心",DAMAGE)
	CALL MIND_BASE_DIRECT_MINUS("尊严",DAMAGE)
	DAMAGE = 3000
	CALL MIND_BASE_DIRECT_MINUS("精神力",DAMAGE)
ENDIF
CALL MIND_PALAM_AFTER_PRINT(1)

