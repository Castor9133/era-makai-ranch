
;ドット絵サイズ・横軸調整
;ARG→1だと着替え画面用調整
@PRINT_PORTRAIT_SIZE(ARG)

;表示サイズ(フォントサイズ19の環境で10なら等倍)
PY_1 = {0}

;着替え画面から来た場合に横軸をずらす
IF !ARG
	PY_2 = {FLAG:像素画／横轴调整}
	PY_2_2 = {FLAG:像素画／横轴调整 -FLAG:像素画／尺寸 *4 /10}
ELSE
	PY_2 = {FLAG:像素画／横轴调整 +FLAG:像素画／更换画面追加横轴调整}
	PY_2_2 = {FLAG:像素画／横轴调整 +FLAG:像素画／更换画面追加横轴调整 -FLAG:像素画／尺寸 *4 /10}
ENDIF
PY_3 = {FLAG:像素画／尺寸 *5945 /1000}
PY_3_2 = {FLAG:像素画／尺寸 *5945 /3500}
PY_3_3 = {FLAG:像素画／尺寸 *5945 /6900}
PY_3_4 = {FLAG:像素画／尺寸 *5945 /2330}

;子供の髪位置
PY_1_2 = {FLAG:像素画／尺寸 *74 /100}



;子供／大人の位置調整
@PRINT_PORTRAIT_HEIGHT_FIX

;低身長ドット絵判定して髪位置を調整
IF CFLAG:身高 < FLAG:像素画／娇小适用上限数值 || CSTR:状态／主人公的孩子 == "成长中"
	PY_FIX = %PY_1_2%
ELSE
	PY_FIX = %PY_1%
ENDIF

;体型
IF CFLAG:身高 < FLAG:像素画／娇小适用上限数值 || CSTR:状态／主人公的孩子 == "成长中"
	PRTCHR_1 = 儿童
ELSE
	PRTCHR_1 = 标准
ENDIF
PRT:0 = <nonbutton pos='%PY_2%'><img src='%PRTCHR_1%_%CSTR:颜色类别／肤色%' height='%PY_3%' ypos = '%PY_1%'></nonbutton>








