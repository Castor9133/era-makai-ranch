
;霊力・魔力・母乳のバー表示
@PRINT_SOME_DRINK

IF MARK:母乳体质
	IF MARK:绝顶魔力回复淫纹
		CALL PRINT_MILKTANK(1,1,0,1)
	ELSE
		PRINTFORM  母乳容量：%TOSTR(BASE:母乳容量,"#,0")%%MILK_COUNTING()% 
		CALL PRINT_MILKTANK(1,1,0,1)
		SIF MARK:魔力母乳体质
			PRINTFORM +%VALUE_DIGIT(BASE:魔力)%MP 
	ENDIF
	PRINTL
ELSE
	CALL PRINTL_WORD_COLOR("　非【母乳体质】","灰")
ENDIF

;常に表示
PRINTFORMLC  灵力：%VALUE_DIGIT(BASE:灵力)%／%VALUE_DIGIT(MAXBASE:灵力)%EP 
CALL PRINT_COLORBAR(BASE:灵力,MAXBASE:灵力,8,BARCOLORSET(""),RESULT:1)
CALL PRINT_REMAINING_EP
PRINTL

;それぞれで表示して並びを揃える
IF MARK:绝顶魔力回复淫纹
	CALL PRINT_WORD_COLOR("【绝顶魔力回复淫纹】","桃")
	CALL PRINT_REMAINING_MP
ELSEIF MAXBASE:魔力
	PRINTFORMLC  魔力：%VALUE_DIGIT(BASE:魔力)%／%VALUE_DIGIT(MAXBASE:魔力)%MP 
	CALL PRINT_COLORBAR(BASE:魔力,MAXBASE:魔力,8,BARCOLORSET("深紫"),RESULT:1)
	CALL PRINT_REMAINING_MP
	PRINTFORM  <{BASE:魔力恢复率,2}\%\/day>
ELSE
	CALL PRINT_WORD_COLOR("　没有魔力","灰")
ENDIF
PRINTL


