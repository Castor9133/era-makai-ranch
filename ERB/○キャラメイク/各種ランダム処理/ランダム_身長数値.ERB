
;奴隷候補の身長数値
@RANDOM_SLAVE_HEIGHT

;オトコの場合オトコ用へ
IF TALENT:男性
	CALL RANDOM_CHARA_HEIGHT_MALE
	RETURN
ENDIF
SELECTCASE CSTR:身高

;一応なんも入ってないと標準にしてもっかい処理
CASE ""
	CSTR:身高 = 标准
	RESTART

;1つ下の数値+1+上限範囲までのRAND
CASE "幼儿体型"
	CFLAG:身高 = HEIGHT_MAX_妖精体型 +1 +RAND:(HEIGHT_MAX_幼儿体型 -HEIGHT_MAX_妖精体型)
CASE "儿童体型"
	CFLAG:身高 = HEIGHT_MAX_幼儿体型 +1 +RAND:(HEIGHT_MAX_儿童体型 -HEIGHT_MAX_幼儿体型)
CASE "矮小"
	CFLAG:身高 = HEIGHT_MAX_儿童体型 +1 +RAND:(HEIGHT_MAX_矮小 -HEIGHT_MAX_儿童体型)
CASE "娇小"
	CFLAG:身高 = HEIGHT_MAX_矮小 +1 +RAND:(HEIGHT_MAX_娇小 -HEIGHT_MAX_矮小)
CASE "标准"
	CFLAG:身高 = HEIGHT_MAX_娇小 +1 +RAND:(HEIGHT_MAX_标准 -HEIGHT_MAX_娇小)
CASE "高挑"
	CFLAG:身高 = HEIGHT_MAX_标准 +1 +RAND:(HEIGHT_MAX_高挑 -HEIGHT_MAX_标准)
CASE "高大"
	CFLAG:身高 = HEIGHT_MAX_高挑 +1 +RAND:(HEIGHT_MAX_高大 -HEIGHT_MAX_高挑)
ENDSELECT



;オトコ用
@RANDOM_CHARA_HEIGHT_MALE

SELECTCASE CSTR:身高
CASE ""
	CSTR:身高 = 标准
	RESTART
CASE "幼儿体型"
	CFLAG:身高 = HEIGHT_MAX_妖精体型 +1 +RAND:(HEIGHT_MAX_幼儿体型 -HEIGHT_MAX_妖精体型)
CASE "儿童体型"
	CFLAG:身高 = HEIGHT_MAX_幼儿体型 +1 +RAND:(HEIGHT_MAX_儿童体型 -HEIGHT_MAX_幼儿体型)
CASE "矮小"
	CFLAG:身高 = HEIGHT_MAX_儿童体型 +1 +RAND:(HEIGHT_MAX_矮小 -HEIGHT_MAX_儿童体型)
CASE "娇小"
	CFLAG:身高 = HEIGHT_MAX_矮小 +1 +RAND:(MALE_HEIGHT_MAX_娇小 -HEIGHT_MAX_矮小)
CASE "标准"
	CFLAG:身高 = MALE_HEIGHT_MAX_娇小 +1 +RAND:(MALE_HEIGHT_MAX_标准 -MALE_HEIGHT_MAX_娇小)
CASE "高挑"
	CFLAG:身高 = MALE_HEIGHT_MAX_标准 +1 +RAND:(MALE_HEIGHT_MAX_高挑 -MALE_HEIGHT_MAX_标准)
CASE "高大"
	CFLAG:身高 = MALE_HEIGHT_MAX_高挑 +1 +RAND:(MALE_HEIGHT_MAX_高大 -MALE_HEIGHT_MAX_高挑)
ENDSELECT



