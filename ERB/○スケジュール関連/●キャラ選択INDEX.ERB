
;スケジュール
;TARGET指定状態でここに来るよ
;ARGS→元ページ　　メインメニュー・全奴隷・牛舎
@SCHEDULE_PLAN(ARGS)
#DIM TRAIN_SLAVE_NUM
#DIM SAVE_TRAIN_TARGET

CLEARLINE LINECOUNT
CALL CALC_PEOPLE_FLAG
CALL SHOW_STATUS_DETAIL

;牛舎にいる場合専用メッセージと専用選択肢　管理コマンドはできてもいいか
IF CFLAG:牛舍号码
	CALL PRINTL_ALIGN(-10)
	PRINTFORM HP：{BASE:体力,4} 
	CALL PRINT_COLORBAR(BASE:体力,MAXBASE:体力,8,BARCOLORSET("青绿"),RESULT:1)
	PRINTFORM 　SP：{BASE:气力,4} 
	CALL PRINT_COLORBAR(BASE:气力,MAXBASE:气力,8,BARCOLORSET("青绿"),RESULT:1)
	CALL PRINT_NOW_PLACE(1)
	DRAWLINE
	CALL PRINTL_WORD_COLOR("因在牛舍内不能修改日程","灰")
	GOTO LIST_END
	
;追跡中のキャラ用情報
ELSEIF CFLAG:追踪对象
	CALL PRINT_CHASE_STATUS(1)
	GOTO LIST_END
ELSEIF CSTR:状态／主人公的孩子 == "成长中"
	PRINTL
	PRINTFORML  成长期间中(剩余{14 + CFLAG:捕获日 - DAY}天)
	CALL PRINTL_ALIGN(-10)
	PRINTFORM HP：{BASE:体力,4} 
	CALL PRINT_COLORBAR(BASE:体力,MAXBASE:体力,8,BARCOLORSET("青绿"),RESULT:1)
	CALL PRINT_NOW_PLACE_PLAN
	DRAWLINE
	PRINTL 　《 日程的变更 》
	PRINTLC [  0] 空闲时间
	PRINTLC [  2] 让其授乳。
	PRINTL
	PRINTL
	PRINTL 　《 管理 》
	PRINTLC [200] 会いに行く
	GOTO LIST_END_CHILD
ENDIF

;ある程度下げる
CALL PRINTL_ALIGN(-10)

;HPこっちで表示するようにした,SP足した
PRINTFORM HP：{BASE:体力,4} 
CALL PRINT_COLORBAR(BASE:体力,MAXBASE:体力,8,BARCOLORSET("青绿"),RESULT:1)
PRINTFORM 　SP：{BASE:气力,4} 
CALL PRINT_COLORBAR(BASE:气力,MAXBASE:气力,8,BARCOLORSET("青绿"),RESULT:1)

;居場所とスケジュールを表示する関数作る
CALL PRINT_NOW_PLACE_PLAN
DRAWLINE

;外出済みなら変更できない
IF CSTR:日程 == "行动完毕"
	PRINTL 无法更改，因为已采取行动。
	GOTO LIST_END
ENDIF
PRINTL 　《 日程的变更 》
CALL PRINT_SCHEDULE_PLAN_STATE
CALL PRINT_SCHEDULE_PLAN_WORK
CALL PRINT_SCHEDULE_PLAN_TRAIN

$LIST_END

;顔グラ・ドット絵で2下がる分を増やしていいかも
CALL PRINTL_ALIGN(2)
CALL PRINT_SCHEDULE_PLAN_MANAGEMENT

;このへんは常にOK　どの状況でも設定には行けるようにする
PRINTLC [210] 个人设置
PRINTLC [211] 详细状态

;追跡中は自動スケジュール不可
IF CFLAG:追踪对象
	CALL PRINTLC_WORD_COLOR("未捕获","灰")
ELSE
	PRINTLC [212] 自动日程管理
ENDIF

;子供はここまで
$LIST_END_CHILD

PRINTL
DRAWLINE
PRINTLC [300] 上一个角色
PRINTLC [301] 下一个角色
PRINTL [ 99] 完成
BINPUT
PRINTL

;別関数へ
CALL SCHEDULE_PLAN_CHANGE(RESULT,ARGS)

;RETURN1してきたらRESTART
SIF RESULT
	RESTART

;ここで調整かけるようにする
CALL SCHEDULE_ADJUST



