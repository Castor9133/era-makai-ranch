	RETURNF 1000
LOCAL:71 = 0
SIF STR:5688 != "" && STRFIND(CSTR:身份, STR:5688) >= 0
	LOCAL:71 ++
SIF STR:5695 != "" && STRFIND(CSTR:身份, STR:5695) >= 0
	LOCAL:71 ++
