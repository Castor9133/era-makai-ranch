
;アクセサリー
@PRINT_PORTRAIT_ACCESSORY

CALL PRINT_PORTRAIT_ACCESSORY_EYE
CALL PRINT_PORTRAIT_ACCESSORY_HEAD
CALL PRINT_PORTRAIT_ACCESSORY_ARM
CALL PRINT_PORTRAIT_ACCESSORY_LEG
CALL PRINT_PORTRAIT_ACCESSORY_NECK
CALL PRINT_PORTRAIT_ACCESSORY_JACKET





;アクセサリ(眼)
@PRINT_PORTRAIT_ACCESSORY_EYE

SIF TFLAG:临时脱衣／眼 || !EQUIP:装备中ID／眼
	RETURN
SELECTCASE ITEMNAME:(EQUIP:装备中ID／眼)
CASE "眼镜"
	SPRITECREATED @"%CSTR:(EQUIP:装备中ID／眼)%眼镜"
	IF RESULT
		PRT:12 = <nonbutton pos='%PY_2%'><img src='%CSTR:(EQUIP:装备中ID／眼)%眼镜' height='%PY_3%' ypos = '%PY_FIX%'></nonbutton>
	ELSE
		PRT:12 = <nonbutton pos='%PY_2%'><img src='眼镜' height='%PY_3%' ypos = '%PY_FIX%'></nonbutton>
	ENDIF
CASE "伊达眼镜"
	SPRITECREATED @"%CSTR:(EQUIP:装备中ID／眼)%伊达眼镜"
	IF RESULT
		PRT:12 = <nonbutton pos='%PY_2%'><img src='%CSTR:(EQUIP:装备中ID／眼)%伊达眼镜' height='%PY_3%' ypos = '%PY_FIX%'></nonbutton>
	ELSE
		PRT:12 = <nonbutton pos='%PY_2%'><img src='伊达眼镜' height='%PY_3%' ypos = '%PY_FIX%'></nonbutton>
	ENDIF
ENDSELECT



;アクセサリ(頭)
@PRINT_PORTRAIT_ACCESSORY_HEAD

SPRITECREATED @"%ITEMNAME:(EQUIP:装备中ID／头)%"
SIF !RESULT || TFLAG:临时脱衣／头 || !EQUIP:装备中ID／头
	RETURN
SPRITECREATED @"%CSTR:(EQUIP:装备中ID／头)%%ITEMNAME:(EQUIP:装备中ID／头)%"
PRT:11 = <nonbutton pos='%PY_2%'><img src='%CSTR:(EQUIP:装备中ID／头)%%ITEMNAME:(EQUIP:装备中ID／头)%' height='%PY_3%' ypos = '%PY_FIX%'></nonbutton>
SIF !RESULT
	PRT:11 = <nonbutton pos='%PY_2%'><img src='%ITEMNAME:(EQUIP:装备中ID／头)%' height='%PY_3%' ypos = '%PY_FIX%'></nonbutton>



