
;1ページ
@SELF_CHARA_MAKE_PROFILE_1

PRINTL 　《 基本资料 》
CALL HALFLINE
PRINTLC [ 0] 名称
PRINTFORML ：%CALLNAME%
CALL NAME_DUPLICATE_CHECK
PRINTL
PRINTLC [ 1] 种族
PRINTFORML ：【%CSTR:种族%】
PRINTLC [ 2] 上位种族
CALL PRINT_ONOFF(CFLAG:上位种族,1)
PRINTLC [ 3] 职业
PRINTFORML ：%CSTR:职业%

IF !SELF_CHARA_MAKE_RANDOM
	PRINTLC [ 4] 身份
	PRINTFORML ：%CSTR:身份%
	PRINTLC [ 5] 所属
	PRINTFORML ：%CSTR:所属%
ELSE
	CALL PRINTLC_WORD_COLOR,@"< 4> 身份…手动输入仅可","灰"
	PRINTFORML ：%CSTR:身份%
	CALL PRINTLC_WORD_COLOR,@"< 5> 所属…手动输入仅可","灰"
	PRINTFORML ：%CSTR:所属%
ENDIF
PRINTL [ 6] 服装变更
CALL SHOW_EQUIP(1)
PRINTL
PRINTLC [ 7] 进入魔界的目的
PRINT ：
CALL PRINT_PURPOSE(CFLAG:进入魔界的目的)
PRINTL
PRINTLC [10] 身高
PRINTFORM ：%PRINT_HEIGHT()%
SIF SELF_CHARA_MAKE_RANDOM
	PRINTFORM （【%CSTR:身高%】内重新调整）
PRINTL
PRINTLC [11] 体型
PRINTFORML ：%CSTR:体型%
PRINTLC [12] 肤色
PRINTFORML ：%CSTR:肤色%
PRINTLC [13] 胸围大小
PRINTFORM ：%PRINT_BUSTSIZE(ABL:胸围大小)%
CALL PRINT_BUST_C(1,1)
SIF SELF_CHARA_MAKE_RANDOM
	PRINTFORM （【%PRINT_BUSTSIZE_TALENT()%】内重新调整）
PRINTL
PRINTLC [14] 性经验
PRINTFORML 【%CSTR:性经验%】



@SELF_CHARA_MAKE_PROFILE_2

PRINTL 　《 种族特征 》
CALL HALFLINE
PRINTL 　《 种族素质 》

;TALENT:魔界種族→50
;【魔界種族】は付与不可
TALENT_REF = 50
FOR LOCAL,1,20
	SIF TALENTNAME:(LOCAL +TALENT_REF) == ""
		CONTINUE
	PRINTFORMLC [{LOCAL,2}] 【%TALENTNAME:(LOCAL +TALENT_REF)%】
	CALL PRINT_ONOFF(TALENT:(LOCAL +TALENT_REF),1)
NEXT



