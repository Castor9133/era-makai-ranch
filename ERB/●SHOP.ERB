
;メイン画面
@SHOW_SHOP

;部屋数とか計算
CALL CALC_PEOPLE_FLAG

;居場所を確認
CALL CHARA_WHEREABOUTS_ALL

;ここでだけスケジュールの可不可判定すればOK
CALL SCHEDULE_POSSIBLE

;淫乳の人数をカウント　同じくここでだけでOK
FLAG:淫乳奴隶存在 = CMATCH(MARK:淫乳,1)
TARGET = -1

;夜のデータをロードした場合
IF TIME >= 3
	CALL MANYL(5)
	PRINTL 指定夜间行动
	PRINTL [ 0] OK
	RETURN
ENDIF

;スケジュールを実行可能かここで見る
CALL SCHEDULE_JUDGE
CALL MANYL(5)

;多少の自動ヒントを出しとく
CALL TUTORIAL_TIPS_SHOP

;簡易牧場情報
CALL SHOW_RESOURCE_MAIN

;全員のスケジュール
CALL ALL_SCHEDULE_PRINT

;ボタン表示
;スケジュール→実行不可なら！
SETCOLOR FLAG:颜色编码／主界面强调选项
IF !JUDGE_NG
	PRINTLC [  0] 日程运行
ELSE
	PRINTLC [  0] ！日程执行
ENDIF
RESETCOLOR
IF CSTR:0:日程 != "行动完毕"
	PRINTLC [  1] 调教对象选择
ELSE
	CALL PRINTLC_WORD_COLOR("　调教对象选择","灰")
ENDIF
PRINTLC [  2] 成批更改日程
PRINTL
PRINTLC 　

;マイルストーン1つ達成が必要
CALL MILESTONE_UNLOCK_CHECK("前往街道","LC")

;RETURN1したら表示、ロック表示は内部でやってる
IF RESULT
	IF TIME > 0 && FLAG:事务工作量 < 20
		PRINTLC [  3] 上街
	ELSE
		CALL PRINTLC_WORD_COLOR("　上街","灰")
	ENDIF
ENDIF
PRINTLC [  4] 开发・习得
PRINTLC [  5] 更改显示项目
PRINTLC [  6] 各种信息・管理
PRINTLC [  7] 提示

;拡張メニュー表示がONなら追加
SIF FLAG:主要／扩展菜单显示
	CALL PRINT_MORE_MENU
PRINTL
DRAWLINE
PRINTLC [ 90] 保存／加载
PRINTLC [ 91] 选项
PRINTFORMLC [ 92] 扩张菜单\@ FLAG:主要／扩展菜单显示 ? ▲ # ▼ \@
PRINTL



;拡張メニュー
@PRINT_MORE_MENU

PRINTL
CALL HALFLINE
PRINTFORMLC [ 50] 显示项切换（{FLAG:列表状态切换 +1}／{TABLE_STATUS_PAGE}）
CALL MILESTONE_UNLOCK_CHECK("奴隶捕获","LC")
IF RESULT
	IF !TIME
		CALL PRINTLC_WORD_COLOR("　身在魔界的人类一览","灰")
	ELSE
		PRINTLC [ 51] 身在魔界的人类一览
	ENDIF
ENDIF
PRINTLC [ 52] 牧场信息
PRINTL

CALL MILESTONE_UNLOCK_CHECK("料理值班","LC")
SIF RESULT
	PRINTLC [ 53] 料理值班变更
CALL MILESTONE_UNLOCK_CHECK("房间分配","LC")
IF RESULT
	IF FLAG:时刻限制／房间分配变更
		CALL PRINTLC_WORD_COLOR("　房间分配变更","灰")
	ELSE
		PRINTLC [ 54] 房间分配变更
	ENDIF
ENDIF
CALL MILESTONE_UNLOCK_CHECK("清洁值日","LC")
SIF RESULT
	PRINTLC [ 55] 清洁担当变更
PRINTL

CALL MILESTONE_UNLOCK_CHECK("商业合作","LC")
IF RESULT
	IF TIME
		PRINTLC [ 56] 访问合作伙伴
	ELSE
		CALL PRINTLC_WORD_COLOR("　访问合作伙伴","灰")
	ENDIF
ENDIF
PRINTLC [ 57] 里程碑确认
PRINTL
PRINTLC [ 80] 奴隶检索
PRINTLC [ 81] 奴隶分类
PRINTFORMLC [ 82] 应用奴隶隐藏设置：\@ FLAG:主要／奴隶隐藏 ? ON # OFF \@



@USERSHOP
;SHOW_SHOP呼び出し後0～99が入力されると購入処理、それ以外が入力されると@USERSHOPを呼び出す
;この範囲は_replace.csvによって変更可能である
;各種メニューから戻ってきたときに画面クリアしようかな？

PRINTL
IF TIME == 3
	CALL NIGHT_PHASE
	RETURN
ENDIF
SELECTCASE RESULT
CASE 0
	CALL MAIN_PHASE
CASE 1
	SAVE_TARGET = 0
	SIF CSTR:0:日程 != "行动完毕"
		CALL TRAIN_SLAVE_SELECT
CASE 2
	CALL BULK_SCHEDULE
CASE 3
	CALL SHOPPING_MOVE_SELECT
	
	;街へ行ける状態ならFLAG:外出済みが1以上
	SIF FLAG:已外出
		CALL TOWN
CASE 4
	CALL UPGRADE_INDEX
CASE 5
	CALL CHANGE_TABLE_STATUS
CASE 6
	CALL SELECT_INFORMATION
CASE 7
	CALL BROWSE_HINT("主菜单")
CASE 20 TO 29
	CALL COWSHED_MANAGE_ENTRANCE(RESULT -19)
CASE 30 TO 39
	INVERTBIT FLAG:主要／折叠BIT,(RESULT -30)
CASE 50
	FLAG:列表状态切换 ++
	SIF FLAG:列表状态切换 >= TABLE_STATUS_PAGE
		FLAG:列表状态切换 = 0
CASE 51
	CALL MILESTONE_UNLOCK_CHECK("奴隶捕获","")
	SIF RESULT && TIME
		CALL PRINT_SLAVE_CANDIDATE
	
CASE 52
	CALL RANCH_STATUS
CASE 53
	SIF ITEM:系统化厨房
		CALL DINNER_DUTY_LIST
CASE 54
	CALL MILESTONE_UNLOCK_CHECK("房间分配","")
	SIF RESULT && !FLAG:时刻限制／房间分配变更
		CALL ROOM_ALLOCATION
CASE 55
	CALL MILESTONE_UNLOCK_CHECK("清洁值日","")
	SIF RESULT
		CALL CLEANING_DUTY_LIST
CASE 56
	CALL MILESTONE_UNLOCK_CHECK("商业合作","")
	SIF RESULT && TIME
		CALL BUISINESS_PARTNER
CASE 57
	CALL MILESTONE_TABLE
CASE 80
	CALL SLAVE_SEARCH(1)
CASE 81
	CALL SLAVE_SORT
CASE 82
	INVERTBIT FLAG:主要／奴隶隐藏,0
CASE 90
	CALL SAVE_MENU
CASE 91
	CALL OPTION
CASE 92
	INVERTBIT FLAG:主要／扩展菜单显示,0
ENDSELECT
IF RESULT >= 100 && RESULT < 100 +CHARANUM
	TARGET = RESULT -100
	CALL SCHEDULE_PLAN("主菜单")
	TARGET = -1
ENDIF



