
;触手変化
@TENTACLE_MAGIC_GET
#DIM DYNAMIC PAGE

PAGE_MAX = 4
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_UPGRADE("触手AP")
PRINTL 使用【触手AP】学习触手变换魔法。
PRINTL
BR = 0
TRYCALLFORM TENTACLE_MAGIC_GET_LIST_{PAGE}
PRINTL
DRAWLINE
CALL ITEM_DETAIL_TENTACLE_MAGIC(SELECT_ITEM)
CALL PRINTL_ALIGN
CALL ABILITY_GET_JUDGE(SELECT_ITEM,"触手魔法")
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTLC [ 90] 批量学习
PRINTLC 　
PRINTL [ 99] 完成
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	;購入処理
	ITEM:SELECT_ITEM ++
	MONEY:触手AP -= ITEMPRICE:SELECT_ITEM
	CALL PRINTW_WORD_COLOR,@"学习了【%ITEMNAME:SELECT_ITEM%】。","浅蓝色"
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
	SELECT_ITEM = 0
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_ITEM = 0
CASE 90
	CALL TENTACLE_MAGIC_GET_BULK
CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART



;一括習得
@TENTACLE_MAGIC_GET_BULK

PRINTL 使用当前的技能点一括学习列表前的可学习页面内魔法。
PRINTL ・如果AP不足，将不会进行后续的魔法学习。
PRINTL 执行批量学习？
CALL ASK_YN
SIF RESULT
	RETURN

;記録
AP_BEFORE = MONEY:触手AP
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	;習得前提魔術も見る
	SIF !ITEMPRICE:LOCAL || ITEM:LOCAL || (MAGIC_GET_PREMISE:LOCAL && !ITEM:(MAGIC_GET_PREMISE:LOCAL))
		CONTINUE
	
	;習得不可魔力で終了
	SIF ITEMPRICE:LOCAL > MONEY:触手AP
		BREAK
	ITEM:LOCAL ++
	MONEY:触手AP -= ITEMPRICE:LOCAL
	CALL PRINTL_WORD_COLOR,@"学习了【%ITEMNAME:LOCAL%】。","浅蓝色"
NEXT
PRINTFORML 消费AP：%TOSTR(AP_BEFORE -MONEY:触手AP)%
IF AP_BEFORE == MONEY:触手AP
	PRINTW 魔法的习得失败了。

;LOCALがITEM_ID_MAXなら全て習得した
ELSEIF LOCAL >= ITEM_ID_MAX
	PRINTW 《 习得了所有的魔法 》
ELSE
	PRINTW
ENDIF
SELECT_ITEM = 0

