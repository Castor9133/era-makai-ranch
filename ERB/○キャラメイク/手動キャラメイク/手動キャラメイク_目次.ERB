
;手動でキャラメイク入り口
@SELF_CHARA_MAKE_ENTRANCE

IF MONEY:贡献PT < CHARA_MAKE_COST && !FLAG:贡献pt零消费
	PRINTL 贡献PT不够。
	PRINTFORMW （在手动角色制作中，将获得贡献pt %VALUE_DIGIT(CHARA_MAKE_COST)%是必需的。）
	RETURN
ENDIF
CALL MANYL(5)
PRINTL 手动为奴隶候选人创建角色。
PRINTL 您可以进行详细设置，但请注意，这需要一些时间。
PRINTL （如果您可以创建CSV文件，您可能希望这样做）
PRINTL 你想开始创建你的角色吗？
IF FLAG:贡献pt零消费
	CALL PRINTL_WORD_COLOR,@"＜贡献pt零消费＞选项有效","黄"
ELSE
	CALL PRINTL_WORD_COLOR,@"（標目标确定时，贡献pt %VALUE_DIGIT(CHARA_MAKE_COST)%将被消费。目前：%VALUE_DIGIT(MONEY:贡献PT)%pt）","黄"
ENDIF
CALL ASK_YN
IF !RESULT
	;ランダムするか聞くのを追加
	CALL MANYL(3)
	PRINTL 您想随机设置基本角色的参数吗？
	CALL ASK_YN
	IF !RESULT
		CALL SELF_CHARA_MAKE_SET_RANDOM
	ELSE
		CALL SELF_CHARA_MAKE_BEFORE
	ENDIF
	CALL SELF_CHARA_MAKE
ELSE
	RETURN
ENDIF



;手動キャラメイク前のデフォルトステータス入れ
@SELF_CHARA_MAKE_BEFORE

FLAG:重新调整BIT = 0
FLAG:正在化妆角色 = 1
ADDCHARA 2
TARGET = CHARANUM -1
CFLAG:追踪对象 = 1
TALENT:普乳 = 1
CALL RANDOM_SLAVE_BUST
CALL HEIGHT_CSTR_CALC
CALL SLAVE_EP_CALC
CALL SLAVE_BATTLE_POWER_CALC(1)
CALL CHOICE_CATEGORY
CALL SWEET_PERSON_CALL_ALL
CALL SWEET_GENITAL_CALL_ALL



;本体
@SELF_CHARA_MAKE

CLEARLINE LINECOUNT

;手動時の共通表示まとめ
CALL PRINT_SELF_CHARA_MAKE_STATUS

;目次
PRINTL 　《 目录 》
CALL HALFLINE
PRINTL [ 0] 基本资料
PRINTFORML [ 1] 外表・%SAVESTR:标识／乳房%
PRINTL [ 2] 状态・工作能力
PRINTL [ 3] 性关联
PRINTL [ 4] 素质一览
PRINTL [ 5] 专用设置
CALL PRINTL_ALIGN(3)
DRAWLINE
PRINTLC [90] 放弃并返回
PRINTLC [91] dat数据输出

;決定ボタン出すか無効か
CALL SLAVE_AUCTION_PRICE_CALC
IF CFLAG:拍卖价格 > MONEY
	CALL PRINTL_WORD_COLOR,@"　资金不足","黄"
ELSEIF CALLNAME == ""
	CALL PRINTL_WORD_COLOR,@"　请设置名称","黄"
ELSE
	PRINTL [99] 转到确认屏幕
ENDIF
SIF CFLAG:拍卖价格
	PRINTFORML 竞卖价格：%VALUE_DIGIT(CFLAG:竞卖价格)%G　资金：%VALUE_DIGIT(MONEY)%G
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL SELF_CHARA_MAKE_PROFILE
CASE 1
	CALL SELF_CHARA_MAKE_APPEARAINCE
CASE 2
	CALL SELF_CHARA_MAKE_STATUS
CASE 3
	CALL SELF_CHARA_MAKE_SENSITIVE
CASE 4
	CALL SELF_CHARA_MAKE_TALENT
CASE 5
	CALL SELF_CHARA_MAKE_EXCLUSIVE
CASE 90
	PRINTL 是否要放弃角色制作信息并返回？
	CALL ASK_YN
	IF !RESULT
		DELCHARA TARGET
		FLAG:正在化妆角色 = 0
		RETURN
	ENDIF
CASE 91
	;キャラメイク中のdat出力
	CALL CHARA_MAKE_OUTPUT_DATA
	
CASE 99
	CALL SELF_CHARA_MAKE_COMPLETE
	
	;RETURN 1してきたら完了
	SIF RESULT
		RETURN
ENDSELECT
RESTART



;手動時の共通表示
@PRINT_SELF_CHARA_MAKE_STATUS

CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT
CALL PRINT_NAME_STATUS
CALL PRINT_AFFILIATION_DATA
CALL PRINT_VISUAL_AGE
PRINTFORM 胸围大小：%PRINT_BUSTSIZE(ABL:胸围大小)%
CALL PRINT_BUST_C(1,1,1)
PRINTFORML 性经验：【%CSTR:性经验%】
CALL PRINT_EXTERIOR
PRINTFORM 性格：【%CSTR:性格%】
SIF !(CFLAG:进入魔界的目的 == 8 || CFLAG:进入魔界的目的 == 9)
	CALL PRINT_PURPOSE(CFLAG:进入魔界的目的)
PRINTFORM  Lv{BASE:等级}　★{CFLAG:级别}
IF CFLAG:同伴规模
	PRINTFORML ／{CFLAG:同伴级别}%GROUP_SCALE()%
ELSE
	CALL PRINTL_WORD_COLOR,@"【没有同伴】","灰"
ENDIF
PRINTL



;キャラメイク完了判定
@SELF_CHARA_MAKE_COMPLETE

CLEARLINE LINECOUNT
CALL CHARA_MAKE_SLAVE_DATA(9)

;各種確認
SIF CALLNAME == "默认子"
	CALL PRINTL_WORD_COLOR,@"！名字仍然是「デフォ子」","黄"
SIF !CFLAG:口上表示 && FLAG:口上表示
	CALL PRINTL_WORD_COLOR,@"口上尚未设定","黄"
PRINTL 在这里决定吗？
CALL ASK_YN
SIF RESULT
	RETURN
SIF !FLAG:贡献pt零消费
	MONEY:贡献PT -= CHARA_MAKE_COST
SIF CFLAG:进入魔界的目的 == 7
	MONEY -= CFLAG:拍卖价格

;終了前に排他素質消去
CALL EXCLUSIVE_TALENT

;整理してこれでOKになったはず
CALL CHARA_MAKE_END_CALC
CALL CHARA_MAKE_END_FLAGSET

;最後までOKならRETURN 1
RETURN 1


