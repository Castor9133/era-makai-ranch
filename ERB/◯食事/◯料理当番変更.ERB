
;料理当番設定
@DINNER_DUTY_LIST
#DIM REF_ID,2

CLEARLINE LINECOUNT
PRINTL 设置料理值班。
PRINTL 如果在实际日程运行时处于不可料理状态，则进入选择画面。
PRINTL

;STR:月（曜日）→3900
;FLAG:食事当番基準／月→300
;FLAG:食事当番ID・ABL／月→310
STR_REF = 3900
FLAG_REF = 300
FLAG_REF:1 = 310
FOR LOCAL,0,7
	REF_ID = FLAG:(FLAG_REF +LOCAL)
	REF_ID:1 = FLAG:(FLAG_REF:1 +LOCAL)
	PRINTFORM [{LOCAL,2}] %STR:(STR_REF +LOCAL)%曜日：
	
	;基準フラグにより変える
	SELECTCASE REF_ID
	CASE 0
		;適当
		PRINTL 随便安排。
	CASE 1
		;毎回選ぶ
		PRINTL 每次选择
	CASE 2
		;料理ABL参照
		IF !REF_ID:1
			PRINTL 从所有角色中随机
		ELSE
			PRINTFORML 从料理等级{REF_ID:1}以上的角色中随机
		ENDIF
		
	CASEELSE
		;指定IDのキャラ
		;見つからないなら-1
		FINDCHARA CFLAG:ID,REF_ID:1
		IF RESULT >= 0
			TARGET = RESULT
			PRINTFORM %CALLNAME_DIGIT()%：料理Lv{ABL:料理,2}
			CALL PRINT_POST_C
			CALL TABLE_STATUS_BUST
			CALL PRINT_MILKTANK(0,1,1,1)
			
			;現在料理不可の状態なら表示
			CALL DINNER_DUTY_IMPOSSIBLE_STATUS
			PRINTL
		ELSE
			CALL PRINTL_WORD_COLOR("　找不到指定的角色","灰")
		ENDIF
	ENDSELECT
NEXT
DRAWLINE
PRINTLC [90] 批量设置
PRINTLC [98] 提示
PRINTLC [99] 完成
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 6
	CALL DINNER_DUTY_WEEK(RESULT)
CASE 90
	CALL DINNER_DUTY_BULK
CASE 98
	CALL BROWSE_HINT("料理")
CASE 99
	RETURN
ENDSELECT
RESTART



;曜日ずつ選択
;ARG→INPUT
;FLAG_REF指定済み
@DINNER_DUTY_WEEK(ARG)

PRINTFORML %STR:(STR_REF +ARG)%曜日的料理轮次请选择。
CALL DINNER_DUTY_CHOICE
SELECTCASE RESULT
CASE 0,1
	;適当・毎回選ぶ
	;食事当番基準フラグに入れる
	FLAG:(FLAG_REF +ARG) = RESULT
	
	;ID・ABL格納部分は0に戻す
	FLAG:(FLAG_REF:1 +ARG) = 0
	
CASE 2
	;Lv指定
	PRINTL
	PRINTL 请输入随机候选的料理等级。
	PRINTL （如果一个人都不满足的话从料理等级最高的角色中随机选择）
	PRINTL
	PRINTLC [  0] 从所有角色中随机
	PRINTLC [  5] 从Lv5以上随机
	PRINTL [100] 取消
	PRINTL 或请输入0～99的数值。
	INPUT
	SIF RESULT < 0 || RESULT >= 100
		RETURN
	FLAG:(FLAG_REF +ARG) = 2
	FLAG:(FLAG_REF:1 +ARG) = RESULT
	
CASE 3
	;キャラ指定
	CALL DINNER_DUTY_SELECT_MANUAL
	SIF RESULT < 0
		RETURN
	FLAG:(FLAG_REF +ARG) = 3
	
	;TARGET指定して帰ってくる
	FLAG:(FLAG_REF:1 +ARG) = CFLAG:ID
ENDSELECT



;一括選択
@DINNER_DUTY_BULK

PRINTL 一次性设置的料理轮次请选择。
CALL DINNER_DUTY_CHOICE
SELECTCASE RESULT
CASE 0,1
	FLAG:FLAG_REF = RESULT
	FLAG:(FLAG_REF:1) = 0
CASE 2
	PRINTL
	PRINTL 请输入随机候选的料理等级。
	PRINTL （如果一个人都不满足的话从料理等级最高的角色中随机选择）
	PRINTL
	PRINTLC [  0] 从所有角色中随机
	PRINTLC [  5] 从Lv5以上随机
	PRINTL [100] 取消
	PRINTL 或请输入0～99的数值。
	INPUT
	SIF RESULT < 0 || RESULT >= 100
		RETURN
	FLAG:FLAG_REF = 2
	FLAG:(FLAG_REF:1) = RESULT
CASE 3
	CALL DINNER_DUTY_SELECT_MANUAL
	SIF RESULT < 0
		RETURN
	FLAG:FLAG_REF = 3
	FLAG:(FLAG_REF:1) = CFLAG:ID
ENDSELECT

;日曜部分に入れたあとに全部にコピー
FOR LOCAL,1,7
	FLAG:(FLAG_REF +LOCAL) = FLAG:FLAG_REF
	FLAG:(FLAG_REF:1 +LOCAL) = FLAG:(FLAG_REF:1)
NEXT



@DINNER_DUTY_CHOICE

PRINTL
PRINTL [ 0] 随便安排。
PRINTL [ 1] 每次选择
PRINTL [ 2] 料理Lv指定以上的角色中的随机
PRINTL [ 3] 角色指定
PRINTL
PRINTL [99] 取消
BINPUT
RETURN RESULT



;料理当番選択
@DINNER_DUTY_SELECT_MANUAL
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTL 请选择晚餐值班的角色。
DRAWLINE
FOR TARGET_COUNT,0,20
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	IF !CFLAG:日程设定可能／事务
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：设定不可","灰"
		CONTINUE
	ENDIF
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("料理值班")
	CALL DINNER_DUTY_IMPOSSIBLE_STATUS
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  8] 更改显示项目
PRINTLC 　
PRINTL [ 99] 取消
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN -1

CASEELSE
	TARGET = RESULT -100
	SIF !CFLAG:日程设定可能／事务
		RESTART
	RETURN TARGET
ENDSELECT
RESTART



;現在料理不可の状態なら表示
@DINNER_DUTY_IMPOSSIBLE_STATUS

;後からなることがあるので個別に
IF CFLAG:家畜
	CALL PRINT_WORD_COLOR("！[家畜] ","桃")
ELSEIF CSTR:住处 == "体内"
	CALL PRINT_WORD_COLOR("！体内 ","黄")
ELSEIF CFLAG:崩坏
	CALL PRINT_WORD_COLOR("！[崩坏] ","红")
ELSEIF CFLAG:牛舍号码
	CALL PRINT_WORD_COLOR("！牛舍内 ","黄")
ELSEIF !BASE:体力
	CALL PRINT_WORD_COLOR("！HP0 ","黄")
ELSEIF CFLAG:追踪对象
	CALL PRINT_WORD_COLOR("！未捕获 ","黄")
ELSEIF !CFLAG:可以工作
	CALL PRINT_WORD_COLOR("！无事务能力 ","黄")
ENDIF




