
;心境変更　ARGS：変更後の心境
@PURPOSE_CHANGE(ARGS)

;同じでもここ来る場合は心境地の文表示してるので止め用に通す
;心境変更時表示のコンフィグがOFFならおわり
IF !FLAG:心境改变时显示
	;止め調整
	SIF !TFLAG:刻印入手 && CSTR:心境 != ""
		PRINTW
	CSTR:心境 = %ARGS%
	SOURCE:目的变更 = 1
	RETURN
ENDIF
IF CSTR:心境 != ARGS
	;心境空欄はキャラ作成時のみ
	SETCOLOR 0xFFFF70
	PRINT 心境变更：
	IF CSTR:心境 != ""
		CALL PRINT_NOW_PURPOSE(1)
		PRINT 　→　
	ENDIF
	CSTR:心境 = %ARGS%
	CALL PRINT_NOW_PURPOSE(1)
	RESETCOLOR
ENDIF

;止め調整
SIF !TFLAG:刻印入手
	PRINTW
SOURCE:目的变更 = 1



;心境表示　ARG：1なら目的変更
@PRINT_NOW_PURPOSE(ARG)

SIF !ARG
	PRINT 心境：
SELECTCASE CSTR:心境
