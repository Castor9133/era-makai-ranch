
;身長でのプレイ制限設定
@HEIGHT_PLAY_LIMIT_CONFIG

CLEARLINE LINECOUNT
PRINTL 设定是否隐藏因身高导致不自然的刺激。（仅在调教中有效）
DRAWLINE
PRINTL ・如果加上身高差对胸围大小的修正仍不足：
PRINT [ 0] 隐藏插入时的乳吸
CALL PRINT_ONOFF(GETBIT(＃身高差限制／插入吸乳＃),1)
PRINTL
PRINTL ・当身高差较大时：
PRINT [ 1] 　隐藏插入时的接吻
CALL PRINT_ONOFF(GETBIT(＃身高差限制／插入接吻＃),1)
PRINTL
PRINTL ・当身高差较小时：
PRINT [ 2] 隐藏站立拘束时的乳交
CALL PRINT_ONOFF(GETBIT(＃身高差限制／站立乳交＃),1)

CALL PRINTL_ALIGN(-5)
CALL DEFAULT_VOID_RETURN_BUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 98
	PRINTL 是否将身高相关的游戏限制设定恢复为默认值？
	CALL ASK_YN
	SIF !RESULT
		FLAG:身高的游戏限制BIT = 0
CASE 99
	RETURN
CASEELSE
	CALL CHANGE_HEIGHT_PLAY_LIMIT_CONFIG(RESULT)
ENDSELECT
RESTART



;設定変更
;ARG→INPUT
@CHANGE_HEIGHT_PLAY_LIMIT_CONFIG(ARG)

;ひっくり返すだけ
INVERTBIT FLAG:身高的游戏限制BIT,ARG


