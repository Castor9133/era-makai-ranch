@NAMING_PET_NAME_LIST

PRINTL 　《 名称 》
BR = 0
FOR LOCAL,STR_REF,STR_REF +10
	SIF STR:LOCAL == ""
		CONTINUE
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
NEXT



