
;処女喪失
@LOST_VARGIN_V_MESSAGE

;非表示設定のときは表示はしないけど奪いはする
SIF !GETBIT(＃经验显示／Ｖ性交＃)
	RETURN
IF CFLAG:崩坏
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%的%V_PENIS%处女被夺走…","红"
ELSEIF ＃陷落状态／隶属＃ && GETBIT(＃Ｐ使用／Ｖ插入＃)
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%露出欢喜的表情，献上了%V_PENIS%处女","桃"
ELSEIF ＃陷落状态／恋慕以上＃ && GETBIT(＃Ｐ使用／Ｖ插入＃)
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%向%V_PENIS%献出了处女…","桃"
ELSEIF CFLAG:乳牛 || ＃陷落状态／陷落以上＃
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%毫无抵抗地接受了%V_PENIS%阴茎进入%SLANG_V()%…","桃"
ELSE
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%的%V_PENIS%处女被夺走…","红"
ENDIF



