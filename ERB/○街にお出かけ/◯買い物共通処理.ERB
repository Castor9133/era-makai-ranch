
;経費か財布から出すか判定
@ITEM_SHOP_BUDGET_MONEY_JUDGE

;毎回経費か財布かの判定をする
;経費を超えるまでは経費計上可能
;「足りない場合に財布から」だと逐一判定出したりまとめ買い判定が大変なので
IF FLAG:最大日销售额 -MONEY:经费计上 > 0
	FLAG:购物／开销记账 = 1
ELSE
	FLAG:购物／开销记账 = 0
ENDIF

;ローンになる高額品は基本的に自動ローン　どうせ金利もないので
;USE_MONEYはここでとりあえず計算
USE_MONEY = FLAG:最大日销售额 -MONEY:经费计上

;一旦OFF
FLAG:１个限定物品 = 0



;店フッター部分
;ARG→現在ページ番号
;ARGS→PAGE関数の呼び方
;1ページのみ・目次付き
@ITEM_SHOP_FOOTER(ARG,ARGS)

DRAWLINE
SELECTCASE ARGS
CASE ""
	CALL PRINT_NOW_PAGE(ARG)
CASE "目录"
	CALL PRINT_NOW_PAGE(ARG,0,1)
ENDSELECT
PRINTLC [ 90] 批量购买未持有的
PRINTLC 　
PRINTL [ 99] 完成



;リスト内ループ中身
;ARG→アイテムID
@ITEM_SHOP_LOOP_JUDGE(ARG)

;名前があれば表示
SIF ITEMNAME:ARG == ""
	RETURN
CALL BR_PLUS(3)

;アイテム番号により制限
CALL ITEM_SHOP_LOOP_JUDGE_ESCAPE(ARG)
SIF RESULT
	RETURN

;1コ限定で持ってるとダメ
IF FLAG:１个限定物品 && ITEM:ARG
	CALL PRINTLC_WORD_COLOR,@"[{ARG,3}] %ITEMNAME:ARG%","浅蓝色"
	RETURN

;価格0はダメ
ELSEIF !ITEMPRICE:ARG
	CALL PRINTLC_WORD_COLOR,@"[{ARG,3}] %ITEMNAME:ARG%","灰"
	RETURN

;経費計上OFFならMONEY判定
ELSEIF !FLAG:购物／开销记账 && ITEMPRICE:ARG > MONEY
	CALL PRINTLC_WORD_COLOR,@"[{ARG,3}] %ITEMNAME:ARG%","灰"
	RETURN

;経費計上・10万以上のITEM・超過する場合はMONEY判定
ELSEIF FLAG:购物／开销记账 && ITEMPRICE:ARG >= BUDGET_CAP && ITEMPRICE:ARG > USE_MONEY && ITEMPRICE:ARG > MONEY
	CALL PRINTLC_WORD_COLOR,@"[{ARG,3}] %ITEMNAME:ARG%","灰"
	RETURN
ENDIF
PRINTFORMLC [{ARG,3}] %ITEMNAME:ARG% 



;アイテム番号制限
;ARG→アイテムID
@ITEM_SHOP_LOOP_JUDGE_ESCAPE(ARG)

SELECTCASE ITEMNAME:ARG
CASE "大容量魔力储存器"
	;業務用を持ってないと大容量を買えない
	IF !ITEM:商用魔力储存器
		CALL PRINTLC_WORD_COLOR,@"[{ARG,3}] %ITEMNAME:ARG%","灰"
		RETURN 1
	ENDIF

CASE "巫女服套装","修女服装套装","礼服套装","夏季连衣裙套装"
	;衣服レプリカを購入できるマイルストーンでないとダメ
	CALL MILESTONE_UNLOCK_CHECK("衣服复制品","")
	IF !RESULT
		CALL PRINTLC_WORD_COLOR,@"<{ARG,3}> %ITEMNAME:ARG%","灰"
		RETURN 1
	ENDIF

CASE "女仆服套装"
	;衣服拡張
	CALL MILESTONE_UNLOCK_CHECK("衣物扩张","")
	IF !RESULT
		CALL PRINTLC_WORD_COLOR,@"<{ARG,3}> %ITEMNAME:ARG%","灰"
		RETURN 1
	ENDIF

CASE "授乳女仆服装套装"
	;アダルト衣装込み
	CALL MILESTONE_UNLOCK_CHECK("成人装束","")
	IF !RESULT
		CALL PRINTLC_WORD_COLOR,@"<{ARG,3}> %ITEMNAME:ARG%","灰"
		RETURN 1
	ENDIF

CASE "兔女郎装套装","反向兔女郎套装","哥特萝莉时尚套装"
	;異世界衣服込み
	CALL MILESTONE_UNLOCK_CHECK("异世界衣服","")
	IF !RESULT
		CALL PRINTLC_WORD_COLOR,@"<{ARG,3}> %ITEMNAME:ARG%","灰"
		RETURN 1
	ENDIF

CASE "乳牛服装套装","微型比基尼乳牛服装套装","开孔奶牛服装套装"
	;乳牛セット
	CALL MILESTONE_UNLOCK_CHECK("乳牛套装服装","")
	IF !RESULT
		CALL PRINTLC_WORD_COLOR,@"<{ARG,3}> %ITEMNAME:ARG%","灰"
		RETURN 1
	ENDIF

ENDSELECT


