
;種族割合設定
@SPECIAL_TRIBE_CONFIG

;FLAG:候補割合／上位種族／仙人→2620
FLAG_REF = 2620
STR_REF = 6530
FLAG:候选比例／上位种族／总计 = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +10)
TOTAL_RATIO = FLAG:候选比例／上位种族／总计
CLEARLINE LINECOUNT
PRINTL 设置人类的上位种族比例。
CALL CONFIG_CHANGE_FLAG_CHECK
CALL PRINT_TENDENCY_BUTTON(1)
CALL PRINTL_ALIGN(-10)
CALL TENDENCY_CONFIG_FOOTER
CALL TENDENCY_INPUT
IF RESULT == 98
	PRINTL 回复上位种族比例默认值？
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_SPECIAL_TRIBE_CONFIG
ELSEIF RESULT == 99
	IF FLAG:候选比例／上位种族／总计 <= 0 || FLAG:候选比例／上位种族／总计 > 1000
		PRINTW 总出现比例应介于1到1000之间。
		RESTART
	ENDIF
	RETURN
ENDIF
RESTART


