@COM582
#DIM FIXATION_RATE
;絶頂魔力回復淫紋

;基本5%、好感度および乳牛堕ちの1/3を上乗せした確率で定着
;けっこうなエンドコンテンツ感出したかった
FIXATION_RATE = 500 +(BASE:好感度 +BASE:乳牛堕落) /3
FIXATION_RATE = LIMIT(FIXATION_RATE,500,10000)
PRINTFORML 【绝顶魔力回复淫纹】的定型概率：{FIXATION_RATE /100}.{FIXATION_RATE %100}\%
CALL PRINTL_WORD_COLOR("增加【好感度】和【乳牛堕落】合计1/3的出现概率","黄")
IF FIXATION_RATE < 10000
	PRINTFORML 无论成功或失败，都会消耗时间和%VALUE_DIGIT(MAGIC_USE_MP:GETNUM(ITEM,"绝顶魔力回复淫纹"))%MP将被消耗。
	PRINTL （没有其他失败惩罚）
ENDIF
PRINTL 执行＜绝顶魔力回复淫纹赋予＞吗？
CALL ASK_YN
SIF RESULT
	RETURN
SELECTCOM = 582
LOSEBASE:体力 += 500
LOSEBASE:气力 += 500

;あなたで触れてないので器具扱い
SOURCE:Ｂ快感／器具 = 30000
SOURCE:Ｎ快感／器具 = 30000
SOURCE:耻辱 = 10000
SOURCE:爱情 = 10000
SOURCE:屈辱 = 10000
SOURCE:支配 = 30000
SOURCE:已用时间 = 1
SOURCE:选择指令口上隐藏 = 1
BASE:0:魔力 -= MAGIC_USE_MP:GETNUM(ITEM,"绝顶魔力回复淫纹")
TRYCALLFORM COM{SELECTCOM}_MESSAGE

;成功・失敗を判定
IF RAND:10000 < FIXATION_RATE
	MARK:绝顶魔力回复淫纹 = 1
	CALL COM582_SUCCESS_MESSAGE
	CALL MILKTANK_CALC

	;魔力10万以下なら引き上げ
	IF MAXBASE:魔力 < INFINITY_MILK_TANK
		MAXBASE:魔力 = INFINITY_MILK_TANK
		CALL PRINTL_WORD_COLOR,@"【绝顶魔力回复淫纹】的次要效果，%CALLNAME%魔力最大值增加 → %VALUE_DIGIT(INFINITY_MILK_TANK)%MP","浅蓝色"
	ENDIF
;失敗
ELSE
	CALL COM582_FAILED_MESSAGE
ENDIF
RETURN 1






