;冬
;雨の代わりに雪
@TOMORROW_WEATHER_WINTER

SELECTCASE RAND:100
CASE 0 TO 49
	SAVESTR:天气／明天 = 灰蒙蒙
CASE 50 TO 69
	SAVESTR:天气／明天 = 雪
CASE 70 TO 79
	SAVESTR:天气／明天 = 大雪
CASE 80 TO 84
