
;開発・習得の入り口
@UPGRADE_INDEX

SELECT_ITEM = 0
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_UPGRADE("ALL")
PRINTL [ 0] 药品制造
IF ITEM:工具套装
	PRINTL [ 1] 新型搾乳器的开发
ELSE
	CALL PRINTL_WORD_COLOR,@"＜工具套件＞必要","灰"
ENDIF
IF ITEM:触手装备作成
	PRINTL [ 2] 触手装备作成
ELSE
	CALL PRINTL_WORD_COLOR,@"＜触手装备制作＞必要","灰"
ENDIF
PRINTL

PRINTL [10] 能力学习
IF ITEM:死灵之书
	PRINTL [11] 魔法学习
ELSE
	CALL PRINTL_WORD_COLOR,@"＜死者之书＞必要","灰"
ENDIF
IF ITEM:触手生物生态图鉴
	PRINTL [12] 触手魔法学习
ELSE
	CALL PRINTL_WORD_COLOR,@"＜触手生物生态图鉴＞必要","灰"
ENDIF
CALL MILESTONE_UNLOCK_CHECK("禁忌魔法","L")
SIF RESULT
	PRINTL [13] 禁断魔法学习
PRINTL
PRINTL [20] 能力・魔法ON／OFF
CALL PRINTL_ALIGN(-5)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(1,"戻る")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL PHARMACEUTICAL
CASE 1
	CALL UPGRADE_LACTATION_MACHINE
CASE 2
	CALL ITEM_CREATION

CASE 10
	CALL ABILITY_GET
CASE 11
	CALL MAGIC_GET
CASE 12
	CALL TENTACLE_MAGIC_GET
CASE 13
	CALL FORBIDDEN_MAGIC_GET

CASE 20
	CALL ABILITY_ACTIVATION
CASE 98
	CALL BROWSE_HINT("开发・习得")
CASE 99
