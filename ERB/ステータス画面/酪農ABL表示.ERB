
;ABLのうち仕事に使うとこの表示
;ARG→飛んできた場所　0：ステータス表示　1：一覧ステータス
@ABL_WORK_LIST(ARG)

CALL ABL_WORK_PRINT(ARG,"奶农")
CALL ABL_WORK_PRINT(ARG,"事务")
CALL ABL_WORK_PRINT(ARG,"清洁")
CALL ABL_WORK_PRINT(ARG,"料理")
CALL ABL_WORK_PRINT(ARG,"药学")
CALL ABL_WORK_PRINT(ARG,"接客")
CALL ABL_WORK_PRINT(ARG,"技巧")
SIF !TALENT:男性
	CALL ABL_WORK_PRINT(ARG,"百合癖")
PRINT 　
SIF !ARG
	PRINTL



;ARG→飛んできた場所　0：ステータス表示　1：一覧ステータス
@ABL_WORK_PRINT(ARG,ARGS)

IF ABL:ARGS >= 10
	SETCOLOR 0x70FFFF
ELSEIF ABL:ARGS >= 5
	SETCOLOR 0x70FF70
ELSEIF ABL:ARGS <= 1
	SETCOLOR 0x606060
ENDIF
IF !ARG
	IF ARGS == "百合癖"
		PRINTFORM 百合Lv{ABL:ARGS,2} 
	ELSE
		PRINTFORM %ARGS%Lv{ABL:ARGS,2} 
	ENDIF

;一覧用の短縮表示
ELSE
	SELECTCASE ARGS
	CASE "奶农"
		PRINTFORM 农Lv{ABL:ARGS,2} 
	CASE "事务"
		PRINTFORM 事Lv{ABL:ARGS,2} 
	CASE "清洁"
		PRINTFORM 洁Lv{ABL:ARGS,2} 
	CASE "料理"
		PRINTFORM 料Lv{ABL:ARGS,2} 
	CASE "药学"
		PRINTFORM 药Lv{ABL:ARGS,2} 
	CASE "接客"
		PRINTFORM 客Lv{ABL:ARGS,2} 
	CASE "技巧"
		PRINTFORM 技Lv{ABL:ARGS,2} 
	CASE "百合癖"
		PRINTFORM ♀Lv{ABL:ARGS,2} 
	ENDSELECT
ENDIF
RESETCOLOR



@ABL_WORK_LIST_PLUS

IF ORIGINAL_STATUS
	CALL ORIGINAL_ABL_WORK_LIST_PLUS
	RETURN
ENDIF
IF TALENT:男性
	CALL WORK_NEXTEXP_BAR("奶农",1)
	CALL WORK_NEXTEXP_BAR("事务",1)
	CALL WORK_NEXTEXP_BAR("清洁",1)
	CALL WORK_NEXTEXP_BAR("料理",1)
	CALL WORK_NEXTEXP_BAR("药学",1)
	CALL WORK_NEXTEXP_BAR("接客",1)
	CALL WORK_NEXTEXP_BAR("技巧",1)
ELSE
	;段々になる
	CALL WORK_NEXTEXP_BAR("奶农")
	CALL WORK_NEXTEXP_BAR("技巧",1,1)
	CALL WORK_NEXTEXP_BAR("事务")
	CALL WORK_NEXTEXP_BAR("母性",1,1)
	CALL WORK_NEXTEXP_BAR("清洁")
	CALL WORK_NEXTEXP_BAR("奉仕精神",1,1)
	CALL WORK_NEXTEXP_BAR("料理")
	CALL WORK_NEXTEXP_BAR("受虐癖",1,1)
	CALL WORK_NEXTEXP_BAR("药学")
	CALL WORK_NEXTEXP_BAR("百合癖",1,1)
	CALL WORK_NEXTEXP_BAR("接客")
ENDIF
CALL MANYL(2)



;ARG→1なら改行
;ARG:1→1なら性系
@WORK_NEXTEXP_BAR(ARGS,ARG:0,ARG:1)
#DIM NEXTLV_EXP
#DIM NOWLV_EXP
#DIM NEXT_EXP
#DIM NOW_EXP
;次レベルまでに必要なEXPから現在EXPで割合を求めようとしたらえらいことになるんだ
#DIMS WORK
#DIMS WORK_EXP

WORK = %ARGS%
WORK_EXP = %WORK%经验

;雑なエラー対策
SELECTCASE WORK
CASE "母性"
	WORK_EXP = 授乳爱情经验
CASE "技巧"
	WORK_EXP = 学习
CASE "奉仕精神"
	WORK_EXP = 奉仕经验
CASE "受虐癖"
	WORK_EXP = 被虐快感经验
CASE "百合癖"
	WORK_EXP = 百合调教经验
ENDSELECT

;性系か違うかでちょっと変える
IF ARG:1
	PRINTFORM %WORK,10%Lv{ABL:WORK,2} <{EXP:WORK_EXP,6}EXP> 
ELSE
	PRINTFORM %WORK%Lv{ABL:WORK,2} <{EXP:WORK_EXP,6}EXP> 
ENDIF

;LV99ならMAXと表示しておわり
IF ABL:ARGS == 99
	SETCOLOR 0x70FF70
	SIF ARG:1
		SETCOLOR 0xFF70FF
	PRINT MAX 　　　　　　　　　
	RESETCOLOR
	SIF ARG:0
		PRINTL
	RETURN
ENDIF

;必要EXP
CALL NEXT_EXP(WORK)
NEXTLV_EXP = RESULT
CALL NEXT_EXP(WORK,1)
NOWLV_EXP = RESULT

;現在ABLから見てNOWLV_EXPが0、NEXTLV_EXPが100のバーを出す
NEXT_EXP = NEXTLV_EXP -NOWLV_EXP
NOW_EXP = EXP:WORK_EXP -NOWLV_EXP
IF ARG:1
	CALL PRINT_COLORBAR(NOW_EXP,NEXT_EXP,10,BARCOLORSET("桃"),RESULT:1)
ELSE
	CALL PRINT_COLORBAR(NOW_EXP,NEXT_EXP,10,BARCOLORSET("绿"),RESULT:1)
ENDIF
;PRINTFORM  NEXT：{NEXTLV_EXP,4,LEFT} 
SIF ARG:0
	PRINTL

