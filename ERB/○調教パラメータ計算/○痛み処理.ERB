
;痛み追加処理
@INSART_ADD_PAIN

;潤滑追加してから痛み処理
IF SOURCE:Ｖ润滑追加
	CALL RANDOM_FIX(SOURCE:Ｖ润滑追加,10,"Ｖ润滑追加")
	SOURCE:Ｖ润滑追加 += FIX
	PALAM:Ｖ润滑 += SOURCE:Ｖ润滑追加
ENDIF
IF SOURCE:Ａ润滑追加
	CALL RANDOM_FIX(SOURCE:Ａ润滑追加,10,"Ａ润滑追加")
	SOURCE:Ａ润滑追加 += FIX
	PALAM:Ａ润滑 += SOURCE:Ａ润滑追加
ENDIF

;Ｖ・Ａにブラシ触手以外が入っていると痛み追加
CALL INSART_ADD_PAIN_V
CALL INSART_ADD_PAIN_A

;部位痛みをマゾっ気・部位感覚で軽減→苦痛SOURCE追加
CALL PAIN_MITIGATION_CALC



;Ｖ・Ａにブラシ触手以外が入っていると痛み追加
@INSART_ADD_PAIN_V

SIF !TFLAG:Ｖ装备 || TEQUIP:刷子触手Ｖ || GETBIT(＃拘束／三角木马＃)
	RETURN
DAMAGE = 20000 -PALAM:Ｖ润滑

;潤滑で軽減
SELECTCASE PALAM:Ｖ润滑
CASE IS < 5000
CASE IS < 10000
	DAMAGE /= 2
CASE IS < 20000
	DAMAGE /= 5
ENDSELECT

;名器なら1/5
SIF TALENT:名器
	DAMAGE /= 5

SIF DAMAGE > 0
	SOURCE:Ｖ疼痛 += DAMAGE



@INSART_ADD_PAIN_A

SIF !TFLAG:Ａ装备 || TEQUIP:刷子触手Ａ
	RETURN
DAMAGE = 25000 -PALAM:Ａ润滑
SELECTCASE PALAM:Ａ润滑
CASE IS < 5000
CASE IS < 10000
	DAMAGE /= 2
CASE IS < 20000
	DAMAGE /= 5
ENDSELECT
SIF TALENT:Ａ名器
	DAMAGE /= 5
SIF DAMAGE > 0
	SOURCE:Ａ疼痛 += DAMAGE



;部位痛みをマゾっ気・部位感覚で軽減→苦痛SOURCE追加
@PAIN_MITIGATION_CALC

;SOURCE:Ａ痛み→190
;ABL:Ａ感覚→0
SOURCE_REF = 190

IF TFLAG:痛苦快乐变换中
	FOR LOCAL,0,6
		SOURCE:(120 + LOCAL) += SOURCE:(SOURCE_REF + LOCAL) / 40
		SOURCE:(SOURCE_REF + LOCAL) = 0
	NEXT
	SOURCE:淫欲 += SOURCE:非性感带疼痛
	SOURCE:非性感带疼痛 = 0
	RETURN
ENDIF

FOR LOCAL,0,6
	SIF !SOURCE:(SOURCE_REF +LOCAL)
		CONTINUE
	
	;マゾ+部位感覚で軽減率
	{
	FIX = LIMIT(ABL:受虐癖 *2 +ABL:LOCAL +MARK:被虐中毒 *10
	+MARK:抖Ｍ *10 +MARK:母猪 *20 +MARK:受虐母畜淫纹 *30,0,100)
	}
	
	;FIXが50%以上のときはマゾヒズム追加
	SIF FIX >= 50
		SOURCE:受虐狂 += (SOURCE:(SOURCE_REF +LOCAL) /2)
	
	;FIX%(軽減分)を快楽へ(補正とかかからないよう器具快楽)
	SOURCE:(120 + LOCAL) += SOURCE:(SOURCE_REF + LOCAL) * FIX / 4000
	
	;(100 -FIX)%に軽減
	SOURCE:(SOURCE_REF +LOCAL) *= (100 -FIX)
	SOURCE:(SOURCE_REF +LOCAL) /= 100
	
	;1/5を苦痛に入れる
	SOURCE:痛苦 += (SOURCE:(SOURCE_REF +LOCAL) /5)
NEXT

;他部位はマゾっ気のみ判定
FIX = LIMIT(ABL:受虐癖 *2 +MARK:被虐中毒 *10 +MARK:抖Ｍ *10 +MARK:母猪 *20 +MARK:受虐母畜淫纹 *30,0,100)
SIF FIX >= 50
	SOURCE:受虐狂 += (SOURCE:非性感带疼痛 /2)
SOURCE:非性感带疼痛 *= (100 -FIX)
SOURCE:非性感带疼痛 /= 100
SOURCE:痛苦 += SOURCE:非性感带疼痛



;Ｖ拡張とそれによる痛み追加
@EXPANSION_V

VARSET FIX
;調教者なしの場合かつ触手服だとあなたのサイズに合わせようとする
IF PLAYER < 0 && ＃穿着内衣下装／名称＃ == "触手服装"
	FIX:6 = 1
	PLAYER = 0
ENDIF

SIF PLAYER < 0
	RETURN
SIF !GETBIT(＃Ｐ使用／Ｖ插入＃) && (!SOURCE:Ｖ快感／主人公刺激 || TRAINNAME:SELECTCOM == "抚摸肚子") && !SOURCE:Ｖ快感／触手 && !SOURCE:Ｖ快感／器具
	RETURN

;FIX:8と9にＶサイズとＶ拡張を記録
FIX:8 = ABL:Ｖ尺寸
FIX:9 = ABL:Ｖ扩张

IF PLAYER_PENIS
	DAMAGE = ABL:PLAYER:阴茎尺寸 - ABL:Ｖ尺寸 - ABL:Ｖ扩张
	FIX = ABL:PLAYER:阴茎尺寸 - ABL:初始值／Ｖ尺寸 * 3
	FIX:2 = ABL:PLAYER:阴茎尺寸 - ABL:Ｖ尺寸
	FIX:3 = ABL:初始值／Ｖ尺寸 * 3 - ABL:Ｖ尺寸 - ABL:Ｖ扩张
ELSE
	;生えてない場合は身長150cmの最低値を基準に
	DAMAGE = 45 - ABL:Ｖ尺寸 - ABL:Ｖ扩张
ENDIF
IF GETBIT(＃Ｐ使用／Ｖ插入＃)
	;サイズ差それなりだけど拡張限界かどうかの判定
	SIF DAMAGE > 10 && DAMAGE < 21 && FIX > 0
		FIX:4 = 1
	SIF GROUPMATCH(TRAINNAME:SELECTCOM,"活塞运动","侍奉服务","正常位","后背位","对面坐位","背面坐位","骑乘位","背面骑乘位","对面立位","背面立位","强制骑乘位")
		FIX:5 = 1
	IF DAMAGE > 0
		;サイズ差がありすぎるとABL:サイズが増える＝緩くなる
		LOCAL = DAMAGE
		IF DAMAGE > 20  || FIX:4
			LOCAL -= 11
			SIF !FIX:5
				LOCAL -= (LOCAL - 10) / 2
			SOURCE:Ｖ疼痛 += MIN(LOCAL * LOCAL,LOCAL * 30) * 500 + 2000
			SIF FIX:4
				LOCAL = 10
			LOCAL = LIMIT(LOCAL * LOCAL / 100 + (RAND:100 < LOCAL * LOCAL % 100 ? 1 # 0),1,LOCAL / 3)
			SIF ABL:Ｖ扩张
				ABL:Ｖ扩张 -= LIMIT(LOCAL / 2,0,ABL:Ｖ扩张)
			ABL:Ｖ尺寸 += LOCAL
			LOCAL = 20
			SIF !FIX:5
				LOCAL = 10
		
		;サイズ差そこそこだけど拡張限界
		ELSEIF FIX > 0
			SIF !FIX:5
				LOCAL -= LOCAL / 2
			IF RAND:10 < LOCAL
				ABL:Ｖ尺寸 ++
				SIF RAND:20 < LOCAL && ABL:Ｖ扩张
					ABL:Ｖ扩张 --
			ENDIF
			LOCAL += 5
			SIF !FIX:5
				LOCAL -= 3
		ELSEIF FIX:3 > 0
			SIF !FIX:5
				LOCAL -= LOCAL / 2
			ABL:Ｖ扩张 += LOCAL / 10 + (RAND:10 < LOCAL / 2 + 5 ? 1 # 0)
		ENDIF
		SOURCE:Ｖ疼痛 += LOCAL * LOCAL * 25
		TFLAG:阴茎尺寸差修正 = LIMIT(LOCAL * LOCAL * (-2),-500,0)
	ELSEIF FIX:2 >= 0
		TFLAG:阴茎尺寸差修正 = 300
	ELSE
		TFLAG:阴茎尺寸差修正 = LIMIT(FIX:2 * FIX:2 * (-1),-500,0)
	ENDIF
	IF DAMAGE > -16 && DAMAGE < 1 && FIX:3 > 0 && FIX:5
		DAMAGE += 15
		ABL:Ｖ扩张 += (RAND:20 < DAMAGE / 2 + 1 ? 1 # 0)
	ENDIF
	SIF ABL:PLAYER:阴茎尺寸 > ABL:PLAYER:初始值／阴茎尺寸
		SOURCE:Ｖ快感／主人公刺激 = SOURCE:Ｖ快感／主人公刺激 * ABL:PLAYER:阴茎尺寸 / ABL:PLAYER:初始值／阴茎尺寸
	SOURCE:Ｖ快感／主人公刺激 = SOURCE:Ｖ快感／主人公刺激 * (1000 + TFLAG:阴茎尺寸差修正) / 1000

;ペニス以外ならペニスサイズ-5か初期値／Ｖサイズ*1.5まで少しずつほぐす
ELSEIF DAMAGE > 5
	LOCAL = MIN(ABL:初始值／Ｖ尺寸 * 3 / 2 - ABL:Ｖ尺寸 - ABL:Ｖ扩张,DAMAGE - 5)
	SIF LOCAL > 0
		ABL:Ｖ扩张 += MIN(LOCAL / 10,1) + (RAND:10 < LOCAL / 2 + 4 ? 1 # 0)
ENDIF
SIF FIX:6
	PLAYER = -1

IF FIX:8 != ABL:Ｖ尺寸 || FIX:9 != ABL:Ｖ扩张
	PRINTFORM < %CALLNAME%的Ｖ尺寸：
	IF FIX:9
		PRINTFORM {FIX:8,3}～{ABL:Ｖ尺寸 + FIX:9,3}
	ELSE
		PRINTFORM {FIX:8,3}
	ENDIF
	IF ABL:Ｖ扩张
		PRINTFORML mm → {ABL:Ｖ尺寸,3}～{ABL:Ｖ尺寸 + ABL:Ｖ扩张,3}mm >
	ELSE
		PRINTFORML mm → {ABL:Ｖ尺寸,3}mm >
	ENDIF
ENDIF


