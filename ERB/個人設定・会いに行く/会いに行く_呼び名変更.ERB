
;呼び名を変更する
@VISIT_SETTING_NEW_CALLNAME_BEFORE

;呼び名を変えてる場合
IF EQUIP:家畜管理标签／称呼
	PRINTFORML 要将称呼恢复为%CSTR:初始值／呼叫名称%吗？（将删除＜牲畜管理标签＞）
	CALL ASK_YN
	SIF RESULT
		RETURN
	EQUIP:家畜管理标签／称呼 = 0
	CALLNAME = %CSTR:初始值／称呼%
	IF ＃陷落状态／隶属＃ && CSTR:第一人称 != CSTR:初始值／第一人称
		PRINTFORML 要将%CALLNAME%的第一人称恢复为「%CSTR:初期値／第一人称%」吗？
		CALL ASK_YN
		IF !RESULT
			CSTR:第一人称 = %CSTR:初始值／第一人称%
			PRINTW 已命令恢复第一人称。
		ELSE
			PRINTW 已命令保持第一人称不变。
		ENDIF
	ENDIF
	RETURN
ENDIF

;5500～,身分・名前候補文面
STR_REF = 5500
STR_MAX = 50
CALL VISIT_SETTING_NEW_CALLNAME



;新呼び名
@VISIT_SETTING_NEW_CALLNAME
#DIMS DYNAMIC NEW_CALLNAME
#DIM DYNAMIC PAGE

PAGE_MAX = 3
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML 通过组合单词为%CALLNAME%设置新的称呼。（持有＜牲畜管理标签＞数量：{ITEM:家畜管理标签}）
PRINTFORML 当前候选：【%NEW_CALLNAME%】
CALL PRINT_TAG_WORD_CATEGORY(PAGE)
DRAWLINE
BR = 0
FOR LOCAL,STR_REF,STR_REF +STR_MAX
	SIF STR:LOCAL == ""
		CONTINUE
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
NEXT
PRINTL
CALL PRINTL_ALIGN(-5)
PRINTFORMLC [101] %CSTR:种族%
SIF CSTR:职业 != ""
	PRINTFORMLC [102] %CSTR:职业%
PRINTFORMLC [103] %CSTR:主人公的称呼／陷落后%
SIF CSTR:初始值／称呼 != ""
	PRINTFORMLC [104] %CSTR:初始值／称呼%
SIF CSTR:所属 != ""
	PRINTFORMLC [105] %CSTR:所属%
PRINTFORMLC [106] %TOSTR(CFLAG:ID,"0000")%（ID番号）
PRINTL
PRINTLC [110] （手动输入）
PRINTLC [111] （重置）
PRINTFORML [112] 种族表示：\@ CFLAG:表示OFF／种族表示 ? OFF # ON \@
DRAWLINE
PRINTLC [ 90] 完成
PRINTFORMLC [ 91] 页面切换：{PAGE}／{PAGE_MAX}
PRINTL [ 99] 取消
INPUT
PRINTL
SELECTCASE RESULT
CASE 101
	NEW_CALLNAME += CSTR:种族
CASE 102
	NEW_CALLNAME += CSTR:职业
CASE 103
	NEW_CALLNAME += CSTR:主人公的称呼／陷落后
CASE 104
	NEW_CALLNAME += CSTR:初始值／称呼
CASE 105
	NEW_CALLNAME += CSTR:所属
CASE 106
	NEW_CALLNAME += TOSTR(CFLAG:ID,"0000")
CASE 110
	PRINTL 请输入。（将添加到当前候选文后）
	INPUTS
	NEW_CALLNAME += RESULTS
CASE 111
	NEW_CALLNAME =
CASE 112
	INVERTBIT CFLAG:表示OFF／种族表示,0
	
CASE 90
	SIF NEW_CALLNAME == ""
		RETURN
	PRINTFORML 要将%CALLNAME%的新称呼设定为【%NEW_CALLNAME%】吗？（消耗1个＜家畜管理タグ＞）
	CALL ASK_YN
	SIF RESULT
		RESTART
	ITEM:家畜管理标签 --
	EQUIP:家畜管理标签／称呼 = 1
	PRINTFORML 已给%CALLNAME%添加了＜家畜管理タグ＞。
	PRINTFORML 标签上刻有%CALLNAME%的新名称，即【%NEW_CALLNAME%】的文字…
	CALLNAME = %NEW_CALLNAME%
	
	;屈辱的な名前かチェック
	CALL CHECK_DISGRACE_WORD(NEW_CALLNAME)
	IF RESULT
		CALL KOJO_PRINT("访问","更改称呼","屈辱的")
	ELSE
		CALL KOJO_PRINT("访问","更改称呼","普通")
	ENDIF
	PRINTW
	
	;隷属している場合一人称もそれにするか尋ねる
	IF ＃陷落状态／隶属＃
		PRINTFORML %CALLNAME%询问是否应该作为%CALLNAME:0%的所有物证明自称为「%CALLNAME%」。
		PRINTFORML 是否也要将第一人称更改为【%CALLNAME%】？（当前：「%CSTR:第一人称%」）
		CALL ASK_YN
		IF !RESULT
			CSTR:第一人称 = %CALLNAME%
			PRINTFORMW 已命令%CALLNAME%从现在开始自称为「%CALLNAME%」。
		ELSE
			PRINTW 已命令保持第一人称不变。
		ENDIF
	ENDIF
	RETURN
	
CASE 91
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	STR_REF = 5500 +(PAGE -1) *50
	
CASE 99
	RETURN
CASEELSE
	SIF RESULT >= 0 && RESULT < 50
		NEW_CALLNAME += STR:(RESULT +STR_REF)
ENDSELECT
RESTART



