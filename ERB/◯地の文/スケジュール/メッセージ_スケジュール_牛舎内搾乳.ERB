
;搾乳開始の1キャラ目の地の文表示
@COWSHED_LACTATION_START_MESSAGE

;1匹でもたちにならないよう調整
PRINTFORM %COWSHED_NAME:COWSHED_NUM%的
CALL PRINT_COWSHED_SLAVE_CALL
CALL LACTATION_COWSHED_SLAVE_MESSAGE



;乳牛の呼び方ランダム
@PRINT_COWSHED_SLAVE_CALL
#DIM WORD_PLUS

WORD_PLUS = 0
SELECTCASE RAND:8
CASE 0
	PRINT 乳牛
CASE 1
	PRINT 雌牛
CASE 2
	PRINT 奶
	WORD_PLUS ++
CASE 3
	PRINT 搾乳
	WORD_PLUS ++
CASE 4
	PRINT 欧派
	WORD_PLUS ++
CASE 5
	PRINT 母乳
	WORD_PLUS ++
CASE 6
	PRINT 母乳
	WORD_PLUS ++
CASE 7
	IF RAND:100 < 50
		PRINT 乳罐
	ELSE
		PRINT 荷斯坦奶牛
	ENDIF
	RETURN
ENDSELECT

;WORD_PLUSがあれば確定表示
IF WORD_PLUS || RAND:100 < 50
	;一応拡張可能なように
	SELECTCASE RAND:2
	CASE 0
		PRINT 奴隶
	CASE 1
		PRINT 家畜
	ENDSELECT
ENDIF

;BOX_COUNTが牛舎内の家畜数
SIF BOX_COUNT >= 2
	PRINT 们



;搾乳文面
@LACTATION_COWSHED_SLAVE_MESSAGE

;TARGET指定されてるのでSLANG使用可能
SELECTCASE RAND:8
CASE 0
	PRINTFORM 安装搾乳器后%SAVESTR:标识／母乳%被源源不断的榨出…
CASE 1
	PRINTFORM 的%SLANG_B()%中挤出%SAVESTR:标识／母乳%…
CASE 2
	PRINTFORM 搾乳%SAVESTR:标识／母乳%…
CASE 3
	PRINTFORM %SAVESTR:标识／母乳%被榨乳器源源不断的榨取…
CASE 4
	PRINTFORM 的%SLANG_B()%接二连三地%SAVESTR:标识／母乳%被榨…
CASE 5
	PRINTFORM 身上安装的榨乳器一直在榨取着%SAVESTR:标识／母乳%…
CASE 6
	PRINTFORM %SLANG_B()%上的榨乳器不断的榨取着新鲜的%SAVESTR:标识／母乳%…
CASE 7
	PRINTFORM 的%SLANG_B()%%SAVESTR:标识／母乳%被搾乳…
ENDSELECT
CALL HEARTCB(0xD02830)
PRINTL


