
;スケジュール実行処理の共通部分

;人数とABLの最大値をセットする
;ARGS→スケジュール
@WORKER_ABL_SET(ARGS)

;人数とあなたが入ってるかを見て「たち」表記するか判断
WORK_GROUP = WORKER
SIF CSTR:0:日程 == ARGS
	WORK_GROUP --
SELECTCASE ARGS
CASE "调剂"
	ABL_NAME = 药学
CASE "大浴场清洁"
	ABL_NAME = 清洁
CASEELSE
	ABL_NAME = %ARGS%
ENDSELECT

;メンバー内でのABL最大値
FLAG:工作ABL最大值 = 0
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 == ARGS && FLAG:工作ABL最大值 < ABL:ABL_NAME
		FLAG:工作ABL最大值 = ABL:ABL_NAME
NEXT
FLAG:工作ABL最大值 = LIMIT(FLAG:工作ABL最大值,0,10)



;メッセージ込みでスケジュールを実行するキャラを優先度つけて選んで実行
;ARGS→スケジュール
@RANDOM_CHARA_SCHEDULE_COMMON(ARGS)

PRINT_DONE = 0
SELECTCASE ARGS
CASE "体内凌辱准备"
	EXP_NAME = 执行次数／体内凌辱
CASEELSE
	EXP_NAME = 执行次数／
	EXP_NAME += ARGS
ENDSELECT

;1人にフォーカスして地の文表示
;[EXP:実行回数]が0は全員表示　業務で体力0の場合を除く
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != ARGS || EXP:EXP_NAME || (!BASE:体力 && GROUPMATCH(ARGS,＃事务日程＃))
		CONTINUE
	
	;メッセージ表示+実行
	CALL SCHEDULE_RUN(ARGS)
	PRINT_DONE ++
NEXT

;全員表示フラグがONならさらに全員
IF FLAG:日程全员详细显示
	FOR TARGET_COUNT,1,CHARANUM
		TARGET = TARGET_COUNT
		SIF CSTR:日程 != ARGS || CFLAG:行动完毕
			CONTINUE
		CALL SCHEDULE_RUN(ARGS)
		PRINT_DONE ++
	NEXT
ENDIF

;初スケジュールがいなかったなら1人選ぶ関数を呼び出し
IF !PRINT_DONE
	CALL RANDOM_CHARA_SCHEDULE_BOX(ARGS)
	
	;BOX_COUNTが0で業務スケジュール→あなたを表示
	;業務じゃないのに0でここ外す場合はエラー吐いていい
	IF !BOX_COUNT && GROUPMATCH(ARGS,＃事务日程＃)
		TARGET = 0
		CALL SCHEDULE_RUN(ARGS)
		
	;BOX_COUNTが1以上→ランダム選択して表示
	ELSE
		CALL PRINT_SCHEDULE_CHARA_LOTTERY(ARGS)
		CALL SCHEDULE_RUN(ARGS)
	ENDIF
ENDIF

;表示しなかったキャラの作業簡易実行
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	
	;実行したキャラは行動済みフラグで飛ばされる
	SIF CSTR:日程 != ARGS || CFLAG:行动完毕
		CONTINUE
	CALL SCHEDULE_RUN_SIMPLE(ARGS)
NEXT



;スケジュール実行+メッセージ
@SCHEDULE_RUN(ARGS)

; 静养期（流产/临产/产后）不可劳动与调教：在各日程入口统一拦截
; 只拦截需要“上班”的日程，避免影响其它非劳动流程
IF TARGET > 0 && GROUPMATCH(ARGS,＃事务日程＃)
	CALL 魔界_静养_不可劳动与调教
	IF RESULT
		CFLAG:行动完毕 = 1
		RETURN
	ENDIF
ENDIF

SELECTCASE ARGS
CASE "奶农"
	CALL WORK_LACTATION_ENTRANCE
CASE "事务"
	CALL WORK_FINANCE_ENTRANCE
CASE "调剂"
	CALL WORK_PHARMACY_ENTRANCE
CASE "大浴场清洁"
	CALL WORK_LARGE_BATHLOOM_CLEANING_ENTRANCE
CASE "搾乳"
	CALL SLAVE_LACTATION_ENTRANCE
CASE "抽出"
	CALL SLAVE_DRAIN_ENTRANCE
CASE "体内凌辱准备"
	CALL MASTER_VORE_MOVE_ENTRANCE
CASE "体内凌辱"
	CALL MASTER_VORE_SEX_ENTRANCE
CASE "触手刺激搾乳"
	CALL SLAVE_T_LACTATION_ENTRANCE
ENDSELECT



;メッセージなし簡易実行
@SCHEDULE_RUN_SIMPLE(ARGS)

; 简易执行也需要拦截劳动（避免静养期仍被扣体力/执行工作）
IF TARGET > 0 && GROUPMATCH(ARGS,＃事务日程＃)
	CALL 魔界_静养_不可劳动与调教
	SIF RESULT
		RETURN
ENDIF

SELECTCASE ARGS
CASE "奶农"
	CALL WORK_LACTATION_RUN
CASE "事务"
	CALL WORK_FINANCE_RUN
CASE "调剂"
	CALL WORK_PHARMACY_RUN
CASE "大浴场清洁"
	;大浴場掃除は最初の1人以外出さなくてOK
	
CASE "搾乳"
	CALL SLAVE_LACTATION_RUN(0,"搾乳")
CASE "抽出"
	CALL SLAVE_LACTATION_RUN(0,"抽出")
CASE "体内凌辱准备"
	CALL MASTER_VORE_MOVE_ENTRANCE(1)
CASE "体内凌辱"
	CALL SLAVE_LACTATION_RUN(0,"体内凌辱")
CASE "触手刺激搾乳"
	CALL SLAVE_LACTATION_RUN(0,"触手刺激搾乳")
ENDSELECT



;調教者人数と技巧補正値計算
@SLAVE_LACTATION_TECHNIQUE_SET

;あなたが搾乳するならあなたのABL、あなた不在なら最大技巧の半分
;あとあなた除く人数も計算
WORK_GROUP = 0
FLAG:补正技巧值 = 0
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 == "奶农"
		WORK_GROUP ++
	SIF CSTR:日程 == "奶农" && FLAG:补正技巧值 < ABL:技巧
		FLAG:补正技巧值 = ABL:技巧
NEXT
IF CSTR:0:日程 == "奶农"
	FLAG:补正技巧值 = ABL:0:技巧
	PLAYER = MASTER
ELSE
	FLAG:补正技巧值 = FLAG:补正技巧值 /2
	PLAYER = -1
ENDIF



;「たち」表示
@PRINT_WORK_GROUP
#FUNCTIONS

SIF WORK_GROUP >= 2
	RETURNF "们"



;スケジュール実行後まとめてABL,MARK処理
;ARG→MARKも見る
;ARGS→スケジュール
@SCHEDULE_ABL_MARK_BULK(ARG,ARGS)

FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:日程 != ARGS
		CONTINUE
	CALL ABL_UP
	SIF ARG
		CALL MARK_GET
	
	;体内凌辱の時だけ虚脱判定
	SIF ARGS == "体内凌辱"
		CALL COLLAPSE_CHECK
NEXT



;虚脱チェック
@COLLAPSE_CHECK

;体力0で虚脱じゃない場合に虚脱化
SIF BASE:体力 || CFLAG:虚脱
	RETURN
CFLAG:虚脱 = 1
CALL BECOME_COLLAPSE_MESSAGE



