
;ニンゲン監視所もしくは町役場
@TOWN_HALL

;役場画面で居場所、部屋数、魔力枷数計算しとく
CALL CALC_PEOPLE_FLAG
CALL CHARA_WHEREABOUTS_ALL
CALL PRINT_ROOM_ALLOCATION

CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_HALL
CALL CHASE_SLAVE_CHECK
CALL PRINT_CHASE_SLAVE
CALL CHASE_SLAVE_REQUEST
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTLC [90] 查找持有的奴隶
PRINTLC [98] 提示
PRINTLC [99] 返回
BINPUT
INPUT_NUM = RESULT
SELECTCASE INPUT_NUM
CASE 0
	CALL TARGET_DECIDE
CASE 1
	CALL ORDER_CHARACTER
CASE 2
	CALL SELF_CHARA_MAKE_ENTRANCE
CASE 3
	CALL CHARA_DATA_LOAD
CASE 90
	CALL SLAVE_SEARCH
CASE 98
	CALL BROWSE_HINT("魔族行会")
CASE 99
	RETURN
CASEELSE
	TARGET = INPUT_NUM -100
	CALL TARGET_STATUS
	TARGET = -1
ENDSELECT
RESTART



;追跡するキャラ指定の選択肢
@CHASE_SLAVE_REQUEST

IF FLAG:追踪中人数 >= 10
	CALL PRINTL_WORD_COLOR("　追踪角色上限","灰")
	RETURN
ENDIF
IF FLAG:魔力枷锁使用可能数 < 1
	CALL PRINTL_WORD_COLOR("　＜魔力枷锁＞不足","灰")
	RETURN
ENDIF
PRINTL [ 0] 指定追踪角色
IF FLAG:仅允许随机角色
	CALL PRINTL_WORD_COLOR("[仅允许随机角色]配置设置无效","灰")
	RETURN
ENDIF
PRINTLC [ 1] 特殊门解封
PRINTL （从CSV文件导入）
PRINTLC [ 2] 寻找人类
PRINTL （输入所有项目并进行角色创建）
PRINTLC [ 3] 回复过去的记忆
PRINTL （从dat文件读取）



