
;プレイヤーが倒された場合の処理
@PLAYER_DEFEAT_CALC

CALL PLAYER_DEFEAT_MESSAGE
BASE:BATTLE_CHARA:体力 = 0
IF BATTLE_CHARA
	EXP:BATTLE_CHARA:主人公的手下战斗次数 ++
ELSE
	EXP:BATTLE_CHARA:主人公战斗次数 ++
ENDIF



;あなた勝利
@MASTER_BATTLE_WIN
#DIM BEFORE_BP
#DIM BP_UP

CALL MASTER_BATTLE_WIN_MESSAGE
IF BATTLE_CHARA
	EXP:BATTLE_CHARA:主人公的手下战斗次数 ++
ELSE
	EXP:BATTLE_CHARA:主人公战斗次数 ++
ENDIF

;削られた戦闘力に応じてHP減る
COST = 0
IF BASE:BATTLE_CHARA:战斗力 < BP_BEFORE *20 /100
	PRINTFORML 在一场相当激烈的战斗中，疲劳积累相当多…
	COST = MAXBASE:BATTLE_CHARA:体力 *80 /100
ELSEIF BASE:BATTLE_CHARA:战斗力 < BP_BEFORE *50 /100
	PRINTFORML 在一场充满挑战的战斗中，疲劳积累颇多。
	COST = MAXBASE:BATTLE_CHARA:体力 *50 /100
ELSEIF BASE:BATTLE_CHARA:战斗力 < BP_BEFORE *80 /100
	PRINTFORML 经历了一些困难的战斗，疲劳感开始积累。
	COST = MAXBASE:BATTLE_CHARA:体力 *30 /100
ELSEIF BASE:BATTLE_CHARA:战斗力 < BP_BEFORE
	PRINTFORML 由于尝试了一些不太熟悉的战术，稍微感到了疲劳。
	COST = MAXBASE:BATTLE_CHARA:体力 *15 /100
ENDIF

;ダメージ受けてないなら消費0
IF COST
	PRINTFORML %CALLNAME:BATTLE_CHARA% HP－{COST}
	BASE:BATTLE_CHARA:体力 = LIMIT(BASE:BATTLE_CHARA:体力 -COST,0,MAXBASE:BATTLE_CHARA:体力)

	;苦戦したほど戦闘適性UP率上昇(最大500%)
	IF BASE:BATTLE_CHARA:战斗适性 < 100
 		IF 100 * BASE:BATTLE_CHARA:战斗力 / BP_BEFORE > 0
 			BP_UP = LIMIT((10000 / (100 * BASE:BATTLE_CHARA:战斗力 / BP_BEFORE)) - 100,0,500)
		ELSE
			BP_UP = 500
		ENDIF
		BEFORE_BP = BASE:BATTLE_CHARA:战斗适性
		BASE:BATTLE_CHARA:战斗适性 += BP_UP / 100
		SIF RAND:100 < BP_UP % 100
			BASE:BATTLE_CHARA:战斗适性 ++
		SIF BASE:BATTLE_CHARA:战斗适性 > 100
			BASE:BATTLE_CHARA:战斗适性 = 100
		IF BASE:BATTLE_CHARA:战斗适性 > BEFORE_BP
			PRINTFORM 战斗适性+{BASE:BATTLE_CHARA:战斗适性 - BEFORE_BP}\%　
			SIF !BATTLE_CHARA
				MAXBASE:BATTLE_CHARA:战斗适性 = LIMIT(MAXBASE:BATTLE_CHARA:战斗适性,BASE:BATTLE_CHARA:战斗适性,100)
		ENDIF
	ENDIF
ENDIF
PRINTW
CALL ARMOR_STRIP
CALL GROUP_CAPTURE
CSTR:陷落状态 = 反抗
CALL SLAVE_RECEIVE_COMMON


