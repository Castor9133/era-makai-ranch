	CASE "继续"
		CALL MESSAGE_BOX,@"「test_调教指令【授乳手交】持续中的台词。」"
	ENDSELECT

CASE "家畜用搾乳器","魔动快感搾乳器","触手快感搾乳器","小型灵力抽出装置"
	SELECTCASE ARGS:2
	CASE "执行"
		CALL MESSAGE_BOX,@"「test_【家畜用搾乳器】等装上瞬间的台词。」"
		SIF !EXP:搾乳器
			CALL MESSAGE_BOX,@"「test_从未被各类搾乳器榨过奶时进入候选。」"
		SIF TEQUIP:触手快感搾乳器
			CALL MESSAGE_BOX,@"「test_搾乳器为【触手快感搾乳器】时进入候选。」"
		SIF NOWEX:Ｎ绝顶
			CALL MESSAGE_BOX,@"「test_『本段责罚若 N 高潮』的说明候选；因高潮判定晚于执行口上，此处通常不会显示。」"
	CASE "继续"
		CALL MESSAGE_BOX,@"「test_【家畜用搾乳器】等持续榨乳中的台词。」"
		SIF GETBIT(＃Ｐ使用／Ｖ插入＃)
			CALL MESSAGE_BOX,@"「test_V 插入同时被搾乳器榨乳时进入候选。」"
		SIF NOWEX:Ｎ绝顶
			CALL MESSAGE_BOX,@"「test_『本段责罚若 N 高潮』的说明候选；因高潮判定晚于执行口上，此处通常不会显示。」"
	
	CASE "移除"
		CALL MESSAGE_BOX,@"「test_卸下搾乳器时的台词（说明）。」"
		CALL MESSAGE_BOX,@"「test_实际会走『搾乳器移除』专用入口，故本句通常不可见。」"
	ENDSELECT

CASE "触手揉胸"
