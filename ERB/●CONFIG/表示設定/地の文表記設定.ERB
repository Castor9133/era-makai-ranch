
;ちんぽと触手ちんぽも入れる
;地の文の表記設定
@SENTENCE_CONFIG

CLEARLINE LINECOUNT
PRINTL 请选择不受奴隶状态影响而显示的词语。
DRAWLINE
STR_REF = 6640
STR_MAX = 50
FOR LOCAL,0,10
	SIF STR:(STR_REF +LOCAL) == ""
		BREAK
	PRINTFORML [{LOCAL,2}] %STR:(STR_REF +LOCAL),12%：%SAVESTR:LOCAL%
NEXT
CALL PRINTL_ALIGN(-10)
CALL DEFAULT_VOID_RETURN_BUTTON(1)
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	PRINTL 请选择＜乳房＞的标识。
	PRINTL ※由于会在不同尺寸下显示，建议使用通用的表述。
	
	;STR参照に変更
	STR_REF = 2100
	FOR LOCAL,STR_REF,STR_REF +STR_MAX
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
	NEXT
	CALL INPUTBUTTON
	BINPUT
	SELECTCASE RESULT
	CASE 0 TO 99
		SAVESTR:标识／乳房 = %STR:(STR_REF +RESULT)%
	CASE 901
		PRINTL 请输入＜乳房＞的标识。
		INPUTS
		SIF RESULTS != ""
			SAVESTR:标识／乳房 = %RESULTS%
	ENDSELECT
	
CASE 1
	PRINTL 请选择＜母乳＞的标识。
	STR_REF = 2150
	FOR LOCAL,STR_REF,STR_REF +STR_MAX
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
	NEXT
	CALL INPUTBUTTON
	BINPUT
	SELECTCASE RESULT
	CASE 0 TO 99
		SAVESTR:标识／母乳 = %STR:(STR_REF +RESULT)%
	CASE 901
		PRINTL 请输入＜母乳＞的标识。
		INPUTS
		SIF RESULTS != ""
			SAVESTR:标识／母乳 = %RESULTS%
	ENDSELECT
	
CASE 2
	PRINTL 请选择＜魔力母乳＞的标识。
	
	;魔力+（入り+）参照文字列なので少し変化
	STR_REF = 2200
	FOR LOCAL,STR_REF,STR_REF +STR_MAX
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL -STR_REF,3}] 魔力%STR:LOCAL%
	NEXT
	FOR LOCAL,STR_REF,STR_REF +STR_MAX
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL -STR_REF +STR_MAX,3}] 魔力消耗%STR:LOCAL%
	NEXT
	CALL INPUTBUTTON
	BINPUT
	SELECTCASE RESULT
	CASE 0 TO 49
		SAVESTR:标识／魔力母乳 = 魔力%STR:(STR_REF +RESULT)%
	CASE 50 TO 100
		SAVESTR:标识／魔力母乳 = 含有魔力的%STR:(STR_REF +RESULT -STR_MAX)%
	CASE 901
		PRINTL 请输入＜魔力母乳＞的标识。
		INPUTS
		SIF RESULTS != ""
			SAVESTR:标识／魔力母乳 = %RESULTS%
	ENDSELECT
	
