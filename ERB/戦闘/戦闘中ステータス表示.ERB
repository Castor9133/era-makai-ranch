
;戦闘中ステータス表示
@BATTLE_STATUS

DRAWLINE
ALIGNMENT CENTER
PRINTFORML --- TURN {TURN} ---
ALIGNMENT LEFT
PRINTL
PRINTFORML 　　%CALLNAME%%PRINT_EXIST_GROUP()%
CALL PRINT_TARGET_BATTLE_STATUS
ALIGNMENT CENTER
PRINTL VS

ALIGNMENT RIGHT
PRINTFORML %PRINT_MONSTER_GROUP()%　　
PRINTFORM 魔物战斗力：%VALUE_DIGIT(TFLAG:兼职战斗力)%／%VALUE_DIGIT(TFLAG:兼职战斗力／最大值)% 
CALL PRINT_COLORBAR(TFLAG:兼职战斗力,TFLAG:兼职战斗力／最大值,8,BARCOLORSET("青绿"),RESULT:1)
PRINTL 　　
PRINTFORML 攻击力：%VALUE_DIGIT(TFLAG:兼职攻击力)%×{TFLAG:兼职攻击次数} 　　
ALIGNMENT LEFT
PRINTW
DRAWLINE



;プレイヤー戦闘中ステータス表示
@MASTER_BATTLE_STATUS

DRAWLINE
ALIGNMENT CENTER
PRINTFORML --- TURN {TURN} ---
ALIGNMENT LEFT
PRINTL
PRINTFORML 　　%CALLNAME%%PRINT_EXIST_GROUP()%
CALL PRINT_TARGET_BATTLE_STATUS
ALIGNMENT CENTER
PRINTL VS

ALIGNMENT RIGHT
PRINTFORML %CALLNAME:BATTLE_CHARA%　　
PRINTFORM 战斗力：%VALUE_DIGIT(BASE:BATTLE_CHARA:战斗力)%／%VALUE_DIGIT(MAXBASE:BATTLE_CHARA:战斗力)% 
CALL PRINT_COLORBAR(BASE:BATTLE_CHARA:战斗力 , MAXBASE:BATTLE_CHARA:战斗力, 8 , BARCOLORSET("青绿") , RESULT:1)
PRINTL 　　
PRINTFORML 攻击力：%VALUE_DIGIT(MAXBASE:BATTLE_CHARA:战斗力 * BASE:BATTLE_CHARA:战斗适性 / 500)%×{CFLAG:BATTLE_CHARA:攻击次数} 　　
ALIGNMENT LEFT
PRINTW
DRAWLINE



;追跡者を表示
@PRINT_MONSTER
#FUNCTIONS

SELECTCASE CFLAG:追踪者
CASE 1
	RETURNF "妖精军团"
CASE 2
	RETURNF "新兵雇佣兵"
CASE 3
	RETURNF "老手雇佣兵"
CASE 4
	RETURNF "鬼人雇佣兵"
CASEELSE
	LOCALS = 错误：追踪者编号{CFLAG:追踪者}
	RETURNF LOCALS
ENDSELECT



;追跡者グループを表示
@PRINT_MONSTER_GROUP
#FUNCTIONS
#DIMS GROUP

SELECTCASE CFLAG:追踪者
CASE 1
	GROUP = 妖精军团%TOSTR(CFLAG:追踪人数)%部队
CASE 2
	GROUP = 新兵雇佣兵%TOSTR(CFLAG:追踪人数)%人
CASE 3
	GROUP = 老手雇佣兵%TOSTR(CFLAG:追踪人数)%人
CASE 4
	GROUP = 鬼人雇佣兵%TOSTR(CFLAG:追踪人数)%人
CASEELSE
	GROUP = 错误：追踪者编号{CFLAG:追踪者}・追踪人数{CFLAG:追踪人数}
ENDSELECT
RETURNF GROUP

