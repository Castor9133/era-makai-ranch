
;キャラメイク中ステータス表示
;ARG→PAGE
;ARGS→基本以外の場面
@CHARA_MAKE_SLAVE_DATA(ARG,ARGS)

CALL PRINT_IMAGE("状态")
CALL PRINT_PORTRAIT
CALL PRINT_NAME_STATUS
CALL PRINT_AFFILIATION_DATA
CALL PRINT_VISUAL_AGE
CALL PRINT_BUST_DETAIL
CALL PRINT_EXTERIOR

;最初は無視
IF ARGS == "初期设定"
ELSE
	SIF !(CFLAG:进入魔界的目的 == 8 || CFLAG:进入魔界的目的 == 9)
		CALL PRINT_PURPOSE(CFLAG:进入魔界的目的)
	PRINTFORM  Lv{BASE:等级}　★{CFLAG:级别}
	IF CFLAG:同伴规模
		PRINTFORML ／{CFLAG:同伴级别}%GROUP_SCALE()%
	ELSE
		CALL PRINTL_WORD_COLOR,@"【没有同伴】","灰"
	ENDIF
ENDIF
PRINTL

;ドバっときてて見づらいのでページを分けた
SELECTCASE ARG
CASE 1
	PRINTFORML 　性格：【%CSTR:性格%】　第一人称：%CSTR:第一人称%　主人公的称呼：%CSTR:主人公的称呼／陷落前%
	CALL PRINT_VIRGIN_DETAIL(1)
	CALL SHOW_TALENT_LIST
CASE 2
	CALL ABL_WORK_LIST_CHARA_MAKE
	CALL SHOW_EQUIP(1)
	CALL ABL_NASTY_LIST_CHARA_MAKE
	CALL SENSITIVE_LIST_CHARA_MAKE
	CALL TALENT_NASTY_CHARA_MAKE
	CALL PRINT_TARGET_BATTLE_STATUS

;9なら全部表示
CASE 9
	PRINTFORML 　性格：【%CSTR:性格%】　第一人称：%CSTR:第一人称%　主人公的称呼：%CSTR:主人公的称呼／陷落前%
	CALL PRINT_VIRGIN_DETAIL(1)
	CALL SHOW_TALENT_LIST
	PRINTL
	CALL ABL_WORK_LIST_CHARA_MAKE
	CALL SHOW_EQUIP(1)
	CALL ABL_NASTY_LIST_CHARA_MAKE
	CALL SENSITIVE_LIST_CHARA_MAKE
	CALL TALENT_NASTY_CHARA_MAKE
	CALL PRINT_TARGET_BATTLE_STATUS
	DRAWLINE
	RETURN
ENDSELECT
CALL PRINTL_ALIGN(-10)
DRAWLINE



;部隊の規模
@GROUP_SCALE
#FUNCTIONS

SELECTCASE CFLAG:同伴规模
CASE 1
	RETURNF "【团队】"
CASE 2
	RETURNF "【精英部队】"
CASE 3
	RETURNF "【军队】"
ENDSELECT



;標的の戦闘力
;ARG→1ならHPとか表示しない
@PRINT_TARGET_BATTLE_STATUS(ARG)

IF ARG
	PRINTL
ELSE
	PRINTFORM 　HP：%VALUE_DIGIT(MAXBASE:体力)%　灵力：%VALUE_DIGIT(MAXBASE:灵力)%EP
	IF MAXBASE:魔力
		PRINTFORML 　魔力：%VALUE_DIGIT(MAXBASE:魔力)%MP<{BASE:魔力恢复率,2}\%\/day>
	ELSE
		CALL PRINTL_WORD_COLOR,@"　没有魔力","灰"
	ENDIF
ENDIF

;戦闘なしで貰える奴隷はこの下表示しない
SIF GROUPMATCH(CFLAG:进入魔界的目的,4,6,7)
	RETURN
PRINTFORM 　战斗力：%VALUE_DIGIT(BASE:战斗力)%
IF !FLAG:正在化妆角色
	PRINTFORM ／%VALUE_DIGIT(MAXBASE:战斗力)% 
	CALL PRINT_COLORBAR(BASE:战斗力,MAXBASE:战斗力,8,BARCOLORSET("青绿"),RESULT:1)
	PRINTFORM  疲劳度：{BASE:疲劳度,3} 
	CALL PRINT_COLORBAR(BASE:疲劳度,MAXBASE:疲劳度,8,BARCOLORSET("黄"),RESULT:1)
ENDIF
PRINTL
IF BASE:回复次数
	PRINTFORM 　回复：{BASE:回复次数}回可能
ELSE
	CALL PRINT_WORD_COLOR,@"　不可回复行动","灰"
ENDIF
IF BASE:大技次数
	PRINTFORM 　大招：{BASE:大技次数}回可能
ELSE
	CALL PRINT_WORD_COLOR,@"　不能发动大招","灰"
ENDIF
PRINTL
SIF !MAXBASE:同伴战斗力1
	RETURN
IF BASE:同伴战斗力1
	PRINTFORM 　同伴战斗力：%VALUE_DIGIT(BASE:同伴战斗力1)%
	IF !FLAG:正在化妆角色
		PRINTFORM ／%VALUE_DIGIT(MAXBASE:同伴战斗力1)% 
		CALL PRINT_COLORBAR(BASE:同伴战斗力1,MAXBASE:同伴战斗力1,8,BARCOLORSET("青绿"),RESULT:1)
	ENDIF
	PRINTFORM %GROUP_SCALE()%
ELSE
	CALL PRINT_WORD_COLOR,@"　同伴全灭","灰"
ENDIF
PRINTL

