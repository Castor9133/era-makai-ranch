
;奴隷のミルク詳細
@SETTLEMENT_DETAIL_MILK_INDEX
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTL 选择奴隶后将显示更详细的信息。
PRINTL
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	
	;当日の出荷金額があれば表示
	IF CFLAG:母乳出荷金额／当日
		PRINTFORM [{TARGET +100}] 
		CALL PRINT_MILK_NAME
		PRINTFORM  %VALUE_DIGIT(CFLAG:预计出货母乳量,"母乳")% ／ %VALUE_DIGIT(CFLAG:母乳出荷金额／当日)%G 
		CALL SELL_MILK_PRICE_NEW_RECORD
	ELSE
		CALL PRINT_WORD_COLOR,@"<{TARGET +100}> %CALLNAME_DIGIT()%：没有出货","灰"
	ENDIF
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
CALL RIGHT_RETURN_BUTTON(0,"完成")
BINPUT
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	TARGET = RESULT -100
	CALL SETTLEMENT_DETAIL_MILK_SLAVE
ENDSELECT
RESTART



;最大値更新したら表示
@SELL_MILK_PRICE_NEW_RECORD
#DIM RECORD

;BIT入れで更新判定
VARSET RECORD
SIF CFLAG:出货母乳／一日最大量 < CFLAG:预计出货母乳量
	SETBIT RECORD,0
SIF CFLAG:出货母乳／一日最大额 < CFLAG:母乳出荷金额／当日
	SETBIT RECORD,1
SIF !RECORD
	RETURN
SELECTCASE RECORD
CASE 1
	CALL PRINT_WORD_COLOR("<出货数量 ","桃")
CASE 2
	CALL PRINT_WORD_COLOR("<出货金额 ","桃")
CASE 3
	CALL PRINT_WORD_COLOR("<出货数量・金额 ","桃")
ENDSELECT
IF FLAG:玩笑表示
	CALL PRINT_WORD_COLOR("奶 RECORD!> ","桃")
ELSE
	CALL PRINT_WORD_COLOR("NEW RECORD!> ","桃")
ENDIF


