
;衣服の脱衣コマンドチェック
@TRAIN_STRIP_COMMAND_CLOTHE

VARSET COMMAND_OK
PRINTL 　《 衣服 》
IF TFLAG:临时脱衣／衣服 || !EQUIP:装备中ID／衣服
	CALL PRINTL_WORD_COLOR("不穿衣服","桃")

;着てるけど脱がすも何もない
ELSEIF ＃穿着衣服／乳房露出＃ && ＃穿着衣服／私处露出＃
	CALL PRINTL_WORD_COLOR,@"%SAVESTR:标识／乳房%%SAVESTR:标识／膣%露出的%＃穿着衣服／名称＃%","桃"
ELSEIF GROUPMATCH(＃穿着衣服／名称＃,"反向兔女郎装")
	CALL PRINTL_WORD_COLOR,@"%＃穿着衣服／名称＃%","桃"
;ここから上下
ELSE
	CALL TRAIN_STRIP_COMMAND_CLOTHE_BUST
	CALL TRAIN_STRIP_COMMAND_CLOTHE_VAGINA
ENDIF
PRINTL



;衣服のおっぱい状態
@TRAIN_STRIP_COMMAND_CLOTHE_BUST

IF ＃穿着衣服／乳房露出＃
	CALL PRINTL_WORD_COLOR,@"%SAVESTR:标识／乳房%露出的%＃穿着衣服／名称＃%","桃"
ELSEIF ＃穿着衣服／胸部撕裂＃
	CALL PRINTL_WORD_COLOR,@"%＃穿着衣服／名称＃%胸部撕裂","桃"
ELSEIF GETBIT(＃半脱／衣服上＃)
	;半脱ぎとか破くとかないエロ衣服→フラグは半脱ぎ扱いにする
	IF ＃穿着衣服／乳暖簾＃
		CALL PRINTL_WORD_COLOR,@"%＃穿着衣服／名称＃%遮盖乳头的布揭开","桃"
	ELSE
		CALL PRINTL_WORD_COLOR,@"%＃穿着衣服／名称＃%上面半脱","桃"
	ENDIF
ELSE
	IF TFLAG:乳暖簾
		PRINTFORML [ 0] ＜%＃穿着衣服／名称＃%＞的遮盖乳头的布的揭开
		COMMAND_OK:0 = 1
	ELSE
		PRINTFORML [ 0] ＜%＃穿着衣服／名称＃%＞的上面半脱
		PRINTFORML [ 1] ＜%＃穿着衣服／名称＃%＞的上面撕裂
		COMMAND_OK:0 = 1
		COMMAND_OK:1 = 1
	ENDIF
ENDIF
;COMMAND_OKで最後のまとめ脱がし見てるのでここはそのまま



;股間
@TRAIN_STRIP_COMMAND_CLOTHE_VAGINA

IF ＃穿着衣服／私处露出＃
	CALL PRINTL_WORD_COLOR,@"%SAVESTR:标识／膣%露出%＃穿着衣服／名称＃%","桃"
ELSEIF ＃穿着衣服／私处撕裂＃
	CALL PRINTL_WORD_COLOR,@"%＃穿着衣服／名称＃%胸部私处撕裂","桃"
ELSEIF GETBIT(＃半脱／衣服下＃)
	IF ＃穿着衣服／围裙＃
		CALL PRINTL_WORD_COLOR,@"%＃穿着衣服／名称＃%遮盖私处的布的揭开","桃"
	ELSE
		CALL PRINTL_WORD_COLOR,@"%＃穿着衣服／名称＃%下面半脱","桃"
	ENDIF
ELSE
	;壁乳だとNG
	IF GETBIT(＃拘束／下半身填壁乳＃)
		CALL PRINTL_WORD_COLOR("下半身被埋入","灰")
	ELSEIF ＃穿着衣服／围裙＃
		PRINTFORML [ 2] ＜%＃穿着衣服／名称＃%＞的围裙揭开
		COMMAND_OK:2 = 1
	ELSE
		PRINTFORML [ 2] ＜%＃穿着衣服／名称＃%＞的下面半脱
		PRINTFORML [ 3] ＜%＃穿着衣服／名称＃%＞的下面撕裂
		COMMAND_OK:2 = 1
		COMMAND_OK:3 = 1
	ENDIF
ENDIF



;ブラ
@TRAIN_STRIP_LINGERIE_BUST

PRINTL 　《 内衣 》
IF TFLAG:临时脱衣／内衣上装 || !EQUIP:装备中ID／内衣上装
	IF GROUPMATCH(＃穿着内衣下装／名称＃,"连体紧身衣","学校游泳衣","触手服装") && !TFLAG:临时脱衣／内衣下装
		CALL PRINTL_WORD_COLOR,@"%＃穿着内衣上装／名称＃%＞的上面脱去","桃"
	ELSE
		CALL PRINTL_WORD_COLOR("无胸罩","桃")
	ENDIF

ELSEIF GETBIT(＃半脱／内衣上装＃)
	IF ＃穿着内衣上装／名称＃ == ＃穿着内衣下装／名称＃
		CALL PRINTL_WORD_COLOR,@"%＃穿着内衣上装／名称＃%上面半脱","桃"
	ELSE
		CALL PRINTL_WORD_COLOR,@"%＃穿着内衣上装／名称＃%半脱","桃"
	ENDIF
	CALL TRAIN_STRIP_COMMAND_LINGERIE_BUST

;下着が見える場合に選択肢
{
ELSEIF ＃穿着衣服／乳暖簾＃ || ＃穿着衣服／乳房露出＃ || ＃穿着衣服／胸部撕裂＃ || 
TFLAG:临时脱衣／衣服 || !EQUIP:装备中ID／衣服 || GETBIT(＃半脱／衣服上＃) || ＃穿着衣服／名称＃ == "反向兔女郎装"
}
	CALL TRAIN_STRIP_COMMAND_LINGERIE_BUST
ELSE
	CALL PRINTL_WORD_COLOR("穿上衣服的上半部分","灰")
ENDIF



;ブラ脱衣判定
@TRAIN_STRIP_COMMAND_LINGERIE_BUST

;紐ほどきかチェック
CALL LINGERIE_STRING_CHECK(＃穿着内衣上装／名称＃)
IF RESULT
	;上下セットの場合文面替え
	IF ＃穿着内衣上装／名称＃ == ＃穿着内衣下装／名称＃
		PRINTFORML [10] ＜%＃穿着内衣上装／名称＃%＞上面的带子解开
		SIF !GETBIT(＃半脱／内衣上装＃)
			PRINTFORML [11] ＜%＃穿着内衣上装／名称＃%＞上面半脱
	ELSE
		PRINTFORML [10] ＜%＃穿着内衣上装／名称＃%＞的带子解开
		SIF !GETBIT(＃半脱／内衣上装＃)
			PRINTFORML [11] ＜%＃穿着内衣上装／名称＃%＞半脱
	ENDIF
	COMMAND_OK:10 = 1
	SIF !GETBIT(＃半脱／内衣上装＃)
		COMMAND_OK:11 = 1

;紐なし　ニップレスだけかもしれない
ELSEIF GROUPMATCH(＃穿着内衣上装／名称＃,"乳贴")
	PRINTFORML [10] ＜%＃穿着内衣上装／名称＃%＞脱下
	COMMAND_OK:10 = 1

ELSE
	IF TFLAG:拘束BIT
		CALL PRINTL_WORD_COLOR("拘束状态下不能完全脱衣","灰")
	ELSEIF CFLAG:无抵抗 || !BASE:体力
		IF GROUPMATCH(＃穿着内衣上装／名称＃,"运动胸罩","连体紧身衣","学校游泳衣","触手服装")
			IF !TFLAG:临时脱衣／衣服 && EQUIP:装备中ID／衣服
				CALL PRINTL_WORD_COLOR("除非脱掉衣服否则不允许","灰")
			ELSEIF GROUPMATCH(＃穿着内衣上装／名称＃,"运动胸罩")
				PRINTFORML [10] ＜%＃穿着内衣上装／名称＃%＞脱下
			ELSE
				PRINTFORML [10] ＜%＃穿着内衣上装／名称＃%＞上面脱下
			ENDIF
		ELSE
			PRINTFORML [10] ＜%＃穿着内衣上装／名称＃%＞脱下
		ENDIF
		COMMAND_OK:10 = 1
	ELSE
		CALL PRINTL_WORD_COLOR("反抗的态度不能完全脱衣","灰")
	ENDIF
	IF !GETBIT(＃半脱／内衣上装＃)
		IF GROUPMATCH(＃穿着内衣上装／名称＃,"连体紧身衣","学校游泳衣","触手服装")
			PRINTFORML [11] ＜%＃穿着内衣上装／名称＃%＞的胸部挤出乳沟
		ELSE
			PRINTFORML [11] ＜%＃穿着内衣上装／名称＃%＞半脱
		ENDIF
		COMMAND_OK:11 = 1
	ENDIF
ENDIF



;ショーツ
@TRAIN_STRIP_LINGERIE_VAGINA

IF TFLAG:临时脱衣／内衣下装 || !EQUIP:装备中ID／内衣下装
	CALL PRINTL_WORD_COLOR("不穿内裤","桃")

ELSEIF GETBIT(＃半脱／内衣下装＃)
	IF ＃穿着内衣上装／名称＃ == ＃穿着内衣下装／名称＃
		CALL PRINTL_WORD_COLOR,@"＜%＃穿着内衣下装／名称＃%＞下面半脱","桃"
	ELSE
		CALL PRINTL_WORD_COLOR,@"＜%＃穿着内衣下装／名称＃%＞半脱","桃"
	ENDIF
	CALL TRAIN_STRIP_COMMAND_LINGERIE_VAGINA
{
ELSEIF ＃穿着衣服／围裙＃ || ＃穿着衣服／私处露出＃  || ＃穿着衣服／私处撕裂＃ || 
TFLAG:临时脱衣／衣服 || !EQUIP:装备中ID／衣服 || GETBIT(＃半脱／衣服下＃) || ＃穿着衣服／名称＃ == "反向兔女郎装"
}
	CALL TRAIN_STRIP_COMMAND_LINGERIE_VAGINA
ELSE
	CALL PRINTL_WORD_COLOR("穿上衣服的下半部分","灰")
ENDIF
PRINTL



;ショーツ脱衣判定
@TRAIN_STRIP_COMMAND_LINGERIE_VAGINA

IF GETBIT(＃拘束／下半身填壁乳＃)
	CALL PRINTL_WORD_COLOR("下半身被埋入","灰")
	RETURN
ENDIF

;紐ほどきかチェック
CALL LINGERIE_STRING_CHECK(＃穿着内衣下装／名称＃)
IF RESULT
	;上下セットの場合文面替え
	IF ＃穿着内衣上装／名称＃ == ＃穿着内衣下装／名称＃
		PRINTFORML [12] 解开＜%＃穿着内衣下装／名称＃%>下面的带子
		SIF !GETBIT(＃半脱／内衣下装＃)
			PRINTFORML [13] ＜%＃穿着内衣下装／名称＃%＞下面半脱
	ELSE
		PRINTFORML [12] ＜%＃穿着内衣下装／名称＃%＞的带子解开
		SIF !GETBIT(＃半脱／内衣下装＃)
			PRINTFORML [13] ＜%＃穿着内衣下装／名称＃%＞半脱
	ENDIF
	COMMAND_OK:12 = 1
	SIF !GETBIT(＃半脱／内衣下装＃)
		COMMAND_OK:13 = 1

;紐なし　前貼りとＣストリング
ELSEIF GROUPMATCH(＃穿着内衣下装／名称＃,"私处贴纸","Ｃ字裤")
	PRINTFORM [12] 把＜%＃穿着内衣下装／名称＃%＞
	IF ＃穿着内衣下装／名称＃ == "私处贴纸"
		PRINTL 剥开
	ELSE
		PRINTL 脱下
	ENDIF
	COMMAND_OK:12 = 1

ELSE
	;触手装備中以外はわりと自由だった
	;触手以外のＡＢＣＶはOK
	IF TFLAG:拘束BIT
		CALL PRINTL_WORD_COLOR("拘束状态下不能完全脱衣","灰")
	ELSEIF TFLAG:搾乳器
		CALL PRINTL_WORD_COLOR("搾乳器使用时不能完全脱衣","灰")
	ELSEIF TFLAG:触手装备
		CALL PRINTL_WORD_COLOR("触手使用时不能完全脱衣","灰")
	ELSEIF TFLAG:Ｐ使用BIT
		CALL PRINTL_WORD_COLOR,@"%SAVESTR:标识／阴茎%使用时不能完全脱衣","灰"
	ELSEIF CFLAG:无抵抗 || !BASE:体力
		;上下一体の場合はここは飛ばす
		SIF ＃穿着内衣上装／名称＃ == ＃穿着内衣下装／名称＃ && !GROUPMATCH(＃穿着内衣下装／名称＃,"连体紧身衣","学校游泳衣","触手服装")
			RETURN
		IF GROUPMATCH(＃穿着内衣下装／名称＃,"连体紧身衣","学校游泳衣","触手服装") && !TFLAG:临时脱衣／衣服 && EQUIP:装备中ID／衣服
			CALL PRINTL_WORD_COLOR("除非脱掉衣服否则不允许","灰")
		ELSE
			PRINTFORML [12] ＜%＃穿着内衣下装／名称＃%＞脱下
			COMMAND_OK:12 = 1
		ENDIF
	ELSE
		CALL PRINTL_WORD_COLOR("反抗的态度不能完全脱衣","灰")
	ENDIF
	IF !GETBIT(＃半脱／内衣下装＃)
		IF GROUPMATCH(＃穿着内衣下装／名称＃,"连体紧身衣","学校游泳衣","触手服装")
			PRINTFORML [13] ＜%＃穿着内衣下装／名称＃%＞的私处部分移开
		ELSE
			PRINTFORML [13] ＜%＃穿着内衣下装／名称＃%＞半脱
		ENDIF
		COMMAND_OK:13 = 1
	ENDIF
ENDIF
PRINTL



;上着
@TRAIN_STRIP_JACKET

IF TFLAG:临时脱衣／外衣 || !EQUIP:装备中ID／外衣
	CALL PRINTL_WORD_COLOR("无外衣","灰")

ELSEIF GROUPMATCH(＃穿着外衣／名称＃,"连体背带裤","围裙装")
	CALL PRINTL_WORD_COLOR("外衣无露出判定","灰")

ELSEIF GETBIT(＃半脱／外衣＃)
	CALL PRINTL_WORD_COLOR,@"%＃穿着外衣／名称＃%半脱","桃"
	
ELSE
	PRINTFORML [14] 将＜%＃穿着外衣／名称＃%＞半脱
	COMMAND_OK:14 = 1
ENDIF
PRINTL








;アクセサリー外し表示
@TRAIN_STRIP_ACCESSORY

;アクセサリー一時的脱衣フラグ：130～
;アクセサリー装備箇所のSTR：6670～
EXIST = 0
PRINTL 　《 饰品 》
FLAG_REF = 120
STR_REF = 6660
FOR LOCAL,10,20
	SIF EQUIPNAME:LOCAL == ""
		CONTINUE
	IF !EQUIP:LOCAL || TFLAG:(LOCAL +FLAG_REF)
		;表示が長いので装備してない場合も飛ばすことにした
		;CALL PRINTL_WORD_COLOR,@"　%STR:(LOCAL +STR_REF)%装備なし","灰"
		CONTINUE
	
	;下半身埋め拘束だと脚はダメ
	ELSEIF GETBIT(＃拘束／下半身填壁乳＃) && LOCAL == 13
		CALL PRINTL_WORD_COLOR("埋入下半身时不可摘下脚上饰品","灰")
		CONTINUE
	ENDIF
	PRINTFORML [{LOCAL +10,2}] <%ITEMNAME:(EQUIP:LOCAL)%>移除
	COMMAND_OK:(LOCAL +10) = 1
	EXIST ++
NEXT

;ない場合ないって書く
SIF !EXIST
	CALL PRINTL_WORD_COLOR("无饰品","灰")
PRINTL



;まとめて脱がす
@TRAIN_STRIP_BULK

PRINTL 　《 总计 》
IF TFLAG:拘束BIT
	CALL PRINTL_WORD_COLOR("拘束状态下不能脱衣","灰")
ELSEIF TFLAG:Ｐ使用BIT
	CALL PRINTL_WORD_COLOR("插入时不能脱衣","灰")
ELSEIF TFLAG:触手装备
	CALL PRINTL_WORD_COLOR("使用触手时不能脱衣","灰")
ELSEIF TFLAG:搾乳器
	CALL PRINTL_WORD_COLOR("搾乳器使用时不能脱衣","灰")
ELSEIF !CFLAG:无抵抗 && BASE:体力
	CALL PRINTL_WORD_COLOR("反抗的态度不能脱衣","灰")
ELSEIF !TFLAG:临时脱衣／衣服 && EQUIP:装备中ID／衣服
	;他の装備はあっても脱がせるようにした
	PRINTFORML [30] ＜%＃穿着衣服／名称＃%＞脱下
	COMMAND_OK:30 = 1
ENDIF
IF COMMAND_OK:0 && COMMAND_OK:2
	PRINTFORML [31] ＜%＃穿着衣服／名称＃%＞的上下统一半脱
	COMMAND_OK:31 = 1
ENDIF
IF COMMAND_OK:1 && COMMAND_OK:3
	PRINTFORML [32] ＜%＃穿着衣服／名称＃%＞的上下统一撕掉
	COMMAND_OK:32 = 1
ENDIF
IF COMMAND_OK:0 && EQUIP:装备中ID／内衣上装
	PRINTL [33] 上身衣服・内衣半脱
	COMMAND_OK:33 = 1
ENDIF
IF COMMAND_OK:2 && EQUIP:装备中ID／内衣下装
	PRINTL [34] 下身衣服・内衣半脱
	COMMAND_OK:34 = 1
ENDIF
IF COMMAND_OK:10 && COMMAND_OK:12 && !GROUPMATCH(＃穿着内衣下装／名称＃,"连体紧身衣","学校游泳衣","触手服装")
	PRINTL [35] 内衣上下一起脱下
	COMMAND_OK:35 = 1
ENDIF
IF COMMAND_OK:11 && COMMAND_OK:13
	PRINTL [36] 内衣上下一起半脱
	COMMAND_OK:36 = 1
ENDIF
IF COMMAND_OK:31 && COMMAND_OK:36
	PRINTL [37] 包括内裤全部半脱
	COMMAND_OK:37 = 1
ENDIF

;下着がどっちかの場合でもOKにした
;30がOKな時点で下着も脱がす準備はできてる
IF COMMAND_OK:30
	;下着の上、下それぞれでフラグ立て判定
	SIF !TFLAG:临时脱衣／内衣上装 && EQUIP:装备中ID／内衣上装
		COMMAND_OK:38 = 1
	SIF !TFLAG:临时脱衣／内衣下装 && EQUIP:装备中ID／内衣下装
		COMMAND_OK:38 = 1
	
	;フラグが立ってたら選択肢出す
	SIF COMMAND_OK:38
		PRINTL [38] 包括内裤全部脱下
ENDIF
IF SUMARRAY(COMMAND_OK,20,30)
	PRINTL [39] 摘下所有饰品
	COMMAND_OK:39 = 1
ENDIF
PRINTL




