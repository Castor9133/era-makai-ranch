@KOJO_GENERAL_INDEX_专属口上底座(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:0
CASE "例文"
	{
	CALL MESSAGE_BOX,@"--------\n此处为专用口上库\n
	本套为「只显示自己写的专用段落、避免与泛用口吻混杂」的底座。\n
